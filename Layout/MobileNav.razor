@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc

<style>
    .mob-nav {
        display: flex;
        flex-direction: row;
        align-items: stretch;
        width: 100%;
        height: 64px;
        background: linear-gradient(90deg, rgb(5, 39, 103) 0%, #3a0647 100%);
        box-shadow: 0 -2px 12px rgba(0,0,0,0.3);
    }
    .mob-item, .mob-item:hover, .mob-item:focus, .mob-item.active,
    a.mob-item, a.mob-item:hover {
        flex: 1;
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
        justify-content: center !important;
        gap: 3px;
        color: rgba(255,255,255,0.65) !important;
        text-decoration: none !important;
        font-size: 0;
        padding: 6px 2px;
        border-radius: 6px;
        margin: 4px 2px;
        transition: color 0.15s, background 0.15s;
        background-image: none !important;
    }
    .mob-item.active, .mob-item:hover, a.mob-item:hover {
        color: #fff !important;
        background-color: rgba(255,255,255,0.18) !important;
    }
    .mob-item i {
        font-size: 1.35rem !important;
        line-height: 1 !important;
        width: auto !important;
        height: auto !important;
        margin: 0 !important;
        top: 0 !important;
        background-image: none !important;
    }
    .mob-item span {
        font-size: 0.55rem !important;
        line-height: 1 !important;
        color: inherit !important;
        font-weight: 500;
    }
</style>

<nav class="mob-nav">
    <NavLink class="mob-item" href="" Match="NavLinkMatch.All">
        <i class="bi bi-house-door-fill"></i>
        <span>Home</span>
    </NavLink>
    <NavLink class="mob-item" href="watching">
        <i class="bi bi-play-circle-fill"></i>
        <span>Watching</span>
    </NavLink>
    <NavLink class="mob-item" href="watched">
        <i class="bi bi-check2-all"></i>
        <span>Watched</span>
    </NavLink>
    <NavLink class="mob-item" href="watchlist">
        <i class="bi bi-list-nested"></i>
        <span>List</span>
    </NavLink>
    <a class="mob-item" @onclick="WatchlistSvc.ShowRandomMovieAsync" style="cursor:pointer;">
        <i class="bi bi-dice-5-fill"></i>
        <span>Random</span>
    </a>
    <NavLink class="mob-item" href="configure">
        <i class="bi bi-gear-fill"></i>
        <span>Config</span>
    </NavLink>
</nav>

@code {}
