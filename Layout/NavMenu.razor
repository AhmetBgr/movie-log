@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc

<!-- Desktop: brand bar + nav links -->
<div class="top-row ps-3 navbar navbar-dark desktop-header">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Movie Log</a>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable desktop-nav" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="watching">
                <span class="bi bi-play-circle-fill-nav-menu" aria-hidden="true"></span> Watching
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="watched">
                <span class="bi bi-check2-all-nav-menu" aria-hidden="true"></span> Watched
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="watchlist">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Watchlist
            </NavLink>
        </div>
        <div class="nav-item px-3 mt-2">
            <a class="nav-link" style="cursor: pointer;" @onclick="WatchlistSvc.ShowRandomMovieAsync">
                <span class="bi bi-dice-5-fill-nav-menu" aria-hidden="true"></span> Random Movie
            </a>
        </div>
        <div class="nav-item px-3 border-top mt-2 pt-2">
            <NavLink class="nav-link" href="configure">
                <span class="bi bi-gear-fill-nav-menu" aria-hidden="true"></span> Configure
            </NavLink>
        </div>
    </nav>
</div>

<!-- Mobile: icon + label bottom bar -->
<nav class="mobile-bottom-nav">
    <NavLink class="mobile-nav-item" href="" Match="NavLinkMatch.All" title="Home">
        <span class="bi bi-house-door-fill-nav-menu"></span>
        <span class="mobile-nav-label">Home</span>
    </NavLink>
    <NavLink class="mobile-nav-item" href="watching" title="Watching">
        <span class="bi bi-play-circle-fill-nav-menu"></span>
        <span class="mobile-nav-label">Watching</span>
    </NavLink>
    <NavLink class="mobile-nav-item" href="watched" title="Watched">
        <span class="bi bi-check2-all-nav-menu"></span>
        <span class="mobile-nav-label">Watched</span>
    </NavLink>
    <NavLink class="mobile-nav-item" href="watchlist" title="Watchlist">
        <span class="bi bi-list-nested-nav-menu"></span>
        <span class="mobile-nav-label">Watchlist</span>
    </NavLink>
    <a class="mobile-nav-item" @onclick="WatchlistSvc.ShowRandomMovieAsync" style="cursor:pointer;" title="Random">
        <span class="bi bi-dice-5-fill-nav-menu"></span>
        <span class="mobile-nav-label">Random</span>
    </a>
    <NavLink class="mobile-nav-item" href="configure" title="Configure">
        <span class="bi bi-gear-fill-nav-menu"></span>
        <span class="mobile-nav-label">Configure</span>
    </NavLink>
</nav>

@code {
    private bool collapseNavMenu = true;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;
    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;
}
