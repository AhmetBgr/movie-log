@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager NavManager
@inject WatchlistService WatchlistSvc
@inject IJSRuntime JS
@using MyPrivateWatchlist.Components

<div class="page">

    <!-- Desktop sidebar: visible sm and up -->
    <div class="sidebar d-none d-sm-flex flex-column">
        <NavMenu />
    </div>

    <main class="pb-sm-0">

        <!-- ── Update banner ──────────────────────────────── -->
        @if (_showUpdateBanner)
        {
            <div class="update-banner">
                <span class="update-banner-text"><i class="bi bi-arrow-clockwise me-2"></i>A new version is available.</span>
                <button class="update-banner-btn" @onclick="ApplyUpdate">Update now</button>
                <button class="update-banner-dismiss" @onclick="() => _showUpdateBanner = false" title="Dismiss"><i class="bi bi-x"></i></button>
            </div>
        }

        <!-- Search bar — always fixed to top -->
        <div class="search-bar-wrap">
            <div class="search-bar-inner">
                <form class="search-form" @onsubmit="PerformSearch" @onsubmit:preventDefault="true">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text"
                           class="search-input"
                           placeholder="Search movies, shows..."
                           @bind="SearchText"
                           @bind:event="oninput"
                           @onfocus="() => isSearchFocused = true"
                           @onblur="HandleBlur" />
                    <button type="submit" class="search-btn">Search</button>
                </form>

                @if (isSearchFocused && WatchlistSvc.EnableSearchHistory && WatchlistSvc.SearchHistory.Any(s => string.IsNullOrEmpty(SearchText) || s.Contains(SearchText, StringComparison.OrdinalIgnoreCase)))
                {
                    <div class="search-history-dropdown">
                        <div class="search-history-header">
                            <span>Recent Searches</span>
                            <button @onclick="WatchlistSvc.ClearSearchHistory">Clear all</button>
                        </div>
                        @foreach (var query in WatchlistSvc.SearchHistory.Where(s => string.IsNullOrEmpty(SearchText) || s.Contains(SearchText, StringComparison.OrdinalIgnoreCase)))
                        {
                            <div class="search-history-item" @onclick="() => QuickSearch(query)">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-clock-history"></i>
                                    <span>@query</span>
                                </div>
                                <button class="search-history-remove"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => WatchlistSvc.RemoveFromSearchHistory(query)">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        @if (WatchlistSvc.IsInitializing)
        {
            <div class="alert alert-info border-0 rounded-0 mb-0 py-2 px-4 d-flex align-items-center gap-2 shadow-sm">
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                <span class="small fw-semibold">Loading your library in the background...</span>
            </div>
        }

        <article class="content px-3 px-md-4 mt-2">
            @Body
        </article>

        <MovieDetailsModal />

        @if (!string.IsNullOrEmpty(WatchlistSvc.ToastMessage))
        {
            <div class="position-fixed bottom-0 start-50 translate-middle-x p-4" style="z-index: 1080;">
                <div class="toast show align-items-center text-white bg-dark border-0 shadow-lg rounded-pill" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="d-flex">
                        <div class="toast-body px-4 py-3 fw-medium">
                            <i class="bi bi-info-circle-fill me-2 text-warning"></i> @WatchlistSvc.ToastMessage
                        </div>
                    </div>
                </div>
            </div>
        }
    </main>

    <!-- Mobile bottom nav: visible below sm only -->
    <div class="d-sm-none" style="position: fixed; bottom: 0; left: 0; right: 0; z-index: 200;">
        <MobileNav />
    </div>

</div>

<style>
    /* ── Search bar wrapper — always sticky to top ─────────── */
    .search-bar-wrap {
        position: sticky;
        top: 0;
        z-index: 100;
        background: #fff;
        border-bottom: 1px solid #e8eaed;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        padding: 10px 16px;
    }

    .search-bar-inner {
        position: relative;
        max-width: 680px;
        margin: 0 auto;
    }

    /* ── Search form ────────────────────────────────────────── */
    .search-form {
        display: flex;
        align-items: center;
        background: #f1f3f4;
        border-radius: 999px;
        border: 2px solid transparent;
        padding: 0 6px 0 16px;
        transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
        height: 46px;
    }

    .search-form:focus-within {
        background: #fff;
        border-color: #1a73e8;
        box-shadow: 0 2px 8px rgba(26,115,232,0.15);
    }

    .search-icon {
        color: #888;
        font-size: 1rem;
        flex-shrink: 0;
        margin-right: 10px;
        transition: color 0.2s;
    }

    .search-form:focus-within .search-icon {
        color: #1a73e8;
    }

    .search-input {
        flex: 1;
        border: none;
        background: transparent;
        outline: none;
        font-size: 0.95rem;
        color: #202124;
        min-width: 0;
    }

    .search-input::placeholder {
        color: #aaa;
    }

    .search-btn {
        flex-shrink: 0;
        background: #1a1a2e;
        color: #fff;
        border: none;
        border-radius: 999px;
        padding: 6px 18px;
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s;
        height: 34px;
    }

    .search-btn:hover {
        background: #3a0647;
        transform: scale(1.03);
    }

    /* ── History dropdown ───────────────────────────────────── */
    .search-history-dropdown {
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        right: 0;
        background: #fff;
        border-radius: 16px;
        border: 1px solid #e8eaed;
        box-shadow: 0 4px 20px rgba(0,0,0,0.12);
        overflow: hidden;
        z-index: 200;
    }

    .search-history-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 16px;
        border-bottom: 1px solid #f1f3f4;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #888;
    }

    .search-history-header button {
        background: none;
        border: none;
        color: #e53935;
        font-size: 0.7rem;
        font-weight: 600;
        cursor: pointer;
        padding: 0;
    }

    .search-history-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 16px;
        cursor: pointer;
        font-size: 0.88rem;
        color: #202124;
        transition: background 0.12s;
    }

    .search-history-item:hover {
        background: #f8f9fa;
    }

    .search-history-item .bi-clock-history {
        color: #aaa;
        font-size: 0.85rem;
    }

    .search-history-remove {
        background: none;
        border: none;
        color: #bbb;
        padding: 2px 4px;
        cursor: pointer;
        font-size: 0.75rem;
        border-radius: 4px;
        transition: color 0.15s;
    }

    .search-history-remove:hover {
        color: #e53935;
    }
    /* ── Update banner ─────────────────────────────────────── */
    .update-banner {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 9999;
        background: #1a1a2e;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 6px 16px;
        font-size: 0.82rem;
        font-weight: 500;
        min-height: 36px;
    }

    .update-banner-text {
        opacity: 0.9;
    }

    .update-banner-btn {
        background: #fff;
        color: #1a1a2e;
        border: none;
        border-radius: 999px;
        padding: 3px 14px;
        font-size: 0.78rem;
        font-weight: 700;
        cursor: pointer;
        transition: opacity 0.15s;
        white-space: nowrap;
    }

    .update-banner-btn:hover { opacity: 0.85; }

    .update-banner-dismiss {
        background: none;
        border: none;
        color: rgba(255,255,255,0.6);
        font-size: 1rem;
        cursor: pointer;
        padding: 0 2px;
        line-height: 1;
        margin-left: 4px;
        transition: color 0.15s;
    }

    .update-banner-dismiss:hover { color: #fff; }

</style>

@code {
    private string SearchText = "";
    private bool _showUpdateBanner = false;
    private DotNetObjectReference<MainLayout>? _dotNetRef;
    private bool isSearchFocused = false;

    private async Task HandleBlur()
    {
        await Task.Delay(200);
        isSearchFocused = false;
        StateHasChanged();
    }

    private void QuickSearch(string query)
    {
        SearchText = query;
        isSearchFocused = false;
        PerformSearch();
    }

    protected override async Task OnInitializedAsync()
    {
        WatchlistSvc.OnStateChanged += HandleWatchlistStateChanged;
        NavManager.LocationChanged += HandleLocationChanged;
        _wasModalOpen = WatchlistSvc.IsModalOpen;
        _ = WatchlistSvc.InitializeAsync();
        _dotNetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("registerUpdateCallback", _dotNetRef);
    }

    private bool _wasModalOpen;
    private bool _isClosingFromNav = false;

    private void HandleWatchlistStateChanged()
    {
        if (WatchlistSvc.IsModalOpen && !_wasModalOpen)
        {
            if (!NavManager.Uri.Contains("#details"))
                NavManager.NavigateTo(NavManager.Uri + "#details");
        }
        else if (!WatchlistSvc.IsModalOpen && _wasModalOpen)
        {
            if (NavManager.Uri.Contains("#details") && !_isClosingFromNav)
                _ = JS.InvokeVoidAsync("history.back");
        }
        _wasModalOpen = WatchlistSvc.IsModalOpen;
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (WatchlistSvc.IsModalOpen && !NavManager.Uri.Contains("#details"))
        {
            _isClosingFromNav = true;
            WatchlistSvc.CloseModal();
            _isClosingFromNav = false;
        }
    }

    [Microsoft.JSInterop.JSInvokable]
    public void OnUpdateAvailable()
    {
        _showUpdateBanner = true;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task ApplyUpdate()
    {
        await JS.InvokeVoidAsync("applyUpdate");
    }

    public void Dispose()
    {
        WatchlistSvc.OnStateChanged -= HandleWatchlistStateChanged;
        NavManager.LocationChanged -= HandleLocationChanged;
        _dotNetRef?.Dispose();
    }

    private void PerformSearch()
    {
        if (!string.IsNullOrWhiteSpace(SearchText))
        {
            isSearchFocused = false;
            WatchlistSvc.AddToSearchHistory(SearchText);
            NavManager.NavigateTo($"search/{Uri.EscapeDataString(SearchText)}");
        }
    }
}
