@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager NavManager
@inject WatchlistService WatchlistSvc
@using MyPrivateWatchlist.Components

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center bg-white shadow-sm" style="height: 4rem;">
            <form class="input-group w-50 shadow-sm rounded-pill overflow-hidden" @onsubmit="PerformSearch" @onsubmit:preventDefault="true">
                <span class="input-group-text bg-light border-0 text-secondary px-4"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control border-0 bg-light py-2 px-0 shadow-none" placeholder="Search globally on TMDB..." 
                       @bind="SearchText" />
                <button type="submit" class="btn btn-dark px-4 fw-medium text-uppercase tracking-wide">Search TMDB</button>
            </form>
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank" class="text-decoration-none text-secondary small fw-medium text-uppercase tracking-wide">About</a>
        </div>

        @if (WatchlistSvc.IsInitializing)
        {
            <div class="alert alert-info border-0 rounded-0 mb-0 py-2 px-4 d-flex align-items-center gap-2 shadow-sm">
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                <span class="small fw-semibold">Loading your library in the background...</span>
            </div>
        }

        <article class="content px-4 mt-2">
            @Body
        </article>

        <MovieDetailsModal />
    </main>
</div>

@code {
    private string SearchText = "";

    protected override void OnInitialized()
    {
        WatchlistSvc.OnStateChanged += HandleWatchlistStateChanged;
    }

    private void HandleWatchlistStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        WatchlistSvc.OnStateChanged -= HandleWatchlistStateChanged;
    }

    private void PerformSearch()
    {
        if (!string.IsNullOrWhiteSpace(SearchText))
        {
            NavManager.NavigateTo($"search/{Uri.EscapeDataString(SearchText)}");
        }
    }
}
