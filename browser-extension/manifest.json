{
  "manifest_version": 3,
  "name": "Movie Log - IMDb Integration",
  "version": "1.0.0",
  "description": "Add movies from IMDb to your personal watchlist",
  "host_permissions": [
    "https://www.imdb.com/*",
    "*://localhost/*"
  ],
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["https://www.imdb.com/title/*"],
      "js": ["content/imdb-injector.js"],
      "css": ["content/imdb-styles.css"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://localhost/*"],
      "js": ["content/movie-log-injector.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Movie Log"
  },
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
