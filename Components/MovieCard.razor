@using MyPrivateWatchlist.Models
@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc

@if (Item != null)
{
    <div class="card shadow-sm border-0 overflow-hidden movie-card" style="cursor: pointer;" @onclick="ShowDetails">
        <!-- Top Group: Poster and Data Column -->
        <div class="d-flex">
            <!-- Left Side: Poster -->
            <div class="position-relative p-0 m-0" style="width: 96px; flex-shrink: 0;">
                <div class="h-100 w-100 d-flex align-items-center justify-content-center bg-light p-0 m-0">
                    @if (!string.IsNullOrEmpty(Item.FullPosterUrl) && !Item.FullPosterUrl.Contains("data:image/png;base64"))
                    {
                        <img src="@Item.FullPosterUrl" 
                             class="h-100 w-100" 
                             alt="@Item.Title" 
                             style="object-fit: contain; display: block;"
                             onerror="this.style.display='none'; this.parentElement.innerHTML='<i class=&quot;bi bi-film fs-1 text-secondary opacity-50&quot;></i>';" />
                    }
                    else
                    {
                        <i class="bi bi-film fs-1 text-secondary opacity-50"></i>
                    }
                </div>
                
                <!-- Action Buttons Overlay (only when edit mode is on) -->
                @if (ShowEditControls && IsInLibrary)
                {
                    <div class="position-absolute top-50 start-50 translate-middle d-flex gap-2 bg-dark bg-opacity-75 p-2 rounded-2">
                        @switch (Item.Status)
                        {
                            case WatchlistStatus.Pending:
                                <button class="btn btn-sm btn-success text-white rounded p-2 shadow-sm" 
                                        @onclick:stopPropagation="true" @onclick="() => SetStatus(WatchlistStatus.Watching)"
                                        title="Start Watching">
                                    <i class="bi bi-play-fill fs-5"></i>
                                </button>
                                <button class="btn btn-sm btn-primary text-white rounded p-2 shadow-sm" 
                                        @onclick:stopPropagation="true" @onclick="() => SetStatus(WatchlistStatus.Watched)"
                                        title="Mark as Watched">
                                    <i class="bi bi-check-lg fs-5"></i>
                                </button>
                                <button class="btn btn-sm btn-danger text-white rounded p-2 shadow-sm" 
                                        @onclick:stopPropagation="true" @onclick="RemoveFromLibrary"
                                        title="Remove from library">
                                    <i class="bi bi-trash3-fill fs-5"></i>
                                </button>
                                break;
                            case WatchlistStatus.Watching:
                                <button class="btn btn-sm btn-primary text-white rounded p-2 shadow-sm" 
                                        @onclick:stopPropagation="true" @onclick="() => SetStatus(WatchlistStatus.Watched)"
                                        title="Mark as Watched">
                                    <i class="bi bi-check-lg fs-5"></i>
                                </button>
                                <button class="btn btn-sm btn-danger text-white rounded p-2 shadow-sm" 
                                        @onclick:stopPropagation="true" @onclick="RemoveFromLibrary"
                                        title="Remove from library">
                                    <i class="bi bi-trash3-fill fs-5"></i>
                                </button>
                                break;
                            case WatchlistStatus.Watched:
                                <button class="btn btn-sm btn-success text-white rounded p-2 shadow-sm" 
                                        @onclick:stopPropagation="true" @onclick="() => SetStatus(WatchlistStatus.Watching)"
                                        title="Watch Again">
                                    <i class="bi bi-arrow-repeat fs-5"></i>
                                </button>
                                <button class="btn btn-sm btn-danger text-white rounded p-2 shadow-sm" 
                                        @onclick:stopPropagation="true" @onclick="RemoveFromLibrary"
                                        title="Remove from library">
                                    <i class="bi bi-trash3-fill fs-5"></i>
                                </button>
                                break;
                        }
                    </div>
                }
                
                <!-- Add Button Overlay (only when edit mode is on and not in library) -->
                @if (ShowEditControls && !IsInLibrary)
                {
                    <div class="position-absolute top-50 start-50 translate-middle">
                        <button class="btn btn-sm btn-primary text-white rounded p-2 shadow-sm" 
                                @onclick:stopPropagation="true" @onclick="AddToWatchlist"
                                title="Add to watchlist">
                            <i class="bi bi-plus-lg fs-5"></i>
                        </button>
                    </div>
                }
            </div>
            
            <!-- Right Side: Data Column (Vertical Stack) -->
            <div class="flex-grow-1 p-3">
                <!-- Rating Badge -->
                @if (Item.Rating20.HasValue)
                {
                    <div class="position-absolute top-0 end-0 m-2">
                        <span class="badge bg-dark text-white rounded-pill shadow-sm" style="background-color: @(GetRatingColor(Item.Rating20.Value)) !important;">
                            <i class="bi bi-star-fill me-1"></i>@Item.UserRating
                        </span>
                    </div>
                }
                
                <!-- Row 1: Title (Full width) -->
                <div class="mb-2">
                    <h6 class="card-title fw-bold mb-0">@Item.Title</h6>
                    @if (Item.DateAdded != default && Item.DateAdded != DateTime.MinValue)
                    {
                        <div class="small text-muted mb-1">
                            <i class="bi bi-calendar-plus me-1"></i>
                            Added @Item.DateAdded.ToString("MMM dd, yyyy")
                        </div>
                    }
                </div>
                
                <!-- Row 2: Release Year & Type (Inline) -->
                <div class="mb-2">
                    <div class="d-flex align-items-center gap-2">
                        @if (!string.IsNullOrEmpty(Item.Year))
                        {
                            <p class="card-text small text-secondary mb-0">
                                <i class="bi bi-calendar3 me-1"></i>@Item.Year
                            </p>
                        }
                        @if (!string.IsNullOrEmpty(Item.TitleType))
                        {
                            <span class="badge bg-light text-dark border small">@Item.TitleType</span>
                        }
                    </div>
                </div>
                
                <!-- Row 3: Director (Full width) -->
                <div class="mb-2">
                    @if (!string.IsNullOrEmpty(Item.Director))
                    {
                        <p class="card-text small text-secondary mb-0">
                            <i class="bi bi-person me-1"></i>@Item.Director
                        </p>
                    }
                </div>
                
                <!-- Row 4: Genres (Large content area) -->
                <div class="mb-3">
                    @if (!string.IsNullOrEmpty(Item.Genres))
                    {
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var genre in Item.Genres.Split(',').Take(5))
                            {
                                <span class="badge bg-light text-dark border small">@genre.Trim()</span>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
        
        <!-- Bottom Group: Overview/Plot -->
        <div class="p-2">
            @if (!string.IsNullOrEmpty(Item.Overview))
            {
                <p class="card-text text-dark mb-0" style="line-height: 1.5; font-size: 0.9rem;">@Item.Overview</p>
            }
            else
            {
                <p class="card-text text-muted fst-italic mb-0" style="line-height: 1.5; font-size: 0.9rem;">No overview available</p>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public WatchlistItem? Item { get; set; }
    
    [Parameter]
    public bool ShowEditControls { get; set; } = false;
    
    [Parameter]
    public bool ShowActionButtons { get; set; } = false;
    
    private bool IsInLibrary => WatchlistSvc.Items.Any(i => i.ImdbId == Item?.ImdbId && !string.IsNullOrEmpty(i.ImdbId));
    
    private void ShowDetails()
    {
        if (Item != null)
        {
            WatchlistSvc.ShowDetailsAsync(Item);
        }
    }
    
    private void AddToWatchlist()
    {
        if (Item != null)
        {
            WatchlistSvc.AddToWatchlistAsync(Item);
        }
    }
    
    private void RemoveFromLibrary()
    {
        if (Item != null)
        {
            var libItem = WatchlistSvc.Items.FirstOrDefault(i => i.ImdbId == Item.ImdbId);
            if (libItem != null)
            {
                WatchlistSvc.RemoveFromWatchlistAsync(libItem);
            }
        }
    }
    
    private void SetStatus(WatchlistStatus status)
    {
        if (Item != null)
        {
            var libItem = WatchlistSvc.Items.FirstOrDefault(i => i.ImdbId == Item.ImdbId);
            if (libItem == null)
            {
                var newItem = new WatchlistItem
                {
                    ImdbId = Item.ImdbId,
                    Title = Item.Title,
                    TitleType = Item.TitleType,
                    Year = Item.Year,
                    ParsedYear = Item.ParsedYear,
                    Genres = Item.Genres,
                    Director = Item.Director,
                    Overview = Item.Overview,
                    PosterPath = Item.PosterPath,
                    Status = status,
                    DateAdded = DateTime.Now
                };
                WatchlistSvc.AddToWatchlistAsync(newItem);
            }
            else
            {
                WatchlistSvc.UpdateStatusAsync(libItem, status);
            }
        }
    }
    
    private string GetStatusText()
    {
        return Item?.Status switch
        {
            WatchlistStatus.Pending => "Watchlist",
            WatchlistStatus.Watching => "Watching",
            WatchlistStatus.Watched => "Watched",
            _ => "Unknown"
        };
    }
    
    private string GetStatusBadgeClass()
    {
        return Item?.Status switch
        {
            WatchlistStatus.Pending => "bg-secondary",
            WatchlistStatus.Watching => "bg-success",
            WatchlistStatus.Watched => "bg-primary",
            _ => "bg-light text-dark"
        };
    }
    
    private string GetTypeBadgeClass()
    {
        return Item?.TitleType?.Contains("TV", StringComparison.OrdinalIgnoreCase) == true 
            ? "bg-light text-dark border" 
            : "bg-secondary text-white";
    }
    
    private string GetRatingColor(int val)
    {
        double hue = (val / 100.0) * 120;
        return $"hsl({hue}, 70%, 45%)";
    }
}

<style>
    .movie-card:hover {
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        transform: translateY(-2px) !important;
        transition: all 0s !important;
    }
    
    @@media (max-width: 768px) {
        .movie-card .position-relative[style*="width: 96px"] {
            width: 64px !important;
        }
        
        .movie-card .flex-grow-1 {
            padding: 6px !important;
        }
        
        .movie-card .card-title {
            font-size: 0.8rem !important;
            margin-bottom: 2px !important;
        }
        
        .movie-card .card-text {
            font-size: 0.7rem !important;
            margin-bottom: 1px !important;
        }
        
        .movie-card .badge {
            font-size: 0.6rem !important;
            padding: 2px 4px !important;
        }
        
        .movie-card .p-2 {
            padding: 4px !important;
        }
        
        .movie-card .p-2 p {
            font-size: 0.75rem !important;
            line-height: 1.4 !important;
        }
        
        .movie-card .fs-5 {
            font-size: 0.8rem !important;
        }
        
        .movie-card .mb-2 {
            margin-bottom: 4px !important;
        }
        
        .movie-card .mb-3 {
            margin-bottom: 6px !important;
        }
    }
</style>
