@using MyPrivateWatchlist.Models
@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc

@if (Item != null)
{
    <div class="card movie-card @(IsSelected ? "movie-card-selected" : "")"
         data-holdselect-id="@Item.ImdbId"
         style="cursor: default;">

        <!-- Outer row: side panel + main content -->
        <div class="d-flex">

            <!-- ── Selection Area: checkbox or reorder buttons ── -->
            <div class="selection-panel d-flex flex-column align-items-center justify-content-center @(IsEditMode || CanReorder ? "active" : "")"
                 @onclick:stopPropagation="true">
                
                @if (IsEditMode)
                {
                    <div class="card-checkbox @(IsSelected ? "card-checkbox-checked" : "") mb-2" @onclick="@(async () => await OnToggleSelect.InvokeAsync())">
                        @if (IsSelected)
                        {
                            <i class="bi bi-check-lg text-white" style="font-size: 0.85rem; line-height: 1;"></i>
                        }
                    </div>
                }

                @if (CanReorder)
                {
                    <div class="reorder-controls d-flex flex-column align-items-center">
                        @if (IsEditMode)
                        {
                            <div class="rank-box">
                                <input type="number" 
                                       class="rank-input shadow-none" 
                                       value="@Rank" 
                                       min="1" 
                                       @onchange="async (e) => { if(int.TryParse(e.Value?.ToString(), out var r)) await OnRankChanged.InvokeAsync(r); }" />
                            </div>
                            <div class="reorder-btns-tiny d-flex flex-column mt-1">
                                <button class="reorder-btn-tiny" @onclick="() => OnMoveUp.InvokeAsync()" title="Move Up">
                                    <i class="bi bi-chevron-up"></i>
                                </button>
                                <button class="reorder-btn-tiny" @onclick="() => OnMoveDown.InvokeAsync()" title="Move Down">
                                    <i class="bi bi-chevron-down"></i>
                                </button>
                            </div>
                        }
                        else
                        {
                            <span class="rank-label">@Rank</span>
                        }
                    </div>
                }
            </div>

            <!-- ── Main Content (poster + data) ─────────────────────── -->
            <div class="flex-grow-1 d-flex flex-column">

                <!-- Top Group: Poster and Data Column -->
                <div class="d-flex">
                    <!-- Left Side: Poster -->
                    <div class="position-relative p-0 m-0 poster-wrap" style="flex-shrink: 0; cursor: pointer;"
                         @onclick="ShowDetails">
                        <div class="h-100 w-100 d-flex align-items-center justify-content-center p-0 m-0 poster-bg">
                            @if (!string.IsNullOrEmpty(Item.FullPosterUrl) && !Item.FullPosterUrl.Contains("data:image/png;base64"))
                            {
                                <img src="@Item.FullPosterUrl"
                                     class="h-100 w-100 poster-img"
                                     alt="@Item.Title"
                                     loading="lazy"
                                     style="object-fit: cover; display: block;"
                                     onerror="this.style.display='none'; this.parentElement.innerHTML='<i class=&quot;bi bi-film fs-1 text-secondary opacity-25&quot;></i>';" />
                            }
                            else
                            {
                                <i class="bi bi-film fs-1 text-secondary opacity-25"></i>
                            }
                        </div>
                    </div>

                    <!-- Right Side: Data Column (Vertical Stack) -->
                    <div class="flex-grow-1 p-2 data-col d-flex flex-column justify-content-center">
                        <!-- Rating Badge -->
                        <!-- 
                        @if (Item.Rating20.HasValue)
                        {
                            <div class="position-absolute top-0 end-0 m-2">
                                <span class="rating-badge" style="background-color: @(GetRatingColor(Item.Rating20.Value));">
                                    @Item.UserRating
                                </span>
                            </div>
                        }
                        -->

                        <!-- Row 1: Title -->
                        <div class="mb-0">
                            <div class="d-flex align-items-start gap-2">
                                <h6 class="card-title fw-bold mb-0 movie-title"
                                    style="cursor: pointer;"
                                    @onclick="ShowDetails">@Item.Title</h6>
                                <OpenOnMenu Title="@Item.Title" Year="@Item.Year" ImdbId="@RealImdbId" FetchImdbIdAsync="FetchImdbIdOnDemand" />
                            </div>
                        </div>

                        <!-- Row 2: Release Year & Type -->
                        <div class="mb-1">
                            <div class="d-flex align-items-center gap-2">
                                @if (!string.IsNullOrEmpty(Item.Year))
                                {
                                    <span class="meta-text meta-year">
                                        <i class="bi bi-calendar3 me-1 opacity-50"></i>@(Item.Year?.Length >= 4 ? Item.Year.Substring(0, 4) : Item.Year)
                                    </span>
                                }
                                @if (!string.IsNullOrEmpty(Item.TitleType))
                                {
                                    <span class="type-badge @(Item.TitleType.Contains("TV", StringComparison.OrdinalIgnoreCase) ? "type-tv" : "type-movie")">
                                        @Item.TitleType
                                    </span>
                                }
                                @if (Badges != null)
                                {
                                    @Badges
                                }
                            </div>
                        </div>

                        <!--  -->
                        <!-- Tracking UI (Optimized for Card View) -->
                        @if ((Item.TitleType?.Contains("TV", StringComparison.OrdinalIgnoreCase) == true) && ShowTracking)
                        {
                            <div class="mt-2 tracking-pill-wrap" @onclick:stopPropagation="true">
                                <div class="d-inline-flex align-items-center bg-light rounded-pill px-2 py-1 border shadow-sm tracking-pill">
                                    <div class="d-flex align-items-center px-1">
                                        @if (IsEditMode) { <button class="track-btn" @onclick="() => ChangeSeason(Item,-1)" @onclick:stopPropagation="true"><i class="bi bi-dash"></i></button> }
                                        <span class="text-secondary small fw-bold mx-1">S</span>
                                        <span class="fw-bolder text-dark" style="min-width:18px;">@Item.CurrentSeason</span>
                                        @if (IsEditMode) { <button class="track-btn" @onclick="() => ChangeSeason(Item,1)" @onclick:stopPropagation="true"><i class="bi bi-plus"></i></button> }
                                    </div>
                                    <div class="vr mx-1 opacity-10" style="height:16px;"></div>
                                    <div class="d-flex align-items-center px-1">
                                        @if (IsEditMode) { <button class="track-btn" @onclick="() => ChangeEpisode(Item,-1)" @onclick:stopPropagation="true"><i class="bi bi-dash"></i></button> }
                                        <span class="text-secondary small fw-bold mx-1">E</span>
                                        <span class="fw-bolder text-dark" style="min-width:18px;">@Item.CurrentEpisode</span>
                                        @if (IsEditMode) { <button class="track-btn" @onclick="() => ChangeEpisode(Item,1)" @onclick:stopPropagation="true"><i class="bi bi-plus"></i></button> }
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- Inline rating display (read-only) -->
                        @if (ShowRating)
                        {
                            <div class="d-flex align-items-center mt-1">
                                <div class="rating-box-sm @(Item.Rating20 == null ? "rating-empty" : "")"
                                     style="@(Item.Rating20 != null ? $"background:{Visuals.GetRatingColor(Item.Rating20.Value)};" : "")">
                                    <span class="rating-static @(Item.Rating20 == null ? "" : "text-white")">
                                        @(Item.Rating20?.ToString() ?? "–")
                                    </span>
                                </div>
                            </div>
                        }




                        <!-- Row 3: Director -->
                        <!--
                        @if (!string.IsNullOrEmpty(Item.Director))
                        {
                            <div class="mb-2">
                                <span class="meta-text">
                                    <i class="bi bi-person me-1 opacity-50"></i>@Item.Director
                                </span>
                            </div>
                        }
                        -->
                        <!-- Row 4: Genres -->
                        <!--
                        @if (!string.IsNullOrEmpty(Item.Genres))
                        {
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var genre in Item.Genres.Split(',').Take(5))
                                {
                                    <span class="genre-pill">@genre.Trim()</span>
                                }
                            </div>
                        }
                        -->

                    </div>
                </div>

                <!-- Bottom Group: Overview/Plot -->
                @if (!string.IsNullOrEmpty(Item.Overview))
                {
                    <div class="overview-section">
                        <p class="overview-text mb-0">@Item.Overview</p>
                    </div>
                }

            </div><!-- /main content -->
        </div><!-- /outer row -->

    </div>
}

@code {
    [Parameter] public WatchlistItem? Item { get; set; }
    [Parameter] public bool ShowEditControls { get; set; } = false;
    [Parameter] public bool ShowActionButtons { get; set; } = false;
    [Parameter] public bool ShowTracking { get; set; } = false;
    [Parameter] public bool ShowRating { get; set; } = false;
    [Parameter] public bool IsEditMode { get; set; } = false;
    [Parameter] public bool IsSelected { get; set; } = false;
    [Parameter] public bool CanReorder { get; set; } = false;
    [Parameter] public int Rank { get; set; } = 0;
    [Parameter] public EventCallback OnToggleSelect { get; set; }
    [Parameter] public EventCallback OnMoveUp { get; set; }
    [Parameter] public EventCallback OnMoveDown { get; set; }
    [Parameter] public EventCallback<int> OnRankChanged { get; set; }
    [Parameter] public RenderFragment? SidePanel { get; set; }
    [Parameter] public RenderFragment? Badges { get; set; }
    [Parameter] public EventCallback<WatchlistItem> OnClick { get; set; }

    private string? RealImdbId => (Item?.ImdbId != null && (Item.ImdbId.StartsWith("movie-") || Item.ImdbId.StartsWith("tv-"))) 
        ? WatchlistSvc.Items.FirstOrDefault(i => string.Equals(i.Title, Item.Title, StringComparison.OrdinalIgnoreCase) && i.Year == Item.Year)?.ImdbId 
        : Item?.ImdbId;

    private async Task ShowDetails()
    {
        if (Item == null) return;
        if (IsEditMode) await OnToggleSelect.InvokeAsync();
        else if (OnClick.HasDelegate) await OnClick.InvokeAsync(Item);
        else await WatchlistSvc.ShowDetailsAsync(Item);
    }

    private async Task<string?> FetchImdbIdOnDemand()
    {
        if (Item?.ImdbId == null || RealImdbId != null) return null;
        if (!Item.ImdbId.StartsWith("movie-") && !Item.ImdbId.StartsWith("tv-")) return null;
        
        var parts = Item.ImdbId.Split('-');
        if (parts.Length == 2 && int.TryParse(parts[1], out int tmdbId))
        {
            var details = await WatchlistSvc.GetTmdbDetailsByIdAsync(tmdbId, parts[0]);
            return details?.ImdbId;
        }
        return null;
    }

    private async Task UpdateRating20(WatchlistItem item, int? r)
    {
        if (r.HasValue) r = Math.Clamp(r.Value, 0, 100);
        await WatchlistSvc.UpdateRatingAsync(item, r);
        if (r.HasValue) { StateHasChanged(); await Task.Delay(1500); StateHasChanged(); }
    }

    private async Task ChangeEpisode(WatchlistItem Item, int d) { var n = (Item.CurrentEpisode ?? 1) + d; if (n >= 1) await WatchlistSvc.UpdateProgressAsync(Item, Item.CurrentSeason, n); }
    private async Task ChangeSeason(WatchlistItem Item, int d) { await WatchlistSvc.UpdateProgressAsync(Item, Math.Max(1, (Item.CurrentSeason ?? 1) + d), Item.CurrentEpisode); }

}

<style>
    .track-btn { width: 26px; height: 26px; padding: 0; border: 1px solid rgba(0,0,0,0.15); background: #fff; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; font-size: 1.02rem; transition: background 0.12s; }
    .track-btn:hover { background: #f0f0f0; }

    .rank-box {
        width: 32px; height: 32px; border: 1px solid #ddd; border-radius: 8px;
        display: flex; align-items: center; justify-content: center; background: #fff;
    }
    .rank-label {
        font-size: 0.85rem; font-weight: 800; color: #aaa; font-family: var(--font-monospace);
    }
    .rank-input {
        width: 100%; height: 100%; border: none; background: transparent; 
        text-align: center; font-weight: 800; font-size: 0.85rem; color: #333;
        font-family: var(--font-monospace);
    }
    input[type=number].rank-input::-webkit-inner-spin-button,
    input[type=number].rank-input::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
    input[type=number].rank-input { -moz-appearance: textfield; }

    .reorder-btns-tiny { gap: 1px; }
    .reorder-btn-tiny {
        width: 32px; height: 18px; padding: 0; border: 1px solid rgba(0,0,0,0.05);
        background: #fff; border-radius: 4px; display: flex; align-items: center; justify-content: center;
        cursor: pointer; color: #888; transition: all 0.1s;
    }
    .reorder-btn-tiny:hover { background: #f0f0f0; color: #111; }
    .reorder-btn-tiny i { font-size: 0.7rem; }

    .tracking-pill { padding: 2px 6px !important; font-size: 0.72rem; transform-origin: left center; transition: transform 0.15s; }
    .tracking-pill .vr { height: 13px !important; }
    .tracking-pill span.fw-bolder { min-width: 15px; font-size: 0.8rem; }

    /* Mobile pill container — shrinks pill if the title cell gets narrow (rules in app.css) */
    .tracking-pill-wrap { container-type: inline-size; }

    /* Rating box (card view — read-only, smaller) */
    .rating-box-sm {
        width: 30px; height: 30px; border-radius: 6px;
        display: flex; align-items: center; justify-content: center;
        border: 2px dashed #dee2e6; background: #f8f9fa;
    }
    .rating-box-sm:not(.rating-empty) { border: none; }
    .rating-static {
        text-align: center; font-weight: 900;
        font-size: 0.75rem; color: #555;
        pointer-events: none; user-select: none;
    }
    .rating-static.text-white { color: #fff !important; }


    .movie-card {
        background: transparent;
        border-radius: 0 !important;
        border: none;
        box-shadow: none;
        transition: background-color 0.1s ease;
        overflow: hidden;
    }

    .movie-card-selected {
        outline: 2px solid rgba(13, 110, 253, 0.5);
        background-color: rgba(13, 110, 253, 0.05) !important;
    }

    .selection-panel {
        width: 0;
        flex-shrink: 0;
        border-right: 0px solid rgba(0,0,0,0.06);
        background: transparent;
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 4px 0;
        cursor: pointer;
        /*transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1), background 0.15s, border-width 0.3s;*/
        overflow: hidden;
    }
    .selection-panel.active {
        width: 44px;
        border-right-width: 0px;
        padding: 8px 4px;
    }
    .selection-panel:hover {
        background: transparent;
    }

    .card-checkbox {
        width: 22px;
        height: 22px;
        border-radius: 6px;
        border: 2px solid #bbb;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.15s ease;
        flex-shrink: 0;
    }
    .card-checkbox-checked {
        background: #0d6efd;
        border-color: #0d6efd;
    }
    .selection-panel:hover .card-checkbox:not(.card-checkbox-checked) {
        border-color: #0d6efd;
        background: rgba(13, 110, 253, 0.08);
    }

    .poster-wrap {
        flex-shrink: 0 !important;
        min-width: 80px !important;
        width: 80px !important;
        height: 120px !important;
        border-radius: 4px;
        overflow: hidden;
    }
    .poster-bg {
        background: transparent;
        height: 120px;
        min-height: 120px;
    }
    .poster-img {
        border-radius: 4px;
    }
    .rating-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 36px;
        height: 36px;
        padding: 0 8px;
        border-radius: 8px;
        color: #fff;
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.01em;
        box-shadow: 0 2px 6px rgba(0,0,0,0.18);
    }

    .data-col {
        border-left: none;
    }
    .movie-title {
        font-size: 0.7rem;
        color: #111;
        line-height: 1.35;
        letter-spacing: -0.01em;
        transition: color 0.15s ease;
    }
    .movie-title:hover {
        color: #f97316 !important;
    }
    .meta-text {
        font-size: 0.62rem;
        color: #888;
        display: block;
    }
    .meta-year {
        font-size: 0.89rem;
    }

    .type-badge {
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        padding: 2px 7px;
        border-radius: 4px;
    }
    .type-movie { background: #e8e8e8; color: #444; }
    .type-tv    { background: #dbeafe; color: #1d4ed8; }

    .genre-pill {
        font-size: 0.65rem;
        font-weight: 500;
        color: #555;
        background: #f4f4f4;
        border: 1px solid #e4e4e4;
        border-radius: 20px;
        padding: 2px 8px;
        white-space: nowrap;
    }

    .overview-section {
        padding: 6px 14px 8px;
        border-top: none;
        background: transparent;
        border-radius: 0;
    }
    .overview-text {
        font-size: 0.68rem;
        color: #1a1a1aff;
        line-height: 1.45;
        cursor: text;
        user-select: text;
    }

    @@media (max-width: 768px) {
        .selection-panel.active { width: 36px; }
        .poster-wrap  { width: 72px !important; min-width: 72px !important; height: 108px !important; }
        .poster-bg    { height: 108px !important; min-height: 108px !important; }
        .data-col     { padding: 8px !important; }
        .movie-title  { font-size: 1.06rem !important; }
        .meta-text    { font-size: 0.72rem !important; }
        .meta-year    { font-size: 0.84rem !important; }
        .rating-badge { min-width: 25px; height: 25px; font-size: 0.7rem; }
        .overview-section { padding: 7px 10px 9px; }
        .overview-text    { font-size: 0.75rem; }
        .genre-pill   { font-size: 0.6rem; padding: 1px 6px; }
        .card-checkbox { width: 20px; height: 20px; }
    }
</style>
