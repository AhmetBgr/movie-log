@using MyPrivateWatchlist.Models
@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc

<div class="card person-card border-0" @onclick="OnClick">
    <div class="card-body p-3 text-center">
        <div class="portrait-container mb-3 shadow-sm mx-auto">
            @if (!string.IsNullOrEmpty(Person.ProfilePath))
            {
                <img src="@Person.FullProfileUrl" 
                     class="img-fluid rounded-circle portrait-img" 
                     alt="@Person.Name" 
                     onerror="this.src='https://www.themoviedb.org/assets/2/v4/glyphicons/basic/glyphicons-basic-4-user-grey-d8fe574e3425d038c5d392ed9342517a9494391.svg'"/>
            }
            else
            {
                <div class="portrait-placeholder rounded-circle d-flex align-items-center justify-content-center">
                    <i class="bi bi-person-fill text-secondary opacity-25" style="font-size: 2.5rem;"></i>
                </div>
            }
        </div>
        <h6 class="card-title fw-bold mb-1 person-name">@Person.DisplayTitle</h6>
        @if (!string.IsNullOrEmpty(Person.KnownForDepartment))
        {
            <div class="text-secondary small department-tag">@Person.KnownForDepartment</div>
        }
    </div>
</div>

@code {
    [Parameter] public TmdbSearchResultItem Person { get; set; } = new();

    private async Task OnClick()
    {
        await WatchlistSvc.OpenPersonProfileAsync(Person.Id);
    }
}

<style>
    .person-card {
        background: #fff;
        border-radius: 12px !important;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        display: block;
        height: 100%;
    }

    .person-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        background: #f8f9fa;
    }

    .portrait-container {
        width: 100px;
        height: 100px;
        position: relative;
        overflow: hidden;
        border: 3px solid #fff;
        background: #f1f3f4;
    }

    .portrait-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .portrait-placeholder {
        width: 100%;
        height: 100%;
        background: #f1f3f4;
    }

    .person-name {
        font-size: 0.95rem;
        color: #1a1a2e;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .department-tag {
        font-size: 0.7rem;
        letter-spacing: 0.02em;
        text-transform: uppercase;
        font-weight: 600;
        opacity: 0.7;
    }

    @@media (max-width: 576px) {
        .portrait-container { width: 80px; height: 80px; }
        .person-name { font-size: 0.85rem; }
        .person-card:hover { transform: none; }
    }
</style>
