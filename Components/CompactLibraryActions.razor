@using MyPrivateWatchlist.Models
@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc
@inject IJSRuntime JS
@implements IDisposable

<div class="compact-actions-container shadow-sm border rounded-4 bg-white p-2">
    <div class="d-flex align-items-center gap-2">
        
        <!-- Rating Box -->
        <div class="d-flex align-items-center gap-1 flex-shrink-0">
            <div class="rounded-3 d-flex flex-column align-items-center justify-content-center shadow-sm transition-all rating-box-indicator" 
                 style="width: 44px; height: 44px; background-color: @(Item?.Rating20 == null ? "#fff" : GetRatingColor(Item.Rating20.Value)); 
                        color: @(Item?.Rating20 == null ? "#adb5bd" : "#fff"); 
                        border: @(Item?.Rating20 == null ? "2px dashed #dee2e6" : "none")">
                <input type="number" class="form-control form-control-sm text-center fw-black p-0 border-0 bg-transparent fs-4 no-spinner shadow-none @(Item?.Rating20 == null ? "text-dark" : "text-white")" 
                       style="width: 44px; height: 44px; cursor: pointer;"
                       min="0" max="100" 
                       placeholder="-"
                       value="@(Item?.Rating20)" 
                       @onchange="HandleRatingEdit" />
            </div>
            @if (Item?.Rating20 != null)
            {
                <button class="remove-rating-btn" title="Clear Rating" @onclick="() => HandleRatingEdit(new ChangeEventArgs { Value = null })">
                    <i class="bi bi-x-circle-fill"></i>
                </button>
            }
        </div>

        <!-- Status Grid -->
        <div class="flex-grow-1">
            <div class="status-compact-pills">
                <button class="status-pill @(Item?.Status == WatchlistStatus.Pending ? "active pending" : "")"
                        title="Watchlist"
                        @onclick="() => ToggleStatus(WatchlistStatus.Pending)">
                    <i class="bi bi-list-nested"></i>
                    <span class="pill-label">Watchlist</span>
                </button>
                <button class="status-pill @(Item?.Status == WatchlistStatus.Watching ? "active watching" : "")"
                        title="Watching"
                        @onclick="() => ToggleStatus(WatchlistStatus.Watching)">
                    <i class="bi bi-play-fill"></i>
                    <span class="pill-label">Watching</span>
                </button>
                <button class="status-pill @(Item?.Status == WatchlistStatus.Watched ? "active watched" : "")"
                        title="Watched"
                        @onclick="() => ToggleStatus(WatchlistStatus.Watched)">
                    <i class="bi bi-check-lg"></i>
                    <span class="pill-label">Watched</span>
                </button>
            </div>
        </div>

        <!-- Collection Actions -->
        <div class="collection-actions flex-shrink-0">
            <details class="open-on-menu" open="@_isCollectionMenuOpen" @ontoggle="() => _isCollectionMenuOpen = !_isCollectionMenuOpen" @onclick:stopPropagation="true">
                <summary class="add-col-btn open-on-trigger" title="Add to Collection" @onclick:stopPropagation="true">
                    <i class="bi bi-plus-lg"></i>
                </summary>
                <div class="open-on-popover">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="open-on-heading">Add to Collection</div>
                        <button type="button" class="open-on-close" title="Close" @onclick='() => JS.InvokeVoidAsync("openOnMenu.closeAll")'>
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                    @foreach (var col in WatchlistSvc.Collections)
                    {
                        var isInCol = col.MovieIds.Contains(ImdbId);
                        <button type="button" class="open-on-item w-100 border-0 text-start d-flex align-items-center justify-content-between @(isInCol ? "text-primary fw-bold" : "")" 
                                @onclick='() => HandleCollectionToggle(col)'>
                            <span>@col.Name</span>
                            @if (isInCol) { <i class="bi bi-check-circle-fill"></i> }
                        </button>
                    }
                    @if (!WatchlistSvc.Collections.Any())
                    {
                        <div class="px-3 py-2 text-muted small italic">No collections yet.</div>
                    }
                </div>
            </details>
        </div>

    </div>
</div>

<style>
    .compact-actions-container {
        transition: all 0.2s;
    }

    .rating-box-indicator {
        position: relative;
    }

    .remove-rating-btn {
        background: transparent;
        border: none;
        color: #94a3b8;
        padding: 0;
        cursor: pointer;
        opacity: 0.5;
        transition: all 0.2s;
        font-size: 0.85rem;
    }
    .remove-rating-btn:hover { color: #ef4444; opacity: 1; }

    .status-compact-pills {
        display: flex;
        background: #f1f5f9;
        padding: 3px;
        border-radius: 12px;
        gap: 3px;
    }

    .status-pill {
        flex: 1;
        height: 38px;
        border: none;
        background: transparent;
        border-radius: 9px;
        color: #94a3b8;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        transition: all 0.2s;
        line-height: 1;
        padding: 0 4px;
    }
    .pill-label { font-size: 0.52rem; font-weight: 700; text-transform: uppercase; margin-top: 2px; }
    .status-pill:hover { color: #64748b; background: rgba(255,255,255,0.5); }
    .status-pill.active { color: #fff; }
    .status-pill.active.pending { background: #64748b; box-shadow: 0 2px 8px rgba(100, 116, 139, 0.3); }
    .status-pill.active.watching { background: #10b981; box-shadow: 0 2px 8px rgba(16, 185, 129, 0.3); }
    .status-pill.active.watched { background: #6366f1; box-shadow: 0 2px 8px rgba(99, 102, 241, 0.3); }

    .add-col-btn {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        background: #f1f5f9;
        color: #64748b;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
    }
    .add-col-btn:hover { background: #e2e8f0; color: #1e293b; }

    .no-spinner::-webkit-outer-spin-button,
    .no-spinner::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .open-on-popover {
        position: fixed;
        min-width: 180px;
        padding: 8px;
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 12px;
        background: #fff;
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.16);
        z-index: 99999;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transition: opacity 0.1s ease, transform 0.1s ease;
    }

    .open-on-menu[open] .open-on-popover[data-positioned="true"] {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
    }

    .open-on-heading {
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6c757d;
        padding: 2px 6px 8px;
        margin: 0;
    }

    .open-on-item {
        display: block;
        padding: 8px 10px;
        border-radius: 8px;
        color: #212529;
        background: transparent;
        font-size: 0.88rem;
        font-weight: 500;
        text-decoration: none;
        white-space: nowrap;
        transition: background 0.1s ease;
    }
    .open-on-item:nth-of-type(even) { background: rgba(0, 0, 0, 0.025); }
    .open-on-item:hover { background: #f5f6f8; color: #111; }

    .open-on-close {
        width: 26px;
        height: 26px;
        border: 0;
        border-radius: 999px;
        background: transparent;
        color: #6c757d;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.12s ease, color 0.12s ease;
    }
    .open-on-close:hover { background: rgba(0, 0, 0, 0.06); color: #212529; }

    .animate-fade-out {
        animation: fadeOutStatus 1.5s forwards;
    }

    @@keyframes fadeOutStatus {
        0% { opacity: 0; transform: translate(-50%, 10px); }
        20% { opacity: 1; transform: translate(-50%, 0); }
        80% { opacity: 1; }
        100% { opacity: 0; transform: translate(-50%, -10px); }
    }
</style>

@code {
    [Parameter] public WatchlistItem? Item { get; set; }
    [Parameter] public string ImdbId { get; set; } = "";
    [Parameter] public TmdbMovie? Movie { get; set; }

    private bool showSavedIndicator = false;
    private bool _isCollectionMenuOpen = false;

    protected override async Task OnInitializedAsync()
    {
        WatchlistSvc.OnStateChanged += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("openOnMenu.init");
        }
    }

    public void Dispose()
    {
        WatchlistSvc.OnStateChanged -= StateHasChanged;
    }

    private string GetRatingColor(int val)
    {
        double hue = (val / 100.0) * 120;
        return $"hsl({hue}, 70%, 40%)";
    }

    private async Task HandleRatingEdit(ChangeEventArgs e)
    {
        var inputVal = e.Value?.ToString();
        int? val = null;
        if (int.TryParse(inputVal, out var parsed)) 
        {
            val = Math.Clamp(parsed, 0, 100);
        }
        
        if (Item != null)
        {
            await WatchlistSvc.UpdateRatingAsync(Item, val);
            showSavedIndicator = true;
            StateHasChanged();
            await Task.Delay(1500);
            showSavedIndicator = false;
            StateHasChanged();
        }
    }

    private async Task RemoveFromLibrary()
    {
        if (await JS.InvokeAsync<bool>("confirm", "Remove this item from your library?"))
        {
            await WatchlistSvc.RemoveFromWatchlistByImdbIdAsync(ImdbId);
            Item = null;
            showSavedIndicator = true;
            StateHasChanged();
            await Task.Delay(1500);
            showSavedIndicator = false;
            StateHasChanged();
        }
    }

    private async Task ToggleStatus(WatchlistStatus newStatus)
    {
        if (Item != null && Item.Status == newStatus)
        {
            await RemoveFromLibrary();
            return;
        }

        if (Item == null && Movie != null)
        {
            // Auto-add to library if movie matches
            Item = new WatchlistItem
            {
                ImdbId = ImdbId,
                Title = Movie.Title,
                Status = newStatus,
                TmdbId = Movie.Id,
                PosterPath = Movie.PosterPath,
                Year = Movie.ReleaseDate ?? "",
                Runtime = Movie.Runtime,
                VoteAverage = Movie.VoteAverage,
                Genres = string.Join(", ", Movie.GenreList?.Select(g => g.Name) ?? Enumerable.Empty<string>())
            };
            WatchlistSvc.Items.Add(Item);
        }
        else if (Item != null)
        {
            Item.Status = newStatus;
        }

        if (Item != null)
        {
            await WatchlistSvc.UpdateStatusAsync(Item, newStatus);
            showSavedIndicator = true;
            StateHasChanged();
            await Task.Delay(1500);
            showSavedIndicator = false;
            StateHasChanged();
        }
    }

    private async Task HandleCollectionToggle(CustomCollection col)
    {
        if (col.MovieIds.Contains(ImdbId))
        {
            await WatchlistSvc.RemoveMovieFromCollectionAsync(col.Id, ImdbId);
        }
        else
        {
            await WatchlistSvc.AddMovieToCollectionAsync(col.Id, ImdbId);
        }
    }
}
