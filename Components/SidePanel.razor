@code {
    private bool showScreenshots = false;
    private string? selectedLightboxPath;
    private bool isTrailerOpen = false;

    private void ClosePanel() => WatchlistSvc.CloseSidePanel();
    private void OpenLightbox(string path) => selectedLightboxPath = path;

    protected override void OnInitialized()
    {
        WatchlistSvc.OnStateChanged += HandleStateChanged;
    }

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        WatchlistSvc.OnStateChanged -= HandleStateChanged;
    }

    private bool showSavedIndicator = false;

    private async Task HandleRatingEdit(ChangeEventArgs e)
    {
        var inputVal = e.Value?.ToString();
        int? val = null;
        if (int.TryParse(inputVal, out var parsed)) 
        {
            val = parsed;
            if (val > 100) val = 100;
            if (val < 0) val = 0;
        }
        
        await UpdateRating(val);
        
        if (val.HasValue)
        {
            showSavedIndicator = true;
            StateHasChanged();
            await Task.Delay(1500);
            showSavedIndicator = false;
            StateHasChanged();
        }
    }

    private async Task UpdateRating(int? val)
    {
        var libItem = GetLibraryItem();
        if (libItem != null)
        {
            await WatchlistSvc.UpdateRatingAsync(libItem, val);
        }
        else if (val.HasValue && WatchlistSvc.SelectedMovie != null)
        {
            var movie = WatchlistSvc.SelectedMovie;
            var newItem = new WatchlistItem
            {
                ImdbId = movie.ImdbId ?? "",
                Title = movie.Title,
                TitleType = WatchlistSvc.SelectedItem?.TitleType ?? "Movie",
                Year = movie.ReleaseDate ?? "",
                ParsedYear = int.TryParse(movie.ReleaseDate?.Split('-')[0], out var y) ? y : 0,
                Status = WatchlistStatus.Watched,
                Rating20 = val,
                DateAdded = DateTime.Now,
                Genres = string.Join(", ", movie.GenreList.Select(g => g.Name)),
                Director = movie.Credits?.Crew?.FirstOrDefault(c => c.Job == "Director")?.Name,
                Overview = movie.Overview,
                PosterPath = movie.PosterPath
            };
            await WatchlistSvc.AddItemAsync(newItem);
        }
    }

    private string GetRatingColor(int val)
    {
        double hue = (val / 100.0) * 120;
        return $"hsl({hue}, 75%, 45%)";
    }

    private string FormatRuntime(int minutes)
    {
        if (minutes < 60) return $"{minutes}m";
        var h = minutes / 60;
        var m = minutes % 60;
        return m == 0 ? $"{h}h" : $"{h}h {m}m";
    }

    private WatchlistItem? GetLibraryItem()
    {
        return WatchlistSvc.Items.FirstOrDefault(i => i.ImdbId == WatchlistSvc.SelectedItem?.ImdbId && !string.IsNullOrEmpty(i.ImdbId));
    }

    private async Task ToggleStatus(WatchlistStatus status)
    {
        if (WatchlistSvc.SelectedItem != null && WatchlistSvc.SelectedMovie != null)
        {
            var libItem = GetLibraryItem();
            if (libItem == null)
            {
                var movie = WatchlistSvc.SelectedMovie;
                var item = WatchlistSvc.SelectedItem;
                var newItem = new WatchlistItem {
                    ImdbId = movie.ImdbId ?? item.ImdbId ?? "",
                    Title = movie.Title,
                    TitleType = item.TitleType,
                    Year = movie.ReleaseDate ?? "",
                    ParsedYear = int.TryParse(movie.ReleaseDate?.Split('-')[0], out var y) ? y : 0,
                    Status = status,
                    DateAdded = DateTime.Now
                };
                await WatchlistSvc.AddToWatchlistAsync(newItem);
            }
            else
            {
                if (libItem.Status == status)
                {
                    await WatchlistSvc.RemoveFromWatchlistAsync(libItem);
                }
                else
                {
                    await WatchlistSvc.UpdateStatusAsync(libItem, status);
                }
            }
        }
    }

    private string GetModalYear(TmdbMovie movie, WatchlistItem item)
    {
        if (!string.IsNullOrWhiteSpace(movie.ReleaseDate) && movie.ReleaseDate.Length >= 4) return movie.ReleaseDate[..4];
        return item.Year ?? "";
    }

    private string GetModalImdbId(TmdbMovie movie, WatchlistItem item) => movie.ImdbId ?? item.ImdbId ?? "";
}

