@using MyPrivateWatchlist.Models
@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc
@inject IJSRuntime JS

<div class="advanced-filter-sidebar @(IsMobile ? "mobile" : "desktop")" @ontouchstart="OnTouchStart" @ontouchend="OnTouchEnd">
    <div class="filter-header">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="fw-bold m-0"><i class="bi bi-sliders2 me-2"></i>@Title</h5>
            <button class="btn-close d-sm-none" @onclick="CloseSidebar" aria-label="Close"></button>
        </div>
    </div>
    
    <div class="filter-scroll-content" style="flex: 0 1 auto;">
        <!-- Title Quick Search -->
        <div class="filter-section mb-4">
             <div class="filter-label">Title Search</div>
             <div class="position-relative mt-2">
                 <input type="text" class="form-control filter-input shadow-none" 
                        placeholder="Filter by title..."
                        @bind="WatchlistSvc.AdvancedFilter.TitleSearch" @bind:event="oninput" @onkeyup="OnStateChanged" />
                 <i class="bi bi-search position-absolute end-0 top-50 translate-middle-y me-3 opacity-25"></i>
             </div>
        </div>

        <!-- Genre Matrix -->
        <div class="filter-section mb-4">
            <div class="filter-label d-flex justify-content-between align-items-center" @onclick="ToggleGenre">
                <span>Genres</span>
                <i class="bi @(_showGenre ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </div>
            @if (_showGenre)
            {
                <div class="mt-2">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="text-secondary" style="font-size:0.65rem;">Matching Logic:</span>
                        <div class="btn-group btn-group-sm" role="group">
                            <input type="radio" class="btn-check" name="genlogic" id="glany" checked="@(WatchlistSvc.AdvancedFilter.GenreLogic == GenreLogic.Any)" @onclick="() => SetGenreLogic(GenreLogic.Any)">
                            <label class="btn btn-outline-secondary px-3" for="glany" style="font-size:0.6rem; font-weight: 700;">ANY</label>
                            
                            <input type="radio" class="btn-check" name="genlogic" id="glall" checked="@(WatchlistSvc.AdvancedFilter.GenreLogic == GenreLogic.All)" @onclick="() => SetGenreLogic(GenreLogic.All)">
                            <label class="btn btn-outline-secondary px-3" for="glall" style="font-size:0.6rem; font-weight: 700;">ALL</label>
                        </div>
                    </div>
                    <div class="genre-grid">
                        @foreach (var g in AvailableGenres)
                        {
                            var state = GetGenreState(g);
                            <button class="genre-btn @(state == 1 ? "genre-inc" : state == 2 ? "genre-exc" : "")"
                                    @onclick="() => CycleGenre(g)">
                                @if (state == 1) { <i class="bi bi-plus-circle-fill me-1"></i> }
                                @if (state == 2) { <i class="bi bi-dash-circle-fill me-1"></i> }
                                @g
                            </button>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Ranges & Ratings -->
        <div class="filter-section mb-4">
             <div class="filter-label d-flex justify-content-between align-items-center" @onclick="ToggleRanges">
                <span>Release & Rating</span>
                <i class="bi @(_showRanges ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </div>
            @if (_showRanges)
            {
                <div class="mt-3">
                    <label class="range-sub-label">Release Year</label>
                    <div class="d-flex gap-2 mb-3">
                        <input type="number" class="form-control form-control-sm filter-input shadow-none" placeholder="Min" 
                               value="@WatchlistSvc.AdvancedFilter.MinYear" @onchange="@(e => { int.TryParse(e.Value?.ToString(), out var v); WatchlistSvc.AdvancedFilter.MinYear = v > 0 ? v : null; OnStateChanged(); })" />
                        <input type="number" class="form-control form-control-sm filter-input shadow-none" placeholder="Max" 
                               value="@WatchlistSvc.AdvancedFilter.MaxYear" @onchange="@(e => { int.TryParse(e.Value?.ToString(), out var v); WatchlistSvc.AdvancedFilter.MaxYear = v > 0 ? v : null; OnStateChanged(); })" />
                    </div>

                    @if (ShowUserRatingFilter)
                    {
                        <label class="range-sub-label">User Rating (0-100)</label>
                        <div class="d-flex gap-2 mb-3">
                            <input type="number" class="form-control form-control-sm filter-input shadow-none" placeholder="Min" 
                                   value="@WatchlistSvc.AdvancedFilter.MinUserRating" @onchange="@(e => { int.TryParse(e.Value?.ToString(), out var v); WatchlistSvc.AdvancedFilter.MinUserRating = v >= 0 ? v : null; OnStateChanged(); })" />
                            <input type="number" class="form-control form-control-sm filter-input shadow-none" placeholder="Max" 
                                   value="@WatchlistSvc.AdvancedFilter.MaxUserRating" @onchange="@(e => { int.TryParse(e.Value?.ToString(), out var v); WatchlistSvc.AdvancedFilter.MaxUserRating = v >= 0 ? v : null; OnStateChanged(); })" />
                        </div>
                    }

                    @if (ShowTmdbRatingFilter)
                    {
                        <label class="range-sub-label">TMDB Rating (0-10)</label>
                        <div class="d-flex gap-2">
                            <input type="number" class="form-control form-control-sm filter-input shadow-none" placeholder="Min" step="0.5"
                                   value="@WatchlistSvc.AdvancedFilter.MinTmdbRating" @onchange="@(e => { double.TryParse(e.Value?.ToString(), out var v); WatchlistSvc.AdvancedFilter.MinTmdbRating = v >= 0 ? v : null; OnStateChanged(); })" />
                            <input type="number" class="form-control form-control-sm filter-input shadow-none" placeholder="Max" step="0.5"
                                   value="@WatchlistSvc.AdvancedFilter.MaxTmdbRating" @onchange="@(e => { double.TryParse(e.Value?.ToString(), out var v); WatchlistSvc.AdvancedFilter.MaxTmdbRating = v >= 0 ? v : null; OnStateChanged(); })" />
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Quick Toggles -->
        <div class="filter-section mb-4">
             <div class="filter-label d-flex justify-content-between align-items-center" @onclick="ToggleQuick">
                <span>Quick Tags</span>
                <i class="bi @(_showQuick ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </div>
            @if (_showQuick)
            {
                <div class="d-flex flex-wrap gap-2 mt-3">
                    <button class="btn btn-sm @(WatchlistSvc.AdvancedFilter.UnratedOnly ? "btn-primary" : "btn-outline-secondary") rounded-pill px-3"
                            @onclick="() => { WatchlistSvc.AdvancedFilter.UnratedOnly = !WatchlistSvc.AdvancedFilter.UnratedOnly; OnStateChanged(); }">
                        Not Rated
                    </button>
                    <button class="btn btn-sm @(WatchlistSvc.AdvancedFilter.ShortFilmsOnly ? "btn-primary" : "btn-outline-secondary") rounded-pill px-3"
                            @onclick="() => { WatchlistSvc.AdvancedFilter.ShortFilmsOnly = !WatchlistSvc.AdvancedFilter.ShortFilmsOnly; OnStateChanged(); }">
                        Shorts &lt;85m
                    </button>
                </div>
            }
        </div>
    </div>

    <!-- Actions Area -->
    <div class="filter-footer">
        <div class="d-flex gap-2">
            <button class="btn btn-primary btn-sm flex-grow-1 py-2 fw-bold shadow-sm" @onclick="PickRandom" title="Pick a random movie from currently filtered results">
                <i class="bi bi-dice-5 me-1"></i> Feeling Lucky
            </button>
            <button class="btn btn-outline-danger btn-sm px-3" @onclick="ResetFilters" title="Reset all current filters">
                <i class="bi bi-trash"></i>
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Filters";
    [Parameter] public List<string> AvailableGenres { get; set; } = new();
    [Parameter] public bool ShowUserRatingFilter { get; set; }
    [Parameter] public bool ShowTmdbRatingFilter { get; set; }
    [Parameter] public EventCallback OnClearFilters { get; set; }
    [Parameter] public EventCallback<TouchEventArgs> OnTouchStart { get; set; }
    [Parameter] public EventCallback<TouchEventArgs> OnTouchEnd { get; set; }
    [Parameter] public WatchlistStatus CurrentStatus { get; set; } = WatchlistStatus.Pending;
    [Parameter] public EventCallback OnClose { get; set; }

    private bool _showGenre = true;
    private bool _showRanges = false;
    private bool _showQuick = false;
    private bool IsMobile = false;

    protected override async Task OnInitializedAsync()
    {
        // Auto-activate since the toggle is gone
        WatchlistSvc.AdvancedFilter.IsActive = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                IsMobile = await JS.InvokeAsync<bool>("uiHelpers.isMobile");
                
                var sGenre = await JS.InvokeAsync<string>("sessionStorage.getItem", $"afp_{Title}_genre");
                if (sGenre != null) _showGenre = sGenre == "1";

                var sRanges = await JS.InvokeAsync<string>("sessionStorage.getItem", $"afp_{Title}_ranges");
                if (sRanges != null) _showRanges = sRanges == "1";

                var sQuick = await JS.InvokeAsync<string>("sessionStorage.getItem", $"afp_{Title}_quick");
                if (sQuick != null) _showQuick = sQuick == "1";

                StateHasChanged();
            }
            catch { }
        }
    }

    private async Task CloseSidebar() => await OnClose.InvokeAsync();
    
    private async Task ToggleGenre() { _showGenre = !_showGenre; await JS.InvokeVoidAsync("sessionStorage.setItem", $"afp_{Title}_genre", _showGenre ? "1" : "0"); }
    private async Task ToggleRanges() { _showRanges = !_showRanges; await JS.InvokeVoidAsync("sessionStorage.setItem", $"afp_{Title}_ranges", _showRanges ? "1" : "0"); }
    private async Task ToggleQuick() { _showQuick = !_showQuick; await JS.InvokeVoidAsync("sessionStorage.setItem", $"afp_{Title}_quick", _showQuick ? "1" : "0"); }

    private int GetGenreState(string g)
    {
        if (WatchlistSvc.AdvancedFilter.IncludedGenres.Contains(g)) return 1;
        if (WatchlistSvc.AdvancedFilter.ExcludedGenres.Contains(g)) return 2;
        return 0;
    }

    private void CycleGenre(string g)
    {
        var state = GetGenreState(g);
        if (state == 0) { WatchlistSvc.AdvancedFilter.IncludedGenres.Add(g); }
        else if (state == 1) { WatchlistSvc.AdvancedFilter.IncludedGenres.Remove(g); WatchlistSvc.AdvancedFilter.ExcludedGenres.Add(g); }
        else { WatchlistSvc.AdvancedFilter.ExcludedGenres.Remove(g); }
        OnStateChanged();
    }

    private void SetGenreLogic(GenreLogic l)
    {
        WatchlistSvc.AdvancedFilter.GenreLogic = l;
        OnStateChanged();
    }

    private void ResetFilters()
    {
        WatchlistSvc.AdvancedFilter = new AdvancedFilterState { IsActive = true };
        OnStateChanged();
    }

    private async Task PickRandom()
    {
        await WatchlistSvc.ShowRandomFromFilteredAsync(CurrentStatus);
    }

    private void OnStateChanged()
    {
        WatchlistSvc.NotifyStateChanged();
    }
}

<style>
    .advanced-filter-sidebar {
        display: flex;
        flex-direction: column;
        background: #fff;
        box-shadow: 0 10px 40px rgba(0,0,0,0.08);
        z-index: 100;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .advanced-filter-sidebar.desktop {
        width: 320px;
        flex-shrink: 0;
        height: auto;
        max-height: calc(100vh - 120px);
        margin: 16px;
        border-radius: 20px;
        border: 1px solid rgba(0,0,0,0.05);
        align-self: flex-start;
    }

    .advanced-filter-sidebar.mobile {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        height: 75vh;
        border-radius: 24px 24px 0 0;
        box-shadow: 0 -10px 40px rgba(0,0,0,0.2);
        border-right: none;
    }

    .filter-header {
        padding: 24px 20px 16px;
        background: linear-gradient(to bottom, #fff, #fdfdfd);
        border-bottom: 1px solid rgba(0,0,0,0.03);
    }

    .filter-scroll-content {
        flex: 0 1 auto;
        overflow-y: auto;
        padding: 20px;
    }

    .filter-footer {
        padding: 16px 20px;
        background: #fdfdfd;
        border-top: 1px solid rgba(0,0,0,0.05);
    }

    .filter-label {
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #999;
        cursor: pointer;
    }

    .range-sub-label {
        display: block;
        font-size: 0.62rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #aaa;
        margin-bottom: 4px;
    }

    .filter-input {
        background: #f8f9fa;
        border: 1px solid #eee;
        border-radius: 8px;
        padding: 10px 12px;
        font-size: 0.85rem;
        transition: all 0.2s;
    }
    .filter-input:focus {
        background: #fff;
        border-color: var(--bs-primary);
        box-shadow: 0 0 0 3px rgba(var(--bs-primary-rgb), 0.1);
    }

    .genre-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 6px;
    }

    .genre-btn {
        background: #f8f9fa;
        border: 1px solid #eee;
        border-radius: 8px;
        padding: 7px 10px;
        font-size: 0.7rem;
        text-align: left;
        transition: all 0.2s;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: #444;
        font-weight: 500;
    }
    .genre-btn:hover { background: #eee; border-color: #ddd; }
    .genre-inc { background: #e7f5ec; border-color: #badcc3; color: #198754; font-weight: 700; }
    .genre-exc { background: #fdf2f2; border-color: #fbd5d5; color: #dc3545; font-weight: 700; }

    @@media (max-width: 576px) {
        .filter-header { padding: 20px 20px 12px; }
        .filter-scroll-content { padding: 16px 20px; }
    }
</style>
