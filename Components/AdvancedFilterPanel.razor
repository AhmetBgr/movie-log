@using MyPrivateWatchlist.Models
@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc
@inject IJSRuntime JS

<div class="advanced-filter-sidebar @(IsMobile ? "mobile" : "desktop")" @ontouchstart="OnTouchStart" @ontouchend="OnTouchEnd">

    <div class="filter-scroll-content">
        <!-- Applied Filters Summary -->
        @if (HasAppliedFilters)
        {
            <div class="applied-filters-box">
                <div class="summary-header d-flex justify-content-between align-items-center">
                    <span>Current Filters</span>
                    <i class="bi bi-x-circle text-danger cursor-pointer" @onclick="ResetFilters" title="Clear All"></i>
                </div>
                <div class="summary-body">
                    @if (WatchlistSvc.AdvancedFilter.IncludedGenres.Any() || WatchlistSvc.AdvancedFilter.ExcludedGenres.Any())
                    {
                        <div class="summary-row">
                            <span><b>Genres:</b> @GetAppliedGenreSummary()</span>
                            <i class="bi bi-x-circle text-danger ms-1 cursor-pointer" @onclick="ClearAppliedGenres"></i>
                        </div>
                    }
                    @if (WatchlistSvc.AdvancedFilter.IncludedTypes.Any() || WatchlistSvc.AdvancedFilter.ExcludedTypes.Any())
                    {
                        <div class="summary-row">
                            <span><b>Types:</b> @GetAppliedTypeSummary()</span>
                            <i class="bi bi-x-circle text-danger ms-1 cursor-pointer" @onclick="ClearAppliedTypes"></i>
                        </div>
                    }
                    @if (WatchlistSvc.AdvancedFilter.ShortFilmsOnly)
                    {
                        <div class="summary-row">
                            <span><b>Shorts:</b> &le;40m</span>
                            <i class="bi bi-x-circle text-danger ms-1 cursor-pointer" @onclick="ClearAppliedShorts"></i>
                        </div>
                    }
                    @if (WatchlistSvc.AdvancedFilter.MinYear.HasValue || WatchlistSvc.AdvancedFilter.MaxYear.HasValue)
                    {
                        <div class="summary-row">
                            <span><b>Years:</b> @WatchlistSvc.AdvancedFilter.MinYear - @WatchlistSvc.AdvancedFilter.MaxYear</span>
                            <i class="bi bi-x-circle text-danger ms-1 cursor-pointer" @onclick="ClearAppliedYears"></i>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Title Quick Search -->
        <div class="filter-section mb-3">
            <div class="position-relative mt-2">
                <input type="text" class="form-control filter-input shadow-none" 
                       placeholder="Search title or director..."
                       @bind="_localFilter.TitleSearch" @bind:event="oninput" />
                <i class="bi bi-search position-absolute end-0 top-50 translate-middle-y me-3 opacity-25"></i>
            </div>
        </div>

        <div class="filter-section">
            <div class="filter-label @(_showGenre ? "expanded" : "")" @onclick="ToggleGenre">
                <span>Genres</span>
            </div>
            @if (_showGenre)
            {
                <div class="mt-2">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="text-secondary" style="font-size:0.65rem;">Matching Logic:</span>
                        <div class="btn-group btn-group-sm" role="group">
                            <input type="radio" class="btn-check" name="genlogic" id="glany" checked="@(_localFilter.GenreLogic == GenreLogic.Any)" @onclick="() => SetGenreLogic(GenreLogic.Any)">
                            <label class="btn btn-outline-secondary px-3" for="glany" style="font-size:0.6rem; font-weight: 700;">ANY</label>
                            
                            <input type="radio" class="btn-check" name="genlogic" id="glall" checked="@(_localFilter.GenreLogic == GenreLogic.All)" @onclick="() => SetGenreLogic(GenreLogic.All)">
                            <label class="btn btn-outline-secondary px-2" for="glall" style="font-size:0.55rem; font-weight: 700;">ALL</label>
                        </div>
                    </div>
                    <div class="genre-grid">
                        @foreach (var g in AvailableGenres)
                        {
                            var state = GetGenreState(g);
                            <button class="genre-btn @(state == 1 ? "genre-inc" : state == 2 ? "genre-exc" : "")"
                                    @onclick="() => CycleGenre(g)">
                                @if (state == 1) { <i class="bi bi-plus-circle-fill me-1"></i> }
                                @if (state == 2) { <i class="bi bi-dash-circle-fill me-1"></i> }
                                @g
                            </button>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="filter-section">
            <div class="filter-label @(_showTypes ? "expanded" : "")" @onclick="ToggleTypes">
                <span>Release Types</span>
            </div>
            @if (_showTypes)
            {
                <div class="mt-2 text-center mb-2" style="font-size: 0.65rem; color: #94a3b8;">
                    Click once to <b>Include</b>, twice to <b>Exclude</b>
                </div>
                <div class="genre-grid">
                    @foreach (var t in AvailableTypes)
                    {
                        var state = GetTypeState(t);
                        <button class="genre-btn @(state == 1 ? "genre-inc" : state == 2 ? "genre-exc" : "")"
                                @onclick="() => CycleType(t)">
                            @if (state == 1) { <i class="bi bi-plus-circle-fill me-1"></i> }
                            @if (state == 2) { <i class="bi bi-dash-circle-fill me-1"></i> }
                            @t
                        </button>
                    }
                </div>
                <div class="d-flex flex-wrap gap-2 mt-2 pt-2 border-top">
                    <button class="genre-btn w-100 @(_localFilter.ShortFilmsOnly ? "genre-inc" : "")"
                            @onclick="() => { _localFilter.ShortFilmsOnly = !_localFilter.ShortFilmsOnly; }">
                        <i class="bi @(_localFilter.ShortFilmsOnly ? "bi-check-circle-fill" : "bi-circle") me-1"></i>
                        Short Films (&le;40m)
                    </button>
                </div>
            }
        </div>

        <div class="filter-section">
             <div class="filter-label @(_showRanges ? "expanded" : "")" @onclick="ToggleRanges">
                <span>Release & Rating</span>
            </div>
            @if (_showRanges)
            {
                <div class="mt-3">
                    <label class="range-sub-label">Release Year</label>
                    <div class="d-flex gap-2 mb-3">
                        <input type="number" class="form-control form-control-sm filter-input shadow-none" placeholder="Min" 
                               @bind="_localFilter.MinYear" />
                        <input type="number" class="form-control form-control-sm filter-input shadow-none" placeholder="Max" 
                               @bind="_localFilter.MaxYear" />
                    </div>

                    @if (ShowUserRatingFilter)
                    {
                        <label class="range-sub-label">User Rating (0-100)</label>
                        <div class="d-flex gap-2 mb-3">
                            <input type="number" class="form-control form-control-sm filter-input shadow-none" placeholder="Min" 
                                   @bind="_localFilter.MinUserRating" />
                            <input type="number" class="form-control form-control-sm filter-input shadow-none" placeholder="Max" 
                                   @bind="_localFilter.MaxUserRating" />
                        </div>
                    }

                    @if (ShowTmdbRatingFilter)
                    {
                        <label class="range-sub-label">TMDB Rating (0-10)</label>
                        <div class="d-flex gap-2">
                            <input type="number" class="form-control form-control-sm filter-input shadow-none" placeholder="Min" step="0.5"
                                   @bind="_localFilter.MinTmdbRating" />
                            <input type="number" class="form-control form-control-sm filter-input shadow-none" placeholder="Max" step="0.5"
                                   @bind="_localFilter.MaxTmdbRating" />
                        </div>
                    }

                    <div class="mt-3 pt-3 border-top">
                        <button class="btn btn-sm w-100 @(_localFilter.UnratedOnly ? "genre-inc" : "btn-outline-secondary") rounded-pill px-3"
                                style="font-size: 0.75rem; font-weight: 700;"
                                @onclick="() => { _localFilter.UnratedOnly = !_localFilter.UnratedOnly; }">
                            <i class="bi @(_localFilter.UnratedOnly ? "bi-check-circle-fill" : "bi-circle") me-1"></i>
                            Not Rated Only
                        </button>
                    </div>
                </div>
            }
        </div>

    </div>

    <!-- Actions Area -->
    <div class="filter-footer">
        <div class="d-grid gap-2">
            <button class="btn @(IsDirty ? "btn-apply-dirty" : "btn-outline-secondary") py-2 fw-bold shadow-sm" 
                    disabled="@(!IsDirty)"
                    @onclick="ApplyFilters">
                <i class="bi bi-check2-circle me-1"></i> Apply
            </button>
            <div class="d-flex gap-2">
                 <button class="btn btn-outline-secondary btn-sm flex-grow-1" @onclick="PickRandom" title="Pick a random movie from currently filtered results">
                    <i class="bi bi-dice-5 me-1"></i> Random
                </button>
                <button class="btn btn-outline-danger btn-sm px-3" @onclick="ResetFilters" title="Reset all current filters">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Filters";
    [Parameter] public List<string> AvailableGenres { get; set; } = new();
    [Parameter] public List<string> AvailableTypes { get; set; } = new();
    [Parameter] public bool ShowUserRatingFilter { get; set; }
    [Parameter] public bool ShowTmdbRatingFilter { get; set; }
    [Parameter] public EventCallback OnClearFilters { get; set; }
    [Parameter] public EventCallback<TouchEventArgs> OnTouchStart { get; set; }
    [Parameter] public EventCallback<TouchEventArgs> OnTouchEnd { get; set; }
    [Parameter] public WatchlistStatus CurrentStatus { get; set; } = WatchlistStatus.Pending;
    [Parameter] public EventCallback OnClose { get; set; }

    private bool _showTitleSearch = false;
    private bool _showGenre = true;
    private bool _showTypes = false;
    private bool _showRanges = false;
    private bool _showQuick = false;
    private bool IsMobile = false;

    private AdvancedFilterState _localFilter = new();

    protected override void OnInitialized()
    {
        _localFilter = CloneState(WatchlistSvc.AdvancedFilter);
    }

    private AdvancedFilterState CloneState(AdvancedFilterState s)
    {
        return new AdvancedFilterState
        {
            IsActive = s.IsActive,
            TitleSearch = s.TitleSearch,
            IncludedGenres = new HashSet<string>(s.IncludedGenres),
            ExcludedGenres = new HashSet<string>(s.ExcludedGenres),
            IncludedTypes = new HashSet<string>(s.IncludedTypes),
            ExcludedTypes = new HashSet<string>(s.ExcludedTypes),
            GenreLogic = s.GenreLogic,
            MinYear = s.MinYear,
            MaxYear = s.MaxYear,
            MinTmdbRating = s.MinTmdbRating,
            MaxTmdbRating = s.MaxTmdbRating,
            MinUserRating = s.MinUserRating,
            MaxUserRating = s.MaxUserRating,
            UnratedOnly = s.UnratedOnly,
            ShortFilmsOnly = s.ShortFilmsOnly
        };
    }

    private bool IsDirty => !AreStatesEqual(_localFilter, WatchlistSvc.AdvancedFilter);

    private bool AreStatesEqual(AdvancedFilterState a, AdvancedFilterState b)
    {
        if ((a.TitleSearch ?? "") != (b.TitleSearch ?? "")) return false;
        if (a.GenreLogic != b.GenreLogic) return false;
        if (a.MinYear != b.MinYear) return false;
        if (a.MaxYear != b.MaxYear) return false;
        if (a.MinUserRating != b.MinUserRating) return false;
        if (a.MaxUserRating != b.MaxUserRating) return false;
        if (a.MinTmdbRating != b.MinTmdbRating) return false;
        if (a.MaxTmdbRating != b.MaxTmdbRating) return false;
        if (a.UnratedOnly != b.UnratedOnly) return false;
        if (a.ShortFilmsOnly != b.ShortFilmsOnly) return false;
        
        if (!a.IncludedGenres.SetEquals(b.IncludedGenres)) return false;
        if (!a.ExcludedGenres.SetEquals(b.ExcludedGenres)) return false;
        if (!a.IncludedTypes.SetEquals(b.IncludedTypes)) return false;
        if (!a.ExcludedTypes.SetEquals(b.ExcludedTypes)) return false;
        
        return true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                IsMobile = await JS.InvokeAsync<bool>("uiHelpers.isMobile");
                
                var sTitle = await JS.InvokeAsync<string>("sessionStorage.getItem", $"afp_{Title}_title");
                if (sTitle != null) _showTitleSearch = sTitle == "1";

                var sGenre = await JS.InvokeAsync<string>("sessionStorage.getItem", $"afp_{Title}_genre");
                if (sGenre != null) _showGenre = sGenre == "1";

                var sTypes = await JS.InvokeAsync<string>("sessionStorage.getItem", $"afp_{Title}_types");
                if (sTypes != null) _showTypes = sTypes == "1";

                var sRanges = await JS.InvokeAsync<string>("sessionStorage.getItem", $"afp_{Title}_ranges");
                if (sRanges != null) _showRanges = sRanges == "1";

                var sQuick = await JS.InvokeAsync<string>("sessionStorage.getItem", $"afp_{Title}_quick");
                if (sQuick != null) _showQuick = sQuick == "1";

                StateHasChanged();
            }
            catch { }
        }
    }

    private async Task CloseSidebar() => await OnClose.InvokeAsync();
    
    private async Task ToggleTitle() { _showTitleSearch = !_showTitleSearch; await JS.InvokeVoidAsync("sessionStorage.setItem", $"afp_{Title}_title", _showTitleSearch ? "1" : "0"); }
    private async Task ToggleGenre() { _showGenre = !_showGenre; await JS.InvokeVoidAsync("sessionStorage.setItem", $"afp_{Title}_genre", _showGenre ? "1" : "0"); }
    private async Task ToggleTypes() { _showTypes = !_showTypes; await JS.InvokeVoidAsync("sessionStorage.setItem", $"afp_{Title}_types", _showTypes ? "1" : "0"); }
    private async Task ToggleRanges() { _showRanges = !_showRanges; await JS.InvokeVoidAsync("sessionStorage.setItem", $"afp_{Title}_ranges", _showRanges ? "1" : "0"); }
    private async Task ToggleQuick() { _showQuick = !_showQuick; await JS.InvokeVoidAsync("sessionStorage.setItem", $"afp_{Title}_quick", _showQuick ? "1" : "0"); }

    private int GetGenreState(string g)
    {
        if (_localFilter.IncludedGenres.Contains(g)) return 1;
        if (_localFilter.ExcludedGenres.Contains(g)) return 2;
        return 0;
    }

    private void CycleGenre(string g)
    {
        var state = GetGenreState(g);
        if (state == 0) { _localFilter.IncludedGenres.Add(g); }
        else if (state == 1) { _localFilter.IncludedGenres.Remove(g); _localFilter.ExcludedGenres.Add(g); }
        else { _localFilter.ExcludedGenres.Remove(g); }
    }

    private int GetTypeState(string t)
    {
        if (_localFilter.IncludedTypes.Contains(t)) return 1;
        if (_localFilter.ExcludedTypes.Contains(t)) return 2;
        return 0;
    }

    private void CycleType(string t)
    {
        var state = GetTypeState(t);
        if (state == 0) { _localFilter.IncludedTypes.Add(t); }
        else if (state == 1) { _localFilter.IncludedTypes.Remove(t); _localFilter.ExcludedTypes.Add(t); }
        else { _localFilter.ExcludedTypes.Remove(t); }
    }

    private void SetGenreLogic(GenreLogic l)
    {
        _localFilter.GenreLogic = l;
    }

    private void ApplyFilters()
    {
        WatchlistSvc.AdvancedFilter = CloneState(_localFilter);
        WatchlistSvc.NotifyStateChanged();
        if (IsMobile) _ = CloseSidebar();
    }

    private void ResetFilters()
    {
        _localFilter = new AdvancedFilterState { IsActive = true };
        ApplyFilters();
    }

    private bool HasAppliedFilters => 
        WatchlistSvc.AdvancedFilter.IncludedGenres.Any() || 
        WatchlistSvc.AdvancedFilter.ExcludedGenres.Any() ||
        WatchlistSvc.AdvancedFilter.IncludedTypes.Any() || 
        WatchlistSvc.AdvancedFilter.ExcludedTypes.Any() ||
        WatchlistSvc.AdvancedFilter.ShortFilmsOnly ||
        WatchlistSvc.AdvancedFilter.MinYear.HasValue ||
        WatchlistSvc.AdvancedFilter.MaxYear.HasValue;

    private string GetAppliedGenreSummary()
    {
        var parts = new List<string>();
        if (WatchlistSvc.AdvancedFilter.IncludedGenres.Any())
            parts.Add(string.Join(", ", WatchlistSvc.AdvancedFilter.IncludedGenres));
        if (WatchlistSvc.AdvancedFilter.ExcludedGenres.Any())
            parts.Add("Excl: " + string.Join(", ", WatchlistSvc.AdvancedFilter.ExcludedGenres));
        return string.Join(" | ", parts);
    }

    private string GetAppliedTypeSummary()
    {
        var parts = new List<string>();
        if (WatchlistSvc.AdvancedFilter.IncludedTypes.Any())
            parts.Add(string.Join(", ", WatchlistSvc.AdvancedFilter.IncludedTypes));
        if (WatchlistSvc.AdvancedFilter.ExcludedTypes.Any())
            parts.Add("Excl: " + string.Join(", ", WatchlistSvc.AdvancedFilter.ExcludedTypes));
        return string.Join(" | ", parts);
    }

    private void ClearAppliedGenres() 
    { 
        _localFilter.IncludedGenres.Clear(); 
        _localFilter.ExcludedGenres.Clear(); 
        ApplyFilters(); 
    }
    private void ClearAppliedTypes() 
    { 
        _localFilter.IncludedTypes.Clear(); 
        _localFilter.ExcludedTypes.Clear(); 
        ApplyFilters(); 
    }
    private void ClearAppliedShorts() { _localFilter.ShortFilmsOnly = false; ApplyFilters(); }
    private void ClearAppliedYears() { _localFilter.MinYear = null; _localFilter.MaxYear = null; ApplyFilters(); }

    private async Task PickRandom()
    {
        await WatchlistSvc.ShowRandomFromFilteredAsync(CurrentStatus);
    }
}

<style>
    .advanced-filter-sidebar {
        display: flex;
        flex-direction: column;
        background: #ffffff;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        z-index: 100;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid #e2e8f0;
    }

    .advanced-filter-sidebar.desktop {
        width: 270px;
        flex-shrink: 0;
        height: calc(100% - 20px);
        margin: 10px 16px 10px 10px;
        border-radius: 16px;
        align-self: stretch;
        font-size: 0.85rem;
    }

    .advanced-filter-sidebar.mobile {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        height: 80vh;
        border-radius: 24px 24px 0 0;
        box-shadow: 0 -10px 40px rgba(0,0,0,0.25);
        border-right: none;
        border-left: none;
    }

    .filter-section {
        border-bottom: 1px solid #f1f5f9;
        transition: background 0.2s;
    }

    .filter-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: #334155;
        cursor: pointer;
        padding: 14px 16px;
        display: flex;
        align-items: center;
        transition: all 0.2s;
        background: transparent;
    }
    .filter-label::after {
        content: '\F64D';
        font-family: 'bootstrap-icons';
        margin-left: auto;
        font-size: 0.75rem;
        opacity: 0.4;
        transition: transform 0.2s;
    }

    .filter-label:hover {
        background: #f8fafc;
        color: #6366f1;
    }

    .filter-label.expanded {
        background: #f1f5f9;
        color: #4f46e5;
    }
    .filter-label.expanded::after {
        transform: rotate(180deg);
        opacity: 0.8;
    }

    .filter-scroll-content {
        flex: 1;
        overflow-y: auto;
        padding: 0;
    }

    .filter-section:last-child {
        border-bottom: none;
    }

    .filter-section > div:not(.filter-label) {
        padding: 0 16px 20px;
    }

    .filter-footer {
        padding: 16px;
        background: #f8fafc;
        border-top: 1px solid #e2e8f0;
        flex-shrink: 0;
    }

    .range-sub-label {
        display: block;
        font-size: 0.65rem;
        font-weight: 600;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 6px;
        letter-spacing: 0.05em;
    }

    .filter-input {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 8px 10px;
        font-size: 0.82rem;
        color: #1e293b;
        transition: all 0.2s;
    }
    .filter-input:focus {
        background: #fff;
        border-color: #6366f1;
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
        outline: none;
    }

    .genre-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 6px;
    }

    .genre-btn {
        background: #f1f5f9;
        border: 1px solid transparent;
        border-radius: 8px;
        padding: 6px 10px;
        font-size: 0.72rem;
        text-align: left;
        transition: all 0.2s;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: #475569;
        font-weight: 500;
    }
    .genre-btn:hover { background: #e2e8f0; color: #1e293b; }
    
    .genre-inc { 
        background: #dcfce7; 
        color: #166534; 
        font-weight: 600;
        border-color: #bbf7d0;
    }
    .genre-exc { 
        background: #fee2e2; 
        color: #991b1b; 
        font-weight: 600;
        border-color: #fecaca;
    }

    .applied-filters-box {
        background: #f1f5f9;
        border-bottom: 1px solid #e2e8f0;
        padding: 16px;
    }

    .summary-header {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #64748b;
        margin-bottom: 12px;
    }

    .summary-body {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .summary-row {
        font-size: 0.78rem;
        color: #334155;
        background: #ffffff;
        padding: 8px 10px;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        line-height: 1.4;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }
    .summary-row b { color: #1e293b; margin-right: 4px; }

    .cursor-pointer { cursor: pointer; }

    .btn-apply-dirty {
        background: #6366f1;
        color: white;
        border: none;
    }
    .btn-apply-dirty:hover {
        background: #4f46e5;
        color: white;
    }

    @@media (max-width: 576px) {
        .filter-section > div:not(.filter-label) {
            padding: 0 20px 24px;
        }
    }
</style>
