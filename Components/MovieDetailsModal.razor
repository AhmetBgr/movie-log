@using MyPrivateWatchlist.Models
@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc
@implements IDisposable

@if (WatchlistSvc.IsModalOpen && WatchlistSvc.SelectedItem != null && WatchlistSvc.SelectedMovie != null)
{
    var item = WatchlistSvc.SelectedItem;
    var movie = WatchlistSvc.SelectedMovie;
    var libItem = GetLibraryItem();

    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.85);" @onclick="WatchlistSvc.CloseModal">
        <div class="modal-dialog modal-dialog-centered modal-xl" @onclick:stopPropagation="true">
            <div class="modal-content bg-transparent border-0">
                <div class="card bg-white text-dark shadow-lg border-0 rounded-2 overflow-hidden position-relative">
                    <div class="row g-0">
                        <!-- Media Section (Poster or Gallery) -->
                        <div class="col-md-5 text-center p-0 bg-black d-flex flex-column" style="min-height: 400px; max-height: 70vh; height: auto;">
                            @if (showScreenshots && movie.BackdropPaths.Any())
                            {
                                <div class="screenshot-gallery flex-grow-1 overflow-auto p-2 d-flex flex-column gap-2 custom-scrollbar">
                                    @foreach (var path in movie.BackdropPaths)
                                    {
                                        <img src="https://image.tmdb.org/t/p/w780@(path)" 
                                             class="img-fluid rounded shadow-sm border border-secondary backdrop-thumb" 
                                             alt="Screenshot" 
                                             @onclick="() => OpenLightbox(path)" 
                                             @onclick:stopPropagation="true" />
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="flex-grow-1 d-flex align-items-center justify-content-center overflow-hidden">
                                    <img src="@movie.FullPosterUrl" class="img-fluid px-2 py-2" alt="Poster" style="object-fit: contain; max-height: 100%; width: 100%;" />
                                </div>
                            }
                            
                            @if (movie.BackdropPaths.Any())
                            {
                                <div class="p-3 bg-dark border-top border-secondary d-flex justify-content-center">
                                    <div class="form-check form-switch d-flex align-items-center gap-2">
                                        <input class="form-check-input custom-switch" type="checkbox" id="galleryToggle" @bind="showScreenshots">
                                        <label class="form-check-label text-white small fw-bold mb-0" for="galleryToggle" style="min-width: 50px;">
                                            Images
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Info Section -->
                        <div class="col-md-7 position-relative">
                            <button type="button" class="btn-close position-absolute top-0 end-0 m-4 shadow-none" aria-label="Close" @onclick="WatchlistSvc.CloseModal"></button>
                            
                            <div class="card-body p-3 p-md-5 d-flex flex-column h-100">
                                <div class="d-flex align-items-start justify-content-between gap-3 mb-1">
                                    <div class="flex-grow-1">
                                        <div class="title-with-1337x-hover d-flex align-items-center gap-2 flex-wrap mb-1">
                                            <h2 class="card-title fw-black text-dark mb-0">
                                                <a href="https://www.imdb.com/title/@item.ImdbId/" target="_blank" class="text-decoration-none text-dark hover-opacity">@movie.Title</a>
                                            </h2>
                                            <a class="btn btn-sm btn-light border-0 text-secondary p-0 d-inline-flex align-items-center justify-content-center link-1337x-hover"
                                               style="width: 28px; height: 28px;"
                                               href="@Get1337xSearchUrl(movie, item)"
                                               target="_blank"
                                               rel="noopener noreferrer"
                                               title="Search on 1337x"
                                               @onclick:stopPropagation="true">
                                                <i class="bi bi-box-arrow-up-right"></i>
                                            </a>
                                        </div>
                                        @if (!string.IsNullOrEmpty(movie.ReleaseDate))
                                        {
                                            <p class="text-secondary fw-semibold small mb-2 text-uppercase tracking-wide">Released: @movie.ReleaseDate</p>
                                        }

                                        <div class="mb-4">
                                            <span class="badge bg-dark text-white fs-6 px-3 py-2 rounded-pill shadow-sm">
                                                <i class="bi bi-star-fill text-warning me-1"></i> @movie.VoteAverage.ToString("0.0") / 10
                                            </span>
                                        </div>
                                    </div>

                                    <!-- Rating Box (Permanently Editable) -->
                                    <div class="d-flex flex-column align-items-center p-2 border rounded-4 bg-white shadow-sm flex-shrink-0 position-relative" style="min-width: 100px; transform: scale(0.9);">
                                        
                                        @if (showSavedIndicator)
                                        {
                                            <div class="position-absolute top-0 start-50 translate-middle-x z-3 mt-n2 animate-fade-out">
                                                <span class="badge bg-success shadow-sm rounded-pill py-1 px-3 fw-bold border border-white" style="font-size: 0.65rem;">SAVED</span>
                                            </div>
                                        }

                                        <span class="small fw-bold text-secondary text-uppercase tracking-wider mb-2" style="font-size: 0.65rem;">Rating</span>
                                        <div class="rounded-3 d-flex flex-column align-items-center justify-content-center shadow-sm transition-all rating-box-indicator" 
                                             style="width: 75px; height: 75px; background-color: @(libItem?.Rating20 == null ? "#fff" : GetRatingColor(libItem.Rating20.Value)); 
                                                    color: @(libItem?.Rating20 == null ? "#adb5bd" : "#fff"); 
                                                    border: @(libItem?.Rating20 == null ? "2px dashed #dee2e6" : "none")">
                                            <input type="number" class="form-control form-control-sm text-center fw-black p-0 border-0 bg-transparent fs-2 no-spinner shadow-none @(libItem?.Rating20 == null ? "text-dark" : "text-white")" 
                                                   style="width: 75px; height: 75px; cursor: pointer; caret-color: @(libItem?.Rating20 == null ? "#212529" : "#fff");"
                                                   min="0" max="100" 
                                                   placeholder="-"
                                                   value="@(libItem?.Rating20)" 
                                                   @onchange="(e) => HandleRatingEdit(e)" />
                                        </div>

                                        @if (libItem?.Rating20 != null)
                                        {
                                            <button class="btn btn-link btn-sm p-0 text-secondary opacity-50 hover-opacity-100 mt-1" 
                                                    style="text-decoration: none;"
                                                    @onclick="() => HandleRatingEdit(new ChangeEventArgs { Value = null })"
                                                    title="Remove Rating">
                                                <i class="bi bi-trash3-fill fs-5"></i>
                                            </button>
                                        }
                                    </div>
                                </div>




                                <div class="info-content custom-scrollbar overflow-auto flex-grow-1 pe-2" style="max-height: 350px;">
                                    @if (movie.Directors.Any())
                                    {
                                        <p class="mb-2 text-dark fs-6"><strong>Director:</strong> 
                                            @foreach (var dir in movie.Directors)
                                            {
                                                <a href="https://www.imdb.com/find/?q=@System.Uri.EscapeDataString(dir)&s=nm" target="_blank" class="text-decoration-none text-secondary fw-semibold me-2 hover-opacity">@dir</a>
                                            }
                                        </p>
                                    }

                                    @if (movie.Actors.Any())
                                    {
                                        <p class="mb-4 text-dark fs-6"><strong>Cast:</strong> 
                                            @foreach (var actor in movie.Actors)
                                            {
                                                <a href="https://www.imdb.com/find/?q=@System.Uri.EscapeDataString(actor)&s=nm" target="_blank" class="text-decoration-none text-secondary fw-semibold me-2 hover-opacity">@actor</a>
                                            }
                                        </p>
                                    }
                                    
                                    <p class="card-text fs-6 text-secondary position-relative" style="line-height: 1.7;">
                                        @if (WatchlistSvc.IsLoadingDetails && string.IsNullOrEmpty(movie.Overview))
                                        {
                                            <div class="d-flex align-items-center gap-2 text-secondary py-3 opacity-50">
                                                <div class="spinner-border spinner-border-sm" role="status"></div>
                                                <span>Fetching cinematic details...</span>
                                            </div>
                                        }
                                        else
                                        {
                                            @(string.IsNullOrEmpty(movie.Overview) ? "No overview available." : movie.Overview)
                                            
                                            @if (WatchlistSvc.IsLoadingDetails)
                                            {
                                                <span class="ms-2 spinner-border spinner-border-sm opacity-25" style="width: 0.8rem; height: 0.8rem;" role="status"></span>
                                            }
                                        }
                                    </p>
                                </div>
                                
                                <div class="mt-auto pt-4 border-top">

                                </div>

                                <div class="mt-auto pt-4 border-top">
                                    <div class="d-flex flex-column flex-sm-row gap-3 align-items-stretch align-items-sm-center">
                                        @{
                                            var status = libItem?.Status;
                                        }

                                        <!-- Status Tabs -->
                                        <div class="btn-group bg-light rounded-3 p-1 shadow-sm flex-grow-1">
                                            <!-- Watchlist -->
                                            <button class="btn btn-lg @(status == WatchlistStatus.Pending ? "btn-secondary shadow-none" : "btn-light border-0 text-secondary bg-transparent") flex-grow-1 py-2.5 rounded-3 d-flex align-items-center justify-content-center transition-all px-1 px-md-3" 
                                                    onmouseover="if(!this.classList.contains('btn-secondary')) this.classList.add('bg-white')"
                                                    onmouseout="if(!this.classList.contains('btn-secondary')) this.classList.remove('bg-white')"
                                                    @onclick="() => {
                                                        var currentItem = GetLibraryItem();
                                                        if (currentItem?.Status == WatchlistStatus.Pending) {
                                                            RemoveItem();
                                                        } else {
                                                            HandleStatusTabClick(WatchlistStatus.Pending);
                                                        }
                                                    }">
                                                <i class="bi bi-list-nested me-1 me-md-2 fs-5"></i> 
                                                <span class="small-mobile-text fw-bold">Watchlist</span>
                                            </button>
                                            
                                            <!-- Watching -->
                                            <button class="btn btn-lg @(status == WatchlistStatus.Watching ? "btn-success shadow-none" : "btn-light border-0 text-success bg-transparent") flex-grow-1 py-2.5 rounded-3 d-flex align-items-center justify-content-center transition-all px-1 px-md-3" 
                                                    onmouseover="if(!this.classList.contains('btn-success')) this.classList.add('bg-white')"
                                                    onmouseout="if(!this.classList.contains('btn-success')) this.classList.remove('bg-white')"
                                                    @onclick="() => {
                                                        var currentItem = GetLibraryItem();
                                                        if (currentItem?.Status == WatchlistStatus.Watching) {
                                                            RemoveItem();
                                                        } else {
                                                            HandleStatusTabClick(WatchlistStatus.Watching);
                                                        }
                                                    }">
                                                <i class="bi bi-play-fill me-1 fs-4"></i> 
                                                <span class="small-mobile-text fw-bold">Watching</span>
                                            </button>
                                            
                                            <!-- Watched -->
                                            <button class="btn btn-lg @(status == WatchlistStatus.Watched ? "btn-primary shadow-none" : "btn-light border-0 text-primary bg-transparent") flex-grow-1 py-2.5 rounded-3 d-flex align-items-center justify-content-center transition-all px-1 px-md-3" 
                                                    onmouseover="if(!this.classList.contains('btn-primary')) this.classList.add('bg-white')"
                                                    onmouseout="if(!this.classList.contains('btn-primary')) this.classList.remove('bg-white')"
                                                    @onclick="() => {
                                                        var currentItem = GetLibraryItem();
                                                        if (currentItem?.Status == WatchlistStatus.Watched) {
                                                            RemoveItem();
                                                        } else {
                                                            HandleStatusTabClick(WatchlistStatus.Watched);
                                                        }
                                                    }">
                                                <i class="bi bi-check-lg me-1 me-md-2 fs-5"></i> 
                                                <span class="small-mobile-text fw-bold">Watched</span>
                                            </button>
                                        </div>

                                        @if (!string.IsNullOrEmpty(movie.TrailerKey))
                                        {
                                            <a href="https://www.youtube.com/watch?v=@movie.TrailerKey" target="_blank" rel="noopener noreferrer" 
                                               class="btn btn-outline-dark px-4 py-2.5 rounded-3 shadow-none fw-bold d-flex align-items-center justify-content-center text-uppercase tracking-wider transition-all" 
                                               style="height: 52px; min-width: 120px; text-decoration: none; --bs-btn-hover-bg: #212529; --bs-btn-hover-color: #fff;" title="Watch Trailer on YouTube">
                                                <i class="bi bi-play-circle-fill me-2 fs-5 text-danger"></i>
                                                <span style="font-size: 0.85rem;">Trailer</span>
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (selectedLightboxPath != null)
    {
        <div class="lightbox-overlay" @onclick="CloseLightbox">
            <div class="lightbox-content shadow-lg">
                <img src="https://image.tmdb.org/t/p/original@(selectedLightboxPath)" class="img-fluid rounded border border-secondary border-opacity-25 shadow-lg" alt="Full Image" />
                <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-4 shadow-lg p-2 rounded-circle bg-dark" aria-label="Close" @onclick="CloseLightbox" style="z-index: 2005;"></button>
            </div>
        </div>
    }

    @if (isTrailerOpen && !string.IsNullOrEmpty(movie.TrailerKey))
    {
        <div class="lightbox-overlay" @onclick="CloseTrailer">
            <div class="lightbox-content trailer-content shadow-lg" @onclick:stopPropagation="true">
                <div class="ratio ratio-16x9" style="min-width: 80vw; max-width: 1200px;">
                    <iframe src="https://www.youtube.com/embed/@movie.TrailerKey?autoplay=1" 
                            title="YouTube video player" frameborder="0" 
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                            allowfullscreen></iframe>
                </div>
                <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-4 shadow-lg p-2 rounded-circle bg-dark" aria-label="Close" @onclick="CloseTrailer" style="z-index: 2005; margin-top: -50px !important; margin-right: -20px !important;"></button>
            </div>
        </div>
    }
}

<style>
    .hover-opacity:hover { opacity: 0.7; }
    
    .screenshot-gallery {
        max-height: 600px;
        background: #111;
    }

    .backdrop-thumb {
        cursor: zoom-in;
        transition: none;
    }
    .backdrop-thumb:hover {
        outline: 3px solid #fff;
        outline-offset: -3px;
        box-shadow: 0 0 15px rgba(255,255,255,0.5);
    }
    
    .lightbox-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0,0,0,0.92);
        backdrop-filter: blur(10px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 2000;
        padding: 60px;
    }
    
    .lightbox-content {
        position: relative;
        max-width: 100%;
        max-height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .lightbox-content img {
        max-height: 90vh;
        object-fit: contain;
    }
    
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: rgba(0,0,0,0.1);
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.2);
        border-radius: 10px;
    }
    
    .custom-switch {
        cursor: pointer;
        width: 3em !important;
        height: 1.5em !important;
    }
    
    .custom-switch:checked {
        background-color: #198754;
        border-color: #198754;
    }

    .trailer-content {
        background: #000;
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px;
        overflow: visible;
    }

    .small-mobile-text {
        font-size: 0.85rem;
    }

    .star-btn:hover {
        transform: scale(1.3);
        color: #ffc107 !important;
        opacity: 1 !important;
    }
    
    .rating-stars:hover .star-btn {
        opacity: 0.4;
    }
    
    .star-btn:hover ~ .star-btn {
        color: #6c757d !important;
        opacity: 0.25 !important;
    }

    .hover-invert:hover {
        background-color: #212529 !important;
        color: #fff !important;
    }

    .fw-black { font-weight: 900; }

    /* Hide increment/decrement buttons in rating input */
    .no-spinner::-webkit-outer-spin-button,
    .no-spinner::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
    .no-spinner[type="number"] {
        -moz-appearance: textfield;
    }

    @@keyframes fadeOutUp {
        0% { opacity: 0; transform: translate(-50%, 0px); }
        20% { opacity: 1; transform: translate(-50%, -8px); }
        80% { opacity: 1; transform: translate(-50%, -8px); }
        100% { opacity: 0; transform: translate(-50%, -15px); }
    }

    .animate-fade-out {
        animation: fadeOutUp 1.5s ease-out forwards;
    }

    .rating-box-indicator:focus-within {
        border-color: #0d6efd !important;
        border-style: solid !important;
        transform: scale(1.05);
        box-shadow: 0 4px 12px rgba(13, 110, 253, 0.2) !important;
    }

    @@media (max-width: 576px) {
        .small-mobile-text {
            font-size: 0.75rem;
        }
        .modal-dialog {
            margin: 0.5rem;
        }
        .info-content {
            max-height: none !important;
        }
    }
</style>

@code {
    private bool showScreenshots = false;
    private string? selectedLightboxPath;
    private bool isTrailerOpen = false;

    private void OpenLightbox(string path)
    {
        selectedLightboxPath = path;
    }

    private void CloseLightbox()
    {
        selectedLightboxPath = null;
    }

    private void OpenTrailer()
    {
        isTrailerOpen = true;
    }

    private void CloseTrailer()
    {
        isTrailerOpen = false;
    }

    protected override void OnInitialized()
    {
        WatchlistSvc.OnStateChanged += () => {
            Console.WriteLine("OnStateChanged event fired!");
            StateHasChanged();
        };
    }

    public void Dispose()
    {
        WatchlistSvc.OnStateChanged -= null;
    }

    private bool showSavedIndicator = false;

    private async Task HandleRatingEdit(ChangeEventArgs e)
    {
        var inputVal = e.Value?.ToString();
        int? val = null;
        if (int.TryParse(inputVal, out var parsed)) 
        {
            val = parsed;
            if (val > 100) val = 100;
            if (val < 0) val = 0;
        }
        
        await UpdateRating(val);
        
        if (val.HasValue)
        {
            showSavedIndicator = true;
            StateHasChanged();
            await Task.Delay(1500);
            showSavedIndicator = false;
            StateHasChanged();
        }
    }

    private string GetRatingColor(int val)
    {
        // 0 to 100 -> Hue 0 to 120
        double hue = (val / 100.0) * 120;
        return $"hsl({hue}, 70%, 45%)";
    }

    private async Task UpdateRating(int? ratingValue)
    {
        var libItem = GetLibraryItem();
        var selectedMovie = WatchlistSvc.SelectedMovie;
        var selectedItem = WatchlistSvc.SelectedItem;

        if (libItem != null)
        {
            await WatchlistSvc.UpdateRatingAsync(libItem, ratingValue);
        }
        else if (ratingValue.HasValue && selectedMovie != null)
        {
            // Auto-add to library if rated but not in library
            var newItem = new WatchlistItem
            {
                ImdbId = selectedMovie.ImdbId ?? "",
                Title = selectedMovie.Title,
                TitleType = selectedItem?.TitleType ?? "Movie",
                Year = selectedMovie.ReleaseDate ?? "",
                ParsedYear = int.TryParse(selectedMovie.ReleaseDate?.Split('-')[0], out var y) ? y : 0,
                Status = WatchlistStatus.Watched, // Assume watched if rated
                Rating20 = ratingValue,
                UserRating = (int)Math.Round(ratingValue.Value / 10.0),
                DateAdded = DateTime.Now,
                Genres = string.Join(", ", selectedMovie.GenreList.Select(g => g.Name)),
                Director = selectedMovie.Directors.Any() ? string.Join(", ", selectedMovie.Directors) : null,
                Overview = selectedMovie.Overview,
                PosterPath = selectedMovie.PosterPath
            };
            await WatchlistSvc.AddItemAsync(newItem);
        }
    }

    private async Task RemoveItem()
    {
        if (WatchlistSvc.SelectedItem != null)
        {
            var libItem = GetLibraryItem();
            if (libItem != null)
            {
                await WatchlistSvc.RemoveFromWatchlistAsync(libItem);
                // UI will update automatically through OnStateChanged event
            }
        }
    }

    private bool IsInLibrary => WatchlistSvc.Items.Any(i => i.ImdbId == WatchlistSvc.SelectedItem?.ImdbId && !string.IsNullOrEmpty(i.ImdbId));
    
    private WatchlistItem? GetLibraryItem()
    {
        return WatchlistSvc.Items.FirstOrDefault(i => i.ImdbId == WatchlistSvc.SelectedItem?.ImdbId && !string.IsNullOrEmpty(i.ImdbId));
    }

    private async Task HandleStatusTabClick(WatchlistStatus status)
    {
        Console.WriteLine($"HandleStatusTabClick called with status: {status}");
        Console.WriteLine($"SelectedItem: {WatchlistSvc.SelectedItem?.Title}");
        Console.WriteLine($"SelectedMovie: {WatchlistSvc.SelectedMovie?.Title}");
        
        if (WatchlistSvc.SelectedItem != null && WatchlistSvc.SelectedMovie != null)
        {
            var libItem = GetLibraryItem();
            Console.WriteLine($"libItem: {libItem?.Title} (null? {libItem == null})");
            
            if (libItem == null)
            {
                var newItem = CreateItem(status);
                Console.WriteLine($"Creating new item: {newItem.Title} with status {newItem.Status}");
                await WatchlistSvc.AddToWatchlistAsync(newItem);
                Console.WriteLine("Item added successfully");
                // Force UI update
                StateHasChanged();
            }
            else
            {
                Console.WriteLine($"Updating existing item from {libItem.Status} to {status}");
                await WatchlistSvc.UpdateStatusAsync(libItem, status);
                Console.WriteLine("Item updated successfully");
                // Force UI update
                StateHasChanged();
            }
        }
        else
        {
            Console.WriteLine("SelectedItem or SelectedMovie is null");
        }
    }

    private static string Get1337xSearchUrl(TmdbMovie movie, WatchlistItem item)
    {
        var title = (movie.Title ?? item.Title)?.Trim() ?? "";
        var year = "";
        if (!string.IsNullOrEmpty(movie.ReleaseDate) && movie.ReleaseDate.Length >= 4)
            year = movie.ReleaseDate[..4];
        else if (!string.IsNullOrEmpty(item.Year))
        {
            var digits = new string(item.Year.TakeWhile(char.IsDigit).ToArray());
            year = digits.Length >= 4 ? digits[..4] : (item.ParsedYear > 0 ? item.ParsedYear.ToString() : "");
        }
        else if (item.ParsedYear > 0)
            year = item.ParsedYear.ToString();

        var query = string.IsNullOrWhiteSpace(year) ? title : $"{title} {year}".Trim();
        var encoded = System.Net.WebUtility.UrlEncode(query) ?? "";
        return $"https://1337x.to/search/{encoded}/1/";
    }

    private WatchlistItem CreateItem(WatchlistStatus status)
    {
        var item = WatchlistSvc.SelectedItem!;
        var movie = WatchlistSvc.SelectedMovie!;
        
        Console.WriteLine($"CreateItem - Movie.ImdbId: '{movie.ImdbId}'");
        Console.WriteLine($"CreateItem - SelectedItem.ImdbId: '{item.ImdbId}'");
        Console.WriteLine($"CreateItem - Movie.Title: {movie.Title}");
        
        return new WatchlistItem
        {
            ImdbId = movie.ImdbId ?? item.ImdbId ?? "",
            Title = movie.Title,
            OriginalTitle = movie.OriginalTitle != movie.Title ? movie.OriginalTitle : null,
            TitleType = item.TitleType,
            Year = movie.ReleaseDate ?? "",
            ParsedYear = int.TryParse(movie.ReleaseDate?.Split('-')[0], out var y) ? y : 0,
            Genres = "",
            Director = movie.Directors.Any() ? string.Join(", ", movie.Directors) : null,
            Status = status,
            CurrentSeason = (status == WatchlistStatus.Watching && item.TitleType.Contains("TV", StringComparison.OrdinalIgnoreCase)) ? 1 : null,
            CurrentEpisode = (status == WatchlistStatus.Watching && item.TitleType.Contains("TV", StringComparison.OrdinalIgnoreCase)) ? 1 : null
        };
    }
}
