@using MyPrivateWatchlist.Models
@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc

<div class="collection-card" @onclick="OnClick">
    <div class="card-inner">
        <div class="poster-stack">
            @if (string.IsNullOrEmpty(Collection.PosterPath))
            {
                <div class="poster-empty">
                    <i class="bi bi-collection-play"></i>
                </div>
            }
            else
            {
                <img src="@Collection.FullPosterUrl" alt="@Collection.Name" class="poster-img" loading="lazy" />
            }
            <div class="poster-overlay">
                <span class="count-badge">@Collection.MovieIds.Count movies</span>
            </div>
        </div>
        <div class="card-info">
            <h3 class="collection-name">@Collection.Name</h3>
            @if (!string.IsNullOrEmpty(Collection.Description))
            {
                <p class="collection-desc">@Collection.Description</p>
            }
        </div>
    </div>
    
    <div class="card-actions">
        <button class="btn-action bg-danger-subtle text-danger" @onclick="OnDelete" @onclick:stopPropagation="true">
            <i class="bi bi-trash3"></i>
        </button>
    </div>
</div>

@code {
    [Parameter] public CustomCollection Collection { get; set; } = null!;
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }
}

<style>
    .collection-card {
        position: relative;
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        height: 100%;
        display: flex;
        flex-direction: column;
        border: 1px solid #eee;
    }
    .collection-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.08);
    }

    .poster-stack {
        position: relative;
        aspect-ratio: 2/3;
        background: #f8f9fa;
        overflow: hidden;
    }
    .poster-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .poster-empty {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        color: #ddd;
    }

    .poster-overlay {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        padding: 40px 10px 10px;
        background: linear-gradient(transparent, rgba(0,0,0,0.7));
        display: flex;
        justify-content: flex-end;
    }
    .count-badge {
        background: rgba(255,255,255,0.2);
        backdrop-filter: blur(8px);
        color: #fff;
        font-size: 0.75rem;
        padding: 2px 10px;
        border-radius: 99px;
        font-weight: 600;
        border: 1px solid rgba(255,255,255,0.3);
    }

    .card-info {
        padding: 12px;
        flex: 1;
    }
    .collection-name {
        font-size: 1rem;
        font-weight: 700;
        margin: 0;
        color: #1a1a1a;
        line-height: 1.3;
    }
    .collection-desc {
        font-size: 0.8rem;
        color: #666;
        margin: 4px 0 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-actions {
        position: absolute;
        top: 8px; right: 8px;
        opacity: 0;
        transition: opacity 0.2s;
    }
    .collection-card:hover .card-actions {
        opacity: 1;
    }
    .btn-action {
        border: none;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(4px);
    }
</style>
