@using MyPrivateWatchlist.Models
@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc

<div class="collection-row" @onclick="OnClick">
    <!-- Poster -->
    <div class="cc-poster">
        @if (string.IsNullOrEmpty(Collection.PosterPath))
        {
            <div class="cc-poster-empty">
                <i class="bi bi-collection-play"></i>
            </div>
        }
        else
        {
            <img src="@Collection.FullPosterUrl" alt="@Collection.Name" class="cc-poster-img" loading="lazy" />
        }
    </div>

    <!-- Info -->
    <div class="cc-info">
        <div class="cc-name">@Collection.Name</div>
        <div class="cc-meta">
            @(Collection.MovieIds.Count) @(Collection.MovieIds.Count == 1 ? "title" : "titles")
            @if (Collection.DateCreated != default)
            {
                <span class="cc-dot">·</span>
                <span>Modified @Collection.DateCreated.ToString("MMM d, yyyy")</span>
            }
        </div>
        @if (!string.IsNullOrEmpty(Collection.Description))
        {
            <div class="cc-desc">@Collection.Description</div>
        }
    </div>

    <!-- Three-dots menu -->
    <div class="cc-menu-wrap" @onclick:stopPropagation="true">
        <details class="cc-details" @ontoggle="OnMenuToggle">
            <summary class="cc-dots-btn" title="Options">
                <i class="bi bi-three-dots-vertical"></i>
            </summary>
            <div class="cc-popover shadow border rounded-3 py-1">
                <button class="cc-menu-item" @onclick="HandleEdit">
                    <i class="bi bi-pencil me-2"></i>Edit
                </button>
                <button class="cc-menu-item text-danger" @onclick="HandleDelete">
                    <i class="bi bi-trash3 me-2"></i>Delete
                </button>
            </div>
        </details>
    </div>
</div>

@code {
    [Parameter] public CustomCollection Collection { get; set; } = null!;
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public EventCallback OnEdit { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }

    private bool _menuOpen = false;

    private void OnMenuToggle() => _menuOpen = !_menuOpen;

    private async Task HandleEdit()
    {
        CloseMenu();
        await OnEdit.InvokeAsync();
    }

    private async Task HandleDelete()
    {
        CloseMenu();
        await OnDelete.InvokeAsync();
    }

    private void CloseMenu()
    {
        _menuOpen = false;
        StateHasChanged();
    }
}

<style>
    .collection-row {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 10px 4px;
        cursor: pointer;
        border-radius: 10px;
        transition: background 0.15s;
        position: relative;
    }
    .collection-row:hover {
        background: #f8f9fa;
    }

    /* Poster */
    .cc-poster {
        flex-shrink: 0;
        width: 54px;
        height: 80px;
        border-radius: 6px;
        overflow: hidden;
        background: #f0f0f0;
        border: 1px solid #e0e0e0;
    }
    .cc-poster-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .cc-poster-empty {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        color: #ccc;
    }

    /* Info */
    .cc-info {
        flex: 1;
        min-width: 0;
        overflow: hidden;
    }
    .cc-name {
        font-size: 0.95rem;
        font-weight: 700;
        color: #1a1a1a;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .cc-meta {
        font-size: 0.78rem;
        color: #888;
        margin-top: 3px;
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 4px;
    }
    .cc-dot {
        opacity: 0.5;
    }
    .cc-desc {
        font-size: 0.78rem;
        color: #aaa;
        margin-top: 3px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* Three-dots menu */
    .cc-menu-wrap {
        flex-shrink: 0;
        position: relative;
    }
    .cc-details {
        position: relative;
    }
    .cc-details summary {
        list-style: none;
    }
    .cc-details summary::-webkit-details-marker { display: none; }

    .cc-dots-btn {
        background: none;
        border: none;
        cursor: pointer;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #888;
        font-size: 1.1rem;
        transition: background 0.15s, color 0.15s;
    }
    .cc-dots-btn:hover, .cc-details[open] .cc-dots-btn {
        background: #efefef;
        color: #333;
    }

    .cc-popover {
        position: absolute;
        right: 0;
        top: calc(100% + 4px);
        min-width: 140px;
        background: #fff;
        z-index: 500;
        animation: ccPop 0.15s cubic-bezier(0.16, 1, 0.3, 1);
    }
    @@keyframes ccPop {
        from { opacity: 0; transform: scale(0.95) translateY(-6px); }
        to   { opacity: 1; transform: scale(1) translateY(0); }
    }

    .cc-menu-item {
        display: flex;
        align-items: center;
        width: 100%;
        padding: 9px 16px;
        border: none;
        background: none;
        font-size: 0.87rem;
        font-weight: 600;
        color: #222;
        text-align: left;
        cursor: pointer;
        transition: background 0.12s;
    }
    .cc-menu-item:hover {
        background: #f5f5f5;
    }
    .cc-menu-item.text-danger { color: #dc3545 !important; }
    .cc-menu-item.text-danger:hover { background: #fff5f5; }
</style>
