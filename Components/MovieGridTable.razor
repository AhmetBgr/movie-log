@using MyPrivateWatchlist.Models

<div class="watched-container">
    @if (!Items.Any())
    {
        <div class="text-center py-5 text-secondary opacity-50 fst-italic">
            No items to display.
        </div>
    }
    else
    {
        var itemsPerCol = 20;
            var pageSize = itemsPerCol * Columns;
            var totalPages = (int)Math.Ceiling(Items.Count / (double)pageSize);
            
            // Ensure PageIndex is valid
            if (PageIndex >= totalPages && totalPages > 0) PageIndex = totalPages - 1;
            if (PageIndex < 0) PageIndex = 0;

            var pagedItems = Items.Skip(PageIndex * pageSize).Take(pageSize).ToList();
            var currentTotal = pagedItems.Count;
            var effectiveCols = (int)Math.Ceiling(currentTotal / (double)itemsPerCol);

        <div class="watched-grid">
            @foreach (var item in pagedItems)
            {
                <div class="watched-entry" 
                     data-holdselect-id="@item.ImdbId"
                     @onclick="() => OnItemClick.InvokeAsync(item)">
                    @if (IsEditing)
                    {
                        <input type="checkbox" class="form-check-input me-2 shadow-none" 
                               checked="@SelectedIds.Contains(item.ImdbId)" 
                               @onchange="() => OnToggleSelect.InvokeAsync(item.ImdbId)" 
                               @onclick:stopPropagation="true" 
                               style="width:15px;height:15px;cursor:pointer;" />
                    }
                    <span class="entry-title">
                        <span class="fw-bold me-1">@item.Title</span>
                        @(!string.IsNullOrEmpty(item.Year) ? $"({item.Year})" : "")
                    </span>
                    <span class="entry-dots"></span>
                    @{
                        // If ShowUserRatingOnly, only show rating if it is a real user rating (not TMDB avg)
                        // User ratings come from Rating20 on the actual library item; TMDB avg is set separately
                        var displayRating = ShowUserRatingOnly ? UserRatingForItem(item) : item.Rating20;
                    }
                    <span class="entry-rating @(displayRating == null ? "no-rating" : "")" 
                          style="@(displayRating.HasValue ? $"color:{GetRatingColor(displayRating.Value)};" : "")">
                        @(displayRating?.ToString() ?? "—")
                    </span>
                </div>
            }
        </div>

        <!-- Footer: Summary (Left) & Pagination (Right) -->
        <div class="watched-footer">
            <div class="watched-summary">
                @if (ShowSummary)
                {
                    <span class="text-secondary">Sorted by @(SortInfo ?? "Default") &bull; Showing @(PageIndex * pageSize + 1)–@(PageIndex * pageSize + currentTotal) of @TotalCount items</span>
                }
            </div>

            @if (totalPages > 1)
            {
                <div class="pagination-wrap">
                    <div class="d-flex align-items-center gap-2">
                        <button class="page-nav-btn" disabled="@(PageIndex == 0)" @onclick="() => SetPage(PageIndex - 1)">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        
                        @{
                            int startPage = Math.Max(0, PageIndex - 2);
                            int endPage = Math.Min(totalPages - 1, startPage + 4);
                            if (endPage - startPage < 4) startPage = Math.Max(0, endPage - 4);
                        }

                        @if (startPage > 0)
                        {
                            <button class="page-num-btn" @onclick="() => SetPage(0)">1</button>
                            @if (startPage > 1) { <span class="text-secondary small px-1">...</span> }
                        }

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            var p = i;
                            <button class="page-num-btn @(PageIndex == p ? "active" : "")" @onclick="() => SetPage(p)">
                                @(p + 1)
                            </button>
                        }

                        @if (endPage < totalPages - 1)
                        {
                            @if (endPage < totalPages - 2) { <span class="text-secondary small px-1">...</span> }
                            <button class="page-num-btn" @onclick="() => SetPage(totalPages - 1)">@totalPages</button>
                        }

                        <button class="page-nav-btn" disabled="@(PageIndex == totalPages - 1)" @onclick="() => SetPage(PageIndex + 1)">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public List<WatchlistItem> Items { get; set; } = new();
    [Parameter] public int Columns { get; set; } = 3;
    [Parameter] public string[] ColumnHeaders { get; set; } = new[] { "List I", "List II", "List III" };
    [Parameter] public bool IsEditing { get; set; }
    [Parameter] public HashSet<string> SelectedIds { get; set; } = new();
    [Parameter] public EventCallback<WatchlistItem> OnItemClick { get; set; }
    [Parameter] public EventCallback<string> OnToggleSelect { get; set; }
    [Parameter] public bool ShowSummary { get; set; } = true;
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public string? SortInfo { get; set; }
    /// <summary>
    /// When true (default), only shows Rating20 if it was set as a user rating.
    /// Items from search results that have Rating20 derived from TMDB vote average will show "—".
    /// Pass false to always show whatever Rating20 is set to (e.g. for monitored library pages).
    /// </summary>
    [Parameter] public bool ShowUserRatingOnly { get; set; } = true;
    /// <summary>
    /// Optional set of ImdbIds that have real user ratings. When ShowUserRatingOnly=true,
    /// only items in this set will show their rating.
    /// </summary>
    [Parameter] public HashSet<string>? UserRatedIds { get; set; }

    [Parameter] public int PageIndex { get; set; } = 0;
    [Parameter] public EventCallback<int> PageIndexChanged { get; set; }

    private async Task SetPage(int index)
    {
        PageIndex = index;
        await PageIndexChanged.InvokeAsync(index);
        StateHasChanged();
    }

    private string GetRatingColor(int val) { double hue = (val / 100.0) * 120; return $"hsl({hue},70%,45%)"; }

    /// <summary>
    /// Returns the rating to display. If ShowUserRatingOnly=true, only returns a value
    /// when the item is confirmed to be a user-rated library item.
    /// </summary>
    private int? UserRatingForItem(WatchlistItem item)
    {
        if (!ShowUserRatingOnly) return item.Rating20;
        // If UserRatedIds is provided, use it; otherwise check if Rating20 was from user
        // (not a TMDB average). We consider it a user rating if UserRatedIds is null (library mode)
        // or if the item's ImdbId is in UserRatedIds.
        if (UserRatedIds == null) return item.Rating20; // library mode - always show
        return UserRatedIds.Contains(item.ImdbId) ? item.Rating20 : null;
    }
}

<style>
    .watched-container { 
        padding: 0; 
        background: transparent; 
        display: flex;
        flex-direction: column;
        height: 100%;
        container-type: inline-size;
    }
    .watched-grid { 
        display: grid; 
        /* Desktop: 3 columns, 20 rows each */
        grid-template-columns: repeat(3, 1fr); 
        grid-template-rows: repeat(20, auto);
        grid-auto-flow: column;
        gap: 0 24px; 
        align-items: start;
        align-content: start;
        padding: 20px 24px;
        flex: 1;
    }
    .watched-entry { 
        display: flex; 
        align-items: center; 
        padding: 4px 6px; 
        cursor: pointer; 
        transition: background 0.1s, transform 0.1s;
        border-radius: 6px;
        margin-bottom: 1px;
        min-width: 0; 
    }
    .watched-entry:hover { 
        background: rgba(0,0,0,0.03);
        transform: translateX(4px);
    }
    .entry-title { 
        font-size: 0.88rem; 
        color: #333; 
        white-space: nowrap; 
        overflow: hidden; 
        text-overflow: ellipsis; 
        flex-shrink: 1;
    }
    .entry-dots { 
        flex: 1; 
        border-bottom: 1px dotted #ddd; 
        margin: 0 8px; 
        height: 14px; 
        opacity: 0.5;
    }
    .entry-rating { 
        font-size: 0.88rem; 
        font-weight: 900; 
        min-width: 26px; 
        text-align: right; 
        font-family: 'JetBrains Mono', 'Courier New', monospace;
    }
    .entry-rating.no-rating { 
        color: #ccc !important; 
        font-weight: 900; 
    }

    /* Footer: Summary on left, Pages on right */
    .watched-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 24px;
        border-top: 1px solid #f0f0f0;
        background: #fafafa;
        gap: 20px;
    }

    .watched-summary {
        font-size: 0.78rem;
        color: #888;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* Pagination */
    .page-nav-btn, .page-num-btn {
        width: 30px; height: 30px;
        border: 1px solid #dee2e6;
        background: #fff;
        border-radius: 6px;
        display: inline-flex;
        align-items: center; justify-content: center;
        font-size: 0.8rem;
        font-weight: 600;
        color: #555;
        transition: all 0.2s;
    }
    .page-nav-btn:hover:not(:disabled), .page-num-btn:hover {
        border-color: #adb5bd;
        background: #f8f9fa;
        color: #111;
    }
    .page-num-btn.active {
        background: #212529;
        border-color: #212529;
        color: #fff;
    }
    .page-nav-btn:disabled {
        opacity: 0.3;
        cursor: not-allowed;
    }

    /* SMART STACKING (Container Queries) */
    @@container (max-width: 950px) {
        .watched-grid { 
            grid-template-columns: repeat(2, 1fr); 
            grid-template-rows: repeat(30, auto);
            gap: 0 24px; 
            padding: 15px 20px;
        }
    }

    @@container (max-width: 650px) {
        .watched-grid { 
            grid-template-columns: 1fr; 
            grid-template-rows: auto;
            grid-auto-flow: row;
            padding: 10px 15px; 
            gap: 2px 0;
            overflow-y: auto;
        }
        .watched-footer {
            flex-direction: column;
            gap: 12px;
            align-items: center;
            text-align: center;
        }
        .watched-summary { white-space: normal; }
        .watched-entry:hover { transform: none; background: rgba(0,0,0,0.04); }
    }
</style>
