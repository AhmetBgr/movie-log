@using MyPrivateWatchlist.Models
@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc
@inject IJSRuntime JS

<div class="filter-sidebar" @ontouchstart="OnTouchStart" @ontouchend="OnTouchEnd">
    <div class="filter-drag-handle d-sm-none"><span></span></div>
    <h6 class="fw-bold mb-3">@Title</h6>

    <div class="mt-3">
        <!-- Search -->
        <div class="mb-3">
            <div class="filter-label d-flex justify-content-between align-items-center" 
                 style="cursor:pointer; margin-bottom: @(_showSearch ? "6px" : "0");" 
                 @onclick="ToggleSearch">
                <span>Search</span>
                <i class="bi @(_showSearch ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </div>
            @if (_showSearch)
            {
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-search text-secondary"></i></span>
                    <input type="text" class="form-control border-start-0 bg-light shadow-none" placeholder="Title or director…"
                           @bind="WatchlistSvc.SearchQuery" @bind:event="oninput" />
                </div>
            }
        </div>
        
        <!-- User Rating Range -->
        @if (ShowUserRatingFilter)
        {
            <div class="mb-3">
                <div class="filter-label d-flex justify-content-between align-items-center" 
                     style="cursor:pointer; margin-bottom: @(_showUserRating ? "6px" : "0");" 
                     @onclick="ToggleUserRating">
                    <span>Rating range</span>
                    <i class="bi @(_showUserRating ? "bi-chevron-up" : "bi-chevron-down")"></i>
                </div>
                @if (_showUserRating)
                {
                    <div class="d-flex gap-2 align-items-center">
                        <select class="form-select form-select-sm bg-light shadow-none"
                                value="@WatchlistSvc.FilterMinRating20"
                                @onchange="@(e => WatchlistSvc.FilterMinRating20 = int.Parse(e.Value?.ToString() ?? "0"))">
                            @for (int i = 0; i <= 100; i += 5) { <option value="@i">@(i == 0 ? "Min" : i.ToString())</option> }
                        </select>
                        <span class="text-secondary" style="font-size:0.75rem;">–</span>
                        <select class="form-select form-select-sm bg-light shadow-none"
                                value="@WatchlistSvc.FilterMaxRating20"
                                @onchange="@(e => WatchlistSvc.FilterMaxRating20 = int.Parse(e.Value?.ToString() ?? "100"))">
                            @for (int i = 0; i <= 100; i += 5) { <option value="@i">@(i == 100 ? "Max" : i.ToString())</option> }
                        </select>
                    </div>
                }
            </div>
        }

        <!-- TMDB Rating Range -->
        @if (ShowTmdbRatingFilter)
        {
            <div class="mb-3">
                <div class="filter-label d-flex justify-content-between align-items-center" 
                     style="cursor:pointer; margin-bottom: @(_showTmdbRating ? "6px" : "0");" 
                     @onclick="ToggleTmdbRating">
                    <span>TMDB rating</span>
                    <i class="bi @(_showTmdbRating ? "bi-chevron-up" : "bi-chevron-down")"></i>
                </div>
                @if (_showTmdbRating)
                {
                    <div class="d-flex gap-2 align-items-center">
                        <select class="form-select form-select-sm bg-light shadow-none"
                                value="@WatchlistSvc.FilterMinVote"
                                @onchange="@(e => WatchlistSvc.FilterMinVote = double.Parse(e.Value?.ToString() ?? "0", System.Globalization.CultureInfo.InvariantCulture))">
                            @for (int i = 0; i <= 10; i++) { <option value="@i">@i</option> }
                        </select>
                        <span class="text-secondary" style="font-size:0.75rem;">–</span>
                        <select class="form-select form-select-sm bg-light shadow-none"
                                value="@WatchlistSvc.FilterMaxVote"
                                @onchange="@(e => WatchlistSvc.FilterMaxVote = double.Parse(e.Value?.ToString() ?? "10", System.Globalization.CultureInfo.InvariantCulture))">
                            @for (int i = 0; i <= 10; i++) { <option value="@i">@i</option> }
                        </select>
                    </div>
                }
            </div>
        }

        <!-- Genre -->
        <div class="mb-3">
            <div class="filter-label d-flex justify-content-between align-items-center" 
                 style="cursor:pointer; margin-bottom: @(_showGenre ? "6px" : "0");" 
                 @onclick="ToggleGenre">
                <span>Genre</span>
                <i class="bi @(_showGenre ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </div>
            @if (_showGenre)
            {
                <select class="form-select form-select-sm bg-light shadow-none" @bind="WatchlistSvc.SelectedGenre">
                    <option value="All">All genres</option>
                    @foreach (var g in AvailableGenres) { <option value="@g">@g</option> }
                </select>
            }
        </div>

        <!-- Type -->
        <div class="mb-3">
            <div class="filter-label d-flex justify-content-between align-items-center" 
                 style="cursor:pointer; margin-bottom: @(_showType ? "6px" : "0");" 
                 @onclick="ToggleType">
                <span>Type</span>
                <i class="bi @(_showType ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </div>
            @if (_showType)
            {
                <select class="form-select form-select-sm bg-light shadow-none" @bind="WatchlistSvc.SelectedType">
                    <option value="All">All types</option>
                    <option value="Movie">Movies</option>
                    <option value="TV Series">TV Series</option>
                </select>
            }
        </div>

        <!-- Year Range -->
        <div class="mb-3">
            <div class="filter-label d-flex justify-content-between align-items-center" 
                 style="cursor:pointer; margin-bottom: @(_showYear ? "6px" : "0");" 
                 @onclick="ToggleYear">
                <span>Year range</span>
                <i class="bi @(_showYear ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </div>
            @if (_showYear)
            {
                <div class="d-flex gap-2">
                    <input type="number" class="form-control form-control-sm bg-light shadow-none" placeholder="From" @bind="WatchlistSvc.StartYear" />
                    <input type="number" class="form-control form-control-sm bg-light shadow-none" placeholder="To" @bind="WatchlistSvc.EndYear" />
                </div>
            }
        </div>

        <div class="d-flex gap-2 mt-4 w-100">
            <button class="btn btn-dark btn-sm fw-semibold flex-grow-1" @onclick="WatchlistSvc.ShowRandomMovieAsync">
                <i class="bi bi-dice-5 me-1"></i> Random pick
            </button>
            <button class="btn btn-outline-secondary btn-sm flex-grow-1" @onclick="OnClearFilters">
                <i class="bi bi-eraser me-1"></i> Clear filters
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Refine";
    [Parameter] public List<string> AvailableGenres { get; set; } = new();
    [Parameter] public bool ShowUserRatingFilter { get; set; } = false;
    [Parameter] public bool ShowTmdbRatingFilter { get; set; } = false;
    [Parameter] public EventCallback OnClearFilters { get; set; }
    [Parameter] public EventCallback<TouchEventArgs> OnTouchStart { get; set; }
    [Parameter] public EventCallback<TouchEventArgs> OnTouchEnd { get; set; }

    // Individual filter collapse states remain false by default (collapsed)
    private bool _showSearch = false;
    private bool _showUserRating = false;
    private bool _showTmdbRating = false;
    private bool _showGenre = false;
    private bool _showType = false;
    private bool _showYear = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var sSearch = await JS.InvokeAsync<string>("sessionStorage.getItem", $"fp_{Title}_search");
                if (sSearch != null) _showSearch = sSearch == "1";

                var sURating = await JS.InvokeAsync<string>("sessionStorage.getItem", $"fp_{Title}_userrating");
                if (sURating != null) _showUserRating = sURating == "1";

                var sTRating = await JS.InvokeAsync<string>("sessionStorage.getItem", $"fp_{Title}_tmdbrating");
                if (sTRating != null) _showTmdbRating = sTRating == "1";

                var sGenre = await JS.InvokeAsync<string>("sessionStorage.getItem", $"fp_{Title}_genre");
                if (sGenre != null) _showGenre = sGenre == "1";

                var sType = await JS.InvokeAsync<string>("sessionStorage.getItem", $"fp_{Title}_type");
                if (sType != null) _showType = sType == "1";

                var sYear = await JS.InvokeAsync<string>("sessionStorage.getItem", $"fp_{Title}_year");
                if (sYear != null) _showYear = sYear == "1";

                StateHasChanged();
            }
            catch { }
        }
    }

    private async Task ToggleSearch() { _showSearch = !_showSearch; await JS.InvokeVoidAsync("sessionStorage.setItem", $"fp_{Title}_search", _showSearch ? "1" : "0"); }
    private async Task ToggleUserRating() { _showUserRating = !_showUserRating; await JS.InvokeVoidAsync("sessionStorage.setItem", $"fp_{Title}_userrating", _showUserRating ? "1" : "0"); }
    private async Task ToggleTmdbRating() { _showTmdbRating = !_showTmdbRating; await JS.InvokeVoidAsync("sessionStorage.setItem", $"fp_{Title}_tmdbrating", _showTmdbRating ? "1" : "0"); }
    private async Task ToggleGenre() { _showGenre = !_showGenre; await JS.InvokeVoidAsync("sessionStorage.setItem", $"fp_{Title}_genre", _showGenre ? "1" : "0"); }
    private async Task ToggleType() { _showType = !_showType; await JS.InvokeVoidAsync("sessionStorage.setItem", $"fp_{Title}_type", _showType ? "1" : "0"); }
    private async Task ToggleYear() { _showYear = !_showYear; await JS.InvokeVoidAsync("sessionStorage.setItem", $"fp_{Title}_year", _showYear ? "1" : "0"); }
}

<style>
    .filter-sidebar {
        width: 374px;
        flex-shrink: 0;
        overflow-y: auto;
        padding: 16px;
        background: #fff;
        align-self: flex-start; /* Prevents stretching vertically with flexbox */
        container-type: inline-size;
    }
    .filter-label {
        display: flex;
        align-items: center;
        margin-bottom: 6px;
        font-size: 0.67rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #888;
        transition: color 0.15s;
    }
    .filter-label:hover {
        color: #555;
    }
</style>
