@page "/open-on"
@using MyPrivateWatchlist.Models
@inject MyPrivateWatchlist.Services.OpenOnLinkService OpenOnLinks
@inject NavigationManager NavManager

<PageTitle>External Link Operations</PageTitle>

<div class="container py-4" style="padding-left: 4.5px; padding-right: 4.5px;">
    <h2 class="mb-2 fw-bold text-dark d-flex align-items-center">
        <i class="bi bi-box-arrow-up-right me-3 text-primary"></i> External Link Operations
    </h2>
    <p class="text-secondary mb-4">Manage reusable outbound link templates for titles in your library.</p>

    <div class="d-flex justify-content-end mb-4">
        <button class="btn btn-outline-secondary rounded-pill px-4" @onclick='() => NavManager.NavigateTo("configure")'>
            <i class="bi bi-arrow-left me-2"></i>Back to Configure
        </button>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <div class="d-flex align-items-center mb-3">
                <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-3 me-3">
                    <i class="bi bi-link-45deg fs-4"></i>
                </div>
                <h5 class="card-title mb-0 fw-bold">External Links</h5>
            </div>

            <p class="text-secondary small mb-3">
                Paste a sample site URL and the app will convert it into a reusable template for any title. Search URLs work best. IMDb title URLs with an IMDb id also work.
            </p>

            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-secondary text-uppercase">Name</label>
                    <input class="form-control bg-light border-0 py-2"
                           placeholder="Optional, e.g. 1337x"
                           @bind="openOnName" />
                </div>
                <div class="col-md-8">
                    <label class="form-label small fw-bold text-secondary text-uppercase">Sample URL</label>
                    <input class="form-control bg-light border-0 py-2"
                           placeholder="https://1337x.to/search/dune+2022/1/"
                           @bind="openOnSampleUrl"
                           @bind:event="oninput" />
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(openOnSampleUrl))
            {
                string? previewTemplate;
                string? previewError;
                previewTemplate = OpenOnLinks.TryBuildTemplatePreview(openOnSampleUrl, out previewError);
                <div class="bg-light border rounded-3 p-3 mb-3">
                    <div class="small fw-bold text-dark mb-1">Template Preview</div>
                    @if (!string.IsNullOrWhiteSpace(previewTemplate))
                    {
                        <div class="small text-secondary"><code>@previewTemplate</code></div>
                    }
                    else
                    {
                        <div class="small text-danger">@previewError</div>
                    }
                </div>
            }

            <div class="d-flex flex-wrap gap-2 mb-3">
                <button class="btn btn-outline-primary btn-sm rounded-pill px-3" @onclick="AddOpenOnLinkAsync">
                    <i class="bi bi-plus-lg me-1"></i>Add Link
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(openOnStatusMessage))
            {
                <div class="alert @(openOnStatusIsError ? "alert-danger" : "alert-success") border-0 py-2 px-3 mb-3 small">
                    @openOnStatusMessage
                </div>
            }

            @if (_openOnLinks.Any())
            {
                <div class="d-grid gap-2">
                    @foreach (var link in _openOnLinks)
                    {
                        <div class="border rounded-3 p-3 bg-light-subtle">
                            <div class="d-flex align-items-start justify-content-between gap-3">
                                <div class="me-3 flex-grow-1 min-w-0">
                                    <div class="fw-semibold text-dark">@link.Name</div>
                                    <div class="small text-secondary mb-1 text-break">@link.SampleUrl</div>
                                    <div class="x-small text-muted text-break"><code>@link.Template</code></div>
                                </div>
                                <button class="btn btn-outline-danger btn-sm rounded-pill px-3"
                                        style="flex-shrink:0;"
                                        @onclick="() => RemoveOpenOnLinkAsync(link.Id)">
                                    <i class="bi bi-trash3 me-1"></i>Remove
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="small text-secondary bg-light border rounded-3 p-3">
                    No custom links yet. Add search URLs like IMDb find, Reddit search, Google search, 1337x search, or any site that can search by title and year.
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string openOnName = "";
    private string openOnSampleUrl = "";
    private string openOnStatusMessage = "";
    private bool openOnStatusIsError;
    private List<OpenOnLink> _openOnLinks = new();

    protected override async Task OnInitializedAsync()
    {
        await OpenOnLinks.EnsureLoadedAsync();
        RefreshOpenOnLinks();
    }

    private async Task AddOpenOnLinkAsync()
    {
        try
        {
            openOnStatusMessage = "";
            openOnStatusIsError = false;
            await OpenOnLinks.AddFromSampleAsync(openOnName, openOnSampleUrl);
            RefreshOpenOnLinks();
            openOnName = "";
            openOnSampleUrl = "";
            openOnStatusMessage = "Open-on link saved.";
        }
        catch (Exception ex)
        {
            openOnStatusIsError = true;
            openOnStatusMessage = ex.Message;
        }
    }

    private async Task RemoveOpenOnLinkAsync(string id)
    {
        await OpenOnLinks.RemoveAsync(id);
        RefreshOpenOnLinks();
        openOnStatusIsError = false;
        openOnStatusMessage = "Open-on link removed.";
    }

    private void RefreshOpenOnLinks()
        => _openOnLinks = OpenOnLinks.Links.OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase).ToList();
}

<style>
    .x-small { font-size: 0.75rem; }
</style>
