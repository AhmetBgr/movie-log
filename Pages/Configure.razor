@page "/configure"
@using System.Text.RegularExpressions
@using MyPrivateWatchlist.Models
@inject HttpClient Http
@inject IConfiguration Config
@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc
@inject MyPrivateWatchlist.Services.GistSyncService GistSync
@inject MyPrivateWatchlist.Services.AutoSyncService AutoSync
@inject NavigationManager NavManager
@inject IJSRuntime JS
@inject LocalStorageService LocalStore
@implements IDisposable

<PageTitle>Configure & Data</PageTitle>

<div class="container py-4" style="padding-left: 4.5px; padding-right: 4.5px;">
    <style>
        @@media (max-width: 768px) {
            .container {
                padding-left: 2px !important;
                padding-right: 2px !important;
            }
        }
    </style>
    <h2 class="mb-4 fw-bold text-dark d-flex align-items-center">
        <i class="bi bi-gear-fill me-3 text-secondary"></i> Configure & Data Management
    </h2>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-3 h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-warning bg-opacity-10 text-warning p-2 rounded-3 me-3">
                            <i class="bi bi-clock-history fs-4"></i>
                        </div>
                        <h5 class="card-title mb-0 fw-bold text-dark">Search Discovery</h5>
                    </div>

                    <div class="form-check form-switch mb-3 p-3 rounded-3 bg-light border">
                        <input class="form-check-input ms-0 me-3 mt-1" type="checkbox" id="enableSearchHistory" 
                                checked="@WatchlistSvc.EnableSearchHistory" 
                                @onchange="(e) => WatchlistSvc.EnableSearchHistory = (bool)e.Value!">
                        <label class="form-check-label fw-bold text-dark" for="enableSearchHistory">Remember Search History</label>
                        <p class="text-secondary x-small mb-0 mt-2">When enabled, the app stores your last 10 searches locally for quick access while typing.</p>
                    </div>

                    @if (WatchlistSvc.SearchHistory.Any())
                    {
                        <button class="btn btn-outline-danger btn-sm w-100 rounded-pill py-2 mt-2 fw-medium border-2" @onclick="WatchlistSvc.ClearSearchHistory">
                            <i class="bi bi-trash3 me-2"></i> Clear History Now
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Advanced Tools -->
    <div class="row g-4 mb-5">
        <div class="col-md-12">
            <div class="card shadow-sm border-0 rounded-3" style="background: linear-gradient(90deg, #f8faff 0%, #ffffff 100%);">
                <div class="card-body p-4 d-flex align-items-center flex-wrap gap-4">
                    <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-circle shadow-sm">
                         <i class="bi bi-clipboard2-pulse-fill fs-3"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h5 class="fw-bold mb-1 text-dark">Data Integrity & Health Audit</h5>
                        <p class="text-secondary small mb-0">Identify items in your library with missing genres, overviews, runtimes, or posters.</p>
                    </div>
                    <button class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm" @onclick='() => NavManager.NavigateTo("audit")'>
                        Run Health Audit
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12">
            <div class="card shadow-sm border-0 rounded-3" style="background: linear-gradient(135deg, #f8fbff 0%, #ffffff 100%);">
                <div class="card-body p-4 d-flex align-items-center flex-wrap gap-4">
                    <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-circle shadow-sm">
                        <i class="bi bi-box-arrow-up-right fs-3"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h5 class="fw-bold mb-1 text-dark">External Link Operations</h5>
                        <p class="text-secondary small mb-0">Manage reusable outbound link templates like IMDb, Letterboxd, Reddit, Google, or site-specific search links on a dedicated page.</p>
                    </div>
                    <button class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm" @onclick='() => NavManager.NavigateTo("open-on")'>
                        Open External Links
                    </button>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card shadow-sm border-0 rounded-3" style="background: linear-gradient(135deg, #f8fbff 0%, #ffffff 100%);">
                <div class="card-body p-4 d-flex align-items-center flex-wrap gap-4">
                    <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-circle shadow-sm">
                        <i class="bi bi-hdd-stack-fill fs-3"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h5 class="fw-bold mb-1 text-dark">import/export operations</h5>
                        <p class="text-secondary small mb-0">Open Data Hub to import CSV files, export watchlist slices and collections as CSV, or back up the whole save file as JSON.</p>
                    </div>
                    <button class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm" @onclick='() => NavManager.NavigateTo("data-hub")'>
                        Open Data Hub
                    </button>
                </div>
            </div>
        </div>

        <!-- API Connection Settings -->
        <div class="col-12">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-dark bg-opacity-10 text-dark p-2 rounded-3 me-3">
                            <i class="bi bi-key-fill fs-4"></i>
                        </div>
                        <h5 class="card-title mb-0 fw-bold">Connection Settings</h5>
                    </div>
                    <div class="row g-4">
                        <div class="col-md-6 border-end">
                            <label class="form-label small fw-bold text-secondary text-uppercase tracking-wider">TMDB API Key</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-shield-lock-fill text-muted"></i></span>
                                <input type="password" class="form-control bg-light border-0 py-2" value="@Config["TmdbApiKey"]" readonly />
                            </div>
                            <div class="form-text x-small mt-1 text-muted"><i class="bi bi-info-circle me-1"></i> Managed via system configuration.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary text-uppercase tracking-wider">OpenSubtitles API Key</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-keyboard-fill text-muted"></i></span>
                                <input type="password" class="form-control bg-light border-0 py-2" 
                                       @bind="WatchlistSvc.OpenSubtitlesApiKey" 
                                       @bind:event="oninput"
                                       placeholder="Enter your API Key" />
                            </div>
                            <div class="form-text x-small mt-1 text-muted">
                                <i class="bi bi-link-45deg me-1"></i> Get from <a href="https://www.opensubtitles.com/en/consumers" target="_blank" class="text-decoration-none">opensubtitles.com</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Library Sync Help -->
        <div class="col-12">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-success bg-opacity-10 text-success p-2 rounded-3 me-3">
                            <i class="bi bi-cloud-arrow-up-fill fs-4"></i>
                        </div>
                        <h5 class="card-title mb-0 fw-bold">Library Sync (GitHub Gist)</h5>
                    </div>

                    <p class="text-secondary small mb-3">
                        Sync lets you use one shared library across devices (mobile + desktop) by saving your list to a <strong>Secret Gist</strong>.
                    </p>

                    <ol class="small text-secondary mb-3 ps-3">
                        <li>Create a <strong>Secret Gist</strong> on GitHub with a file named <code>watchlist.json</code>. GitHub does not allow empty content, so put <code>[]</code> as the initial file content.</li>
                        <li>Copy the Gist ID from the gist URL (the long id after <code>/gists/...</code>).</li>
                        <li>Create a GitHub Personal Access Token with <strong>Gist</strong> permission (minimum required scope). See quick steps below.</li>
                        <li>Enter <strong>Gist ID</strong> and <strong>PAT</strong> in the form below and press <strong>Save Sync Settings</strong>.</li>
                        <li>Use <strong>Check Sync</strong> to compare your device with the gist, then use <strong>Sync Now</strong> to push or pull the newer side.</li>
                    </ol>

                    <div class="bg-light border rounded-3 p-3 mb-3">
                        <div class="small fw-bold text-dark mb-2">PAT quick setup (GitHub)</div>
                        <ol class="small text-secondary mb-0 ps-3">
                            <li>GitHub → <strong>Settings</strong> → <strong>Developer settings</strong> → <strong>Personal access tokens</strong>.</li>
                            <li>Choose <strong>Tokens (classic)</strong> or fine-grained token with gist access.</li>
                            <li>Set an expiration date (recommended), then grant <strong>Gist</strong> access.</li>
                            <li>Generate token and copy it immediately (GitHub shows it once).</li>
                            <li>Paste token into this page's sync settings and save.</li>
                        </ol>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary text-uppercase">Gist ID</label>
                            <input class="form-control bg-light border-0 py-2"
                                   placeholder="e.g. 1a2b3c4d5e6f..."
                                   @bind="gistId" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary text-uppercase">GitHub PAT (gist scope)</label>
                            <input type="password"
                                   class="form-control bg-light border-0 py-2"
                                   placeholder="ghp_..."
                                   @bind="gistPat" />
                        </div>
                        <div class="col-12">
                            <div class="small text-secondary bg-light border rounded-3 p-3">
                                Sync is manual now. Use Check Sync to compare local data with the gist, and Sync Now to push or pull the newer side.
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mb-2">
                        <button class="btn btn-outline-dark btn-sm rounded-pill px-3" @onclick="SaveGistSettingsAsync" disabled="@syncBusy">
                            <i class="bi bi-save me-1"></i>Save Sync Settings
                        </button>
                        <button class="btn btn-outline-primary btn-sm rounded-pill px-3" @onclick="CheckSyncStatusAsync" disabled="@syncBusy">
                            <i class="bi bi-arrow-repeat me-1"></i>Check Sync
                        </button>
                        <button class="btn btn-outline-success btn-sm rounded-pill px-3" @onclick="SyncNowAsync" disabled="@(syncBusy || !syncActionNeeded)">
                            <i class="bi bi-stars me-1"></i>Smart Sync
                        </button>
                        <button class="btn btn-outline-info btn-sm rounded-pill px-3" @onclick="PullNowAsync" disabled="@syncBusy">
                            <i class="bi bi-cloud-download me-1"></i>Pull from Gist
                        </button>
                        <button class="btn btn-outline-secondary btn-sm rounded-pill px-3" @onclick="PushNowAsync" disabled="@syncBusy">
                            <i class="bi bi-cloud-upload me-1"></i>Push to Gist
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(gistStatusMessage))
                    {
                        <div class="alert @(gistStatusIsError ? "alert-danger" : "alert-success") border-0 py-2 px-3 mb-2 small">
                            @gistStatusMessage
                        </div>
                    }

                    <div class="bg-light border rounded-3 p-3 mb-2">
                        <div class="small fw-bold text-dark mb-2">Manual Sync Status</div>
                        <div class="small text-secondary">@syncStateLabel</div>
                        <div class="small text-secondary">Last sync: @(autoSyncLastAt ?? "Never")</div>
                        <div class="small text-secondary">Direction: @autoSyncDirection</div>
                        @if (!string.IsNullOrWhiteSpace(syncRemoteSummary))
                        {
                            <div class="small text-secondary mt-1">@syncRemoteSummary</div>
                        }
                        @if (syncHasConflict)
                        {
                            <div class="small text-warning mt-1">Both local and gist changed. Sync Now will use whichever side changed more recently.</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(autoSyncLastError))
                        {
                            <div class="small text-danger mt-1">Last error: @autoSyncLastError</div>
                        }
                    </div>

                    <div class="alert alert-warning border-0 py-2 px-3 mb-2 small">
                        <i class="bi bi-shield-lock me-2"></i>
                        Your PAT is sensitive. Keep it private and rotate/revoke it from GitHub if compromised.
                    </div>

                    <div class="text-muted x-small">
                        Sync credentials are stored locally in your browser's localStorage on this device and are not hardcoded in the app. You should be able to configure sync entirely from the Configure page/UI without opening code.
                    </div>
                </div>
            </div>
        </div>

        <!-- Danger Zone -->
        <div class="col-12 mt-4">
            <div class="card shadow-sm border-danger border-opacity-25 rounded-3 bg-danger bg-opacity-10">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold text-danger mb-1 d-flex align-items-center">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> Danger Zone
                        </h5>
                        <p class="text-danger small mb-0 opacity-75">This will permanently delete your entire library (Watchlist & History) from this device.</p>
                    </div>
                    <button class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm" @onclick="ClearLibrary">
                        <i class="bi bi-trash3-fill me-2"></i> Delete All Data
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .x-small { font-size: 0.75rem; }
    .tracking-wider { letter-spacing: 0.05em; }
</style>

@code {
    private string statusMessage = "";
    private string gistId = "";
    private string gistPat = "";
    private string gistStatusMessage = "";
    private bool gistStatusIsError = false;
    private bool syncBusy = false;
    private string? autoSyncLastAt = null;
    private string autoSyncDirection = "Never";
    private string? autoSyncLastError = null;
    private string syncStateLabel = "Sync status unknown";
    private string? syncRemoteSummary = null;
    private bool syncActionNeeded = false;
    private bool syncHasConflict = false;
    private bool importAsWatched = false;
    private string selectedImportSource = "Auto";
    private int importProgress = 0;
    private int importTotal = 0;
    private string backupStatusMessage = "";
    private bool backupStatusIsError = false;

    protected override async Task OnInitializedAsync()
    {
        var saved = await GistSync.GetSettingsAsync();
        gistId = saved.GistId;
        gistPat = saved.PersonalAccessToken;
        await AutoSync.EnsureStartedAsync();
        AutoSync.OnStatusChanged += HandleAutoSyncStatusChanged;
        RefreshAutoSyncStatus();
        await AutoSync.RefreshStatusAsync();
    }

    private async Task SaveGistSettingsAsync()
    {
        try
        {
            syncBusy = true;
            gistStatusMessage = "";
            gistStatusIsError = false;

            await GistSync.SaveSettingsAsync(new GistSettings
            {
                GistId = gistId,
                PersonalAccessToken = gistPat
            });
            await AutoSync.RefreshStatusAsync();

            gistStatusMessage = "Sync settings saved locally.";
        }
        catch (Exception ex)
        {
            gistStatusIsError = true;
            gistStatusMessage = $"Error saving settings: {ex.Message}";
        }
        finally
        {
            syncBusy = false;
        }
    }

    private async Task CheckSyncStatusAsync()
    {
        try
        {
            syncBusy = true;
            gistStatusMessage = "";
            gistStatusIsError = false;

            await GistSync.SaveSettingsAsync(new GistSettings
            {
                GistId = gistId,
                PersonalAccessToken = gistPat
            });
            await AutoSync.RefreshStatusAsync();

            gistStatusMessage = "Sync status refreshed.";
        }
        catch (Exception ex)
        {
            gistStatusIsError = true;
            gistStatusMessage = $"Sync check failed: {ex.Message}";
        }
        finally
        {
            syncBusy = false;
        }
    }

    private async Task SyncNowAsync()
    {
        try
        {
            syncBusy = true;
            gistStatusMessage = "";
            gistStatusIsError = false;

            await GistSync.SaveSettingsAsync(new GistSettings
            {
                GistId = gistId,
                PersonalAccessToken = gistPat
            });
            await AutoSync.SyncNowAsync();

            gistStatusMessage = "Smart sync completed.";
        }
        catch (Exception ex)
        {
            gistStatusIsError = true;
            gistStatusMessage = $"Sync failed: {ex.Message}";
        }
        finally
        {
            syncBusy = false;
        }
    }

    private async Task PullNowAsync()
    {
        try
        {
            var confirmed = await JS.InvokeAsync<bool>("confirm", "This will OVERWRITE your local library with the data from GitHub. Are you sure?");
            if (!confirmed) return;

            syncBusy = true;
            gistStatusMessage = "";
            gistStatusIsError = false;

            await AutoSync.ManualPullAsync();
            gistStatusMessage = "Local data updated from Gist.";
        }
        catch (Exception ex)
        {
            gistStatusIsError = true;
            gistStatusMessage = $"Pull failed: {ex.Message}";
        }
        finally
        {
            syncBusy = false;
        }
    }

    private async Task PushNowAsync()
    {
        try
        {
            var confirmed = await JS.InvokeAsync<bool>("confirm", "This will OVERWRITE the data on GitHub with your local library. Are you sure?");
            if (!confirmed) return;

            syncBusy = true;
            gistStatusMessage = "";
            gistStatusIsError = false;

            await AutoSync.ManualPushAsync();
            gistStatusMessage = "Gist data updated from local library.";
        }
        catch (Exception ex)
        {
            gistStatusIsError = true;
            gistStatusMessage = $"Push failed: {ex.Message}";
        }
        finally
        {
            syncBusy = false;
        }
    }

    private async Task ClearLibrary()
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to PERMANENTLY delete your entire library? This cannot be undone.");
        if (confirmed)
        {
            await WatchlistSvc.ClearAllDataAsync();
            statusMessage = "Library cleared successfully.";
            StateHasChanged();
        }
    }

    private async Task ExportWatchlistJsonAsync()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(WatchlistSvc.Items, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
            var filename = $"movie-log-watchlist-{DateTime.Now:yyyy-MM-dd}.json";
            await JS.InvokeVoidAsync("uiHelpers.downloadFile", filename, json);
        }
        catch (Exception ex)
        {
            statusMessage = $"Error exporting watchlist: {ex.Message}";
        }
    }

    private async Task ExportLocalStorageAsync()
    {
        try
        {
            backupStatusMessage = "";
            backupStatusIsError = false;
            var json = await LocalStore.ExportAllAsync();
            var filename = $"movie-log-full-backup-{DateTime.Now:yyyy-MM-dd}.json";
            await JS.InvokeVoidAsync("uiHelpers.downloadFile", filename, json);
            backupStatusMessage = "Local storage backup exported.";
        }
        catch (Exception ex)
        {
            backupStatusIsError = true;
            backupStatusMessage = $"Export failed: {ex.Message}";
        }
    }

    private async Task HandleLocalStorageImport(InputFileChangeEventArgs e)
    {
        try
        {
            backupStatusMessage = "";
            backupStatusIsError = false;

            var confirmed = await JS.InvokeAsync<bool>("confirm", "This will OVERWRITE all your current settings and library with the backup data. Your browser will reload after import. Continue?");
            if (!confirmed) return;

            using var stream = e.File.OpenReadStream(20_971_520); // 20MB limit
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();

            if (string.IsNullOrWhiteSpace(json))
            {
                backupStatusIsError = true;
                backupStatusMessage = "The selected file is empty.";
                return;
            }

            await LocalStore.ImportAllAsync(json);
            backupStatusMessage = "Backup restored successfully. Reloading...";
            StateHasChanged();

            await Task.Delay(1500);
            await JS.InvokeVoidAsync("location.reload");
        }
        catch (Exception ex)
        {
            backupStatusIsError = true;
            backupStatusMessage = $"Import failed: {ex.Message}";
        }
    }

    private void HandleAutoSyncStatusChanged()
    {
        RefreshAutoSyncStatus();
        _ = InvokeAsync(StateHasChanged);
    }

    private void RefreshAutoSyncStatus()
    {
        autoSyncLastAt = AutoSync.LastSyncAt?.ToLocalTime().ToString("MMM dd, yyyy HH:mm:ss");
        autoSyncDirection = AutoSync.LastSyncDirection;
        autoSyncLastError = AutoSync.LastError;
        syncStateLabel = AutoSync.SyncStateLabel;
        syncRemoteSummary = AutoSync.LastRemoteSummary;
        syncHasConflict = AutoSync.HasConflict;
        syncActionNeeded = AutoSync.HasUnsyncedLocalChanges || AutoSync.HasRemoteChanges || AutoSync.HasConflict;
    }

    public void Dispose()
    {
        AutoSync.OnStatusChanged -= HandleAutoSyncStatusChanged;
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        try
        {
            statusMessage = "Reading file...";
            StateHasChanged();

            using var stream = e.File.OpenReadStream(10_485_760);
            using var reader = new StreamReader(stream);
            
            var config = new CsvHelper.Configuration.CsvConfiguration(System.Globalization.CultureInfo.InvariantCulture)
            {
                PrepareHeaderForMatch = args => args.Header.ToLower().Replace(" ", "").Replace("_", "").Replace("\"", ""),
                HeaderValidated = null,
                MissingFieldFound = null,
                TrimOptions = CsvHelper.Configuration.TrimOptions.Trim
            };

            using var csv = new CsvHelper.CsvReader(reader, config);
            await csv.ReadAsync();
            csv.ReadHeader(); 
            
            var headers = csv.HeaderRecord?.ToList() ?? new List<string>();

            var mergedItems = new List<WatchlistItem>(WatchlistSvc.Items);
            var existingIds = new HashSet<string>(
                mergedItems.Where(i => !string.IsNullOrWhiteSpace(i.ImdbId))
                          .Select(i => i.ImdbId),
                StringComparer.OrdinalIgnoreCase);

            static string NormalizeHeader(string value) =>
                value.ToLower().Replace(" ", "").Replace("_", "").Replace("\"", "");

            var normalizedHeaderToActual = headers
                .Select(h => new { Actual = h, Normalized = NormalizeHeader(h) })
                .GroupBy(h => h.Normalized)
                .ToDictionary(g => g.Key, g => g.First().Actual, StringComparer.OrdinalIgnoreCase);

            static string? ReadByAliases(CsvHelper.CsvReader csvReader, Dictionary<string, string> headerMap, string[] aliases)
            {
                foreach (var alias in aliases)
                {
                    if (headerMap.TryGetValue(alias, out var actualHeader))
                    {
                        return csvReader.GetField(actualHeader);
                    }
                }
                return null;
            }

            var aliasSet = GetAliasSet(selectedImportSource);

            importTotal = 0;
            importProgress = 0;
            int importErrorCount = 0;
            int newItemsCount = 0;
            int duplicateCount = 0;

            while (await csv.ReadAsync())
            {
                importTotal++;
                importProgress++;
                if (importProgress % 5 == 0)
                {
                    statusMessage = $"Hydrating {importProgress} / {importTotal}...";
                    StateHasChanged();
                }

                var id = ReadByAliases(csv, normalizedHeaderToActual, aliasSet.IdAliases);
                var tmdbIdRaw = ReadByAliases(csv, normalizedHeaderToActual, aliasSet.TmdbAliases);
                var title = ReadByAliases(csv, normalizedHeaderToActual, aliasSet.TitleAliases);
                var year = ReadByAliases(csv, normalizedHeaderToActual, aliasSet.YearAliases);
                var rating = ReadByAliases(csv, normalizedHeaderToActual, aliasSet.RatingAliases);
                var type = ReadByAliases(csv, normalizedHeaderToActual, aliasSet.TypeAliases);
                var directors = ReadByAliases(csv, normalizedHeaderToActual, aliasSet.DirectorAliases);
                var genres = ReadByAliases(csv, normalizedHeaderToActual, aliasSet.GenreAliases);
                string? posterPath = null;

                // If type is missing, try to infer it from any URL present in the row
                string? urlHint = null;
                if (string.IsNullOrWhiteSpace(type))
                {
                    // Check the id field first — Letterboxd exports a full URL as the id column
                    if (!string.IsNullOrWhiteSpace(id) && id.Contains("://"))
                        urlHint = id;

                    // Otherwise scan every cell for any URL containing type path segments
                    if (urlHint == null)
                    {
                        foreach (var header in headers)
                        {
                            var cell = csv.GetField(header);
                            if (!string.IsNullOrWhiteSpace(cell) && cell.Contains("://"))
                            {
                                urlHint = cell;
                                break;
                            }
                        }
                    }
                }

                if (string.IsNullOrEmpty(title)) {
                    importErrorCount++;
                    continue;
                }

                string? finalImdbId = NormalizeImdbId(id);
                int? parsedYear = null;
                if (!string.IsNullOrEmpty(year))
                {
                    var yearDigits = new string(year.TakeWhile(char.IsDigit).ToArray());
                    if (int.TryParse(yearDigits, out int py)) parsedYear = py;
                }

                // Hydration: If ID is missing, resolve it asynchronously
                if (string.IsNullOrEmpty(finalImdbId))
                {
                    if (!string.IsNullOrWhiteSpace(tmdbIdRaw) && int.TryParse(new string(tmdbIdRaw.Where(char.IsDigit).ToArray()), out var tmdbId))
                    {
                        var mediaType = InferMediaType(type, urlHint);
                        var tmdbMovie = await WatchlistSvc.GetTmdbDetailsByIdAsync(tmdbId, mediaType);
                        finalImdbId = NormalizeImdbId(tmdbMovie?.ImdbId);
                    }

                    if (string.IsNullOrEmpty(finalImdbId))
                    {
                        finalImdbId = await WatchlistSvc.ResolveImdbIdAsync(title, parsedYear);
                    }

                    // If we hydrated from TMDB, we might have better genres
                    if (string.IsNullOrEmpty(genres) && !string.IsNullOrEmpty(finalImdbId))
                    {
                        var tmdbItem = await WatchlistSvc.GetTmdbDetailsAsync(finalImdbId);
                        if (tmdbItem != null && tmdbItem.GenreList.Any())
                        {
                            genres = string.Join(", ", tmdbItem.GenreList.Select(g => g.Name));
                        }
                        if (tmdbItem != null && !string.IsNullOrEmpty(tmdbItem.PosterPath))
                        {
                            posterPath = tmdbItem.PosterPath;
                        }
                    }
                }

                if (!string.IsNullOrEmpty(finalImdbId))
                {
                    if (existingIds.Contains(finalImdbId))
                    {
                        duplicateCount++;
                        continue;
                    }

                    int? rating20 = null;
                    if (!string.IsNullOrEmpty(rating))
                    {
                        var ratingDigits = new string(rating.TakeWhile(c => char.IsDigit(c) || c == '.').ToArray());
                        if (double.TryParse(ratingDigits, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out double pr)) {
                            // Detect scale
                            if (pr > 10) // Assume 1-100
                                rating20 = (int)Math.Round(pr);
                            else // Assume 1-10
                                rating20 = (int)Math.Round(pr * 10.0);
                            
                            if (rating20 > 100) rating20 = 100;
                            if (rating20 < 1) rating20 = 1;
                        }
                    }

                    var dateAddedStr = ReadByAliases(csv, normalizedHeaderToActual, new[] { "daterated", "dateadded", "watchedon", "datewatched", "added", "createdat", "date", "ratingdate", "watched" });
                    DateTime dateAdded = DateTime.Now;
                    if (!string.IsNullOrEmpty(dateAddedStr) && DateTime.TryParse(dateAddedStr, out var parsedDate)) {
                        dateAdded = parsedDate;
                    }

                    var normalizedImdbId = finalImdbId.Trim();
                    mergedItems.Add(new WatchlistItem {
                        ImdbId = normalizedImdbId,
                        Title = title.Trim(),
                        TitleType = InferTitleType(type, urlHint),
                        Year = year?.Trim() ?? "",
                        Director = directors?.Trim() ?? "",
                        Genres = genres?.Trim() ?? "",
                        PosterPath = posterPath,
                        ParsedYear = parsedYear ?? 0,
                        Status = importAsWatched ? WatchlistStatus.Watched : WatchlistStatus.Pending,
                        DateAdded = dateAdded,
                        Rating20 = rating20,
                        UserRating = rating20.HasValue ? (int)Math.Max(1, Math.Min(10, Math.Round(rating20.Value / 10.0))) : null
                    });
                    existingIds.Add(normalizedImdbId);
                    newItemsCount++;
                }
                else
                {
                    importErrorCount++;
                }
            }

            if (newItemsCount > 0) {
                await WatchlistSvc.UpdateListAsync(mergedItems);
                statusMessage = $"Success ({selectedImportSource}): Added {newItemsCount} new items. (Skipped {duplicateCount} duplicates, {importErrorCount} failures)";
            }
            else {
                statusMessage = $"No new items found ({selectedImportSource}). ({duplicateCount} already in library, {importErrorCount} failures)";
            }

        }
        catch (Exception ex)
        {
            Console.WriteLine($"CSV Import Detail Error: {ex}");
            statusMessage = $"Error: {ex.Message}";
        }
    }

    private static string? NormalizeImdbId(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
            return null;

        var value = raw.Trim();
        if (value.StartsWith("http", StringComparison.OrdinalIgnoreCase))
        {
            var marker = value.IndexOf("/title/", StringComparison.OrdinalIgnoreCase);
            if (marker >= 0)
            {
                var rest = value[(marker + "/title/".Length)..];
                var slash = rest.IndexOf('/');
                value = slash >= 0 ? rest[..slash] : rest;
            }
        }

        if (!value.StartsWith("tt", StringComparison.OrdinalIgnoreCase))
            return null;

        return value.ToLowerInvariant();
    }

    private static string InferTitleType(string? type, string? urlHint = null)
    {
        // 1. Use explicit type field if present
        if (!string.IsNullOrWhiteSpace(type))
        {
            var t = type.ToLowerInvariant();
            if (t.Contains("tv") || t.Contains("show") || t.Contains("series") || t.Contains("episode") || t.Contains("mini"))
                return "TV Series";
            if (t.Contains("short"))
                return "Short";
            if (t.Contains("documentary"))
                return "Documentary";
            return "Movie";
        }

        // 2. Try to infer from URL path segments
        if (!string.IsNullOrWhiteSpace(urlHint))
        {
            var u = urlHint.ToLowerInvariant();
            // TV indicators in URL
            if (u.Contains("/tv/") || u.Contains("/show/") || u.Contains("/shows/") ||
                u.Contains("/series/") || u.Contains("/episode/") || u.Contains("/tvseries"))
                return "TV Series";
            // Movie indicators in URL
            if (u.Contains("/movie/") || u.Contains("/movies/") || u.Contains("/film/") || u.Contains("/films/"))
                return "Movie";
        }

        // 3. Default fallback
        return "Movie";
    }

    private static string InferMediaType(string? type, string? urlHint = null)
    {
        var titleType = InferTitleType(type, urlHint);
        return titleType == "TV Series" ? "tv" : "movie";
    }

