@page "/movie/{imdbId}"
@using MyPrivateWatchlist.Models
@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc
@inject NavigationManager NavManager
@inject IJSRuntime JS

<PageTitle>@(movie?.Title ?? "Loading...") - Movie Log</PageTitle>

<div class="movie-details-page">
    @if (isLoading)
    {
        <div class="loading-screen">
            <div class="spinner-ripple"></div>
            <p>Gathering data...</p>
        </div>
    }
    else if (movie == null)
    {
        <div class="container py-5 text-center">
            <div class="card border-0 shadow-sm p-5 rounded-4">
                <i class="bi bi-search fs-1 text-muted mb-3"></i>
                <h2 class="fw-black">Movie Not Found</h2>
                <p class="text-secondary">We couldn't find details for ID: @imdbId</p>
                <button class="btn btn-primary rounded-pill px-4 mt-3" @onclick='() => NavManager.NavigateTo("/")'>Return Home</button>
            </div>
        </div>
    }
    else
    {
        <!-- Hero Header -->
        <div class="hero-section">
            <!-- Background Layer -->
            <div class="hero-bg-wrapper">
                <div class="hero-bg" style="background-image: url('https://image.tmdb.org/t/p/original@(movie.BackdropPaths.FirstOrDefault())')"></div>
                <div class="hero-overlay"></div>
            </div>
            
            <div class="container hero-container">
                <div class="row g-4 align-items-center">
                    <div class="col-lg-3 col-md-4">
                        <div class="hero-poster shadow-premium">
                            <img src="@movie.FullPosterUrl" alt="@movie.Title" />
                        </div>
                    </div>
                    <div class="col-lg-9 col-md-8">
                        <div class="hero-content text-white">
                            <div class="d-flex align-items-center gap-3 flex-wrap mb-2">
                                <h1 class="movie-title fw-black m-0">@movie.Title</h1>
                                <div class="hero-actions-inline">
                                    <OpenOnMenu Title="@movie.Title" 
                                               Year="@(movie.ReleaseDate?.Length >= 4 ? movie.ReleaseDate[..4] : "")" 
                                               ImdbId="@imdbId"
                                               ButtonClass="btn-dots-white" />
                                </div>
                            </div>
                            
                            @if (!string.IsNullOrEmpty(movie.OriginalTitle) && movie.OriginalTitle != movie.Title)
                            {
                                <h4 class="text-white-50 fw-semibold mb-3">@movie.OriginalTitle</h4>
                            }
                            
                            <div class="movie-meta d-flex flex-wrap gap-3 mb-4">
                                <span class="meta-item"><i class="bi bi-calendar3"></i> @(movie.ReleaseDate?.Length >= 4 ? movie.ReleaseDate[..4] : "N/A")</span>
                                @if (movie.Runtime > 0)
                                {
                                    <span class="meta-item"><i class="bi bi-clock"></i> @FormatRuntime(movie.Runtime.Value)</span>
                                }
                                <div class="rating-badge">
                                    <i class="bi bi-star-fill text-warning"></i>
                                    <span>@movie.VoteAverage.ToString("0.0")</span>
                                    <small>TMDB</small>
                                </div>
                            </div>
                            
                            <div class="genres-wrap d-flex flex-wrap gap-2 mb-4">
                                @foreach (var g in movie.GenreList)
                                {
                                    <span class="genre-tag">@g.Name</span>
                                }
                            </div>
                            
                            <div class="d-flex flex-wrap gap-3">
                                @if (!string.IsNullOrEmpty(movie.TrailerKey))
                                {
                                    <a href="https://www.youtube.com/watch?v=@movie.TrailerKey" target="_blank" class="btn btn-primary btn-lg rounded-pill px-4 fw-bold shadow-sm text-decoration-none d-inline-flex align-items-center">
                                        <i class="bi bi-play-fill me-2 fs-4"></i> Play Trailer
                                    </a>
                                }
                                <button class="btn btn-glass btn-lg rounded-pill px-4 fw-bold" @onclick="OpenAsPopup">
                                    <i class="bi bi-layout-sidebar-reverse me-2"></i> Open Summary
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="container main-content">
            <div class="row g-4">
                <!-- Primary Column -->
                <div class="col-lg-8">
                    <!-- Overview -->
                    <section class="details-section shadow-sm animate-in">
                        <h3 class="section-heading"><i class="bi bi-text-left me-2"></i> Overview</h3>
                        <p class="overview-p">@movie.Overview</p>
                    </section>

                    <!-- Full Cast & Crew -->
                    <section class="details-section shadow-sm animate-in">
                        <h3 class="section-heading mb-4"><i class="bi bi-people me-2"></i> Cast & Crew</h3>
                        
                        <div class="credits-wrap">
                            @if (movie.Credits?.Crew?.Any(c => c.Job == "Director") == true)
                            {
                                <div class="crew-group mb-4">
                                    <label class="group-label">Directors</label>
                                    <div class="person-grid-small">
                                        @foreach (var dir in movie.Credits.Crew.Where(c => c.Job == "Director"))
                                        {
                                            <div class="person-compact-card clickable" @onclick="() => WatchlistSvc.OpenPersonProfileAsync(dir.Id)">
                                                <img src="@dir.FullProfileUrl" alt="@dir.Name" />
                                                <span>@dir.Name</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            @if (movie.Credits?.Crew?.Any(c => c.Job == "Writer" || c.Job == "Screenplay") == true)
                            {
                                <div class="crew-group mb-4">
                                    <label class="group-label">Writers</label>
                                    <div class="person-grid-small">
                                        @foreach (var writer in movie.Credits.Crew.Where(c => c.Job == "Writer" || c.Job == "Screenplay").GroupBy(x => x.Id).Select(g => g.First()).Take(6))
                                        {
                                            <div class="person-compact-card clickable" @onclick="() => WatchlistSvc.OpenPersonProfileAsync(writer.Id)">
                                                <img src="@writer.FullProfileUrl" alt="@writer.Name" />
                                                <span>@writer.Name</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }

                            @if (movie.Credits?.Cast?.Any() == true)
                            {
                                <div class="crew-group">
                                    <label class="group-label">Lead Actors</label>
                                    <div class="person-grid-small">
                                        @foreach (var actor in movie.Credits.Cast.Take(12))
                                        {
                                            <div class="person-compact-card clickable" @onclick="() => WatchlistSvc.OpenPersonProfileAsync(actor.Id)">
                                                <img src="@actor.FullProfileUrl" alt="@actor.Name" />
                                                <span>@actor.Name</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </section>

                    <!-- Wikipedia Snippet -->
                    @if (wikiSnippet != null)
                    {
                        <section class="details-section shadow-sm animate-in">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h3 class="section-heading m-0"><i class="bi bi-wikipedia me-2"></i> From Wikipedia</h3>
                                <a href="@wikiSnippet.ContentUrls?.Desktop?.Page" target="_blank" class="btn btn-sm btn-outline-secondary rounded-pill">Read More</a>
                            </div>
                            <div class="wiki-content">
                                <p class="mb-0">@wikiSnippet.Extract</p>
                            </div>
                        </section>
                    }
                    else if (isWikiLoading)
                    {
                        <div class="details-section shadow-sm shimmer-box" style="height: 150px;"></div>
                    }

                    <!-- Subtitles Section -->
                    <section class="details-section shadow-sm animate-in">
                        <h3 class="section-heading mb-3"><i class="bi bi-chat-left-dots me-2"></i> Subtitles</h3>
                        @if (isSubsLoading)
                        {
                            <div class="shimmer-box" style="height: 100px;"></div>
                        }
                        else if (subtitles != null && subtitles.Any())
                        {
                            <div class="subs-list">
                                @foreach (var sub in subtitles.OrderByDescending(s => s.Attributes?.DownloadCount).Take(5))
                                {
                                    <div class="sub-item">
                                        <div class="sub-info">
                                            <span class="badge bg-secondary me-2">@sub.Attributes?.Language.ToUpper()</span>
                                            <span class="sub-release text-truncate">@sub.Attributes?.Release</span>
                                        </div>
                                        <div class="sub-stats">
                                            <small class="text-muted me-3"><i class="bi bi-download"></i> @sub.Attributes?.DownloadCount</small>
                                            <a href="@sub.Attributes?.Url" target="_blank" class="btn btn-xs btn-primary rounded-pill px-3">View</a>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-3 text-muted">
                                <i class="bi bi-search mb-2 d-block opacity-50"></i>
                                @if (string.IsNullOrEmpty(WatchlistSvc.OpenSubtitlesApiKey))
                                {
                                    <p class="small mb-0">API Key not configured. Link your OpenSubtitles key in Settings.</p>
                                }
                                else
                                {
                                    <p class="small mb-0">No subtitles found via API.</p>
                                }
                                <a href="https://www.opensubtitles.org/en/search/imdbid-@imdbId" target="_blank" class="btn btn-link btn-sm mt-1">Manual Search <i class="bi bi-box-arrow-up-right ms-1"></i></a>
                            </div>
                        }
                    </section>
                </div>

                <!-- Secondary Column -->
                <div class="col-lg-4">
                    <div class="details-section shadow-sm sticky-side status-box accent-border animate-in p-3">
                        <h4 class="small fw-bold text-secondary text-uppercase tracking-wider mb-3 ms-1" style="font-size: 0.65rem;">Library Actions</h4>
                        <CompactLibraryActions Item="libItem" ImdbId="@imdbId" Movie="movie" />
                    </div>

                    <!-- Media Gallery Grid -->
                    @if (movie.BackdropPaths.Count > 1)
                    {
                        <div class="details-section shadow-sm animate-in">
                            <h4 class="section-label mb-3">Gallery</h4>
                            <div class="row g-2">
                                @foreach (var path in movie.BackdropPaths.Skip(1))
                                {
                                    <div class="col-6">
                                        <div class="gallery-thumb rounded-3 clickable" @onclick="() => OpenLightbox(path)">
                                            <img src="https://image.tmdb.org/t/p/w300@(path)" class="img-fluid" alt="Backdrop" />
                                            <div class="thumb-overlay"><i class="bi bi-zoom-in"></i></div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <!-- Collection -->
                    @if (movie.Collection != null)
                    {
                        <div class="details-section shadow-sm collection-promo clickable animate-in" 
                             style="background-image: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.8)), url('https://image.tmdb.org/t/p/w500@(movie.Collection.BackdropPath)')"
                             @onclick='() => NavManager.NavigateTo($"franchise/{movie.Collection.Id}")'>
                            <span class="promo-badge">Collection</span>
                            <h4 class="m-0 text-white fw-black">@movie.Collection.Name</h4>
                            <div class="mt-3 text-white-50 small fw-bold">Deep Dive <i class="bi bi-arrow-right ms-1"></i></div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<!-- Lightbox & Player Overlay -->
@if (selectedLightboxPath != null)
{
    <div class="lightbox-portal" @onclick="() => selectedLightboxPath = null">
        <div class="lightbox-stage animate-pop-in">
            <img src="https://image.tmdb.org/t/p/original@(selectedLightboxPath)" class="img-fluid shadow-premium rounded-4" />
            <button class="btn-close-portal" @onclick="() => selectedLightboxPath = null"><i class="bi bi-x-lg"></i></button>
        </div>
    </div>
}

<TrailerPlayer VideoKey="@movie?.TrailerKey" IsOpen="isTrailerOpen" OnClose="() => isTrailerOpen = false" />

<style>
    :root {
        --movie-accent: #6366f1;
        --movie-bg: #f8fafc;
        --movie-card: #ffffff;
        --movie-text: #0f172a;
        --movie-muted: #64748b;
    }

    .movie-details-page {
        min-height: 100vh;
        background: var(--movie-bg);
        padding-bottom: 200px;
    }

    /* Hero Section - Refactored to avoid overflow Clipping */
    .hero-section {
        position: relative;
        height: min(60vh, 600px);
        width: calc(100% + 2rem);
        margin-left: -1rem;
        margin-right: -1rem;
        margin-top: -1.5rem;
        /* Remove global overflow: hidden; to allow popups to overlay */
        background: #000;
        margin-bottom: -100px;
    }
    @@media (min-width: 576px) {
        .hero-section {
            width: calc(100% + 1.5rem);
            margin-left: -0.75rem;
            margin-right: -0.75rem;
        }
    }
    @@media (min-width: 768px) {
        .hero-section {
            width: calc(100% + 4.5rem); 
            margin-left: -2.25rem; 
            margin-right: -2.25rem;
        }
    }
    @@media (min-width: 1200px) {
         .hero-section {
            width: calc(100% + 6rem);
            margin-left: -3rem;
            margin-right: -3rem;
        }
    }

    .hero-bg-wrapper {
        position: absolute;
        inset: 0;
        overflow: hidden; /* Only clip the background, not the whole section */
        pointer-events: none;
    }
    .hero-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center 20%;
        filter: brightness(0.5) blur(2px);
        transform: scale(1.1);
    }
    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(0deg, var(--movie-bg) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0.6) 100%);
    }

    .hero-container {
        position: relative;
        height: 100%;
        display: flex;
        align-items: center;
        z-index: 100; /* Higher to stay above content */
        padding-top: 50px;
    }
    .hero-poster {
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.2);
    }
    .hero-poster img { width: 100%; height: auto; display: block; }
    
    .movie-title { font-size: clamp(2rem, 5vw, 3.5rem); letter-spacing: -1.5px; line-height: 1.1; }
    
    /* OpenOnMenu Custom Trigger Styling for Hero */
    .hero-actions-inline .open-on-trigger.btn-dots-white {
        color: rgba(255,255,255,0.7) !important;
        background: rgba(255,255,255,0.1) !important;
        width: 32px !important;
        height: 32px !important;
        font-size: 1.2rem !important;
        border: 1px solid rgba(255,255,255,0.2) !important;
        transition: all 0.2s ease;
    }
    .hero-actions-inline .open-on-trigger.btn-dots-white:hover {
        background: rgba(255,255,255,0.25) !important;
        color: #fff !important;
        transform: scale(1.1);
    }

    .meta-item { font-weight: 700; color: rgba(255,255,255,0.8); font-size: 0.95rem; display: flex; align-items: center; gap: 8px; }
    
    .rating-badge {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(0,0,0,0.4);
        backdrop-filter: blur(8px);
        padding: 4px 14px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,0.1);
    }
    .rating-badge span { font-weight: 800; font-size: 1.1rem; }
    
    .genre-tag {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.2);
        padding: 5px 15px;
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    .btn-glass {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.2);
        color: #fff;
    }
    .btn-glass:hover {
        background: rgba(255,255,255,0.2);
        color: #fff;
    }

    /* Main Content */
    .main-content { position: relative; z-index: 20; }
    .details-section {
        background: var(--movie-card);
        border-radius: 24px;
        padding: 32px;
        margin-bottom: 24px;
        border: 1px solid rgba(0,0,0,0.03);
    }
    .section-heading {
        font-weight: 900;
        font-size: 1.3rem;
        letter-spacing: -0.5px;
        color: #1e293b;
    }
    .section-label {
        font-weight: 800;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--movie-muted);
    }
    .overview-p { font-size: 1.1rem; line-height: 1.7; color: #475569; }

    /* Cast & Credits */
    .group-label { display: block; font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: #94a3b8; margin-bottom: 12px; letter-spacing: 1px; }
    .person-grid-small { display: flex; flex-wrap: wrap; gap: 8px; }
    .person-compact-card {
        display: flex;
        align-items: center;
        gap: 10px;
        background: #f8fafc;
        padding: 6px 12px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        transition: all 0.2s;
    }
    .person-compact-card:hover { transform: translateY(-2px); border-color: var(--movie-accent); background: #fff; }
    .person-compact-card img { width: 32px; height: 32px; border-radius: 8px; object-fit: cover; }
    .person-compact-card span { font-weight: 700; font-size: 0.85rem; color: #1e293b; }


    /* Wiki & Subs */
    .wiki-content p { font-size: 1rem; line-height: 1.6; color: #475569; }
    .subs-list { display: flex; flex-direction: column; gap: 10px; }
    .sub-item {
        display: flex; justify-content: space-between; align-items: center;
        background: #f8fafc; padding: 12px 16px; border-radius: 16px;
        border: 1px solid #e2e8f0;
    }
    .sub-release { font-weight: 700; font-size: 0.85rem; color: #1e293b; max-width: 200px; display: inline-block; }

    /* Media Gallery */
    .gallery-thumb { position: relative; overflow: hidden; height: 100px; border: 1px solid #e2e8f0; }
    .gallery-thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
    .thumb-overlay {
        position: absolute; inset: 0; background: rgba(99, 102, 241, 0.4);
        display: flex; align-items: center; justify-content: center;
        opacity: 0; color: #fff; font-size: 1.5rem; transition: opacity 0.2s;
    }
    .gallery-thumb:hover img { transform: scale(1.1); }
    .gallery-thumb:hover .thumb-overlay { opacity: 1; }

    .collection-promo {
        height: 180px; border-radius: 24px; padding: 30px;
        background-size: cover; background-position: center;
        display: flex; flex-direction: column; justify-content: flex-end;
        position: relative; overflow: hidden;
    }
    .promo-badge { font-size: 0.6rem; font-weight: 900; background: var(--movie-accent); color: #fff; padding: 2px 8px; border-radius: 999px; width: fit-content; margin-bottom: 8px; text-transform: uppercase; }

    /* Utils */
    .shadow-premium { box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); }
    .clickable { cursor: pointer; }
    .no-spinner::-webkit-outer-spin-button, .no-spinner::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    .shimmer-box {
        background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite;
        border-radius: 12px;
    }
    @@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
    .animate-in { animation: fadeInUp 0.5s ease-out both; }
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

    /* Lightbox Portal */
    .lightbox-portal {
        position: fixed; inset: 0; background: rgba(0,0,0,0.95);
        z-index: 10000; display: flex; align-items: center; justify-content: center; padding: 30px;
    }
    .lightbox-stage { position: relative; max-width: 1280px; width: 100%; }
    .btn-close-portal {
        position: fixed; top: 30px; right: 30px; background: #fff;
        border: none; width: 44px; height: 44px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center; font-size: 1.2rem;
    }

    .loading-screen {
        height: 80vh; display: flex; flex-direction: column; align-items: center; justify-content: center;
    }
    .spinner-ripple {
        width: 60px; height: 60px; border: 4px solid var(--movie-accent);
        border-radius: 50%; border-top-color: transparent;
        animation: spin 1s linear infinite;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    @@media (max-width: 991px) {
        .hero-section { height: auto; padding: 120px 0 60px; }
        .hero-poster { width: 180px; margin: 0 auto; }
        .hero-content { text-align: center; margin-top: 20px; }
        .movie-meta, .genres-wrap, .d-flex { justify-content: center; }
        .sticky-side { position: static !important; }
    }
</style>

@code {
    [Parameter] public string imdbId { get; set; } = "";
    private TmdbMovie? movie;
    private WatchlistItem? libItem;
    private bool isLoading = true;
    
    private WikipediaSnippet? wikiSnippet;
    private bool isWikiLoading = false;
    
    private List<OpenSubtitlesData>? subtitles;
    private bool isSubsLoading = false;

    private bool isTrailerOpen = false;
    private string? selectedLightboxPath;
    private bool showSavedIndicator = false;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        movie = null;
        libItem = null;
        wikiSnippet = null;
        subtitles = null;
        StateHasChanged();

        movie = await WatchlistSvc.GetTmdbDetailsAsync(imdbId);
        
        if (movie != null)
        {
            libItem = WatchlistSvc.Items.FirstOrDefault(i => i.ImdbId == imdbId);

            // Fire off external API requests
            _ = LoadWikiDataAsync();
            _ = LoadSubtitlesAsync();
        }

        isLoading = false;
    }

    private async Task LoadWikiDataAsync()
    {
        if (movie == null) return;
        isWikiLoading = true;
        wikiSnippet = await WatchlistSvc.GetWikipediaSnippetAsync(movie.Title);
        isWikiLoading = false;
        StateHasChanged();
    }

    private async Task LoadSubtitlesAsync()
    {
        if (movie == null) return;
        isSubsLoading = true;
        subtitles = await WatchlistSvc.GetSubtitlesAsync(imdbId);
        isSubsLoading = false;
        StateHasChanged();
    }

    private string FormatRuntime(int minutes)
    {
        var h = minutes / 60;
        var m = minutes % 60;
        return h > 0 ? $"{h}h {m}m" : $"{m}m";
    }

    private void OpenLightbox(string path) => selectedLightboxPath = path;

    private async Task OpenAsPopup()
    {
        if (libItem != null)
        {
            await WatchlistSvc.ShowDetailsAsync(libItem);
        }
    }
}
