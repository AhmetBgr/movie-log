@code {
    [Parameter] public string imdbId { get; set; } = "";
    private TmdbMovie? movie;
    private WatchlistItem? libItem;
    private bool isLoading = true;
    
    private WikipediaSnippet? wikiSnippet;
    private bool isWikiLoading = false;
    
    private List<OpenSubtitlesData>? subtitles;
    private bool isSubsLoading = false;
    private bool isEnhancingDetails = false;

    private bool isTrailerOpen = false;
    private string? selectedLightboxPath;
    private bool showSavedIndicator = false;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        isEnhancingDetails = false;
        movie = null;
        libItem = null;
        wikiSnippet = null;
        subtitles = null;
        StateHasChanged();

        movie = await WatchlistSvc.GetTmdbBasicDetailsAsync(imdbId);
        
        if (movie != null)
        {
            libItem = WatchlistSvc.Items.FirstOrDefault(i => i.ImdbId == imdbId);

            // Render basic metadata first, then hydrate heavier details in the background.
            _ = LoadWikiDataAsync();
            _ = LoadSubtitlesAsync();
            _ = EnhanceMovieDetailsAsync(movie.Id);
        }

        isLoading = false;
    }

    private async Task EnhanceMovieDetailsAsync(int currentMovieId)
    {
        isEnhancingDetails = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var fullMovie = await WatchlistSvc.GetTmdbDetailsAsync(imdbId);
            if (fullMovie != null && movie?.Id == currentMovieId)
            {
                movie = fullMovie;
            }
        }
        finally
        {
            isEnhancingDetails = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadWikiDataAsync()
    {
        if (movie == null) return;
        isWikiLoading = true;
        wikiSnippet = await WatchlistSvc.GetWikipediaSnippetAsync(movie.Title);
        isWikiLoading = false;
        StateHasChanged();
    }

    private async Task LoadSubtitlesAsync()
    {
        if (movie == null) return;
        isSubsLoading = true;
        subtitles = await WatchlistSvc.GetSubtitlesAsync(imdbId);
        isSubsLoading = false;
        StateHasChanged();
    }

    private string FormatRuntime(int minutes)
    {
        var h = minutes / 60;
        var m = minutes % 60;
        return h > 0 ? $"{h}h {m}m" : $"{m}m";
    }

    private static string GetDisplayValue(string? value)
        => string.IsNullOrWhiteSpace(value) ? "Unknown" : value;

    private static string GetCountLabel(int count)
        => count > 0 ? count.ToString("N0", CultureInfo.InvariantCulture) : "Unknown";

    private static string GetPopularityLabel(double popularity)
        => popularity > 0 ? popularity.ToString("0.0", CultureInfo.InvariantCulture) : "Unknown";

    private static string FormatCurrency(long? amount)
    {
        var value = amount.GetValueOrDefault();
        return value > 0
            ? string.Format(CultureInfo.GetCultureInfo("en-US"), "{0:C0}", value)
            : "Unknown";
    }

    private static string GetLanguageLabel(string? languageCode)
    {
        if (string.IsNullOrWhiteSpace(languageCode))
            return "Unknown";

        try
        {
            var normalized = languageCode.Trim().ToLowerInvariant();
            var culture = CultureInfo
                .GetCultures(CultureTypes.NeutralCultures)
                .FirstOrDefault(c => string.Equals(c.TwoLetterISOLanguageName, normalized, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrWhiteSpace(culture?.EnglishName) &&
                !string.Equals(culture.EnglishName, normalized, StringComparison.OrdinalIgnoreCase))
            {
                return $"{culture.EnglishName} ({normalized.ToUpperInvariant()})";
            }
        }
        catch
        {
        }

        return languageCode.ToUpperInvariant();
    }

    private void OpenLightbox(string path) => selectedLightboxPath = path;

    private async Task OpenAsPopup()
    {
        if (libItem != null)
        {
            await WatchlistSvc.ShowDetailsAsync(libItem);
        }
    }
}
