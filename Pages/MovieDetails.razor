@page "/movie/{imdbId}"
@using MyPrivateWatchlist.Models
@using System.Globalization
@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc
@inject NavigationManager NavManager
@inject IJSRuntime JS

<PageTitle>@(movie?.Title ?? "Loading...") - Movie Log</PageTitle>

<div class="movie-details-page">
    @if (isLoading)
    {
        <div class="loading-screen">
            <div class="spinner-ripple"></div>
            <p>Gathering data...</p>
        </div>
    }
    else if (movie == null)
    {
        <div class="container py-5 text-center">
            <div class="card border-0 shadow-sm p-5 rounded-4">
                <i class="bi bi-search fs-1 text-muted mb-3"></i>
                <h2 class="fw-black">Movie Not Found</h2>
                <p class="text-secondary">We couldn't find details for ID: @imdbId</p>
                <button class="btn btn-primary rounded-pill px-4 mt-3" @onclick='() => NavManager.NavigateTo("/")'>Return Home</button>
            </div>
        </div>
    }
    else
    {
        <!-- Hero Header -->
        <div class="hero-section">
            <!-- Background Layer -->
            <div class="hero-bg-wrapper">
                <div class="hero-bg" style="background-image: url('https://image.tmdb.org/t/p/original@(movie.BackdropPaths.FirstOrDefault())')"></div>
                <div class="hero-overlay"></div>
            </div>
            
            <div class="container hero-container">
                <div class="row justify-content-center w-100 m-0">
                    <div class="col-lg-11 col-xl-10 text-center">
                        <div class="hero-poster shadow-premium mb-4 mx-auto" style="max-width: 200px;">
                            <img src="@movie.FullPosterUrl" alt="@movie.Title" class="rounded-4" />
                        </div>
                        
                        <div class="hero-content text-white">
                            <div class="d-flex align-items-center justify-content-center gap-3 flex-wrap mb-2">
                                <h1 class="movie-title fw-black m-0">@movie.Title</h1>
                                <div class="hero-actions-inline">
                                    <OpenOnMenu Title="@movie.Title" 
                                               Year="@(movie.ReleaseDate?.Length >= 4 ? movie.ReleaseDate[..4] : "")" 
                                               ImdbId="@imdbId"
                                               ButtonClass="btn-dots-white" />
                                </div>
                            </div>
                            
                            @if (!string.IsNullOrEmpty(movie.OriginalTitle) && movie.OriginalTitle != movie.Title)
                            {
                                <h5 class="text-white-50 fw-semibold mb-3">@movie.OriginalTitle</h5>
                            }
                            
                            <div class="hero-meta-group d-flex flex-column align-items-center gap-2 mb-4">
                                <div class="movie-meta d-flex justify-content-center flex-wrap align-items-center gap-3">
                                    <span class="meta-item text-white-50"><i class="bi bi-calendar3"></i> @(movie.ReleaseDate?.Length >= 4 ? movie.ReleaseDate[..4] : "TBA")</span>
                                    <span class="meta-item text-white-50"><i class="bi bi-clock"></i> @FormatRuntime(movie.Runtime ?? 0)</span>
                                    <div class="rating-badge-glass">
                                        <i class="bi bi-star-fill text-warning"></i>
                                        <span>@movie.VoteAverage.ToString("0.0")</span>
                                        <small>TMDB</small>
                                    </div>
                                </div>
                                
                                <div class="genres-wrap d-flex justify-content-center flex-wrap gap-2">
                                    @foreach (var g in movie.GenreList)
                                    {
                                        <span class="genre-tag-small">@g.Name</span>
                                    }
                                </div>
                            </div>
                            
                            <div class="hero-footer-actions d-flex flex-column align-items-center gap-3">
                                <div class="d-flex flex-wrap justify-content-center gap-2">
                                    @if (!string.IsNullOrEmpty(movie.TrailerKey))
                                    {
                                        <a href="https://www.youtube.com/watch?v=@movie.TrailerKey" target="_blank" class="btn btn-primary rounded-pill px-3 py-1 fw-bold shadow-sm text-decoration-none d-inline-flex align-items-center" style="font-size: 0.85rem;">
                                            <i class="bi bi-play-fill me-1 fs-5"></i> Trailer
                                        </a>
                                    }
                                    <button class="btn btn-glass rounded-pill px-3 py-1 fw-bold" style="font-size: 0.85rem;" @onclick="OpenAsPopup">
                                        <i class="bi bi-layout-sidebar-reverse me-2"></i> Summary
                                    </button>
                                </div>

                                <div class="hero-library-box mt-1">
                                    <CompactLibraryActions Item="libItem" ImdbId="@imdbId" Movie="movie" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="container-fluid main-content pb-5">
            <div class="row justify-content-center">
                <div class="col-12">
                    @if (isEnhancingDetails)
                    {
                        <div class="details-section shadow-sm animate-in details-loading-section">
                            <div class="details-loading-inline">
                                <div class="spinner-ripple spinner-ripple-sm"></div>
                                <div>
                                    <h4 class="m-0">Loading full details</h4>
                                    <p class="text-secondary m-0">Cast, gallery, certifications, and extra metadata are on the way.</p>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="split-layout">
                        @* Column 1: Overview & Gallery *@
                        <div class="split-column">
                            <section class="details-section shadow-sm animate-in">
                                <h3 class="section-heading mb-3"><i class="bi bi-text-left me-2 text-primary"></i> Overview</h3>
                                <p class="overview-p">@movie.Overview</p>
                            </section>



                            @if (movie.BackdropPaths.Count > 1)
                            {
                                <section class="details-section shadow-sm animate-in" style="animation-delay: 0.3s;">
                                    <h3 class="section-heading mb-4"><i class="bi bi-images me-2 text-primary"></i> Gallery</h3>
                                    <div class="row g-3">
                                        @foreach (var path in movie.BackdropPaths.Skip(1).Take(12))
                                        {
                                            <div class="col-6 col-md-4">
                                                <div class="gallery-thumb rounded-4 clickable" @onclick="() => OpenLightbox(path)">
                                                    <img src="https://image.tmdb.org/t/p/w500@(path)" class="img-fluid" alt="Backdrop" />
                                                    <div class="thumb-overlay"><i class="bi bi-zoom-in"></i></div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </section>
                            }
                        </div>

                        @* Column 2: Cast & Details *@
                        <div class="split-column">
                            <section class="details-section shadow-sm animate-in" style="animation-delay: 0.1s;">
                                <h3 class="section-heading mb-4"><i class="bi bi-people me-2 text-primary"></i> Cast & Crew</h3>
                                <div class="credits-wrap">
                                    @if (movie.Credits?.Crew?.Any(c => c.Job == "Director") == true)
                                    {
                                        <div class="crew-group mb-4">
                                            <label class="group-label">Directors</label>
                                            <div class="person-grid-small">
                                                @foreach (var dir in movie.Credits.Crew.Where(c => c.Job == "Director"))
                                                {
                                                    <div class="person-compact-card clickable" @onclick="() => WatchlistSvc.OpenPersonProfileAsync(dir.Id)">
                                                        @if (!string.IsNullOrEmpty(dir.ProfilePath))
                                                        {
                                                            <img src="@dir.FullProfileUrl" alt="@dir.Name" />
                                                        }
                                                        else
                                                        {
                                                            <div class="person-placeholder-icon"><i class="bi bi-person-fill"></i></div>
                                                        }
                                                        <span>@dir.Name</span>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }

                                    @if (movie.Credits?.Cast?.Any() == true)
                                    {
                                        <div class="crew-group">
                                            <label class="group-label">Lead Actors</label>
                                            <div class="person-grid-small">
                                                @foreach (var actor in movie.Credits.Cast.Take(12))
                                                {
                                                    <div class="person-compact-card clickable" @onclick="() => WatchlistSvc.OpenPersonProfileAsync(actor.Id)">
                                                        @if (!string.IsNullOrEmpty(actor.ProfilePath))
                                                        {
                                                            <img src="@actor.FullProfileUrl" alt="@actor.Name" />
                                                        }
                                                        else
                                                        {
                                                            <div class="person-placeholder-icon"><i class="bi bi-person-fill"></i></div>
                                                        }
                                                        <span>@actor.Name</span>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </section>

                            <section class="details-section compact-details-section shadow-sm animate-in" style="animation-delay: 0.25s;">
                                <h3 class="section-heading compact-heading mb-3"><i class="bi bi-info-circle me-2 text-primary"></i> Details</h3>
                                <div class="details-grid">
                                    <div class="detail-card compact-detail-card">
                                        <span class="section-label compact-label">Language</span>
                                        <strong>@GetLanguageLabel(movie.OriginalLanguage)</strong>
                                    </div>
                                    <div class="detail-card compact-detail-card">
                                        <span class="section-label compact-label">Status</span>
                                        <strong>@GetDisplayValue(movie.Status)</strong>
                                    </div>
                                    <div class="detail-card compact-detail-card">
                                        <span class="section-label compact-label">Vote Count</span>
                                        <strong>@GetCountLabel(movie.VoteCount)</strong>
                                    </div>
                                    <div class="detail-card compact-detail-card">
                                        <span class="section-label compact-label">Popularity</span>
                                        <strong>@GetPopularityLabel(movie.Popularity)</strong>
                                    </div>
                                    @if (movie.Revenue.GetValueOrDefault() > 0)
                                    {
                                        <div class="detail-card compact-detail-card">
                                            <span class="section-label compact-label">Revenue</span>
                                            <strong>@FormatCurrency(movie.Revenue)</strong>
                                        </div>
                                    }
                                    @if (movie.Budget.GetValueOrDefault() > 0)
                                    {
                                        <div class="detail-card compact-detail-card">
                                            <span class="section-label compact-label">Budget</span>
                                            <strong>@FormatCurrency(movie.Budget)</strong>
                                        </div>
                                    }
                                </div>

                                @if (movie.Certifications.Any())
                                {
                                    <div class="detail-block compact-detail-block">
                                        <span class="section-label compact-label d-block mb-2">Certification</span>
                                        <div class="tag-wrap">
                                            @foreach (var certification in movie.Certifications.Take(16))
                                            {
                                                <span class="detail-tag compact-detail-tag">
                                                    <span class="detail-tag-region">@certification.Region</span>
                                                    <span>@certification.Rating</span>
                                                </span>
                                            }
                                        </div>
                                    </div>
                                }

                                @if (movie.Keywords.Any())
                                {
                                    <div class="detail-block compact-detail-block">
                                        <span class="section-label compact-label d-block mb-2">Keywords</span>
                                        <div class="tag-wrap">
                                            @foreach (var keyword in movie.Keywords.Take(18))
                                            {
                                                <span class="detail-tag compact-detail-tag">@keyword.Name</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </section>
                        </div>
                    </div>

                    @* Full Width Episodes Section *@
                    @if (movie.MediaType == "tv" && movie.Seasons != null && movie.Seasons.Any())
                    {
                        <section class="details-section shadow-sm animate-in episodes-section-wide" style="animation-delay: 0.1s; margin-top: 20px;">
                            <div class="d-flex flex-column gap-4">
                                <div class="episodes-header-block d-flex justify-content-between align-items-center flex-wrap gap-3">
                                    <h3 class="section-heading m-0"><i class="bi bi-collection-play me-2 text-primary"></i> Episodes</h3>
                                    <div class="season-tabs-wrap">
                                        <div class="season-tabs">
                                            @foreach (var season in movie.Seasons.OrderBy(s => s.SeasonNumber))
                                            {
                                                <button class="season-tab-btn @(selectedSeasonNumber == season.SeasonNumber ? "active" : "")" 
                                                        @onclick="() => SetSeason(season.SeasonNumber)">
                                                    @(string.IsNullOrEmpty(season.Name) || season.Name.StartsWith("Season ") ? $"S{season.SeasonNumber}" : season.Name)
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </div>

                                @if (isLoadingEpisodes)
                                {
                                    <div class="episodes-loading text-center py-5">
                                        <div class="spinner-ripple spinner-ripple-sm mx-auto mb-3"></div>
                                        <p class="text-secondary small fw-bold">Syncing episode data...</p>
                                    </div>
                                }
                                else if (episodes != null && episodes.Any())
                                {
                                    <div class="row row-cols-1 row-cols-md-2 g-3">
                                        @foreach (var ep in episodes)
                                        {
                                            <div class="col">
                                                <div class="episode-card h-100 p-3 rounded-4 bg-light-soft border-0 shadow-sm-hover transition-all">
                                                    <div class="d-flex gap-3 h-100">
                                                        <div class="episode-thumb-wrap flex-shrink-0">
                                                            <div class="episode-thumb rounded-3 overflow-hidden shadow-sm">
                                                                @if (!string.IsNullOrEmpty(ep.StillPath))
                                                                {
                                                                    <img src="@ep.FullStillUrl" alt="@ep.Name" class="w-100 h-100 object-fit-cover" />
                                                                }
                                                                else
                                                                {
                                                                    <div class="ep-placeholder d-flex align-items-center justify-content-center">
                                                                        <i class="bi bi-play-circle text-white-50 fs-2"></i>
                                                                    </div>
                                                                }
                                                                <div class="ep-number-tag">E@(ep.EpisodeNumber)</div>
                                                            </div>
                                                        </div>
                                                        <div class="episode-content flex-grow-1 d-flex flex-column min-width-0">
                                                            <div class="d-flex justify-content-between align-items-start gap-2 mb-1">
                                                                <h5 class="episode-title m-0">@ep.Name</h5>
                                                                @if (ep.VoteAverage > 0)
                                                                {
                                                                    <div class="ep-rating-badge flex-shrink-0">
                                                                        <i class="bi bi-star-fill text-warning me-1"></i>@ep.VoteAverage.ToString("0.0")
                                                                    </div>
                                                                }
                                                            </div>
                                                            <p class="episode-desc flex-grow-1 mb-2">@ep.Overview</p>
                                                            <div class="episode-footer-meta d-flex gap-3 mt-auto">
                                                                @if (!string.IsNullOrEmpty(ep.AirDate))
                                                                {
                                                                    <span class="ep-meta-item"><i class="bi bi-calendar2-event me-1"></i> @ep.AirDate</span>
                                                                }
                                                                @if (ep.Runtime.HasValue)
                                                                {
                                                                    <span class="ep-meta-item"><i class="bi bi-clock me-1"></i> @ep.Runtime min</span>
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </section>
                    }

                    @* Full Width Wikipedia Section *@
                    @if (wikiSnippet != null)
                    {
                        <section class="details-section shadow-sm animate-in" style="animation-delay: 0.3s; margin-top: 20px;">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h3 class="section-heading m-0"><i class="bi bi-wikipedia me-2 text-primary"></i> Wikipedia</h3>
                                <a href="@wikiSnippet.ContentUrls?.Desktop?.Page" target="_blank" class="btn btn-sm btn-outline-secondary rounded-pill">Open Source</a>
                            </div>
                            <div class="wiki-content">
                                <div class="wiki-text wiki-html-content">
                                    @((MarkupString)GetProcessedWikiExtract())
                                </div>
                            </div>
                        </section>
                    }

                    @* Full Width Collection Section *@
                    @if (movie.Collection != null)
                    {
                        <div class="details-section shadow-sm collection-promo-wide clickable animate-in"
                             style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.8)), url('https://image.tmdb.org/t/p/original@(movie.Collection.BackdropPath)')"
                             @onclick='() => NavManager.NavigateTo($"franchise/{movie.Collection.Id}")'>
                            <div class="d-flex justify-content-between align-items-end h-100" style="min-height: 140px;">
                                <div>
                                    <span class="promo-badge">Part of Collection</span>
                                    <h2 class="m-0 text-white fw-black">@movie.Collection.Name</h2>
                                </div>
                                <div class="text-white-50 fw-bold pb-1">View Franchise <i class="bi bi-arrow-right ms-2"></i></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<!-- Lightbox & Player Overlay -->
@if (selectedLightboxPath != null)
{
    <div class="lightbox-portal" @onclick="() => selectedLightboxPath = null">
        <div class="lightbox-stage animate-pop-in">
            <img src="https://image.tmdb.org/t/p/original@(selectedLightboxPath)" class="img-fluid shadow-premium rounded-4" />
            <button class="btn-close-portal" @onclick="() => selectedLightboxPath = null"><i class="bi bi-x-lg"></i></button>
        </div>
    </div>
}

<TrailerPlayer VideoKey="@movie?.TrailerKey" IsOpen="isTrailerOpen" OnClose="() => isTrailerOpen = false" />

<style>
    :root {
        --movie-accent: #6366f1;
        --movie-bg: #f8fafc;
        --movie-card: #ffffff;
        --movie-text: #0f172a;
        --movie-muted: #64748b;
    }

    .movie-details-page {
        min-height: 100vh;
        background: var(--movie-bg);
        padding-bottom: 200px;
    }

    /* Hero Section - Refactored for centered layout */
    .hero-section {
        position: relative;
        min-height: 550px;
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        margin-right: calc(-50vw + 50%);
        background: #0b0f19;
        margin-bottom: -60px;
        display: flex;
        align-items: center;
        overflow: hidden;
    }

    .hero-bg-wrapper {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 1;
    }
    .hero-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center 20%;
        filter: brightness(0.4) blur(3px);
        transform: scale(1.05);
    }
    .hero-overlay {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at center, rgba(11, 15, 25, 0.4) 0%, rgba(11, 15, 25, 0.85) 70%, #0b0f19 100%);
    }

    .hero-container {
        position: relative;
        z-index: 50;
        padding: 76px 0;
        max-width: 1200px;
    }
    .hero-poster {
        width: 180px;
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .hero-poster:hover { transform: scale(1.05); }
    .hero-poster img { 
        width: 100%; 
        box-shadow: 0 20px 50px rgba(0,0,0,0.6);
        border: 1px solid rgba(255,255,255,0.1);
    }
    
    .movie-title { font-size: clamp(2.2rem, 6vw, 3.8rem); letter-spacing: -2px; line-height: 1; }
    
    .genre-tag-small {
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.2);
        padding: 3px 12px;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.3px;
        color: rgba(255,255,255,0.9);
    }

    .rating-badge-glass {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(255,255,255,0.12);
        padding: 4px 12px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,0.2);
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }
    .rating-badge-glass span { font-weight: 800; font-size: 1rem; color: #fff; }
    .rating-badge-glass small { font-size: 0.6rem; text-transform: uppercase; font-weight: 800; opacity: 0.6; margin-left: -2px; }
    
    /* OpenOnMenu Custom Trigger Styling for Hero */
    .hero-actions-inline .open-on-trigger.btn-dots-white {
        color: rgba(255,255,255,0.7) !important;
        background: rgba(255,255,255,0.1) !important;
        width: 32px !important;
        height: 32px !important;
        font-size: 1.2rem !important;
        border: 1px solid rgba(255,255,255,0.2) !important;
        transition: all 0.2s ease;
    }
    .hero-actions-inline .open-on-trigger.btn-dots-white:hover {
        background: rgba(255,255,255,0.25) !important;
        color: #fff !important;
        transform: scale(1.1);
    }

    .meta-item { font-weight: 700; color: rgba(255,255,255,0.8); font-size: 0.95rem; display: flex; align-items: center; gap: 8px; }
    
    .rating-badge {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(0,0,0,0.4);
        backdrop-filter: blur(8px);
        padding: 4px 14px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,0.1);
    }
    .rating-badge span { font-weight: 800; font-size: 1.1rem; }
    
    .genre-tag {
        background: rgba(255,255,255,0.1);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.2);
        padding: 5px 15px;
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    .btn-glass {
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.2);
        color: #fff;
    }
    .btn-glass:hover {
        background: rgba(255,255,255,0.2);
        color: #fff;
    }

    /* Main Content */
    .main-content {
        position: relative;
        z-index: 20;
        max-width: 1200px;
        width: 100%;
        margin: 0 auto;
    }
    .split-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 18px;
        align-items: start;
    }
    .split-column {
        display: flex;
        flex-direction: column;
        gap: 0;
        min-width: 0;
    }
    .split-span-2 {
        grid-column: 1 / -1;
    }
    .details-section {
        background: #ffffff;
        border-radius: 18px;
        padding: 18px 20px;
        margin-bottom: 18px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 12px rgba(15, 23, 42, 0.03);
    }
    .section-heading {
        font-weight: 900;
        font-size: 1.08rem;
        letter-spacing: -0.5px;
        color: #1e293b;
    }
    .section-label {
        font-weight: 800;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--movie-muted);
    }
    .overview-p { font-size: 0.98rem; line-height: 1.6; color: #475569; margin-bottom: 0; }
    .details-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 8px;
    }
    .detail-card {
        display: flex;
        flex-direction: column;
        gap: 6px;
        padding: 10px 12px;
        border-radius: 12px;
        background: rgba(255,255,255,0.35);
        border: 1px solid #e2e8f0;
    }
    .detail-card strong {
        font-size: 0.9rem;
        color: #1e293b;
        line-height: 1.25;
    }
    .detail-block {
        margin-top: 12px;
    }
    .compact-details-section {
        padding: 16px 18px;
    }
    .compact-heading {
        font-size: 1rem;
    }
    .compact-detail-card {
        flex-direction: row;
        align-items: baseline;
        justify-content: space-between;
        gap: 10px;
        padding: 8px 10px;
        border-radius: 12px;
    }
    .compact-detail-card strong {
