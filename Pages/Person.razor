@page "/person/{Id:int}"
@using MyPrivateWatchlist.Models
@using MyPrivateWatchlist.Components
@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc
@inject NavigationManager NavManager
@inject HttpClient Http
@inject IConfiguration Config
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>@(person?.Name ?? "Person Profile")</PageTitle>

<div class="page-shell">
    <!-- Navbar with Back Button -->
    <div class="toolbar-primary sticky-top bg-white border-bottom px-3 py-2">
        <button class="btn btn-link text-dark p-0 me-3 d-flex align-items-center text-decoration-none" @onclick="GoBack">
            <i class="bi bi-arrow-left fs-4"></i>
            <span class="ms-2 fw-bold">Back</span>
        </button>
        <div class="tb-divider"></div>
        <span class="text-secondary small fw-bold text-uppercase tracking-wider">Person Profile</span>
    </div>

    @if (isLoading)
    {
        <div class="d-flex align-items-center justify-content-center p-5" style="min-height: 70vh;">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (person != null)
    {
        <div class="page-content scroll-y p-0">
            <!-- Header Section -->
            <div class="position-relative">
                <div class="person-header-bg" style="background-image: url(@credits?.Cast?.FirstOrDefault(c => !string.IsNullOrEmpty(c.BackdropPath))?.FullBackdropUrl);"></div>
                <div class="table-wrap px-3 py-5 person-header-content position-relative">
                    <div class="row g-4 align-items-end">
                        <div class="col-auto">
                            <div class="person-poster shadow-lg">
                                <img src="@person.FullProfileUrl" class="img-fluid" alt="@person.Name" />
                            </div>
                        </div>
                        <div class="col">
                            <h1 class="person-name">@person.Name</h1>
                            <div class="person-meta d-flex flex-wrap gap-3">
                                @if (!string.IsNullOrEmpty(person.Birthday))
                                {
                                    <div class="meta-item">
                                        <i class="bi bi-calendar3 me-2"></i>
                                        Born: @person.Birthday
                                        @if (!string.IsNullOrEmpty(person.PlaceOfBirth))
                                        {
                                            <span> in @person.PlaceOfBirth</span>
                                        }
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(person.KnownForDepartment))
                                {
                                    <div class="meta-item">
                                        <i class="bi bi-briefcase me-2"></i>
                                        @KnownForCategoryLabel
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-wrap px-3 py-4">
                <div class="row g-4">
                    <div class="col-12">
                        <!-- Quick Stats / Personal Info -->
                        <div class="d-flex flex-wrap gap-4 mb-5 p-4 rounded-4 bg-light bg-opacity-50 border shadow-sm">
                            <div class="stat-item">
                                <div class="stat-label">Known For</div>
                                <div class="stat-value">@KnownForCategoryLabel</div>
                            </div>
                            <div class="tb-divider d-none d-md-block"></div>
                            <div class="stat-item">
                                <div class="stat-label">Gender</div>
                                <div class="stat-value">@(person.Gender == 1 ? "Female" : (person.Gender == 2 ? "Male" : "Not specified"))</div>
                            </div>
                            @if (!string.IsNullOrEmpty(person.Deathday))
                            {
                                <div class="tb-divider d-none d-md-block"></div>
                                <div class="stat-item">
                                    <div class="stat-label">Died</div>
                                    <div class="stat-value">@person.Deathday</div>
                                </div>
                            }
                            @if (person.AlsoKnownAs?.Any() == true)
                            {
                                <div class="tb-divider d-none d-md-block"></div>
                                <div class="stat-item flex-grow-1">
                                    <div class="stat-label">Also Known As</div>
                                    <div class="stat-value text-secondary small">@string.Join(", ", person.AlsoKnownAs.Take(3))</div>
                                </div>
                            }
                        </div>

                        @if (KnownForCredits.Any())
                        {
                            <section class="mb-5">
                                <h2 class="section-title mb-4">
                                    Known For
                                    <span class="badge rounded-pill bg-light border text-dark ms-2">@KnownForCategoryLabel</span>
                                </h2>
                                <div class="row row-cols-3 row-cols-sm-4 row-cols-md-5 row-cols-lg-5 g-2">
                                    @foreach (var credit in KnownForCredits)
                                    {
                                        <div class="col">
                                            <div class="movie-card" @onclick="() => OpenMovie(credit)">
                                                <div class="movie-poster-wrap shadow-sm">
                                                    <img src="@credit.FullPosterUrl" class="movie-poster" alt="@(credit.Title ?? credit.Name)" />
                                                    <div class="movie-overlay">
                                                        <i class="bi bi-plus-lg fs-4"></i>
                                                    </div>
                                                </div>
                                                <div class="movie-info p-1">
                                                    <div class="movie-title" title="@(credit.Title ?? credit.Name)" style="@GetTitleStyle(credit.Title ?? credit.Name)">@(credit.Title ?? credit.Name)</div>
                                                    <div class="movie-meta d-flex justify-content-between" style="font-size: 0.65rem;">
                                                        <span>@(credit.Year > 0 ? credit.Year.ToString() : "N/A")</span>
                                                        @if (credit.VoteAverage > 0)
                                                        {
                                                            <span class="text-warning fw-bold"><i class="bi bi-star-fill smaller me-1"></i>@(credit.VoteAverage.ToString("F1"))</span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </section>
                        }

                        <section class="mb-5 border-top pt-4">
                            <h2 class="section-title">Biography</h2>
                            <div class="biography-text @(showFullBio ? "" : "bio-collapsed")">
                                @if (string.IsNullOrEmpty(person.Biography))
                                {
                                    <p class="text-secondary fs-5 opacity-75">No biography available for this person.</p>
                                }
                                else
                                {
                                    @((MarkupString)person.Biography.Replace("\n", "<br/>"))
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(person.Biography) && person.Biography.Length > 400)
                            {
                                <button class="btn btn-sm btn-outline-secondary rounded-pill mt-3 fw-bold px-3 py-1" @onclick="() => showFullBio = !showFullBio">
                                    @(showFullBio ? "Read Less" : "Read More")
                                </button>
                            }
                        </section>

                        @if (credits?.Cast?.Any() == true || credits?.Crew?.Any() == true)
                        {
                            <section>
                                <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-4 gap-3">
                                    <div class="d-flex flex-column gap-2">
                                        <h2 class="section-title mb-0">Full Filmography</h2>

                                        <div class="toolbar-primary bg-light border p-1 rounded-pill d-inline-flex flex-wrap">
                                            <button class="tb-btn @(filmographyRole == FilmographyRoleAll ? "active" : "")"
                                                    @onclick='() => SetFilmographyRole(FilmographyRoleAll)'
                                                    aria-pressed="@(filmographyRole == FilmographyRoleAll)">
                                                <i class="bi bi-grid-3x3-gap"></i>
                                                <span class="tb-label">All</span>
                                            </button>
                                            <button class="tb-btn @(filmographyRole == FilmographyRoleActing ? "active" : "")"
                                                    @onclick='() => SetFilmographyRole(FilmographyRoleActing)'
                                                    disabled="@(!HasFilmographyCreditsFor(FilmographyRoleActing))"
                                                    aria-pressed="@(filmographyRole == FilmographyRoleActing)">
                                                <i class="bi bi-people"></i>
                                                <span class="tb-label">Acting</span>
                                            </button>
                                            <button class="tb-btn @(filmographyRole == FilmographyRoleDirecting ? "active" : "")"
                                                    @onclick='() => SetFilmographyRole(FilmographyRoleDirecting)'
                                                    disabled="@(!HasFilmographyCreditsFor(FilmographyRoleDirecting))"
                                                    aria-pressed="@(filmographyRole == FilmographyRoleDirecting)">
                                                <i class="bi bi-camera-reels"></i>
                                                <span class="tb-label">Directing</span>
                                            </button>
                                            <button class="tb-btn @(filmographyRole == FilmographyRoleWriting ? "active" : "")"
                                                    @onclick='() => SetFilmographyRole(FilmographyRoleWriting)'
                                                    disabled="@(!HasFilmographyCreditsFor(FilmographyRoleWriting))"
                                                    aria-pressed="@(filmographyRole == FilmographyRoleWriting)">
                                                <i class="bi bi-pencil-square"></i>
                                                <span class="tb-label">Writing</span>
                                            </button>
                                            <button class="tb-btn @(filmographyRole == FilmographyRoleCinematography ? "active" : "")"
                                                    @onclick='() => SetFilmographyRole(FilmographyRoleCinematography)'
                                                    disabled="@(!HasFilmographyCreditsFor(FilmographyRoleCinematography))"
                                                    aria-pressed="@(filmographyRole == FilmographyRoleCinematography)">
                                                <i class="bi bi-camera"></i>
                                                <span class="tb-label">Cinematography</span>
                                            </button>
                                            <button class="tb-btn @(filmographyRole == FilmographyRoleCrew ? "active" : "")"
                                                    @onclick='() => SetFilmographyRole(FilmographyRoleCrew)'
                                                    disabled="@(!HasFilmographyCreditsFor(FilmographyRoleCrew))"
                                                    aria-pressed="@(filmographyRole == FilmographyRoleCrew)">
                                                <i class="bi bi-gear"></i>
                                                <span class="tb-label">Crew</span>
                                            </button>
                                        </div>
                                    </div>

                                    <div class="toolbar-primary bg-light border p-1 rounded-pill d-inline-flex">
                                        <button class="tb-btn @(sortColumn == "Rating" ? "active" : "")" @onclick='() => SetSort("Rating")'>
                                            <i class="bi @(sortColumn == "Rating" ? (sortDescending ? "bi-star-fill" : "bi-star") : "bi-star")"></i>
                                            <span class="tb-label">Rating</span>
                                        </button>
                                        <button class="tb-btn @(sortColumn == "Popularity" ? "active" : "")" @onclick='() => SetSort("Popularity")'>
                                            <i class="bi bi-graph-up"></i>
                                            <span class="tb-label">Popularity</span>
                                        </button>
                                        <button class="tb-btn @(sortColumn == "Year" ? "active" : "")" @onclick='() => SetSort("Year")'>
                                            <i class="bi @(sortColumn == "Year" ? (sortDescending ? "bi-sort-numeric-down-alt" : "bi-sort-numeric-up") : "bi-calendar-event")"></i>
                                            <span class="tb-label">Year</span>
                                        </button>
                                    </div>
                                </div>
                                
                                @{
                                    var filmographyCredits = SortedCredits.ToList();
                                }

                                @if (filmographyCredits.Count == 0)
                                {
                                    <div class="text-secondary fs-6 opacity-75">
                                        No credits found for <span class="fw-bold">@filmographyRole</span>.
                                    </div>
                                }
                                else
                                {
                                    <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 row-cols-xl-6 g-3 g-md-4">
                                    @foreach (var credit in filmographyCredits)
                                    {
                                        <div class="col">
                                            <div class="movie-card" @onclick="() => OpenMovie(credit)">
                                                <div class="movie-poster-wrap shadow-sm">
                                                    <img src="@credit.FullPosterUrl" class="movie-poster" alt="@(credit.Title ?? credit.Name)" />
                                                    <div class="movie-overlay">
                                                        <i class="bi bi-plus-lg fs-4"></i>
                                                    </div>
                                                </div>
                                                <div class="movie-info p-2">
                                                    <div class="movie-title" title="@(credit.Title ?? credit.Name)" style="@GetTitleStyle(credit.Title ?? credit.Name)">@(credit.Title ?? credit.Name)</div>
                                                    <div class="movie-meta d-flex justify-content-between">
                                                        <span>@(credit.Year > 0 ? credit.Year.ToString() : "N/A")</span>
                                                        @if (credit.VoteAverage > 0)
                                                        {
                                                            <span class="text-warning fw-bold"><i class="bi bi-star-fill smaller me-1"></i>@(credit.VoteAverage.ToString("F1"))</span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                    </div>
                                }
                            </section>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .person-header-bg {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 100%;
        background-size: cover;
        background-position: center 20%;
        filter: blur(40px) brightness(0.4);
        opacity: 0.6;
        z-index: 0;
        transition: background-image 0.2s ease;
    }

    .person-header-content {
        z-index: 1;
        color: #fff;
    }

    .person-poster {
        width: 180px;
        border-radius: 20px;
        overflow: hidden;
        border: 4px solid #fff;
        background: #f0f0f0;
    }

    .person-name {
        font-size: 3.5rem;
        font-weight: 900;
        margin-bottom: 12px;
        line-height: 1.1;
        text-shadow: 0 4px 12px rgba(0,0,0,0.3);
    }

    .meta-item {
        font-size: 1.1rem;
        font-weight: 500;
        opacity: 0.9;
    }

    .section-title {
        font-size: 1.8rem;
        font-weight: 800;
        color: #1a1a2e;
        margin-bottom: 24px;
        position: relative;
    }

    .biography-text {
        font-size: 1.15rem;
        line-height: 1.8;
        color: #444;
        max-width: 900px;
        transition: max-height 0.3s ease;
    }
    
    .bio-collapsed {
        display: -webkit-box;
        -webkit-line-clamp: 5;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .movie-card {
        cursor: pointer;
        transition: all 0.1s cubic-bezier(0.16, 1, 0.3, 1);
        border-radius: 12px;
        overflow: hidden;
    }
    
    .movie-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(26, 26, 46, 0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        opacity: 0;
        transition: opacity 0.1s ease;
    }

    .movie-card:hover {
        transform: translateY(-8px);
    }

    .movie-poster-wrap {
        position: relative;
        aspect-ratio: 2/3;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    }

    .movie-poster {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.2s ease;
    }

    .movie-card:hover .movie-poster {
        transform: scale(1.05);
    }

    .movie-card:hover .movie-overlay {
        opacity: 1;
    }

    .movie-title {
        font-weight: 700;
        color: #1a1a2e;
        margin-top: 6px;
        white-space: normal;
        line-height: 1.25;
        margin-bottom: 4px;
        word-break: break-word; /* ensure extremely long continuous words also wrap */
    }

    .movie-meta {
        font-size: 0.75rem;
        color: #666;
        font-weight: 600;
    }

    .stat-item {
        display: flex;
        flex-direction: column;
    }

    .stat-label {
        font-size: 0.72rem;
        font-weight: 800;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 2px;
    }

    .stat-value {
        font-size: 1rem;
        font-weight: 700;
        color: #1a1a2e;
    }

    .toolbar-primary .tb-btn.active {
        background: #1a1a2e;
        color: #fff;
    }

    .toolbar-primary .tb-btn {
        border-radius: 999px;
        border: none;
        padding: 5px 15px;
        transition: all 0.2s;
        font-size: 0.8rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .toolbar-primary .tb-btn:hover:not(.active) {
        background: rgba(0,0,0,0.05);
    }

    @@media (max-width: 768px) {
        .person-name { font-size: 2.5rem; }
        .person-poster { width: 140px; }
        .biography-text { font-size: 1rem; }
    }
</style>

@code {
    [Parameter] public int Id { get; set; }

    private TmdbPerson? person;
    private TmdbPersonCombinedCredits? credits;
    private bool isLoading = true;
    private bool showFullBio = false;

    private const string FilmographyRoleAll = "All";
    private const string FilmographyRoleActing = "Acting";
    private const string FilmographyRoleDirecting = "Directing";
    private const string FilmographyRoleWriting = "Writing";
    private const string FilmographyRoleCinematography = "Cinematography";
    private const string FilmographyRoleCrew = "Crew";

    private static readonly HashSet<string> DirectingJobs = new(StringComparer.OrdinalIgnoreCase)
    {
        "Director",
        "Co-Director",
        "Series Director",
        "Second Unit Director",
        "Assistant Director",
        "First Assistant Director",
        "Second Assistant Director",
        "Third Assistant Director"
    };

    private static readonly HashSet<string> WritingJobs = new(StringComparer.OrdinalIgnoreCase)
    {
        "Writer",
        "Screenplay",
        "Story",
        "Teleplay",
        "Novel",
        "Comic Book",
        "Original Story"
    };

    private static readonly HashSet<string> CinematographyJobs = new(StringComparer.OrdinalIgnoreCase)
    {
        "Director of Photography",
        "Cinematography",
        "Cinematographer"
    };

    private string filmographyRole = FilmographyRoleAll;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        showFullBio = false;
        filmographyRole = FilmographyRoleAll;
        person = null;
        credits = null;
        StateHasChanged();

        try
        {
            var apiKey = Config["TmdbApiKey"];
            person = await Http.GetFromJsonAsync<TmdbPerson>($"https://api.themoviedb.org/3/person/{Id}?api_key={apiKey}");
            credits = await Http.GetFromJsonAsync<TmdbPersonCombinedCredits>($"https://api.themoviedb.org/3/person/{Id}/combined_credits?api_key={apiKey}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching person: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private string sortColumn = "Year";
    private bool sortDescending = true;

    private void SetSort(string col)
    {
        if (sortColumn == col) sortDescending = !sortDescending;
        else { sortColumn = col; sortDescending = true; }
        StateHasChanged();
    }

    private void SetFilmographyRole(string role)
    {
        filmographyRole = role;
        StateHasChanged();
    }

    private static IEnumerable<TmdbPersonCreditItem> NormalizeCredits(IEnumerable<TmdbPersonCreditItem> credits)
    {
        return credits
            .Where(c => !string.IsNullOrEmpty(c.PosterPath))
            .Where(c => !c.GenreIds.Contains(10767)); // exclude Talk/late-night shows
    }

    private static bool IsDirectingCredit(TmdbPersonCreditItem credit)
    {
        if (string.IsNullOrWhiteSpace(credit.Job)) return false;
        return DirectingJobs.Contains(credit.Job.Trim());
    }

    private static bool IsWritingCredit(TmdbPersonCreditItem credit)
    {
        if (string.IsNullOrWhiteSpace(credit.Job)) return false;
        var job = credit.Job.Trim();
        return WritingJobs.Contains(job) || job.Contains("writer", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsCinematographyCredit(TmdbPersonCreditItem credit)
    {
        if (string.IsNullOrWhiteSpace(credit.Job)) return false;
        var job = credit.Job.Trim();
        return CinematographyJobs.Contains(job)
               || job.Contains("cinematograph", StringComparison.OrdinalIgnoreCase)
               || job.Contains("photography", StringComparison.OrdinalIgnoreCase);
    }

    private string? MapKnownForDepartmentToRole(string? knownForDepartment)
    {
        if (string.IsNullOrWhiteSpace(knownForDepartment)) return null;

        return knownForDepartment.Trim() switch
        {
            "Acting" => FilmographyRoleActing,
            "Directing" => FilmographyRoleDirecting,
            "Writing" => FilmographyRoleWriting,
            "Camera" => FilmographyRoleCinematography,
            "Cinematography" => FilmographyRoleCinematography,
            _ => null
        };
    }

    private IEnumerable<TmdbPersonCreditItem> CreditsForRole(string role)
    {
        if (credits == null) return Enumerable.Empty<TmdbPersonCreditItem>();

        IEnumerable<TmdbPersonCreditItem> filtered = role switch
        {
            FilmographyRoleActing => NormalizeCredits(credits.Cast),
            FilmographyRoleCrew => NormalizeCredits(credits.Crew),
            FilmographyRoleDirecting => NormalizeCredits(credits.Crew).Where(IsDirectingCredit),
            FilmographyRoleWriting => NormalizeCredits(credits.Crew).Where(IsWritingCredit),
            FilmographyRoleCinematography => NormalizeCredits(credits.Crew).Where(IsCinematographyCredit),
            _ => NormalizeCredits(credits.Cast.Concat(credits.Crew))
        };

        return filtered.DistinctBy(c => $"{c.MediaType}-{c.Id}");
    }

    private string PrimaryKnownForRole
    {
        get
        {
            if (person == null || credits == null) return FilmographyRoleAll;

            // Prefer TMDB's declared known_for_department if it maps cleanly and has results.
            var mapped = MapKnownForDepartmentToRole(person.KnownForDepartment);
            if (!string.IsNullOrEmpty(mapped) && CreditsForRole(mapped).Any()) return mapped;

            // Otherwise pick the biggest category based on available credits.
            var candidates = new[]
            {
                FilmographyRoleActing,
                FilmographyRoleDirecting,
                FilmographyRoleWriting,
                FilmographyRoleCinematography,
                FilmographyRoleCrew
            };

            var best = candidates
                .Select(r => new { Role = r, Count = CreditsForRole(r).Count() })
                .OrderByDescending(x => x.Count)
                .FirstOrDefault(x => x.Count > 0);

            return best?.Role ?? FilmographyRoleAll;
        }
    }

    private string KnownForCategoryLabel => PrimaryKnownForRole;

    private IEnumerable<TmdbPersonCreditItem> FilmographyCredits
    {
        get
        {
            if (credits == null) return Enumerable.Empty<TmdbPersonCreditItem>();

            IEnumerable<TmdbPersonCreditItem> filtered = filmographyRole switch
            {
                FilmographyRoleActing => NormalizeCredits(credits.Cast),
                FilmographyRoleCrew => NormalizeCredits(credits.Crew),
                FilmographyRoleDirecting => NormalizeCredits(credits.Crew).Where(IsDirectingCredit),
                FilmographyRoleWriting => NormalizeCredits(credits.Crew).Where(IsWritingCredit),
                FilmographyRoleCinematography => NormalizeCredits(credits.Crew).Where(IsCinematographyCredit),
                _ => NormalizeCredits(credits.Cast.Concat(credits.Crew))
            };

            return filtered.DistinctBy(c => $"{c.MediaType}-{c.Id}");
        }
    }

    private bool HasFilmographyCreditsFor(string role)
    {
        if (credits == null) return false;

        // Evaluate against the normalized (poster/genre filtered) set for a predictable UX.
        return role switch
        {
            FilmographyRoleActing => NormalizeCredits(credits.Cast).Any(),
            FilmographyRoleCrew => NormalizeCredits(credits.Crew).Any(),
            FilmographyRoleDirecting => NormalizeCredits(credits.Crew).Any(IsDirectingCredit),
            FilmographyRoleWriting => NormalizeCredits(credits.Crew).Any(IsWritingCredit),
            FilmographyRoleCinematography => NormalizeCredits(credits.Crew).Any(IsCinematographyCredit),
            _ => NormalizeCredits(credits.Cast.Concat(credits.Crew)).Any()
        };
    }

    private IEnumerable<TmdbPersonCreditItem> SortedCredits
    {
        get
        {
            var all = FilmographyCredits;

            return sortColumn switch
            {
                "Year" => sortDescending 
                    ? all.OrderByDescending(c => c.Year).ThenByDescending(c => c.Popularity)
                    : all.OrderBy(c => c.Year).ThenByDescending(c => c.Popularity),
                "Popularity" => sortDescending
                    ? all.OrderByDescending(c => c.Popularity).ThenByDescending(c => c.VoteAverage)
                    : all.OrderBy(c => c.Popularity).ThenByDescending(c => c.VoteAverage),
                _ => sortDescending
                    ? all.OrderByDescending(c => c.VoteAverage * (c.VoteCount > 10 ? 1 : 0.5)).ThenByDescending(c => c.Popularity)
                    : all.OrderBy(c => c.VoteAverage * (c.VoteCount > 10 ? 1 : 0.5)).ThenByDescending(c => c.Popularity)
            };
        }
    }

    private IEnumerable<TmdbPersonCreditItem> KnownForCredits
    {
        get
        {
            if (credits == null) return Enumerable.Empty<TmdbPersonCreditItem>();
            
            var all = CreditsForRole(PrimaryKnownForRole);

            return all.OrderByDescending(c => c.Popularity * Math.Max(1, c.VoteCount)).Take(5);
        }
    }

    private void GoBack()
    {
        _ = JS.InvokeVoidAsync("uiHelpers.historyBack");
    }

    private string GetTitleStyle(string? title)
    {
        if (string.IsNullOrEmpty(title)) return "font-size: 1.0rem;";
        if (title.Length <= 15) return "font-size: 1.0rem;";
        double newSize = Math.Max(0.7, 0.45 - ((title.Length - 15) * 0.005));
        return $"font-size: {newSize.ToString(System.Globalization.CultureInfo.InvariantCulture)}rem;";
    }

    private async Task OpenMovie(TmdbPersonCreditItem credit)
    {
        var item = new TmdbSearchResultItem { 
            Id = credit.Id, 
            MediaType = credit.MediaType ?? "movie",
            Title = credit.Title ?? credit.Name,
            PosterPath = credit.PosterPath
        };
        await WatchlistSvc.ShowDetailsAsync(item);
    }

