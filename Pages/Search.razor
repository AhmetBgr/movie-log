@page "/search/{Query}"
@using MyPrivateWatchlist.Models
@using MyPrivateWatchlist.Components
@inject HttpClient Http
@inject IConfiguration Config
@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc
@implements IDisposable

<PageTitle>Search Results</PageTitle>

<div class="page-shell">

    <!-- ── Primary toolbar ──────────────────────────────────── -->
    <div class="toolbar-primary">
        <button class="tb-btn @(isEditing ? "active" : "")" @onclick="ToggleEdit">
            <i class="bi @(isEditing ? "bi-check-lg" : "bi-pencil")"></i>
            <span class="tb-label">@(isEditing ? "Done" : "Edit")</span>
        </button>

        <div class="tb-divider"></div>

        <button class="tb-btn tb-btn-sort @(_searchSortColumn == "Title" ? "sorted" : "")"
                @onclick='() => ToggleSearchSort("Title")'>
            <i class="bi @(_searchSortColumn == "Title"
                ? (_searchSortDescending ? "bi-sort-alpha-up-alt" : "bi-sort-alpha-down")
                : "bi-sort-alpha-down")"></i>
            <span class="tb-label">Title</span>
        </button>
        <button class="tb-btn tb-btn-sort @(_searchSortColumn == "Year" ? "sorted" : "")"
                @onclick='() => ToggleSearchSort("Year")'>
            <i class="bi @(_searchSortColumn == "Year"
                ? (_searchSortDescending ? "bi-sort-numeric-up-alt" : "bi-sort-numeric-down")
                : "bi-sort-numeric-down")"></i>
            <span class="tb-label">Year</span>
        </button>

        <div class="tb-spacer"></div>
        <span class="text-secondary d-none d-sm-inline search-title" style="font-size:0.76rem;white-space:nowrap;padding-right:4px;">
            "@Uri.UnescapeDataString(Query)"
        </span>
    </div>

    <!-- ── Action bar (edit mode only) ──────────────────────── -->
    @if (isEditing)
    {
        <div class="toolbar-actions @(_selectedKeys.Count > 0 ? "has-selection" : "")">
            @if (_selectedKeys.Count > 0)
            {
                <span class="sel-badge">@_selectedKeys.Count selected</span>
                <button class="tb-btn tb-btn-primary live" @onclick="BulkAddToWatchlist">
                    <i class="bi bi-plus-lg"></i>
                    <span class="tb-label">Add to Watchlist</span>
                </button>
                <button class="tb-btn tb-btn-success live" @onclick="BulkStartWatching">
                    <i class="bi bi-play-fill"></i>
                    <span class="tb-label">Start Watching</span>
                </button>
                <button class="tb-btn tb-btn-danger live" @onclick="BulkRemove">
                    <i class="bi bi-trash3-fill"></i>
                    <span class="tb-label">Remove</span>
                </button>
            }
            else
            {
                <span class="sel-hint"><i class="bi bi-check2-square me-1 opacity-50"></i>Select items to perform bulk actions</span>
            }
        </div>
    }

    <!-- ── Content ───────────────────────────────────────────── -->
    @if (isLoading)
    {
        <div class="page-content" style="overflow-y:auto;display:flex;align-items:center;justify-content:center;">
            <div class="spinner-border text-secondary" style="width:3rem;height:3rem;" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (results != null && !results.Any(r => r.MediaType == "movie" || r.MediaType == "tv"))
    {
        <div class="page-content" style="overflow-y:auto;display:flex;align-items:center;justify-content:center;">
            <div class="text-center py-5">
                <i class="bi bi-search fs-1 d-block mb-3 text-secondary opacity-25"></i>
                <p class="fs-5 text-secondary">No results found for "@Uri.UnescapeDataString(Query)".</p>
            </div>
        </div>
    }
    else if (results != null)
    {
        <div class="page-content scroll-y">
            <table class="table table-hover align-middle mb-0 sticky-thead">
                <thead class="text-secondary fw-semibold">
                    <tr>
                        @if (isEditing)
                        {
                            <th class="py-2 px-3" style="width:1%;white-space:nowrap;text-align:center;">
                                <input type="checkbox" class="form-check-input shadow-none" style="width:17px;height:17px;cursor:pointer;"
                                       checked="@IsAllSelected" @onchange="ToggleSelectAll" />
                            </th>
                        }
                        <th class="py-2 px-3" style="width:1%;white-space:nowrap;text-align:center;"><i class="bi bi-image opacity-40"></i></th>
                        <th class="py-2 px-3">Title</th>
                        <th class="py-2 px-3 d-none d-lg-table-cell" style="width:22%;">Director</th>
                        <th class="py-2 d-none d-md-table-cell" style="width:10%;">Year</th>
                        <th class="py-2 d-none d-md-table-cell" style="width:13%;">Type</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in SortedResults)
                    {
                        var itemKey = $"{item.MediaType}-{item.Id}";
                        var isSelected = _selectedKeys.Contains(itemKey);
                        <tr class="@(isSelected ? "row-selected" : "")">
                            @if (isEditing)
                            {
                                <td class="px-3 text-center" style="width:1%;white-space:nowrap;" @onclick:stopPropagation="true">
                                    <input type="checkbox" class="form-check-input shadow-none" style="width:17px;height:17px;cursor:pointer;"
                                           checked="@isSelected" @onchange="() => ToggleSelect(itemKey)" />
                                </td>
                            }
                            <td style="width:1%;white-space:nowrap;padding:0.1rem;" class="text-center">
                                <img src="@(string.IsNullOrEmpty(item.PosterPath) ? "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mNkYAAAAAYAAjCB0C8AAAAASUVORK5CYII=" : $"https://image.tmdb.org/t/p/w92{item.PosterPath}")"
                                     class="rounded shadow-sm" style="width:56px;height:84px;object-fit:cover;border:1px solid rgba(0,0,0,0.05);" alt="Thumbnail" />
                            </td>
                            <td class="px-3" style="cursor:pointer;" @onclick="() => WatchlistSvc.ShowDetailsAsync(item)">
                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                    <span class="fw-bold text-dark title-hover">
                                        @item.DisplayTitle
                                        @if (!string.IsNullOrEmpty(item.DisplayOriginalTitle))
                                        {
                                            <span class="text-secondary small fw-normal ms-1">(@item.DisplayOriginalTitle)</span>
                                        }
                                    </span>
                                    <a class="ext-link" href="@Get1337xSearchUrl(item)" target="_blank" rel="noopener noreferrer"
                                       title="Search on 1337x" @onclick:stopPropagation="true">
                                        <i class="bi bi-box-arrow-up-right"></i>
                                    </a>
                                </div>
                                <span class="d-lg-none text-secondary d-block" style="font-size:0.72rem;opacity:0.75;">
                                    @if (directorsMap.TryGetValue($"{item.MediaType}-{item.Id}", out var dirMobile)) { @dirMobile }
                                </span>
                                <span class="d-md-none text-secondary" style="font-size:0.72rem;opacity:0.75;">
                                    @(item.DisplayDate.Length >= 4 ? item.DisplayDate.Substring(0,4) : item.DisplayDate) · @(item.MediaType == "movie" ? "Movie" : "TV")
                                </span>
                            </td>
                            <td class="text-secondary small px-3 d-none d-lg-table-cell">
                                @if (directorsMap.TryGetValue($"{item.MediaType}-{item.Id}", out var director))
                                    { @director }
                                else
                                    { <span class="spinner-border spinner-border-sm opacity-25" role="status"></span> }
                            </td>
                            <td class="text-secondary fw-medium d-none d-md-table-cell">
                                @(item.DisplayDate.Length >= 4 ? item.DisplayDate.Substring(0,4) : item.DisplayDate)
                            </td>
                            <td class="d-none d-md-table-cell">
                                <span class="badge rounded-pill @(item.MediaType == "movie" ? "bg-secondary text-white" : "bg-light text-dark border")">
                                    @(item.MediaType == "movie" ? "Movie" : "TV Series")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <!-- initial/empty state -->
        <div class="page-content" style="overflow-y:auto;display:flex;align-items:center;justify-content:center;">
            <div class="text-center py-5 text-secondary opacity-50">
                <i class="bi bi-search fs-1 d-block mb-2"></i>
                <p>Searching…</p>
            </div>
        </div>
    }

</div>

@code {
    [Parameter] public string Query { get; set; } = "";

    private bool isEditing = false;
    private bool isLoading = false;
    private List<TmdbSearchResultItem>? results;
    private Dictionary<string, string> directorsMap = new();
    private CancellationTokenSource? cts;
    private int _directorRefreshCounter = 0;
    private string _searchSortColumn = "Year";
    private bool _searchSortDescending = true;
    private HashSet<string> _selectedKeys = new();

    private bool IsAllSelected
    {
        get { var keys = SortedResults.Select(r => $"{r.MediaType}-{r.Id}").ToList(); return keys.Count > 0 && keys.All(k => _selectedKeys.Contains(k)); }
    }

    private void ToggleSelectAll()
    {
        var keys = SortedResults.Select(r => $"{r.MediaType}-{r.Id}").ToList();
        if (IsAllSelected) foreach (var k in keys) _selectedKeys.Remove(k);
        else foreach (var k in keys) _selectedKeys.Add(k);
    }

    private void ToggleSelect(string key) { if (!_selectedKeys.Remove(key)) _selectedKeys.Add(key); }
    private void ToggleEdit() { isEditing = !isEditing; if (!isEditing) _selectedKeys.Clear(); }

    private IEnumerable<TmdbSearchResultItem> SortedResults => results == null
        ? Enumerable.Empty<TmdbSearchResultItem>()
        : (_searchSortColumn switch
        {
            "Title" => _searchSortDescending
                ? results.Where(r => r.MediaType == "movie" || r.MediaType == "tv").OrderByDescending(r => r.DisplayTitle)
                : results.Where(r => r.MediaType == "movie" || r.MediaType == "tv").OrderBy(r => r.DisplayTitle),
            _ => _searchSortDescending
                ? results.Where(r => r.MediaType == "movie" || r.MediaType == "tv").OrderByDescending(r => r.DisplayDate)
                : results.Where(r => r.MediaType == "movie" || r.MediaType == "tv").OrderBy(r => r.DisplayDate)
        });

    private void ToggleSearchSort(string col) { if (_searchSortColumn == col) _searchSortDescending = !_searchSortDescending; else { _searchSortColumn = col; _searchSortDescending = col == "Year"; } }

    private async Task BulkAddToWatchlist()
    {
        foreach (var item in SortedResults.Where(r => _selectedKeys.Contains($"{r.MediaType}-{r.Id}")).ToList())
            if (FindLibraryItem(item) == null) await HandleStatusClick(item, WatchlistStatus.Pending);
        _selectedKeys.Clear(); StateHasChanged();
    }
    private async Task BulkStartWatching()
    {
        foreach (var item in SortedResults.Where(r => _selectedKeys.Contains($"{r.MediaType}-{r.Id}")).ToList())
            await HandleStatusClick(item, WatchlistStatus.Watching);
        _selectedKeys.Clear(); StateHasChanged();
    }
    private async Task BulkRemove()
    {
        foreach (var item in SortedResults.Where(r => _selectedKeys.Contains($"{r.MediaType}-{r.Id}")).ToList())
        {
            var lib = FindLibraryItem(item);
            if (lib != null) await WatchlistSvc.RemoveFromWatchlistAsync(lib);
        }
        _selectedKeys.Clear(); StateHasChanged();
    }

    private WatchlistItem? FindLibraryItem(TmdbSearchResultItem item)
        => WatchlistSvc.Items.FirstOrDefault(i =>
            i.Title.Equals(item.DisplayTitle, StringComparison.OrdinalIgnoreCase) &&
            (item.DisplayDate.Length >= 4 && i.Year.Contains(item.DisplayDate.Substring(0, 4))));

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(Query)) return;
        cts?.Cancel(); cts = new CancellationTokenSource();
        directorsMap.Clear(); _directorRefreshCounter = 0; _selectedKeys.Clear(); isEditing = false;
        isLoading = true; results = null;
        try
        {
            var apiKey = Config["TmdbApiKey"];
            var url = $"https://api.themoviedb.org/3/search/multi?api_key={apiKey}&query={Uri.EscapeDataString(Uri.UnescapeDataString(Query))}";
            var response = await Http.GetFromJsonAsync<TmdbSearchResponse>(url);
            results = response?.Results;
        }
        catch (Exception ex) { Console.WriteLine($"Search API Error: {ex.Message}"); results = new(); }
        finally { isLoading = false; }
        if (results != null) _ = FetchDirectorsAsync(results, cts.Token);
    }

    private async Task FetchDirectorsAsync(List<TmdbSearchResultItem> items, CancellationToken token)
    {
        foreach (var item in items.Where(r => r.MediaType == "movie" || r.MediaType == "tv"))
        {
            if (token.IsCancellationRequested) break;
            var key = $"{item.MediaType}-{item.Id}";
            if (directorsMap.ContainsKey(key)) continue;
            try
            {
                var movie = await WatchlistSvc.GetTmdbDetailsByIdAsync(item.Id, item.MediaType);
                if (movie != null) { directorsMap[key] = movie.Directors.Any() ? string.Join(", ", movie.Directors) : "N/A"; _directorRefreshCounter++; if (_directorRefreshCounter % 5 == 0) await InvokeAsync(StateHasChanged); }
            }
            catch { }
            try { await Task.Delay(100, token); } catch (OperationCanceledException) { break; }
        }
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose() { cts?.Cancel(); cts?.Dispose(); WatchlistSvc.OnStateChanged -= StateHasChanged; }

    private async Task HandleStatusClick(TmdbSearchResultItem item, WatchlistStatus status)
    {
        var lib = FindLibraryItem(item);
        if (lib == null)
        {
            var movie = await WatchlistSvc.GetTmdbDetailsByIdAsync(item.Id, item.MediaType);
            if (movie != null && !string.IsNullOrEmpty(movie.ImdbId))
                await WatchlistSvc.AddToWatchlistAsync(new WatchlistItem
                {
                    ImdbId = movie.ImdbId, Title = movie.Title,
                    OriginalTitle = movie.OriginalTitle != movie.Title ? movie.OriginalTitle : null,
                    TitleType = item.MediaType == "movie" ? "Movie" : "TV Series",
                    Year = movie.ReleaseDate ?? "",
                    ParsedYear = int.TryParse(movie.ReleaseDate?.Split('-')[0], out var y) ? y : 0,
                    Genres = string.Join(", ", movie.GenreList.Select(g => g.Name)),
                    Director = movie.Directors.Any() ? string.Join(", ", movie.Directors) : null,
                    Status = status,
                    CurrentSeason = (status == WatchlistStatus.Watching && item.MediaType == "tv") ? 1 : null,
                    CurrentEpisode = (status == WatchlistStatus.Watching && item.MediaType == "tv") ? 1 : null,
                    PosterPath = movie.PosterPath
                });
        }
        else await WatchlistSvc.UpdateStatusAsync(lib, status);
    }

    private static string Get1337xSearchUrl(TmdbSearchResultItem item)
    {
        var year = item.DisplayDate.Length >= 4 ? item.DisplayDate.Substring(0, 4) : "";
        var q = string.IsNullOrWhiteSpace(year) ? item.DisplayTitle?.Trim() ?? "" : $"{item.DisplayTitle?.Trim()} {year}".Trim();
        return $"https://1337x.to/search/{System.Net.WebUtility.UrlEncode(q)}/1/";
    }
}

<style>
    .title-hover { transition: opacity 0.15s; }
    .title-hover:hover { opacity: 0.6; }
    .ext-link { opacity: 0; width: 20px; height: 20px; display: inline-flex; align-items: center; justify-content: center; color: #888; font-size: 0.7rem; transition: opacity 0.15s; text-decoration: none; }
    tr:hover .ext-link { opacity: 1; }
    .search-title { max-width: 220px; overflow: hidden; text-overflow: ellipsis; }
</style>
