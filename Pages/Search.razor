@page "/search/{Query}"
@using MyPrivateWatchlist.Models
@inject HttpClient Http
@inject IConfiguration Config
@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc

<PageTitle>Search Results</PageTitle>

<div class="container-fluid mt-4">
    <h2 class="mb-4 fw-bold text-dark border-bottom pb-3">Search Results for "@Uri.UnescapeDataString(Query)"</h2>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center py-5 mt-5">
            <div class="spinner-border text-secondary" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (results != null && !results.Any())
    {
        <div class="alert alert-secondary border-0 shadow-sm text-center py-5 fs-5 rounded-2 mt-4">
            No results found on TMDB for "@Uri.UnescapeDataString(Query)".
        </div>
    }
    else if (results != null)
    {
        <div class="card shadow border-0 overflow-hidden rounded-2">
            <div class="card-body p-0 table-responsive bg-white" style="max-height: 85vh; overflow-y: auto;">
                <table class="table table-hover align-middle mb-0 border-light">
                    <thead class="bg-light text-secondary fw-semibold" style="position: sticky; top: 0; z-index: 1;">
                        <tr>
                            <th scope="col" style="width: 5%; text-align: center;" class="border-bottom py-3 px-4"></th>
                            <th scope="col" style="width: 45%;" class="border-bottom py-3 px-4">
                                Title <span class="badge bg-secondary text-white shadow-sm fw-normal ms-2 rounded-2 px-2 py-1">@results.Count(r => r.MediaType == "movie" || r.MediaType == "tv") Total Items</span>
                            </th>
                            <th scope="col" style="width: 15%;" class="border-bottom py-3">Year</th>
                            <th scope="col" style="width: 15%;" class="border-bottom py-3">Type</th>
                            <th scope="col" style="width: 20%;" class="border-bottom py-3">Genres</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var item in results.Where(r => r.MediaType == "movie" || r.MediaType == "tv"))
                        {
                            <tr>
                                <td class="text-center px-3">
                                    @if (!IsAlreadyInWatchlist(item))
                                    {
                                        <button class="btn btn-sm btn-outline-dark rounded-circle shadow-none p-1 d-inline-flex align-items-center justify-content-center show-on-row-hover" 
                                                style="width: 30px; height: 30px;"
                                                @onclick="() => HandleAddClick(item)" @onclick:stopPropagation="true" title="Add to Watchlist">
                                            <i class="bi bi-plus-lg"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-link text-danger p-0 shadow-none d-inline-flex align-items-center justify-content-center show-on-row-hover" 
                                                style="width: 30px; height: 30px;"
                                                @onclick="() => HandleRemoveClick(item)" @onclick:stopPropagation="true" title="Remove from Watchlist">
                                            <i class="bi bi-x-lg fs-4"></i>
                                        </button>
                                    }
                                </td>
                                <td style="cursor: pointer;" class="px-4" @onclick="() => ShowMovieDetails(item)">
                                    <span class="fw-bold text-dark" style="transition: opacity 0.2s;" onmouseover="this.style.opacity='0.6'" onmouseout="this.style.opacity='1'">
                                        @item.DisplayTitle
                                        @if (!string.IsNullOrEmpty(item.DisplayOriginalTitle))
                                        {
                                            <span class="text-secondary small fw-normal ms-2">(@item.DisplayOriginalTitle)</span>
                                        }
                                    </span>
                                </td>
                                <td class="text-secondary fw-medium">
                                    @(item.DisplayDate.Length >= 4 ? item.DisplayDate.Substring(0,4) : item.DisplayDate)
                                </td>
                                <td>
                                    <span class="badge rounded-pill @(item.MediaType == "movie" ? "bg-secondary text-white" : "bg-light text-dark border")">
                                        @(item.MediaType == "movie" ? "Movie" : "TV Series")
                                    </span>
                                </td>
                                <td class="text-secondary small">
                                    @WatchlistSvc.GetGenreNames(item.GenreIds)
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (selectedMovie != null && selectedItem != null)
    {
        <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.85);" @onclick="CloseModal">
            <div class="modal-dialog modal-dialog-centered modal-xl" @onclick:stopPropagation="true">
                <div class="modal-content bg-transparent border-0">
                    <div class="card bg-white text-dark shadow-lg border-0 rounded-2 overflow-hidden">
                        <div class="row g-0">
                            <div class="col-md-5 text-center p-0 bg-dark d-flex align-items-center justify-content-center">
                                <img src="@selectedMovie.FullPosterUrl" class="img-fluid px-2 py-2" alt="Poster" style="object-fit: contain; max-height: 100%; width: 100%;" />
                            </div>
                            <div class="col-md-7 position-relative">
                                <button type="button" class="btn-close position-absolute top-0 end-0 m-4" aria-label="Close" @onclick="CloseModal"></button>
                                <div class="card-body p-5 d-flex flex-column h-100">
                                    <h2 class="card-title fw-bolder text-dark mb-1 pe-4">
                                        <a href="https://www.themoviedb.org/@selectedItem.MediaType/@selectedItem.Id" target="_blank" class="text-decoration-none text-dark" onmouseover="this.style.opacity='0.6'" onmouseout="this.style.opacity='1'">@selectedMovie.Title</a>
                                    </h2>
                                    
                                    @if (!string.IsNullOrEmpty(selectedMovie.ReleaseDate))
                                    {
                                        <p class="text-secondary fw-semibold small mb-4 text-uppercase tracking-wide">Released: @selectedMovie.ReleaseDate</p>
                                    }

                                    <div class="mb-4 d-flex align-items-center gap-3">
                                        <span class="badge bg-dark text-white fs-6 px-3 py-2 rounded-pill shadow-sm">
                                            @selectedMovie.VoteAverage.ToString("0.0") / 10
                                        </span>
                                        @if (!WatchlistSvc.IsInWatchlist(selectedMovie.ImdbId))
                                        {
                                            <button class="btn btn-outline-dark rounded-pill px-4 fw-bold" @onclick="AddToWatchlistFromModal">
                                                <i class="bi bi-plus-lg me-2"></i> Add to Watchlist
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-outline-danger rounded-pill px-4 fw-bold" @onclick="RemoveFromWatchlistFromModal">
                                                <i class="bi bi-x-lg me-2"></i> Remove from Watchlist
                                            </button>
                                        }
                                    </div>

                                    @if (selectedMovie.Directors.Any())
                                    {
                                        <p class="mb-2 text-dark fs-6"><strong>Director:</strong> 
                                            @foreach (var dir in selectedMovie.Directors)
                                            {
                                                <a href="https://www.themoviedb.org/search/person?query=@System.Uri.EscapeDataString(dir)" target="_blank" class="text-decoration-none text-secondary fw-semibold me-2">@dir</a>
                                            }
                                        </p>
                                    }

                                    @if (selectedMovie.Actors.Any())
                                    {
                                        <p class="mb-4 text-dark fs-6"><strong>Cast:</strong> 
                                            @foreach (var actor in selectedMovie.Actors)
                                            {
                                                <a href="https://www.themoviedb.org/search/person?query=@System.Uri.EscapeDataString(actor)" target="_blank" class="text-decoration-none text-secondary fw-semibold me-2">@actor</a>
                                            }
                                        </p>
                                    }
                                    
                                    <p class="card-text fs-6 text-secondary flex-grow-1" style="line-height: 1.7;">
                                        @if (string.IsNullOrEmpty(selectedMovie.Overview) && !selectedMovie.Directors.Any())
                                        {
                                            <div class="d-flex align-items-center gap-2 text-secondary">
                                                <div class="spinner-border spinner-border-sm" role="status"></div>
                                                <span>Loading full details...</span>
                                            </div>
                                        }
                                        else
                                        {
                                            @(string.IsNullOrEmpty(selectedMovie.Overview) ? "No overview available." : selectedMovie.Overview)
                                        }
                                    </p>
                                    
                                    <div class="mt-4 pt-4 border-top">
                                        <a href="https://www.themoviedb.org/@selectedItem.MediaType/@selectedItem.Id" target="_blank" class="btn btn-dark btn-lg px-5 rounded-pill shadow-sm w-100 fw-semibold">
                                            Open on TMDB
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string Query { get; set; } = "";

    private bool isLoading = false;
    private List<TmdbSearchResultItem>? results;
    
    private TmdbMovie? selectedMovie;
    private TmdbSearchResultItem? selectedItem;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(Query)) return;

        isLoading = true;
        results = null;

        try
        {
            var apiKey = Config["TmdbApiKey"];
            var decodedQuery = Uri.UnescapeDataString(Query);
            var url = $"https://api.themoviedb.org/3/search/multi?api_key={apiKey}&query={Uri.EscapeDataString(decodedQuery)}";
            var response = await Http.GetFromJsonAsync<TmdbSearchResponse>(url);
            results = response?.Results;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Search API Error: {ex.Message}");
            results = new();
        }
        finally
        {
            isLoading = false;
        }
    }

    private bool IsAlreadyInWatchlist(TmdbSearchResultItem item)
    {
        return WatchlistSvc.IsInWatchlistFuzzy(item.DisplayTitle, 
            item.DisplayDate.Length >= 4 ? item.DisplayDate.Substring(0, 4) : null);
    }

    private async Task HandleAddClick(TmdbSearchResultItem item)
    {
        var movie = await WatchlistSvc.GetTmdbDetailsByIdAsync(item.Id, item.MediaType);
        if (movie != null && !string.IsNullOrEmpty(movie.ImdbId))
        {
            await WatchlistSvc.AddToWatchlistAsync(new WatchlistItem
            {
                ImdbId = movie.ImdbId,
                Title = movie.Title,
                OriginalTitle = movie.OriginalTitle != movie.Title ? movie.OriginalTitle : null,
                TitleType = item.MediaType == "movie" ? "Movie" : "TV Series",
                Year = movie.ReleaseDate ?? "",
                ParsedYear = int.TryParse(movie.ReleaseDate?.Split('-')[0], out var y) ? y : 0,
                Genres = "" // We'd need to fetch genre names if we wanted this perfectly, but empty is safe for now
            });
        }
        StateHasChanged();
    }

    private async Task AddToWatchlistFromModal()
    {
        if (selectedMovie != null && selectedItem != null && !string.IsNullOrEmpty(selectedMovie.ImdbId))
        {
            await WatchlistSvc.AddToWatchlistAsync(new WatchlistItem
            {
                ImdbId = selectedMovie.ImdbId,
                Title = selectedMovie.Title,
                OriginalTitle = selectedMovie.OriginalTitle != selectedMovie.Title ? selectedMovie.OriginalTitle : null,
                TitleType = selectedItem.MediaType == "movie" ? "Movie" : "TV Series",
                Year = selectedMovie.ReleaseDate ?? "",
                ParsedYear = int.TryParse(selectedMovie.ReleaseDate?.Split('-')[0], out var y) ? y : 0,
                Genres = ""
            });
            StateHasChanged();
        }
    }

    private async Task RemoveFromWatchlistFromModal()
    {
        if (selectedMovie != null && !string.IsNullOrEmpty(selectedMovie.ImdbId))
        {
            await WatchlistSvc.RemoveFromWatchlistByImdbIdAsync(selectedMovie.ImdbId);
            StateHasChanged();
        }
    }

    private async Task HandleRemoveClick(TmdbSearchResultItem item)
    {
        // We might not have ImdbId in the item, so we fetch it if needed, or if we have a way to match.
        // Actually, IsAlreadyInWatchlist uses Fuzzy check. 
        // For removal from search list, we should be careful. 
        // Let's find the item in watchlist correctly.
        var wlItem = WatchlistSvc.Items.FirstOrDefault(i => i.Title.Equals(item.DisplayTitle, StringComparison.OrdinalIgnoreCase) && 
                                                         (item.DisplayDate.Length >= 4 && i.Year.Contains(item.DisplayDate.Substring(0,4))));
        if (wlItem != null)
        {
            await WatchlistSvc.RemoveFromWatchlistAsync(wlItem);
        }
    }

    private async Task ShowMovieDetails(TmdbSearchResultItem item)
    {
        selectedItem = item;
        // Show skeleton instantly
        selectedMovie = new TmdbMovie
        {
            Title = item.DisplayTitle,
            OriginalTitle = item.OriginalTitle ?? item.OriginalName,
            ReleaseDate = item.DisplayDate,
            PosterPath = item.PosterPath
        };
        StateHasChanged();

        var fullDetails = await WatchlistSvc.GetTmdbDetailsByIdAsync(item.Id, item.MediaType);
        if (fullDetails != null && selectedItem == item)
        {
            selectedMovie = fullDetails;
            StateHasChanged();
        }
    }

    private void CloseModal()
    {
        selectedMovie = null;
        selectedItem = null;
    }
}
