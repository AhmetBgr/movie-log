@page "/search/{Query}"
@using MyPrivateWatchlist.Models
@inject HttpClient Http
@inject IConfiguration Config

<PageTitle>Search Results</PageTitle>

<div class="container mt-4">
    <h2 class="mb-4 fw-bold text-dark border-bottom pb-3">Search Results for "@Uri.UnescapeDataString(Query)"</h2>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center py-5 mt-5">
            <div class="spinner-border text-secondary" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (results != null && !results.Any())
    {
        <div class="alert alert-secondary border-0 shadow-sm text-center py-5 fs-5 rounded-2 mt-4">
            No results found on TMDB for "@Uri.UnescapeDataString(Query)".
        </div>
    }
    else if (results != null)
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4 mb-5">
            @foreach (var item in results.Where(r => r.MediaType == "movie" || r.MediaType == "tv"))
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 rounded-2 overflow-hidden bg-white" style="transition: transform 0.2s ease;" onmouseover="this.style.transform='scale(1.02)'" onmouseout="this.style.transform='scale(1)'">
                        <img src="@item.FullPosterUrl" class="card-img-top bg-dark px-2 py-2" alt="Poster" style="height: 350px; object-fit: contain;" />
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold text-dark mb-1">
                                <a href="https://www.themoviedb.org/@(item.MediaType)/@item.Id" target="_blank" class="text-decoration-none text-dark">
                                    @item.DisplayTitle
                                </a>
                            </h5>
                            <div class="mt-auto pt-3">
                                <span class="badge rounded-pill @(item.MediaType == "movie" ? "bg-secondary text-white" : "bg-light text-dark border") mb-2">
                                    @(item.MediaType == "movie" ? "Movie" : "TV Series")
                                </span>
                                <p class="card-text text-secondary small fw-medium text-uppercase tracking-wide mb-0">Released: @item.DisplayDate</p>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public string Query { get; set; } = "";

    private bool isLoading = false;
    private List<TmdbSearchResultItem>? results;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(Query)) return;

        isLoading = true;
        results = null; // Clear previous results immediately layout-wise

        try
        {
            var apiKey = Config["TmdbApiKey"];
            var decodedQuery = Uri.UnescapeDataString(Query);
            var url = $"https://api.themoviedb.org/3/search/multi?api_key={apiKey}&query={Uri.EscapeDataString(decodedQuery)}";
            var response = await Http.GetFromJsonAsync<TmdbSearchResponse>(url);
            results = response?.Results;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Search API Error: {ex.Message}");
            results = new(); // empty list means no results
        }
        finally
        {
            isLoading = false;
        }
    }
}
