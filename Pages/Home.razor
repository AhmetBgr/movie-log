@page "/"
@inject WatchlistService Watchlist
@inject NavigationManager NavManager

<PageTitle>Library Statistics</PageTitle>

<div class="container py-4" style="padding-left: 4.5px; padding-right: 4.5px;">
    <style>
        @@media (max-width: 768px) {
            .container {
                padding-left: 8px !important;
                padding-right: 8px !important;
            }
        }
        .stat-card {
            background: transparent;
            border-radius: 12px;
            border: 1.5px solid rgba(0, 0, 0, 0.20);
            padding: 20px;
            height: 100%;
        }
        .stat-card-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: #333;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
        }
        .stat-card-title i {
            margin-right: 8px;
            color: #6366f1;
        }
        .chart-container {
            overflow-x: auto;
            overflow-y: hidden;
            flex-wrap: nowrap;
            padding-bottom: 4px;
        }
        .chart-container::-webkit-scrollbar {
            height: 4px;
        }
        .chart-container::-webkit-scrollbar-thumb {
            background-color: #cbd5e1;
            border-radius: 4px;
        }
        .director-link {
            transition: all 0.2s;
        }
        .director-link:hover {
            color: #6366f1 !important;
            text-decoration: underline !important;
        }
        .bg-alternate {
            background: rgba(99, 102, 241, 0.05);
        }
        .rating-row {
            transition: background 0.2s;
        }
        .rating-row:hover {
            background: rgba(99, 102, 241, 0.08);
        }
        .cursor-pointer {
            cursor: pointer;
        }
        .rating-movie-title {
            cursor: pointer;
            transition: color 0.1s ease;
        }
        .rating-movie-title:hover {
            color: #f97316 !important;
            text-decoration: underline !important;
        }
        .extra-small {
            font-size: 0.75rem;
        }
    </style>
    
    <div class="mb-4 pb-3 border-bottom">
        <h1 class="mb-1 fw-bolder text-dark">Statistics</h1>
        <p class="text-muted mb-0">Insights and graphs about your library.</p>
    </div>

    @if (RecentRatings.Any())
    {
        <div class="col-12 mb-4">
            <div class="stat-card">
                <div class="stat-card-title justify-content-between">
                    <div><i class="bi bi-clock-history"></i> Recent Ratings</div>
                    <button class="btn btn-link text-decoration-none text-muted fw-bold p-0" 
                            @onclick='() => NavManager.NavigateTo("library/watched")' 
                            style="font-size: 0.85rem;">
                        Show All <i class="bi bi-chevron-right small"></i>
                    </button>
                </div>
                <div class="recent-ratings-list mt-1">
                    @foreach (var (item, index) in RecentRatings.Select((v, i) => (v, i)))
                    {
                        var rating = item.Rating20 ?? 0;
                        var hue = (rating / 100.0) * 120;
                        var color = $"hsl({hue}, 70%, 45%)";
                        var percentile = RatingPercentiles.GetValueOrDefault(rating, 0);
                        
                        <div class="rating-row d-flex align-items-center py-1 px-2 mb-1 @(index % 2 != 0 ? "bg-alternate" : "")" style="border-radius: 6px;">
                            <div class="d-flex align-items-baseline me-2" style="min-width: 60px;">
                                <span class="fw-bold" style="color: @color; font-size: 1.15rem; min-width: 28px; display: inline-block;">@rating</span>
                                <span class="ms-1" style="color: @color; opacity: 0.7; font-size: 0.7rem;">@percentile.ToString("0")%</span>
                            </div>
                            <div class="text-dark d-flex flex-wrap align-items-baseline overflow-hidden" style="font-size: 0.95rem;">
                                <span class="fw-bold me-1 rating-movie-title text-truncate" @onclick="() => Watchlist.ShowDetailsAsync(item)">@item.Title</span>
                                <span class="text-secondary small me-2">(@item.Year)</span>
                                <span class="text-muted extra-small d-none d-sm-inline">— @item.DateAdded.ToString("dd MMM yyyy")</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <div class="row row-cols-1 row-cols-lg-2 g-4 mb-5">
        
        <!-- 1. Status Distribution -->
        <div class="col">
            <div class="stat-card">
                <div class="stat-card-title">
                    <i class="bi bi-pie-chart-fill text-dark opacity-75"></i> Library Overview
                </div>
                <div class="row row-cols-2 g-3 mt-2">
                    <div class="col">
                        <a href="/library/watched" class="p-3 rounded-3 text-center h-100 d-flex flex-column justify-content-center text-decoration-none" style="background: rgba(99, 102, 241, 0.08); display: block;">
                            <div class="fs-2 fw-bold" style="color: #6366f1;">@WatchedCount</div>
                            <div class="small fw-semibold mt-1" style="color: #6366f1; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px;">Watched</div>
                        </a>
                    </div>
                    <div class="col">
                        <a href="/library/watchlist" class="p-3 rounded-3 text-center h-100 d-flex flex-column justify-content-center text-decoration-none" style="background: rgba(100, 116, 139, 0.08); display: block;">
                            <div class="fs-2 fw-bold" style="color: #64748b;">@WatchlistCount</div>
                            <div class="small fw-semibold mt-1" style="color: #64748b; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px;">Watchlist</div>
                        </a>
                    </div>
                    <div class="col">
                        <a href="/library/watching" class="p-3 rounded-3 text-center h-100 d-flex flex-column justify-content-center text-decoration-none" style="background: rgba(16, 185, 129, 0.08); display: block;">
                            <div class="fs-2 fw-bold" style="color: #10b981;">@WatchingCount</div>
                            <div class="small fw-semibold mt-1" style="color: #10b981; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px;">Watching</div>
                        </a>
                    </div>
                    <div class="col">
                        <a href="/library/collections" class="p-3 rounded-3 text-center h-100 d-flex flex-column justify-content-center text-decoration-none" style="background: rgba(245, 158, 11, 0.08); display: block;">
                            <div class="fs-2 fw-bold" style="color: #f59e0b;">@CollectionCount</div>
                            <div class="small fw-semibold mt-1" style="color: #f59e0b; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px;">Collections</div>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- 3. Watched Movies Per Month -->
        <div class="col">
            <div class="stat-card d-flex flex-column">
                <div class="stat-card-title d-flex justify-content-between align-items-center">
                    <div><i class="bi bi-bar-chart-fill" style="color: #22c55e;"></i> Watched In @SelectedYear</div>
                    <div class="d-flex align-items-center gap-2">
                        @if (AvailableYears.Count > 1)
                        {
                            <select class="form-select form-select-sm border-0 bg-light fw-bold" style="width: auto; cursor: pointer;" @onchange="OnYearChanged">
                                @foreach (var y in AvailableYears)
                                {
                                    <option value="@y" selected="@(y == SelectedYear.ToString())">@y</option>
                                }
                            </select>
                        }
                        <div class="badge rounded-pill px-3 py-2 fw-bolder" style="font-size: 0.9rem; background: rgba(34, 197, 94, 0.1); color: #22c55e;">@YearlyTotal</div>
                    </div>
                </div>
                <div class="flex-grow-1 d-flex flex-column justify-content-end">
                    @{ var maxMonth = MoviesPerMonth.Any() ? MoviesPerMonth.Max(x => x.Value) : 0; }
                    <div class="chart-container d-flex align-items-end justify-content-between pt-3" style="height: 200px; gap: 4px;">
                        @foreach(var m in MoviesPerMonth)
                        {
                            var h = maxMonth > 0 ? (m.Value * 140 / maxMonth) : 0;
                            <div class="d-flex flex-column align-items-center justify-content-end h-100" style="flex: 1; min-width: 24px;">
                                <div class="text-muted mb-1 fw-bold" style="font-size: 0.75rem; height: 1.2rem;">@(m.Value > 0 ? m.Value.ToString() : "")</div>
                                <div class="rounded-top" style="width: 60%; max-width: 24px; height: @(h)px; background-color: #22c55e; min-height: @(m.Value > 0 ? "4px" : "0px"); transition: height 0.5s ease; @(m.Value == 0 ? "display:none;" : "")"></div>
                                <div class="mt-2 text-secondary fw-semibold" style="font-size: 0.65rem; height: 40px; display: flex; align-items: center; justify-content: center; writing-mode: vertical-rl; transform: rotate(180deg);">@m.Key</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- 4. Rating Distribution -->
        <div class="col">
            <div class="stat-card d-flex flex-column">
                <div class="stat-card-title">
                    <i class="bi bi-star-fill" style="color: #f59e0b;"></i> Rating Distribution
                </div>
                
                <div class="row mb-4">
                    @{
                        var avgHue = (AvgRating / 100.0) * 120;
                        var mostCommonHue = (MostCommonRating / 100.0) * 120;
                    }
                    <div class="col-6 text-center border-end">
                        <div class="fs-2 fw-bold" style="color: hsl(@avgHue, 70%, 45%);">@(AvgRating > 0 ? AvgRating.ToString("0.0") : "—")</div>
                        <div class="small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.5px;">Avg Rating</div>
                    </div>
                    <div class="col-6 text-center">
                        <div class="fs-2 fw-bold" style="color: hsl(@mostCommonHue, 70%, 45%);">@(MostCommonRating > 0 ? MostCommonRating.ToString() : "—")</div>
                        <div class="small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.5px;">Most Common</div>
                    </div>
                </div>

                <div class="flex-grow-1 d-flex flex-column justify-content-end">
                    @{ var maxRating = RatingDistribution.Any() ? RatingDistribution.Max(x => x.Value) : 0; }
                    <div class="chart-container d-flex align-items-end justify-content-between pt-2" style="height: 140px; gap: 4px;">
                        @foreach(var r in RatingDistribution)
                        {
                            var h = maxRating > 0 ? (r.Value * 90 / maxRating) : 0;
                            // Extract upper bound for color calculation (e.g. "71-80" -> 80)
                            int upper = 0;
                            if (int.TryParse(r.Key.Split('-').LastOrDefault(), out var val)) upper = val;
                            var hue = (upper / 100.0) * 120;
                            var color = $"hsl({hue}, 70%, 40%)";
                            
                            <div class="d-flex flex-column align-items-center justify-content-end h-100" style="flex: 1; min-width: 28px;" title="@r.Key: @r.Value movies">
                                <div class="text-muted mb-1 fw-bold" style="font-size: 0.65rem; height: 1.1rem; white-space: nowrap;">@(r.Value > 0 ? r.Value.ToString() : "")</div>
                                <div class="rounded-top" style="width: 70%; max-width: 28px; height: @(h)px; min-height: @(r.Value > 0 ? "4px" : "0px"); background-color: @color; transition: height 0.5s ease; @(r.Value == 0 ? "display:none;" : "")"></div>
                                <div class="mt-2 text-secondary text-center fw-bold" style="font-size: 0.6rem; height: 1.2rem; line-height: 1.1;">@r.Key.Replace("-", "-\n")</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
        
        <!-- 2. Top Watched Genres -->
        <div class="col">
            <div class="stat-card">
                <div class="stat-card-title d-flex justify-content-between align-items-center">
                    <div><i class="bi bi-tags-fill" style="color: #ef4444;"></i> @(_showLeastWatchedGenres ? "Least" : "Top") Watched Genres</div>
                    <div class="form-check form-switch m-0" title="Toggle Least/Top">
                        <input class="form-check-input cursor-pointer shadow-none m-0" type="checkbox" @bind="_showLeastWatchedGenres">
                    </div>
                </div>
                @{ var currentWatchGenres = _showLeastWatchedGenres ? BottomGenres : TopGenres; }
                @if (!currentWatchGenres.Any())
                {
                    <div class="text-muted fst-italic py-3">No genre data available.</div>
                }
                else
                {
                    var maxGenreIdx = currentWatchGenres.Any() ? currentWatchGenres.Max(x => x.Value) : 1;
                    @foreach(var g in currentWatchGenres)
                    {
                        var pct = maxGenreIdx > 0 ? (g.Value * 100 / maxGenreIdx) : 0;
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-semibold text-dark">@g.Key</span>
                                <span class="fw-bold text-secondary">@g.Value <span class="fw-normal text-muted small" style="font-size: 0.75em;">movies</span></span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar" style="width: @pct%; background-color: #ef4444;"></div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- 5. Most Watched Directors -->
        <div class="col">
            <div class="stat-card">
                <div class="stat-card-title">
                    <i class="bi bi-person-video2" style="color: #0ea5e9;"></i> Most Watched Directors
                </div>
                @if (!TopDirectors.Any())
                {
                    <div class="text-muted fst-italic py-3">No director data available.</div>
                }
                else
                {
                    var maxDir = TopDirectors.First().Value;
                    @foreach(var d in TopDirectors)
                    {
                        var pct = maxDir > 0 ? (d.Value * 100 / maxDir) : 0;
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <a href="/search/@Uri.EscapeDataString(d.Key)" target="_blank" class="fw-semibold text-dark text-truncate text-decoration-none director-link" style="max-width: 75%;" title="@d.Key">@d.Key</a>
                                <span class="fw-bold text-secondary">@d.Value <span class="fw-normal text-muted small" style="font-size: 0.75em;">movies</span></span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar" style="width: @pct%; background-color: #0ea5e9;"></div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- 6. Era Distribution (Decades) -->
        <div class="col">
            <div class="stat-card d-flex flex-column">
                <div class="stat-card-title">
                    <i class="bi bi-hourglass-split" style="color: #8b5cf6;"></i> Era Distribution
                </div>
                <div class="flex-grow-1 d-flex flex-column justify-content-end">
                    @{ var maxDecade = DecadeDistribution.Any() ? DecadeDistribution.Max(x => x.Value) : 0; }
                    <div class="chart-container d-flex align-items-end justify-content-between pt-2" style="height: 140px; gap: 4px;">
                        @foreach(var d in DecadeDistribution)
                        {
                            var h = maxDecade > 0 ? (d.Value * 100 / maxDecade) : 0;
                            <div class="d-flex flex-column align-items-center justify-content-end h-100" style="flex: 1; min-width: 38px;" title="@d.Key: @d.Value movies">
                                <div class="text-muted mb-1 fw-bold" style="font-size: 0.7rem; height: 1.1rem;">@(d.Value > 0 ? d.Value.ToString() : "")</div>
                                <div class="rounded-top" style="width: 70%; max-width: 28px; height: @(h)px; background-color: #8b5cf6; min-height: @(d.Value > 0 ? "4px" : "0px"); transition: height 0.5s ease; @(d.Value == 0 ? "display:none;" : "")"></div>
                                <div class="mt-2 text-secondary text-center fw-bold" style="font-size: 0.75rem; height: 1.2rem;">@d.Key</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- 7. Top Rated Genres -->
        <div class="col">
            <div class="stat-card">
                <div class="stat-card-title d-flex justify-content-between align-items-center">
                    <div><i class="bi bi-shield-star" style="color: #ec4899;"></i> @(_showLowestRatedGenres ? "Lowest" : "Highest") Rated Genres</div>
                    <div class="form-check form-switch m-0" title="Toggle Lowest/Highest">
                        <input class="form-check-input cursor-pointer shadow-none m-0" type="checkbox" @bind="_showLowestRatedGenres">
                    </div>
                </div>
                @{ var currentRatedGenres = _showLowestRatedGenres ? GenreLowestQuality : GenreQuality; }
                @if (!currentRatedGenres.Any())
                {
                    <div class="text-muted fst-italic py-3">No rated genre data.</div>
                }
                else
                {
                    @foreach(var g in currentRatedGenres)
                    {
                        var hue = (g.Value / 100.0) * 120;
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-semibold text-dark">@g.Key</span>
                                <span class="fw-bold" style="color: hsl(@hue, 70%, 40%);">@g.Value.ToString("0.0")</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar" style="width: @g.Value%; background-color: #ec4899;"></div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- 7b. Highest Rated Directors -->
        <div class="col">
            <div class="stat-card">
                <div class="stat-card-title d-flex justify-content-between align-items-center">
                    <div class="text-truncate flex-grow-1"><i class="bi bi-person-star" style="color: #f59e0b;"></i> @(_showLowestRatedDirectors ? "Lowest" : "Highest") Rated Directors</div>
                    <div class="d-flex align-items-center gap-2 ps-2">
                        <div class="input-group input-group-sm flex-nowrap" style="width: 80px;" title="Minimum Movies">
                            <span class="input-group-text border-0 bg-light text-muted px-1" style="font-size: 0.65rem;">Min</span>
                            <input type="number" class="form-control border-0 bg-light fw-bold text-center px-1" @bind="DirectorMinMovies" min="1" max="99" style="font-size: 0.75rem;">
                        </div>
                        <div class="form-check form-switch m-0" title="Toggle Lowest/Highest">
                            <input class="form-check-input cursor-pointer shadow-none m-0" type="checkbox" @bind="_showLowestRatedDirectors">
                        </div>
                    </div>
                </div>
                @{ var currentDirRatings = _showLowestRatedDirectors ? BottomRatedDirectors : TopRatedDirectors; }
                @if (!currentDirRatings.Any())
                {
                    <div class="text-muted fst-italic py-3">No rated director data (try lowering min movies).</div>
                }
                else
                {
                    @foreach(var d in currentDirRatings)
                    {
                        var hue = (d.Value / 100.0) * 120;
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <a href="/search/@Uri.EscapeDataString(d.Key)" target="_blank" class="fw-semibold text-dark text-truncate text-decoration-none director-link" style="max-width: 75%;" title="@d.Key">@d.Key</a>
                                <span class="fw-bold" style="color: hsl(@hue, 70%, 40%);">@d.Value.ToString("0.0")</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar" style="width: @d.Value%; background-color: #f59e0b;"></div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- 8. Runtime Distribution -->
        <div class="col">
            <div class="stat-card d-flex flex-column">
                <div class="stat-card-title">
                    <i class="bi bi-clock-history" style="color: #3b82f6;"></i> Runtime Distribution
                </div>
                <div class="flex-grow-1 d-flex flex-column justify-content-end">
                    @{ var maxRuntime = RuntimeDistribution.Any() ? RuntimeDistribution.Max(x => x.Value) : 0; }
                    <div class="chart-container d-flex align-items-end justify-content-between pt-2" style="height: 140px; gap: 4px;">
                        @foreach(var r in RuntimeDistribution)
                        {
                            var h = maxRuntime > 0 ? (r.Value * 100 / maxRuntime) : 0;
                            <div class="d-flex flex-column align-items-center justify-content-end h-100" style="flex: 1; min-width: 48px;" title="@r.Key: @r.Value movies">
                                <div class="text-muted mb-1 fw-bold" style="font-size: 0.7rem; height: 1.1rem;">@(r.Value > 0 ? r.Value.ToString() : "")</div>
                                <div class="rounded-top" style="width: 70%; max-width: 28px; height: @(h)px; background-color: #3b82f6; min-height: @(r.Value > 0 ? "4px" : "0px"); transition: height 0.5s ease; @(r.Value == 0 ? "display:none;" : "")"></div>
                                <div class="mt-2 text-secondary text-center fw-bold" style="font-size: 0.7rem; height: 1.2rem; line-height: 1.1;">@r.Key.Replace(" ", "\n")</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- 9. Avg Rating by Decade -->
        <div class="col">
            <div class="stat-card d-flex flex-column">
                <div class="stat-card-title">
                    <i class="bi bi-graph-up-arrow" style="color: #14b8a6;"></i> Ratings by Decade
                </div>
                <div class="flex-grow-1 d-flex flex-column justify-content-end">
                    @{ var maxTrend = DecadeRatingTrend.Any() ? DecadeRatingTrend.Max(x => x.Value) : 0; }
                    <div class="chart-container d-flex align-items-end justify-content-between pt-2" style="height: 140px; gap: 4px;">
                        @foreach(var d in DecadeRatingTrend)
                        {
                            var h = maxTrend > 0 ? (d.Value * 100 / 100) : 0; // Scale to 100
                            var hue = (d.Value / 100.0) * 120;
                            <div class="d-flex flex-column align-items-center justify-content-end h-100" style="flex: 1; min-width: 32px;" title="@d.Key: @d.Value.ToString("0.0") avg">
                                <div class="fw-bold mb-1" style="font-size: 0.7rem; height: 1.1rem; color: hsl(@hue, 70%, 40%);">@d.Value.ToString("0.0")</div>
                                <div class="rounded-top" style="width: 70%; max-width: 28px; height: @(d.Value)px; background-color: #14b8a6; transition: height 0.5s ease;"></div>
                                <div class="mt-2 text-secondary text-center fw-bold" style="font-size: 0.75rem; height: 1.2rem;">@d.Key</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- 10. Activity Heatmap -->
        <div class="col-12">
            <div class="stat-card">
                <div class="stat-card-title">
                    <i class="bi bi-calendar3 text-dark"></i> Activity Heatmap (Last 12 Months)
                </div>
                <div class="d-flex flex-wrap gap-1 mt-3" style="max-height: 140px; overflow-y: auto;">
                    @foreach(var date in Enumerable.Range(0, 365).Select(i => DateTime.Today.AddDays(-364 + i)))
                    {
                        var count = ActivityHeatmap.GetValueOrDefault(date.Date);
                        var color = count switch {
                            0 => "#f3f4f6", // gray-100
                            1 => "#dcfce7", // green-100
                            2 => "#86efac", // green-300
                            3 => "#22c55e", // green-500
                            _ => "#15803d"  // green-700
                        };
                        <div style="width: 10px; height: 10px; background: @color; border-radius: 2px; flex-shrink: 0;" title="@date.ToShortDateString(): @count movies"></div>
                    }
                </div>
                <div class="d-flex align-items-center gap-3 mt-3 small text-muted fw-semibold">
                    <span>Less</span>
                    <div class="d-flex gap-1">
                        <div style="width: 10px; height: 10px; background: #f3f4f6; border-radius: 2px;"></div>
                        <div style="width: 10px; height: 10px; background: #dcfce7; border-radius: 2px;"></div>
