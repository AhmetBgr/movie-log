@page "/"
@using System.Text.RegularExpressions
@inject HttpClient Http
@inject IConfiguration Config
@inject WatchlistService Watchlist

<PageTitle>My Private Watchlist</PageTitle>

<div class="container mt-4">
    <h1 class="mb-4">🎬 My Private Watchlist</h1>

    <div class="card p-4 mb-4 shadow-sm">
        <h5>Step 1: Import IMDb Watchlist</h5>
        <InputFile OnChange="HandleFileSelected" class="form-control" />
        
        @if (Watchlist.Items.Any())
        {
            <div class="alert alert-success mt-3">
                ✅ Loaded <strong>@Watchlist.Items.Count</strong> items.
            </div>
        }
    </div>

    @* FILTERS *@
    <div class="row g-3 mb-4 bg-light p-3 rounded shadow-sm">
        <div class="col-md-3">
            <label>Type</label>
            <select class="form-select" @bind="Watchlist.SelectedType">
                <option value="All">All Types</option>
                <option value="Movie">Movies Only</option>
                <option value="TV Series">TV Shows Only</option>
            </select>
        </div>
        <div class="col-md-3">
            <label>Genre</label>
            <select class="form-select" @bind="Watchlist.SelectedGenre">
                <option value="All">All Genres</option>
                @foreach (var genre in AvailableGenres)
                {
                    <option value="@genre">@genre</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label>From Year</label>
            <input type="number" class="form-control" @bind="Watchlist.StartYear" />
        </div>
        <div class="col-md-3">
            <label>To Year</label>
            <input type="number" class="form-control" @bind="Watchlist.EndYear" />
        </div>
    </div>

    @if (Watchlist.Items.Any())
    {
        <div class="text-center mb-5">
            <button class="btn btn-primary btn-lg px-5 shadow" @onclick="PickRandomMovie" disabled="@isPicking">
                <span>🎲 Show Me a Random Movie (@Watchlist.FilteredItems.Count() matches)</span>
            </button>
            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <p class="text-danger mt-2">@statusMessage</p>
            }
        </div>
    }

    @* MOVIE DISPLAY AREA *@
    @if (selectedMovie != null)
    {
        <div class="card bg-white text-dark shadow-lg mt-4 border-0 rounded-4 overflow-hidden" style="transition: transform 0.3s ease;">
            <div class="row g-0">
                <div class="col-md-4 text-center p-3 bg-light d-flex align-items-center justify-content-center">
                    <img src="@selectedMovie.FullPosterUrl" class="img-fluid rounded shadow-sm" alt="Poster" style="max-height: 450px; cursor: pointer;" @onclick="TogglePoster" />
                </div>
                <div class="col-md-8">
                    <div class="card-body p-4 d-flex flex-column h-100">
                        <h2 class="card-title fw-bold text-primary mb-1">
                            @selectedMovie.Title
                        </h2>
                        
                        @if (!string.IsNullOrEmpty(selectedMovie.ReleaseDate))
                        {
                            <p class="text-muted small mb-3">📅 Released: @selectedMovie.ReleaseDate</p>
                        }

                        <div class="mb-3">
                            <span class="badge bg-warning text-dark fs-6 px-3 py-2 shadow-sm">
                                ⭐ @selectedMovie.VoteAverage.ToString("0.0") / 10
                            </span>
                        </div>
                        
                        <p class="card-text fs-5 text-secondary flex-grow-1" style="line-height: 1.6;">
                            @(string.IsNullOrEmpty(selectedMovie.Overview) ? "No overview available." : selectedMovie.Overview)
                        </p>
                        
                        <div class="mt-4 pt-3 border-top">
                            <a href="https://www.imdb.com/title/@lastPickedImdbId/" target="_blank" class="btn btn-dark btn-lg px-4 shadow-sm">
                                🎬 Open on IMDb
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (showBigPoster && selectedMovie != null)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.85);" @onclick="TogglePoster">
            <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content bg-transparent border-0 text-center">
                    <img src="@selectedMovie.FullPosterUrl" class="img-fluid mx-auto rounded shadow-lg" style="max-height: 90vh;" alt="Large Poster" />
                </div>
            </div>
        </div>
    }

</div>

@code {
    private TmdbMovie? selectedMovie;
    private bool isPicking = false;
    private string statusMessage = "";
    private string lastPickedImdbId = "";
    private bool showBigPoster = false;

    protected override async Task OnInitializedAsync()
    {
        await Watchlist.InitializeAsync();
    }

    private async Task PickRandomMovie()
    {
        statusMessage = "";
        var options = Watchlist.FilteredItems.ToList();

        if (!options.Any())
        {
            statusMessage = "No matches found! Try adjusting your filters.";
            return;
        }

        isPicking = true;
        var winner = options[Random.Shared.Next(options.Count)];
        lastPickedImdbId = winner.ImdbId;
        selectedMovie = await Watchlist.GetTmdbDetailsAsync(winner.ImdbId);
        isPicking = false;
    }

    private List<string> AvailableGenres => Watchlist.Items
        .SelectMany(m => m.Genres.Split(','))
        .Select(g => g.Trim())
        .Where(g => !string.IsNullOrEmpty(g))
        .Distinct()
        .OrderBy(g => g)
        .ToList();

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        try
        {
            // Allow up to 10MB file
            using var stream = e.File.OpenReadStream(10_485_760);
            using var reader = new StreamReader(stream);
            
            using var csv = new CsvHelper.CsvReader(reader, System.Globalization.CultureInfo.InvariantCulture);
            var tempItems = new List<WatchlistItem>();

            csv.Read();
            csv.ReadHeader();
            while (csv.Read())
            {
                var imdbId = csv.GetField(1);
                var title = csv.GetField(5);
                var type = csv.GetField(8);
                var year = csv.GetField(11);
                var genres = csv.GetField(12);

                if (!string.IsNullOrEmpty(imdbId) && !string.IsNullOrEmpty(title))
                {
                    tempItems.Add(new WatchlistItem {
                        ImdbId = imdbId.Trim(),
                        Title = title.Trim(),
                        TitleType = type?.Trim() ?? "",
                        Year = year?.Trim() ?? "",
                        Genres = genres?.Trim() ?? ""
                    });
                }
            }
            await Watchlist.UpdateListAsync(tempItems);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error reading file: {ex.Message}");
            statusMessage = "Error reading CSV file. Ensure it's a valid IMDb export.";
        }
    }

    private void TogglePoster() => showBigPoster = !showBigPoster;
}