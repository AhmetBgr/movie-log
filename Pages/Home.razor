@code {
    private int TotalCount => Watchlist.Items.Count;
    private int WatchlistCount => Watchlist.Items.Count(i => i.Status == WatchlistStatus.Pending);
    private int WatchingCount => Watchlist.Items.Count(i => i.Status == WatchlistStatus.Watching);
    private int WatchedCount => Watchlist.Items.Count(i => i.Status == WatchlistStatus.Watched);
    private int CollectionCount => Watchlist.Collections.Count;
    private int SelectedYear = DateTime.Now.Year;
    private int YearlyTotal = 0;
    private List<string> AvailableYears = new();

    private bool _showLeastWatchedGenres = false;
    private bool _showLowestRatedGenres = false;
    private bool _showLowestRatedDirectors = false;
    private int _directorMinMovies = 3;
    private int DirectorMinMovies
    {
        get => _directorMinMovies;
        set
        {
            if (_directorMinMovies != value && value > 0)
            {
                _directorMinMovies = value;
                CalculateRatedDirectors();
            }
        }
    }

    private List<KeyValuePair<string, int>> TopGenres = new();
    private List<KeyValuePair<string, int>> BottomGenres = new();
    private List<KeyValuePair<string, int>> TopDirectors = new();
    private List<KeyValuePair<string, double>> TopRatedDirectors = new();
    private List<KeyValuePair<string, double>> BottomRatedDirectors = new();
    
    private List<KeyValuePair<string, int>> MoviesPerMonth = new();
    
    private double AvgRating = 0;
    private int MostCommonRating = 0;
    private List<KeyValuePair<string, int>> RatingDistribution = new();
    private List<KeyValuePair<string, int>> DecadeDistribution = new();
    private List<KeyValuePair<string, double>> GenreQuality = new();
    private List<KeyValuePair<string, double>> GenreLowestQuality = new();
    private List<KeyValuePair<string, int>> RuntimeDistribution = new();
    private List<KeyValuePair<string, double>> DecadeRatingTrend = new();
    private Dictionary<DateTime, int> ActivityHeatmap = new();
    private List<WatchlistItem> RecentRatings = new();
    private Dictionary<int, double> RatingPercentiles = new();
    private bool _showAllRatings = false;
    private int _ratingsCount = 10;
    private int TotalWatchedWithRating = 0;

    protected override void OnInitialized()
    {
        Watchlist.OnStateChanged += HandleStateChanged;
        CalculateStats();
    }

    private void HandleStateChanged()
    {
        CalculateStats();
        InvokeAsync(StateHasChanged);
    }

    private void OnYearChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var year))
        {
            SelectedYear = year;
            CalculateStats();
        }
    }

    private void CalculateStats()
    {
        var watched = Watchlist.Items.Where(i => i.Status == WatchlistStatus.Watched).ToList();
        
        // --- 0. Metadata for Select ---
        AvailableYears = watched
            .Select(m => m.DateAdded.Year.ToString())
            .Append(DateTime.Now.Year.ToString())
            .Distinct()
            .OrderByDescending(y => y)
            .ToList();

        // --- 2. Top Watched Genres & ---
        // --- 2b. Average Rating by Genre ---
        var genreGroups = watched
            .Where(m => !string.IsNullOrWhiteSpace(m.Genres))
            .SelectMany(m => m.Genres.Split(','))
            .Select(g => g.Trim())
            .GroupBy(g => g)
            .ToList();

        TopGenres = genreGroups
            .OrderByDescending(g => g.Count())
            .Take(5)
            .Select(g => new KeyValuePair<string, int>(g.Key, g.Count()))
            .ToList();

        BottomGenres = genreGroups
            .OrderBy(g => g.Count())
            .Take(5)
            .Select(g => new KeyValuePair<string, int>(g.Key, g.Count()))
            .ToList();

        var ratedGenreGroups = watched
            .Where(m => !string.IsNullOrWhiteSpace(m.Genres) && m.Rating20.HasValue)
            .SelectMany(m => m.Genres.Split(',').Select(g => new { G = g.Trim(), R = m.Rating20!.Value }))
            .GroupBy(x => x.G)
            .ToList();

        GenreQuality = ratedGenreGroups
            .OrderByDescending(g => g.Average(x => x.R))
            .Take(5)
            .Select(g => new KeyValuePair<string, double>(g.Key, g.Average(x => x.R)))
            .ToList();

        GenreLowestQuality = ratedGenreGroups
            .OrderBy(g => g.Average(x => x.R))
            .Take(5)
            .Select(g => new KeyValuePair<string, double>(g.Key, g.Average(x => x.R)))
            .ToList();

        // --- 5. Most Watched Directors ---
        TopDirectors = watched
            .Where(m => !string.IsNullOrWhiteSpace(m.Director))
            .SelectMany(m => m.Director.Split(','))
            .Select(d => d.Trim())
            .GroupBy(d => d)
            .OrderByDescending(g => g.Count())
            .Take(5)
            .Select(g => new KeyValuePair<string, int>(g.Key, g.Count()))
            .ToList();

        // --- 5b. Highest Rated Directors ---
        CalculateRatedDirectors();

        // --- 3. Watched Movies Per Month (Selected Year) ---
        var monthsInYear = Enumerable.Range(1, 12).ToList();
        var yearData = watched.Where(m => m.DateAdded.Year == SelectedYear).ToList();
        YearlyTotal = yearData.Count;

        MoviesPerMonth = monthsInYear.Select(m => 
        {
            int count = yearData.Count(x => x.DateAdded.Month == m);
            var monthName = new DateTime(SelectedYear, m, 1).ToString("MMM");
            return new KeyValuePair<string, int>(monthName, count);
        }).ToList();

        // --- 4. Rating Distribution ---
        var ratedMovies = watched.Where(m => m.Rating20.HasValue).ToList();
        if (ratedMovies.Any())
        {
            AvgRating = ratedMovies.Average(m => m.Rating20.Value);
            
            var distList = new List<KeyValuePair<string, int>>();
            for (int i = 10; i <= 100; i += 10)
            {
                int lower = i - 9;
                int upper = i;
                int count = ratedMovies.Count(m => m.Rating20 >= lower && m.Rating20 <= upper);
                distList.Add(new KeyValuePair<string, int>($"{lower}-{upper}", count));
            }
            RatingDistribution = distList;

            var exactCounts = ratedMovies.GroupBy(m => m.Rating20.Value).OrderByDescending(g => g.Count());
            MostCommonRating = exactCounts.First().Key;
        }
        else
        {
            AvgRating = 0; MostCommonRating = 0; RatingDistribution = new();
        }

        // --- 6. Era Distribution (Decades) ---
        DecadeDistribution = watched
            .Where(m => m.ParsedYear > 0)
            .GroupBy(m => (m.ParsedYear / 10 * 10).ToString() + "s")
            .OrderBy(g => g.Key)
            .Select(g => new KeyValuePair<string, int>(g.Key, g.Count()))
            .ToList();

        // --- 7. Decade Rating Trend ---
        DecadeRatingTrend = watched
            .Where(m => m.ParsedYear > 0 && m.Rating20.HasValue)
            .GroupBy(m => (m.ParsedYear / 10 * 10).ToString() + "s")
            .OrderBy(g => g.Key)
            .Select(g => new KeyValuePair<string, double>(g.Key, g.Average(m => m.Rating20!.Value)))
            .ToList();

        // --- 8. Runtime Distribution ---
        var runtimes = watched.Where(m => m.Runtime > 0).ToList();
        RuntimeDistribution = new List<KeyValuePair<string, int>> {
            new("< 90m", runtimes.Count(m => m.Runtime < 90)),
            new("90-120m", runtimes.Count(m => m.Runtime >= 90 && m.Runtime <= 120)),
            new("121-150m", runtimes.Count(m => m.Runtime > 120 && m.Runtime <= 150)),
            new("150-180m", runtimes.Count(m => m.Runtime > 150 && m.Runtime <= 180)),
            new("> 180m", runtimes.Count(m => m.Runtime > 180))
        };

        // --- 9. Activity Heatmap (Last 365 Days) ---
        var today = DateTime.Today;
        var startDate = today.AddDays(-364);
        ActivityHeatmap = watched
            .Where(m => m.DateAdded.Date >= startDate)
            .GroupBy(m => m.DateAdded.Date)
            .ToDictionary(g => g.Key, g => g.Count());

        // --- 10. Recent Ratings ---
        var watchedWithRating = watched.Where(m => m.Rating20.HasValue).ToList();
        TotalWatchedWithRating = watchedWithRating.Count;
        RecentRatings = watchedWithRating.OrderByDescending(m => m.DateAdded).Take(_ratingsCount).ToList();
        
        var allRatings = watchedWithRating.Select(m => m.Rating20!.Value).OrderBy(r => r).ToList();
        if (allRatings.Any())
        {
            RatingPercentiles = allRatings.Distinct().ToDictionary(
                r => r,
                r => (double)allRatings.Count(x => x <= r) / allRatings.Count * 100
            );
        }
    }

    private void ToggleShowMore()
    {
        _showAllRatings = !_showAllRatings;
        _ratingsCount = _showAllRatings ? 50 : 10;
        CalculateStats();
    }

    private void CalculateRatedDirectors()
    {
        var watched = Watchlist.WatchedItems.ToList();
        var directorGroups = watched
            .Where(m => !string.IsNullOrWhiteSpace(m.Director) && m.Rating20.HasValue)
            .SelectMany(m => m.Director.Split(',').Select(d => new { D = d.Trim(), R = m.Rating20!.Value }))
            .GroupBy(x => x.D)
            .Where(g => g.Count() >= _directorMinMovies)
            .ToList();

        TopRatedDirectors = directorGroups
            .OrderByDescending(g => g.Average(x => x.R))
            .Take(5)
            .Select(g => new KeyValuePair<string, double>(g.Key, g.Average(x => x.R)))
            .ToList();
            
        BottomRatedDirectors = directorGroups
            .OrderBy(g => g.Average(x => x.R))
            .Take(5)
            .Select(g => new KeyValuePair<string, double>(g.Key, g.Average(x => x.R)))
            .ToList();
    }

    public void Dispose()
    {
        Watchlist.OnStateChanged -= HandleStateChanged;
    }
}