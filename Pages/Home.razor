@page "/"
@inject WatchlistService Watchlist

<PageTitle>Dashboard</PageTitle>

<div class="container py-4" style="padding-left: 4.5px; padding-right: 4.5px;">
    <style>
        @@media (max-width: 768px) {
            .container {
                padding-left: 2px !important;
                padding-right: 2px !important;
            }
        }
    </style>
    <div class="mb-5 pb-3 border-bottom">
        <h1 class="mb-1 fw-bolder text-dark">Home</h1>
    </div>

    <!-- Stats Dashboard -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <a href="library/watchlist" class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden bg-white text-decoration-none text-dark hover-lift transition-all d-block cursor-pointer">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-primary bg-opacity-10 text-primary d-inline-flex align-items-center justify-content-center rounded-3 me-3 flex-shrink-0" style="width: 56px; height: 56px;">
                            <i class="bi bi-archive fs-3"></i>
                        </div>
                        <div>
                            <h6 class="text-secondary small fw-bold text-uppercase mb-1">Watchlist</h6>
                            <h2 class="fw-bolder mb-0">@WatchlistCount</h2>
                        </div>
                    </div>
                    <div class="progress" style="height: 6px; opacity: 0.1;">
                        <div class="progress-bar bg-primary" style="width: 100%"></div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="library/watching" class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden bg-white text-decoration-none text-dark hover-lift transition-all d-block cursor-pointer">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-success bg-opacity-10 text-success d-inline-flex align-items-center justify-content-center rounded-3 me-3 flex-shrink-0" style="width: 56px; height: 56px;">
                            <i class="bi bi-play-circle fs-3"></i>
                        </div>
                        <div>
                            <h6 class="text-secondary small fw-bold text-uppercase mb-1">Paused / Watching</h6>
                            <h2 class="fw-bolder mb-0">@WatchingCount</h2>
                        </div>
                    </div>
                    <div class="progress" style="height: 6px; opacity: 0.1;">
                        <div class="progress-bar bg-success" style="width: @(TotalCount > 0 ? (WatchingCount * 100 / TotalCount) : 0)%"></div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="library/watched" class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden bg-white text-decoration-none text-dark hover-lift transition-all d-block cursor-pointer">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-indigo bg-opacity-10 text-indigo d-inline-flex align-items-center justify-content-center rounded-3 me-3 flex-shrink-0" style="width: 56px; height: 56px; color: #6366f1;">
                            <i class="bi bi-check2-circle fs-3" style="color: #6366f1;"></i>
                        </div>
                        <div>
                            <h6 class="text-secondary small fw-bold text-uppercase mb-1">Completed</h6>
                            <h2 class="fw-bolder mb-0">@WatchedCount</h2>
                        </div>
                    </div>
                    <div class="progress" style="height: 6px; opacity: 0.1;">
                        <div class="progress-bar bg-indigo" style="width: @(TotalCount > 0 ? (WatchedCount * 100 / TotalCount) : 0)%; background-color: #6366f1;"></div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- Features Highlight -->
    <div class="mb-5 mt-5 pt-3 border-top">
        <h3 class="fw-bold text-dark mb-4 d-flex align-items-center">
            <i class="bi bi-stars text-warning me-3 fs-4"></i> Features
        </h3>
        <div class="row g-4">
            <!-- Feature 1 -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 h-100 bg-white hover-lift transition-all">
                    <div class="card-body p-4 text-center">
                        <div class="bg-primary bg-opacity-10 text-primary d-inline-flex align-items-center justify-content-center rounded-3 mb-4" style="width: 50px; height: 50px;">
                            <i class="bi bi-search fs-4"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-2">Global Movie Search</h5>
                    </div>
                </div>
            </div>
            
            <!-- Feature 2 -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 h-100 bg-white hover-lift transition-all">
                    <div class="card-body p-4 text-center">
                        <div class="bg-success bg-opacity-10 text-success d-inline-flex align-items-center justify-content-center rounded-3 mb-4" style="width: 50px; height: 50px;">
                            <i class="bi bi-tv fs-4"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-2">TV Show Tracking</h5>
                    </div>
                </div>
            </div>

            <!-- Feature 3 -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 h-100 bg-white hover-lift transition-all">
                    <div class="card-body p-4 text-center">
                        <div class="bg-danger bg-opacity-10 text-danger d-inline-flex align-items-center justify-content-center rounded-3 mb-4" style="width: 50px; height: 50px;">
                            <i class="bi bi-dice-5 fs-4"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-2">Random Movie Picker</h5>
                    </div>
                </div>
            </div>

            <!-- Feature 4 -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 h-100 bg-white hover-lift transition-all">
                    <div class="card-body p-4 text-center">
                        <div class="bg-info bg-opacity-10 text-info d-inline-flex align-items-center justify-content-center rounded-3 mb-4" style="width: 50px; height: 50px;">
                            <i class="bi bi-funnel fs-4"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-2">Filters</h5>
                    </div>
                </div>
            </div>

            <!-- Feature 5 -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 h-100 bg-white hover-lift transition-all">
                    <div class="card-body p-4 text-center">
                        <div class="bg-warning bg-opacity-10 text-warning d-inline-flex align-items-center justify-content-center rounded-3 mb-4" style="width: 50px; height: 50px;">
                            <i class="bi bi-star-fill fs-4"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-2">Custom Ratings</h5>
                    </div>
                </div>
            </div>

            <!-- Feature 6 -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 h-100 bg-white hover-lift transition-all">
                    <div class="card-body p-4 text-center">
                        <div class="bg-dark bg-opacity-10 text-dark d-inline-flex align-items-center justify-content-center rounded-3 mb-4" style="width: 50px; height: 50px;">
                            <i class="bi bi-shield-lock-fill fs-4"></i>
                        </div>
                        <h5 class="fw-bold text-dark mb-2">Local Library</h5>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int TotalCount => Watchlist.Items.Count;
    private int WatchlistCount => Watchlist.Items.Count(i => i.Status == WatchlistStatus.Pending);
    private int WatchingCount => Watchlist.Items.Count(i => i.Status == WatchlistStatus.Watching);
    private int WatchedCount => Watchlist.Items.Count(i => i.Status == WatchlistStatus.Watched);

    protected override void OnInitialized()
    {
        Watchlist.OnStateChanged += StateHasChanged;
    }

    public void Dispose()
    {
        Watchlist.OnStateChanged -= StateHasChanged;
    }
}