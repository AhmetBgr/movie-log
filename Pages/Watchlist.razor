@page "/watchlist"
@implements IDisposable
@inject WatchlistService WatchlistSvc
@inject IJSRuntime JS

<PageTitle>Watchlist Table</PageTitle>

<div class="container-fluid">
    @if (!WatchlistSvc.Items.Any())
    {
        <div class="alert alert-secondary border-0 shadow-sm text-center py-4 fs-5 rounded-2">
            Please import a watchlist CSV file on the Home tab or search and add movies from the Search tab.
        </div>
    }
    else
    {
        <div class="d-flex justify-content-start align-items-center mb-4 gap-2">
            <button class="btn btn-sm @(showFilters ? "btn-dark shadow" : "btn-outline-secondary") rounded-pill px-4 py-2 transition-all fw-medium" @onclick="ToggleFilters">
                <i class="bi @(showFilters ? "bi-chevron-left" : "bi-funnel") me-2"></i> 
                @(showFilters ? "Hide Filters" : "Show Filters")
            </button>
            <button class="btn btn-sm @(WatchlistSvc.ShowDetailedView ? "btn-secondary shadow" : "btn-outline-secondary") rounded-pill px-4 py-2 transition-all fw-medium" 
                    @onclick="() => WatchlistSvc.ShowDetailedView = !WatchlistSvc.ShowDetailedView">
                <i class="bi @(WatchlistSvc.ShowDetailedView ? "bi-eye-fill" : "bi-eye") me-2"></i> 
                @(WatchlistSvc.ShowDetailedView ? "Simple View" : "Detailed View")
            </button>
            <button class="btn btn-sm @(isEditing ? "btn-primary shadow" : "btn-outline-primary") rounded-pill px-4 py-2 transition-all fw-medium" @onclick="ToggleEdit">
                <i class="bi @(isEditing ? "bi-check-lg" : "bi-pencil") me-2"></i> 
                @(isEditing ? "Done Editing" : "Edit List")
            </button>
        </div>

        <div class="row g-4 h-100">
            @if (showFilters)
            {
                <div class="col-md-3 position-sticky top-0 h-100" style="max-height: 88vh; overflow-y: auto;">
                    <div class="card shadow-sm border-0 rounded-2 bg-white sticky-top">
                        <div class="card-body p-4">
                            <h5 class="fw-bold text-dark mb-4 border-bottom pb-2">Refine List</h5>
                            
                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary text-uppercase tracking-wider">Search Title</label>
                                <div class="input-group shadow-none border rounded-2 overflow-hidden">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                                    <input type="text" class="form-control border-0 bg-light shadow-none" placeholder="Search..." 
                                           @bind="WatchlistSvc.SearchQuery" @bind:event="oninput" />
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary text-uppercase tracking-wider">Genre</label>
                                <select class="form-select border rounded-2 bg-light shadow-none" @bind="WatchlistSvc.SelectedGenre">
                                    <option value="All">All Genres</option>
                                    @foreach (var genre in AvailableGenres)
                                    {
                                        <option value="@genre">@genre</option>
                                    }
                                </select>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary text-uppercase tracking-wider">Type</label>
                                <select class="form-select border rounded-2 bg-light shadow-none" @bind="WatchlistSvc.SelectedType">
                                    <option value="All">All Types</option>
                                    <option value="Movie">Movies</option>
                                    <option value="TV Series">TV Series</option>
                                </select>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary text-uppercase tracking-wider">Year Range</label>
                                <div class="d-flex gap-2">
                                    <input type="number" class="form-control border rounded-2 bg-light shadow-none px-2" placeholder="From" 
                                           @bind="WatchlistSvc.StartYear" />
                                    <input type="number" class="form-control border rounded-2 bg-light shadow-none px-2" placeholder="To" 
                                           @bind="WatchlistSvc.EndYear" />
                                </div>
                            </div>

                            <div class="d-grid gap-2 pt-2">
                                <button class="btn btn-dark rounded-pill py-2 shadow-sm border-0 fw-semibold" @onclick="WatchlistSvc.ShowRandomMovieAsync">
                                    <i class="bi bi-dice-5 me-2"></i> Pick Random Movie
                                </button>
                                <button class="btn btn-outline-secondary btn-sm border-0 py-2" @onclick="ClearFilters">
                                    <i class="bi bi-eraser me-2"></i> Clear All Filters
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="@(showFilters ? "col-md-9" : "col-12")">
                <div class="card shadow border-0 overflow-hidden rounded-2">
                    <div class="card-body p-0 bg-white" style="height: 88vh; min-height: 80vh; overflow-y: auto;">
                        <table class="table table-hover align-middle mb-0 border-light">
                    <thead class="bg-light text-secondary fw-semibold" style="position: sticky; top: 0; z-index: 1;">
                        <tr>
                            @if (isEditing)
                            {
                                <th scope="col" style="width: 1%; white-space: nowrap;" class="border-bottom py-2.5 px-3 text-center"></th>
                            }
                            <th scope="col" style="width: @(isEditing ? "57%" : "65%"); cursor: pointer;" class="border-bottom py-2.5 px-3" @onclick='() => WatchlistSvc.ToggleSort("Title")'>
                                Title 
                                @if (WatchlistSvc.SortColumn == "Title") { <i class="bi @(WatchlistSvc.SortDescending ? "bi-sort-alpha-up-alt" : "bi-sort-alpha-down") ms-1"></i> }
                                <span class="badge bg-secondary text-white shadow-sm fw-normal ms-2 rounded-2 px-2 py-1">@WatchlistSvc.FilteredItems.Count() Items</span>
                            </th>
                             <th scope="col" style="width: 12%; cursor: pointer;" class="border-bottom py-2.5" @onclick='() => WatchlistSvc.ToggleSort("Year")'>
                                Year
                                @if (WatchlistSvc.SortColumn == "Year") { <i class="bi @(WatchlistSvc.SortDescending ? "bi-sort-numeric-up-alt" : "bi-sort-numeric-down") ms-1"></i> }
                            </th>
                            <th scope="col" style="width: 10%; cursor: pointer;" class="border-bottom py-2.5" @onclick='() => WatchlistSvc.ToggleSort("DateAdded")'>
                                Added
                                @if (WatchlistSvc.SortColumn == "DateAdded") { <i class="bi @(WatchlistSvc.SortDescending ? "bi-sort-numeric-up-alt" : "bi-sort-numeric-down") ms-1"></i> }
                            </th>
                            <th scope="col" style="width: 13%; cursor: pointer;" class="border-bottom py-2.5" @onclick='() => WatchlistSvc.ToggleSort("Type")'>
                                Type
                                @if (WatchlistSvc.SortColumn == "Type") { <i class="bi @(WatchlistSvc.SortDescending ? "bi-sort-alpha-up-alt" : "bi-sort-alpha-down") ms-1"></i> }
                            </th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        <Virtualize Items="_filteredItems" Context="item" ItemSize="250" OverscanCount="20">
                            <tr @key="item">
                                @if (isEditing)
                                {
                                <td class="text-center px-1" style="width: 1%; white-space: nowrap;">
                                    <div class="d-flex align-items-center justify-content-center gap-1">
                                        <button class="btn btn-sm btn-light border-0 text-success bg-success bg-opacity-10 rounded-3 shadow-none p-1 d-inline-flex align-items-center justify-content-center" 
                                                style="width: 32px; height: 32px; transition: all 0.2s;"
                                                onmouseover="this.classList.replace('bg-opacity-10','bg-opacity-25')"
                                                onmouseout="this.classList.replace('bg-opacity-25','bg-opacity-10')"
                                                @onclick="() => StartWatching(item)" @onclick:stopPropagation="true" title="Start Watching">
                                            <i class="bi bi-play-fill fs-5"></i>
                                        </button>
                                        <button class="btn btn-sm btn-light border-0 text-primary bg-primary bg-opacity-10 rounded-3 shadow-none p-1 d-inline-flex align-items-center justify-content-center" 
                                                style="width: 32px; height: 32px; transition: all 0.2s;"
                                                onmouseover="this.classList.replace('bg-opacity-10','bg-opacity-25')"
                                                onmouseout="this.classList.replace('bg-opacity-25','bg-opacity-10')"
                                                @onclick="() => MarkAsWatched(item)" @onclick:stopPropagation="true" title="Mark as Watched">
                                            <i class="bi bi-check-lg fs-5"></i>
                                        </button>
                                        <button class="btn btn-sm btn-light border-0 text-danger bg-danger bg-opacity-10 rounded-3 shadow-none p-1 d-inline-flex align-items-center justify-content-center ms-1" 
                                                style="width: 32px; height: 32px; transition: all 0.2s;"
                                                onmouseover="this.classList.replace('bg-opacity-10','bg-opacity-25')"
                                                onmouseout="this.classList.replace('bg-opacity-25','bg-opacity-10')"
                                                @onclick="() => WatchlistSvc.RemoveFromWatchlistAsync(item)" @onclick:stopPropagation="true" title="Remove from Watchlist">
                                            <i class="bi bi-trash3-fill fs-6"></i>
                                        </button>
                                    </div>
                                </td>
                                }
                                <td style="cursor: pointer;" class="px-3 py-3" @onclick="() => WatchlistSvc.ShowDetailsAsync(item)">
                                    <div class="d-flex flex-column gap-1">
                                        <div class="d-flex align-items-baseline gap-2 flex-wrap pb-1">
                                            <span class="fw-bold text-dark fs-6" style="transition: opacity 0.2s;" onmouseover="this.style.opacity='0.6'" onmouseout="this.style.opacity='1'">
                                                @item.Title
                                            </span>
                                            @if (!string.IsNullOrEmpty(item.Director))
                                            {
                                                <span class="text-secondary opacity-75 small fw-medium">by @item.Director</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrEmpty(item.OriginalTitle) && !string.Equals(item.OriginalTitle, item.Title, StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="text-secondary small fw-normal pb-1">(@item.OriginalTitle)</span>
                                        }
                                        @if (WatchlistSvc.ShowDetailedView)
                                        {
                                            @if (!string.IsNullOrEmpty(item.Overview))
                                            {
                                                <div class="overview-text mt-1" style="max-width: 700px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.6;">
                                                    @item.Overview
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(item.Genres))
                                            {
                                                <div class="d-flex flex-wrap gap-1 mt-1">
                                                    @foreach (var g in item.Genres.Split(',').Take(4))
                                                    {
                                                        <span class="badge rounded-pill bg-light text-dark border-0 shadow-sm x-small fw-normal">@g.Trim()</span>
                                                    }
                                                </div>
                                            }
                                        }
                                    </div>
                                </td>
                                <td class="text-secondary fw-medium px-2">
                                    @item.Year
                                </td>
                                <td class="text-secondary small px-2">
                                    @item.DateAdded.ToString("MMM dd")
                                </td>
                                <td>
                                    <span class="badge rounded-pill @(item.TitleType.Equals("Movie", StringComparison.OrdinalIgnoreCase) ? "bg-secondary text-white" : "bg-light text-dark border")">
                                        @item.TitleType
                                    </span>
                                </td>
                            </tr>
                        </Virtualize>
                    </tbody>
                </table>
            </div>
        </div>
    </div>


        </div>
    }
</div>

<style>
    .overview-text {
        font-size: 0.875rem;
        color: #4a5568; /* Slate gray for soft but readable text */
        letter-spacing: 0.01em;
    }
    .x-small { font-size: 0.65rem; }
    .sticky-top { top: 1rem; }
</style>

@code {
    private bool showFilters = false;
    private bool isEditing = false;
    private void ToggleEdit() => isEditing = !isEditing;
    private List<WatchlistItem> _filteredItems = new();
    private List<string> _availableGenres = new();

    private void ToggleFilters()
    {
        showFilters = !showFilters;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        WatchlistSvc.OnStateChanged += HandleStateChanged;
        UpdateLocalList();

        try
        {
            var isDesktop = await JS.InvokeAsync<bool>("uiHelpers.isDesktop");
            if (isDesktop)
            {
                showFilters = true;
                WatchlistSvc.ShowDetailedView = true;
            }
        }
        catch { /* Fallback */ }
    }

    private void HandleStateChanged()
    {
        UpdateLocalList();
        InvokeAsync(StateHasChanged);
    }

    private void UpdateLocalList()
    {
        _filteredItems = WatchlistSvc.FilteredItems.ToList();
        _availableGenres = WatchlistSvc.Items
            .SelectMany(m => (m.Genres ?? "").Split(','))
            .Select(g => g.Trim())
            .Where(g => !string.IsNullOrEmpty(g))
            .Distinct()
            .OrderBy(g => g)
            .ToList();
    }

    public void Dispose()
    {
        WatchlistSvc.OnStateChanged -= HandleStateChanged;
    }

    private void ClearFilters()
    {
        WatchlistSvc.SearchQuery = "";
        WatchlistSvc.SelectedType = "All";
        WatchlistSvc.SelectedGenre = "All";
        WatchlistSvc.StartYear = "";
        WatchlistSvc.EndYear = "";
    }

    private List<string> AvailableGenres => _availableGenres;

    private async Task StartWatching(WatchlistItem item)
    {
        await WatchlistSvc.UpdateStatusAsync(item, WatchlistStatus.Watching);
    }

    private async Task RemoveFromWatchlist(WatchlistItem item)
    {
        await WatchlistSvc.RemoveFromWatchlistAsync(item);
    }

    private async Task MarkAsWatched(WatchlistItem item)
    {
        await WatchlistSvc.UpdateStatusAsync(item, WatchlistStatus.Watched);
    }
}
