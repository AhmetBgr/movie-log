@page "/watchlist"
@implements IDisposable
@inject WatchlistService WatchlistSvc

<PageTitle>Watchlist Table</PageTitle>

<div class="container-fluid">
    @if (!WatchlistSvc.Items.Any())
    {
        <div class="alert alert-secondary border-0 shadow-sm text-center py-4 fs-5 rounded-2">
            Please import a watchlist CSV file on the Home tab or search and add movies from the Search tab.
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0 fw-bolder text-dark d-flex align-items-center">
                <i class="bi bi-list-nested me-3 text-secondary"></i> Watchlist
                <span class="badge bg-light text-secondary ms-3 rounded-pill fs-6 fw-normal border shadow-sm">@WatchlistSvc.FilteredItems.Count() Items</span>
            </h2>
            <button class="btn btn-sm @(showFilters ? "btn-dark shadow" : "btn-outline-secondary") rounded-pill px-4 py-2 transition-all fw-medium" @onclick="() => showFilters = !showFilters">
                <i class="bi @(showFilters ? "bi-chevron-left" : "bi-funnel") me-2"></i> 
                @(showFilters ? "Hide Filters" : "Show Filters")
            </button>
        </div>

        <div class="row g-4 h-100">
            <div class="@(showFilters ? "col-md-9" : "col-12")">
                <div class="card shadow border-0 overflow-hidden rounded-2">
                    <div class="card-body p-0 bg-white" style="height: 88vh; min-height: 80vh; overflow-y: auto;">
                        <table class="table table-hover align-middle mb-0 border-light">
                    <thead class="bg-light text-secondary fw-semibold" style="position: sticky; top: 0; z-index: 1;">
                        <tr>
                            <th scope="col" style="width: 5%;" class="border-bottom py-2.5 px-3 text-center"></th>
                            <th scope="col" style="width: 40%; cursor: pointer;" class="border-bottom py-2.5 px-3" @onclick='() => WatchlistSvc.ToggleSort("Title")'>
                                Title 
                                @if (WatchlistSvc.SortColumn == "Title") { <i class="bi @(WatchlistSvc.SortDescending ? "bi-sort-alpha-up-alt" : "bi-sort-alpha-down") ms-1"></i> }
                                <span class="badge bg-secondary text-white shadow-sm fw-normal ms-2 rounded-2 px-2 py-1">@WatchlistSvc.FilteredItems.Count() Items</span>
                            </th>
                            <th scope="col" style="width: 25%;" class="border-bottom py-2.5 px-3">Director</th>
                             <th scope="col" style="width: 12%; cursor: pointer;" class="border-bottom py-2.5" @onclick='() => WatchlistSvc.ToggleSort("Year")'>
                                Year
                                @if (WatchlistSvc.SortColumn == "Year") { <i class="bi @(WatchlistSvc.SortDescending ? "bi-sort-numeric-up-alt" : "bi-sort-numeric-down") ms-1"></i> }
                            </th>
                            <th scope="col" style="width: 10%; cursor: pointer;" class="border-bottom py-2.5" @onclick='() => WatchlistSvc.ToggleSort("DateAdded")'>
                                Added
                                @if (WatchlistSvc.SortColumn == "DateAdded") { <i class="bi @(WatchlistSvc.SortDescending ? "bi-sort-numeric-up-alt" : "bi-sort-numeric-down") ms-1"></i> }
                            </th>
                            <th scope="col" style="width: 13%; cursor: pointer;" class="border-bottom py-2.5" @onclick='() => WatchlistSvc.ToggleSort("Type")'>
                                Type
                                @if (WatchlistSvc.SortColumn == "Type") { <i class="bi @(WatchlistSvc.SortDescending ? "bi-sort-alpha-up-alt" : "bi-sort-alpha-down") ms-1"></i> }
                            </th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        <Virtualize Items="_filteredItems" Context="item" ItemSize="60" OverscanCount="20">
                            <tr @key="item">
                                <td class="text-center px-3">
                                    <div class="d-flex align-items-center justify-content-center gap-1">
                                        <button class="btn btn-sm btn-outline-success border-0 rounded-circle shadow-none p-1 d-inline-flex align-items-center justify-content-center show-on-row-hover" 
                                                style="width: 30px; height: 30px;"
                                                @onclick="() => StartWatching(item)" @onclick:stopPropagation="true" title="Start Watching">
                                            <i class="bi bi-play-fill fs-5"></i>
                                        </button>
                                        <button class="btn btn-sm btn-link text-danger p-0 shadow-none d-inline-flex align-items-center justify-content-center show-on-row-hover" 
                                                style="width: 30px; height: 30px;"
                                                @onclick="() => RemoveFromWatchlist(item)" @onclick:stopPropagation="true" title="Remove from Watchlist">
                                            <i class="bi bi-x-lg fs-4"></i>
                                        </button>
                                    </div>
                                </td>
                                <td style="cursor: pointer;" class="px-3" @onclick="() => ShowMovieDetails(item)">
                                    <span class="fw-bold text-dark" style="transition: opacity 0.2s;" onmouseover="this.style.opacity='0.6'" onmouseout="this.style.opacity='1'">
                                        @item.Title
                                    </span>
                                    @if (item.DisplayOriginalTitle != null)
                                    {
                                        <span class="text-secondary small ms-2 opacity-50 fw-normal">(@item.DisplayOriginalTitle)</span>
                                    }
                                </td>
                                <td class="text-secondary small px-3">
                                    @item.Director
                                </td>
                                <td class="text-secondary fw-medium">
                                    @item.Year
                                </td>
                                <td class="text-secondary small">
                                    @item.DateAdded.ToString("MMM dd")
                                </td>
                                <td>
                                    <span class="badge rounded-pill @(item.TitleType.Equals("Movie", StringComparison.OrdinalIgnoreCase) ? "bg-secondary text-white" : "bg-light text-dark border")">
                                        @item.TitleType
                                    </span>
                                </td>
                            </tr>
                        </Virtualize>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

            @if (showFilters)
            {
                <div class="col-md-3 position-sticky top-0 h-100" style="max-height: 88vh; overflow-y: auto;">
                    <div class="card shadow-sm border-0 rounded-2 bg-white sticky-top">
                        <div class="card-body p-4">
                            <h5 class="fw-bold text-dark mb-4 border-bottom pb-2">Refine List</h5>
                            
                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary text-uppercase tracking-wider">Search Title</label>
                                <div class="input-group shadow-none border rounded-2 overflow-hidden">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                                    <input type="text" class="form-control border-0 bg-light shadow-none" placeholder="Search..." 
                                           @bind="WatchlistSvc.SearchQuery" @bind:event="oninput" />
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary text-uppercase tracking-wider">Genre</label>
                                <select class="form-select border rounded-2 bg-light shadow-none" @bind="WatchlistSvc.SelectedGenre">
                                    <option value="All">All Genres</option>
                                    @foreach (var genre in AvailableGenres)
                                    {
                                        <option value="@genre">@genre</option>
                                    }
                                </select>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary text-uppercase tracking-wider">Type</label>
                                <select class="form-select border rounded-2 bg-light shadow-none" @bind="WatchlistSvc.SelectedType">
                                    <option value="All">All Types</option>
                                    <option value="Movie">Movies</option>
                                    <option value="TV Series">TV Series</option>
                                </select>
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary text-uppercase tracking-wider">Year Range</label>
                                <div class="d-flex gap-2">
                                    <input type="number" class="form-control border rounded-2 bg-light shadow-none px-2" placeholder="From" 
                                           @bind="WatchlistSvc.StartYear" />
                                    <input type="number" class="form-control border rounded-2 bg-light shadow-none px-2" placeholder="To" 
                                           @bind="WatchlistSvc.EndYear" />
                                </div>
                            </div>

                            <div class="d-grid gap-2 pt-2">
                                <button class="btn btn-dark rounded-pill py-2 shadow-sm border-0 fw-semibold" @onclick="ShowRandomMovie">
                                    <i class="bi bi-dice-5 me-2"></i> Pick Random Movie
                                </button>
                                <button class="btn btn-outline-secondary btn-sm border-0 py-2" @onclick="ClearFilters">
                                    <i class="bi bi-eraser me-2"></i> Clear All Filters
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }


    @if (selectedMovie != null)
    {
        <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.85);" @onclick="CloseModal">
            <div class="modal-dialog modal-dialog-centered modal-xl" @onclick:stopPropagation="true">
                <div class="modal-content bg-transparent border-0">
                    <div class="card bg-white text-dark shadow-lg border-0 rounded-2 overflow-hidden">
                        <div class="row g-0">
                            <div class="col-md-5 text-center p-0 bg-black d-flex align-items-center justify-content-center" style="min-height: 600px;">
                                <img src="@selectedMovie.FullPosterUrl" class="img-fluid px-2 py-2" alt="Poster" style="object-fit: contain; max-height: 100%; width: 100%;" />
                            </div>
                            <div class="col-md-7 position-relative">
                                <button type="button" class="btn-close position-absolute top-0 end-0 m-4" aria-label="Close" @onclick="CloseModal"></button>
                                <div class="card-body p-5 d-flex flex-column h-100">
                                    <h2 class="card-title fw-bolder text-dark mb-1 pe-4">
                                        <a href="https://www.imdb.com/title/@selectedItem!.ImdbId/" target="_blank" class="text-decoration-none text-dark" onmouseover="this.style.opacity='0.6'" onmouseout="this.style.opacity='1'">@selectedMovie.Title</a>
                                    </h2>
                                    
                                    @if (!string.IsNullOrEmpty(selectedMovie.ReleaseDate))
                                    {
                                        <p class="text-secondary fw-semibold small mb-4 text-uppercase tracking-wide">Released: @selectedMovie.ReleaseDate</p>
                                    }

                                    <div class="mb-4 d-flex align-items-center gap-3">
                                        <span class="badge bg-dark text-white fs-6 px-3 py-2 rounded-pill shadow-sm">
                                            @selectedMovie.VoteAverage.ToString("0.0") / 10
                                        </span>
                                        <button class="btn btn-outline-danger rounded-pill px-4 fw-bold" @onclick="RemoveFromWatchlistFromModal">
                                            <i class="bi bi-x-lg me-2"></i> Remove from Watchlist
                                        </button>
                                    </div>

                                    @if (!string.IsNullOrEmpty(selectedItem!.Genres))
                                    {
                                        <div class="mb-4">
                                            @foreach (var genre in selectedItem.Genres.Split(','))
                                            {
                                                <a href="https://www.imdb.com/search/title/?genres=@genre.Trim().ToLower()" target="_blank" class="badge bg-light text-dark border me-1 text-decoration-none rounded-pill shadow-sm px-3 py-2">
                                                    @genre.Trim()
                                                </a>
                                            }
                                        </div>
                                    }

                                    @if (selectedMovie.Directors.Any())
                                    {
                                        <p class="mb-2 text-dark fs-6"><strong>Director:</strong> 
                                            @foreach (var dir in selectedMovie.Directors)
                                            {
                                                <a href="https://www.imdb.com/find/?q=@System.Uri.EscapeDataString(dir)&s=nm" target="_blank" class="text-decoration-none text-secondary fw-semibold me-2">@dir</a>
                                            }
                                        </p>
                                    }

                                    @if (selectedMovie.Actors.Any())
                                    {
                                        <p class="mb-4 text-dark fs-6"><strong>Cast:</strong> 
                                            @foreach (var actor in selectedMovie.Actors)
                                            {
                                                <a href="https://www.imdb.com/find/?q=@System.Uri.EscapeDataString(actor)&s=nm" target="_blank" class="text-decoration-none text-secondary fw-semibold me-2">@actor</a>
                                            }
                                        </p>
                                    }
                                    
                                    <p class="card-text fs-6 text-secondary flex-grow-1" style="line-height: 1.7;">
                                        @if (string.IsNullOrEmpty(selectedMovie.Overview) && string.IsNullOrEmpty(selectedMovie.Directors.FirstOrDefault()))
                                        {
                                            <div class="d-flex align-items-center gap-2 text-secondary">
                                                <div class="spinner-border spinner-border-sm" role="status"></div>
                                                <span>Loading full details...</span>
                                            </div>
                                        }
                                        else
                                        {
                                            @(string.IsNullOrEmpty(selectedMovie.Overview) ? "No overview available." : selectedMovie.Overview)
                                        }
                                    </p>
                                    
                                    <div class="mt-4 pt-4 border-top">
                                        <a href="https://www.imdb.com/title/@selectedItem.ImdbId/" target="_blank" class="btn btn-dark btn-lg px-5 rounded-pill shadow-sm w-100 fw-semibold">
                                            Open on IMDb
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private TmdbMovie? selectedMovie;
    private WatchlistItem? selectedItem;
    private bool showFilters = false;
    private List<WatchlistItem> _filteredItems = new();

    protected override void OnInitialized()
    {
        WatchlistSvc.OnStateChanged += HandleStateChanged;
        UpdateLocalList();
    }

    private void HandleStateChanged()
    {
        UpdateLocalList();
        StateHasChanged();
    }

    private void UpdateLocalList()
    {
        _filteredItems = WatchlistSvc.FilteredItems.ToList();
    }

    public void Dispose()
    {
        WatchlistSvc.OnStateChanged -= HandleStateChanged;
    }

    private void ClearFilters()
    {
        WatchlistSvc.SearchQuery = "";
        WatchlistSvc.SelectedType = "All";
        WatchlistSvc.SelectedGenre = "All";
        WatchlistSvc.StartYear = "";
        WatchlistSvc.EndYear = "";
        WatchlistSvc.NotifyStateChanged();
    }

    private List<string> AvailableGenres => WatchlistSvc.Items
        .SelectMany(m => m.Genres.Split(','))
        .Select(g => g.Trim())
        .Where(g => !string.IsNullOrEmpty(g))
        .Distinct()
        .OrderBy(g => g)
        .ToList();

    private async Task RemoveFromWatchlistFromModal()
    {
        if (selectedItem != null)
        {
            await WatchlistSvc.RemoveFromWatchlistAsync(selectedItem);
            CloseModal();
        }
    }

    private async Task RemoveFromWatchlist(WatchlistItem item)
    {
        await WatchlistSvc.RemoveFromWatchlistAsync(item);
    }

    private async Task StartWatching(WatchlistItem item)
    {
        await WatchlistSvc.UpdateStatusAsync(item, WatchlistStatus.Watching);
        StateHasChanged();
    }
    
    private async Task ShowMovieDetails(WatchlistItem item)
    {
        selectedItem = item;
        // Show basic info instantly
        selectedMovie = new TmdbMovie 
        { 
            Title = item.Title, 
            OriginalTitle = item.OriginalTitle,
            ReleaseDate = item.Year
        };
        StateHasChanged();

        // Load full details in background
        var fullDetails = await WatchlistSvc.GetTmdbDetailsAsync(item.ImdbId);
        if (fullDetails != null && selectedItem == item) // Ensure we haven't switched movies
        {
            selectedMovie = fullDetails;
            StateHasChanged();
        }
    }

    private async Task ShowRandomMovie()
    {
        var filtered = WatchlistSvc.FilteredItems.ToList();
        if (filtered.Any())
        {
            var random = new Random();
            var item = filtered[random.Next(filtered.Count)];
            await ShowMovieDetails(item);
        }
    }

    private void CloseModal()
    {
        selectedMovie = null;
        selectedItem = null;
    }
}
