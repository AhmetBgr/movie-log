@page "/watchlist"
@inject WatchlistService WatchlistSvc

<PageTitle>Watchlist Table</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>📑 Watchlist Data</h1>
        <span class="badge bg-primary fs-5">@WatchlistSvc.Items.Count Total Items</span>
    </div>

    @if (!WatchlistSvc.Items.Any())
    {
        <div class="alert alert-info shadow-sm">
            Please import a watchlist CSV file on the Home tab first.
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-body p-0 table-responsive" style="max-height: 75vh; overflow-y: auto;">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark" style="position: sticky; top: 0; z-index: 1;">
                        <tr>
                            <th scope="col" style="width: 50%;">Title</th>
                            <th scope="col" style="width: 10%;">Type</th>
                            <th scope="col" style="width: 10%;">Year</th>
                            <th scope="col" style="width: 20%;">Genres</th>
                            <th scope="col" style="width: 10%; text-align: center;">Links</th>
                        </tr>
                    </thead>
                    <tbody>
                        <Virtualize Items="WatchlistSvc.Items" Context="item" ItemSize="50">
                            <tr>
                                <td class="fw-bold" style="cursor: pointer;" @onclick="() => ShowMovieDetails(item)">
                                    <span class="text-primary" style="text-decoration: underline; text-underline-offset: 3px;">@item.Title</span>
                                </td>
                                <td>
                                    <span class="badge @(item.TitleType.Contains("Movie", StringComparison.OrdinalIgnoreCase) ? "bg-success" : "bg-info text-dark")">
                                        @item.TitleType
                                    </span>
                                </td>
                                <td>@item.Year</td>
                                <td>@item.Genres</td>
                                <td class="text-center">
                                    <a href="https://www.imdb.com/title/@item.ImdbId/" target="_blank" class="btn btn-sm btn-outline-dark">
                                        IMDb <i class="bi bi-box-arrow-up-right"></i>
                                    </a>
                                </td>
                            </tr>
                        </Virtualize>
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.85);">
            <div class="modal-dialog modal-dialog-centered justify-content-center">
                <div class="spinner-border text-light" style="width: 3rem; height: 3rem;" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        </div>
    }

    @if (selectedMovie != null && !isLoading)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.85);" @onclick="CloseModal">
            <div class="modal-dialog modal-dialog-centered modal-lg" @onclick:stopPropagation="true">
                <div class="modal-content bg-transparent border-0">
                    <div class="card bg-white text-dark shadow-lg border-0 rounded-4 overflow-hidden">
                        <div class="row g-0">
                            <div class="col-md-4 text-center p-3 bg-light d-flex align-items-center justify-content-center">
                                <img src="@selectedMovie.FullPosterUrl" class="img-fluid rounded shadow-sm" alt="Poster" style="max-height: 450px;" />
                            </div>
                            <div class="col-md-8 position-relative">
                                <button type="button" class="btn-close position-absolute top-0 end-0 m-3" aria-label="Close" @onclick="CloseModal"></button>
                                <div class="card-body p-4 d-flex flex-column h-100">
                                    <h2 class="card-title fw-bold text-primary mb-1 pe-4">
                                        <a href="https://www.imdb.com/title/@selectedItem!.ImdbId/" target="_blank" class="text-decoration-none text-primary">@selectedMovie.Title</a>
                                    </h2>
                                    
                                    @if (!string.IsNullOrEmpty(selectedMovie.ReleaseDate))
                                    {
                                        <p class="text-muted small mb-3">📅 Released: @selectedMovie.ReleaseDate</p>
                                    }

                                    <div class="mb-3">
                                        <span class="badge bg-warning text-dark fs-6 px-3 py-2 shadow-sm me-2">
                                            ⭐ @selectedMovie.VoteAverage.ToString("0.0") / 10
                                        </span>
                                        @if (!string.IsNullOrEmpty(selectedItem!.Genres))
                                        {
                                            @foreach (var genre in selectedItem.Genres.Split(','))
                                            {
                                                <a href="https://www.imdb.com/search/title/?genres=@genre.Trim().ToLower()" target="_blank" class="badge bg-secondary me-1 text-decoration-none shadow-sm">
                                                    @genre.Trim()
                                                </a>
                                            }
                                        }
                                    </div>

                                    @if (selectedMovie.Directors.Any())
                                    {
                                        <p class="mb-1 text-dark fs-6"><strong>Director:</strong> 
                                            @foreach (var dir in selectedMovie.Directors)
                                            {
                                                <a href="https://www.imdb.com/find/?q=@System.Uri.EscapeDataString(dir)&s=nm" target="_blank" class="text-decoration-none fw-semibold me-2">@dir</a>
                                            }
                                        </p>
                                    }

                                    @if (selectedMovie.Actors.Any())
                                    {
                                        <p class="mb-3 text-dark fs-6"><strong>Cast:</strong> 
                                            @foreach (var actor in selectedMovie.Actors)
                                            {
                                                <a href="https://www.imdb.com/find/?q=@System.Uri.EscapeDataString(actor)&s=nm" target="_blank" class="text-decoration-none fw-semibold me-2">@actor</a>
                                            }
                                        </p>
                                    }
                                    
                                    <p class="card-text fs-5 text-secondary flex-grow-1" style="line-height: 1.6;">
                                        @(string.IsNullOrEmpty(selectedMovie.Overview) ? "No overview available." : selectedMovie.Overview)
                                    </p>
                                    
                                    <div class="mt-4 pt-3 border-top">
                                        <a href="https://www.imdb.com/title/@selectedItem.ImdbId/" target="_blank" class="btn btn-dark btn-lg px-4 shadow-sm">
                                            🎬 Open on IMDb
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private TmdbMovie? selectedMovie;
    private WatchlistItem? selectedItem;
    private bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        if (!WatchlistSvc.Items.Any())
        {
            await WatchlistSvc.InitializeAsync();
        }
    }

    private async Task ShowMovieDetails(WatchlistItem item)
    {
        selectedItem = item;
        isLoading = true;
        // The API response is heavily cached securely in the backend, meaning
        // hovering or clicking the button repeatedly costs zero network hits! 
        selectedMovie = await WatchlistSvc.GetTmdbDetailsAsync(item.ImdbId);
        isLoading = false;
    }

    private void CloseModal()
    {
        selectedMovie = null;
        selectedItem = null;
    }
}
