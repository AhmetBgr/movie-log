@page "/watchlist"
@using MyPrivateWatchlist.Components
@using System.Runtime.InteropServices
@implements IDisposable
@inject WatchlistService WatchlistSvc
@inject IJSRuntime JS

<PageTitle>Watchlist</PageTitle>

<div class="container-fluid" style="padding-left: 4.5px; padding-right: 4.5px;">
    <style>
        @@media (max-width: 768px) {
            .container-fluid {
                padding-left: 2px !important;
                padding-right: 2px !important;
            }
            
            .d-flex.justify-content-start {
                flex-wrap: wrap !important;
            }
            
            .btn-group {
                flex-direction: column !important;
                gap: 8px !important;
            }
            
            .position-sticky {
                position: relative !important;
                max-height: none !important;
            }
        }
    </style>
    @if (!WatchlistSvc.Items.Any())
    {
        <div class="alert alert-secondary border-0 shadow-sm text-center py-4 fs-5 rounded-2">
            Please import a watchlist CSV file on Home tab or search and add movies from the Search tab.
        </div>
    }
    else
    {
        <div class="d-flex justify-content-start align-items-center mb-4 gap-2 flex-wrap">
            <button class="btn btn-sm @(showFilters ? "btn-dark shadow" : "btn-outline-secondary") rounded-2 px-3 py-2 transition-all fw-medium position-relative" @onclick="ToggleFilters">
                <i class="bi @(showFilters ? "bi-x-lg" : "bi-funnel") me-1"></i>
                Filters
                @{
                    int activeFilterCount = (!string.IsNullOrEmpty(WatchlistSvc.StartYear) ? 1 : 0)
                        + (!string.IsNullOrEmpty(WatchlistSvc.EndYear) ? 1 : 0)
                        + (WatchlistSvc.SelectedType != "All" ? 1 : 0)
                        + (WatchlistSvc.SelectedGenre != "All" ? 1 : 0)
                        + (!string.IsNullOrEmpty(WatchlistSvc.SearchQuery) ? 1 : 0)
                        + (WatchlistSvc.FilterMinVote > 0 ? 1 : 0)
                        + (WatchlistSvc.FilterMaxVote < 10 ? 1 : 0);
                }
                @if (activeFilterCount > 0 && !showFilters)
                {
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">@activeFilterCount</span>
                }
            </button>
            
            <button class="btn btn-sm @(isEditing ? "btn-dark shadow" : "btn-outline-secondary") rounded-2 px-3 py-2 transition-all fw-medium" @onclick="ToggleEdit">
                <i class="bi @(isEditing ? "bi-check-lg" : "bi-pencil") me-1"></i> 
                @(isEditing ? "Done" : "Edit")
            </button>
        </div>
        
        <div class="row g-4 h-100">
            @if (showFilters)
            {
                <div class="col-md-3 position-sticky top-0 h-100" style="max-height: 88vh; overflow-y: auto;">
                    <div class="card shadow-sm border-0 rounded-2 bg-white sticky-top">
                        <div class="card-body p-4">
                            <h5 class="fw-bold text-dark mb-4 border-bottom pb-2">Refine List</h5>
                            
                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary text-uppercase tracking-wider">Search Title</label>
                                <div class="input-group shadow-none border rounded-2 overflow-hidden">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                                    <input type="text" class="form-control border-0 bg-light shadow-none" placeholder="Search..." 
                                           @bind="WatchlistSvc.SearchQuery" @bind:event="oninput" />
                                </div>
                            </div>
                            
                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary text-uppercase tracking-wider">Genre</label>
                                <select class="form-select border rounded-2 bg-light shadow-none" @bind="WatchlistSvc.SelectedGenre">
                                    <option value="All">All Genres</option>
                                    @foreach (var genre in AvailableGenres)
                                    {
                                        <option value="@genre">@genre</option>
                                    }
                                </select>
                            </div>
                            
                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary text-uppercase tracking-wider">Type</label>
                                <select class="form-select border rounded-2 bg-light shadow-none" @bind="WatchlistSvc.SelectedType">
                                    <option value="All">All Types</option>
                                    <option value="Movie">Movies</option>
                                    <option value="TV Series">TV Series</option>
                                </select>
                            </div>
                            
                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary text-uppercase tracking-wider">Year Range</label>
                                <div class="d-flex gap-2">
                                    <input type="number" class="form-control border rounded-2 bg-light shadow-none px-2" placeholder="From" 
                                           @bind="WatchlistSvc.StartYear" />
                                    <input type="number" class="form-control border rounded-2 bg-light shadow-none px-2" placeholder="To" 
                                           @bind="WatchlistSvc.EndYear" />
                                </div>
                            </div>
                            
                            <div class="mb-4">
                                <label class="form-label small fw-bold text-secondary text-uppercase tracking-wider">TMDB Rating</label>
                                <div class="d-flex gap-2 align-items-center">
                                    <select class="form-select form-select-sm border rounded-2 bg-light shadow-none py-1"
                                            value="@WatchlistSvc.FilterMinVote"
                                            @onchange="@(e => WatchlistSvc.FilterMinVote = double.Parse(e.Value?.ToString() ?? "0", System.Globalization.CultureInfo.InvariantCulture))">
                                        @for (int i = 0; i <= 10; i++)
                                        {
                                            <option value="@i">@i</option>
                                        }
                                    </select>
                                    <span class="text-secondary x-small">to</span>
                                    <select class="form-select form-select-sm border rounded-2 bg-light shadow-none py-1"
                                            value="@WatchlistSvc.FilterMaxVote"
                                            @onchange="@(e => WatchlistSvc.FilterMaxVote = double.Parse(e.Value?.ToString() ?? "10", System.Globalization.CultureInfo.InvariantCulture))">
                                        @for (int i = 0; i <= 10; i++)
                                        {
                                            <option value="@i">@i</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            
                            <div class="d-grid gap-2 pt-2">
                                <button class="btn btn-dark rounded-pill py-2 shadow-sm border-0 fw-semibold" @onclick="WatchlistSvc.ShowRandomMovieAsync">
                                    <i class="bi bi-dice-5 me-2"></i> Pick Random Movie
                                </button>
                                <button class="btn btn-outline-secondary btn-sm border-0 py-2" @onclick="ClearFilters">
                                    <i class="bi bi-eraser me-2"></i> Clear All Filters
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
            
            <div class="col-md-@(showFilters ? "9" : "12")">
                <!-- Card View -->
                <div class="p-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0 fw-bold">@WatchlistSvc.FilteredItems.Count() Movies</h5>
                        <div class="d-flex gap-2 flex-wrap">
                            <button class="btn btn-sm @(WatchlistSvc.SortColumn == "Title" ? "btn-dark" : "btn-outline-secondary")" @onclick='() => WatchlistSvc.ToggleSort("Title")'>
                                    <i class="bi bi-sort-alpha-down me-1"></i> Title
                                </button>
                                <button class="btn btn-sm @(WatchlistSvc.SortColumn == "Year" ? "btn-dark" : "btn-outline-secondary")" @onclick='() => WatchlistSvc.ToggleSort("Year")'>
                                    <i class="bi bi-sort-numeric-down me-1"></i> Year
                                </button>
                                <button class="btn btn-sm @(WatchlistSvc.SortColumn == "DateAdded" ? "btn-dark" : "btn-outline-secondary")" @onclick='() => WatchlistSvc.ToggleSort("DateAdded")'>
                                    <i class="bi bi-calendar-plus me-1"></i> Date Added
                                </button>
                            </div>
                        </div>
                        
                        @* Split into two loops so isEditing is evaluated OUTSIDE RenderFragment lambdas *@
                        @if (isEditing)
                        {
                            <div class="row row-cols-1 g-3">
                                @foreach (var item in WatchlistSvc.FilteredItems)
                                {
                                    var capturedItem = item;
                                    <div class="col">
                                        <MovieCard Item="capturedItem" ShowEditControls="true" ShowActionButtons="true">
                                            <SidePanel>
                                                @switch (capturedItem.Status)
                                                {
                                                    case WatchlistStatus.Pending:
                                                        <button class="btn btn-sm action-btn action-btn-success"
                                                                @onclick:stopPropagation="true"
                                                                @onclick="() => WatchlistSvc.UpdateStatusAsync(capturedItem, WatchlistStatus.Watching)"
                                                                title="Start Watching">
                                                            <i class="bi bi-play-fill fs-5"></i>
                                                        </button>
                                                        <button class="btn btn-sm action-btn action-btn-primary"
                                                                @onclick:stopPropagation="true"
                                                                @onclick="() => WatchlistSvc.UpdateStatusAsync(capturedItem, WatchlistStatus.Watched)"
                                                                title="Mark as Watched">
                                                            <i class="bi bi-check-lg fs-5"></i>
                                                        </button>
                                                        <button class="btn btn-sm action-btn action-btn-danger"
                                                                @onclick:stopPropagation="true"
                                                                @onclick="() => WatchlistSvc.RemoveFromWatchlistAsync(capturedItem)"
                                                                title="Remove from library">
                                                            <i class="bi bi-trash3-fill fs-5"></i>
                                                        </button>
                                                        break;
                                                    case WatchlistStatus.Watching:
                                                        <button class="btn btn-sm action-btn action-btn-primary"
                                                                @onclick:stopPropagation="true"
                                                                @onclick="() => WatchlistSvc.UpdateStatusAsync(capturedItem, WatchlistStatus.Watched)"
                                                                title="Mark as Watched">
                                                            <i class="bi bi-check-lg fs-5"></i>
                                                        </button>
                                                        <button class="btn btn-sm action-btn action-btn-danger"
                                                                @onclick:stopPropagation="true"
                                                                @onclick="() => WatchlistSvc.RemoveFromWatchlistAsync(capturedItem)"
                                                                title="Remove from library">
                                                            <i class="bi bi-trash3-fill fs-5"></i>
                                                        </button>
                                                        break;
                                                    case WatchlistStatus.Watched:
                                                        <button class="btn btn-sm action-btn action-btn-success"
                                                                @onclick:stopPropagation="true"
                                                                @onclick="() => WatchlistSvc.UpdateStatusAsync(capturedItem, WatchlistStatus.Watching)"
                                                                title="Watch Again">
                                                            <i class="bi bi-arrow-repeat fs-5"></i>
                                                        </button>
                                                        <button class="btn btn-sm action-btn action-btn-danger"
                                                                @onclick:stopPropagation="true"
                                                                @onclick="() => WatchlistSvc.RemoveFromWatchlistAsync(capturedItem)"
                                                                title="Remove from library">
                                                            <i class="bi bi-trash3-fill fs-5"></i>
                                                        </button>
                                                        break;
                                                }
                                            </SidePanel>
                                        </MovieCard>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="row row-cols-1 g-3">
                                @foreach (var item in WatchlistSvc.FilteredItems)
                                {
                                    <div class="col">
                                        <MovieCard Item="item" ShowEditControls="false" ShowActionButtons="true" />
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
    }
</div>

@code {
    private bool isEditing = false;
    private bool showFilters = false;
    private List<WatchlistItem> _filteredItems = new();
    private List<string> _availableGenres = new();
    
    protected override void OnInitialized()
    {
        WatchlistSvc.OnStateChanged += StateHasChanged;
        UpdateFilteredItems();
        
        // Auto-enable card view on mobile
        if (OperatingSystem.IsBrowser() && RuntimeInformation.IsOSPlatform(OSPlatform.Create("WEB")))
        {
            // Simple mobile detection - can be enhanced
            var userAgent = System.Text.RegularExpressions.Regex.Match(Environment.GetEnvironmentVariable("HTTP_USER_AGENT") ?? "", 
                "(Mobile|Android|iPhone|iPad)", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            showFilters = userAgent.Success;
        }
    }
    
    protected override void OnParametersSet()
    {
        UpdateFilteredItems();
    }
    
    private void UpdateFilteredItems()
    {
        _filteredItems = WatchlistSvc.FilteredItems.ToList();
        _availableGenres = WatchlistSvc.Items
            .SelectMany(m => (m.Genres ?? "").Split(','))
            .Select(g => g.Trim())
            .Where(g => !string.IsNullOrEmpty(g))
            .Distinct()
            .OrderBy(g => g)
            .ToList();
    }
    
    private void ToggleEdit() => isEditing = !isEditing;
    private void ToggleFilters() => showFilters = !showFilters;
    
    private async Task StartWatching(WatchlistItem item)
    {
        await WatchlistSvc.UpdateStatusAsync(item, WatchlistStatus.Watching);
    }
    
    private async Task MarkAsWatched(WatchlistItem item)
    {
        await WatchlistSvc.UpdateStatusAsync(item, WatchlistStatus.Watched);
    }
    
    private void ClearFilters()
    {
        WatchlistSvc.StartYear = "";
        WatchlistSvc.EndYear = "";
        WatchlistSvc.SelectedGenre = "All";
        WatchlistSvc.SelectedType = "All";
        WatchlistSvc.SearchQuery = "";
        WatchlistSvc.FilterMinVote = 0;
        WatchlistSvc.FilterMaxVote = 10;
    }
    
    private List<string> AvailableGenres => _availableGenres;
    
    public void Dispose()
    {
        WatchlistSvc.OnStateChanged -= StateHasChanged;
    }
    
    private static string Get1337xSearchUrl(WatchlistItem item)
    {
        var query = string.IsNullOrWhiteSpace(item.Year)
            ? (item.Title ?? "").Trim()
            : $"{item.Title?.Trim()} {item.Year?.Trim()}".Trim();
        var encoded = System.Net.WebUtility.UrlEncode(query) ?? "";
        return $"https://1337x.to/search/{encoded}/1/";
    }
}

<style>
    .overview-text {
        font-size: 0.875rem;
        color: #4a5568; /* Slate gray for soft but readable text */
        letter-spacing: 0.01em;
    }
    .x-small { font-size: 0.65rem; }
    .sticky-top { top: 1rem; }
</style>
