@page "/watchlist"
@using MyPrivateWatchlist.Models
@using MyPrivateWatchlist.Components
@using System.Runtime.InteropServices
@implements IDisposable
@inject WatchlistService WatchlistSvc
@inject IJSRuntime JS

<PageTitle>Watchlist</PageTitle>

<div class="page-shell">

    @if (!WatchlistSvc.Items.Any())
    {
        <div class="page-content" style="overflow-y:auto;display:flex;align-items:center;justify-content:center;">
            <div class="alert alert-secondary border-0 shadow-sm text-center py-4 fs-5 rounded-2 mx-3">
                Import a watchlist CSV on the Home tab or add movies from the Search tab.
            </div>
        </div>
    }
    else
    {
        <!-- ── Primary toolbar ────────────────────────────────── -->
        <div class="toolbar-primary">
            <button class="tb-btn @(showFilters ? "active" : "") position-relative" @onclick="ToggleFilters">
                <i class="bi bi-funnel"></i>
                <span class="tb-label">Filters</span>
                @if (activeFilterCount > 0 && !showFilters)
                {
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                          style="font-size:0.55rem;padding:2px 5px;min-width:16px;">@activeFilterCount</span>
                }
            </button>

            <button class="tb-btn @(isEditing ? "active" : "")" @onclick="ToggleEdit">
                <i class="bi @(isEditing ? "bi-check-lg" : "bi-pencil")"></i>
                <span class="tb-label">@(isEditing ? "Done" : "Edit")</span>
            </button>

            <div class="tb-divider"></div>

            <button class="tb-btn tb-btn-sort @(WatchlistSvc.SortColumn == "Title" ? "sorted" : "")"
                    @onclick='() => WatchlistSvc.ToggleSort("Title")'>
                <i class="bi bi-sort-alpha-down"></i>
                <span class="tb-label">Title</span>
            </button>
            <button class="tb-btn tb-btn-sort @(WatchlistSvc.SortColumn == "Year" ? "sorted" : "")"
                    @onclick='() => WatchlistSvc.ToggleSort("Year")'>
                <i class="bi bi-sort-numeric-down"></i>
                <span class="tb-label">Year</span>
            </button>
            <button class="tb-btn tb-btn-sort @(WatchlistSvc.SortColumn == "DateAdded" ? "sorted" : "")"
                    @onclick='() => WatchlistSvc.ToggleSort("DateAdded")'>
                <i class="bi bi-calendar-plus"></i>
                <span class="tb-label">Added</span>
            </button>

            <div class="tb-spacer"></div>
            <span class="text-secondary d-none d-sm-inline" style="font-size:0.76rem;white-space:nowrap;">@_filteredItems.Count items</span>

            <!-- View toggle -->
            <div class="tb-divider"></div>
            <button class="tb-btn @(!isCardView ? "active" : "")" @onclick="() => isCardView = false" title="Table view">
                <i class="bi bi-table"></i>
            </button>
            <button class="tb-btn @(isCardView ? "active" : "")" @onclick="() => isCardView = true" title="Card view">
                <i class="bi bi-card-list"></i>
            </button>
        </div>

        <!-- ── Action bar ──────────────────────────────────────── -->
        @if (isEditing)
        {
            <div class="toolbar-actions @(_selectedIds.Count > 0 ? "has-selection" : "")">
                <input type="checkbox" class="form-check-input shadow-none flex-shrink-0"
                       style="width:17px;height:17px;cursor:pointer;margin-right:6px;"
                       checked="@IsAllSelected" @onchange="ToggleSelectAll"
                       title="Select all" />
                @if (_selectedIds.Count > 0)
                {
                    <span class="sel-badge">@_selectedIds.Count selected</span>
                    <button class="tb-btn tb-btn-success live" @onclick="BulkStartWatching">
                        <i class="bi bi-play-fill"></i>
                        <span class="tb-label">Start Watching</span>
                    </button>
                    <button class="tb-btn tb-btn-primary live" @onclick="BulkMarkWatched">
                        <i class="bi bi-check-lg"></i>
                        <span class="tb-label">Mark Watched</span>
                    </button>
                    <button class="tb-btn tb-btn-danger live" @onclick="BulkRemove">
                        <i class="bi bi-trash3-fill"></i>
                        <span class="tb-label">Remove</span>
                    </button>
                }
                else
                {
                    <span class="sel-hint"><i class="bi bi-check2-square me-1 opacity-50"></i>Select items to perform bulk actions</span>
                }
            </div>
        }

        <!-- ── Content: sidebar + main ────────────────────────── -->
        <div class="page-content">

            <!-- Filter sidebar -->
            @if (showFilters)
            {
                <div class="filter-sidebar">
                    <h6 class="fw-bold mb-3">Refine List</h6>
                    <div class="mb-3">
                        <label class="filter-label">Search</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-search text-secondary"></i></span>
                            <input type="text" class="form-control border-start-0 bg-light shadow-none" placeholder="Title…"
                                   @bind="WatchlistSvc.SearchQuery" @bind:event="oninput" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="filter-label">Genre</label>
                        <select class="form-select form-select-sm bg-light shadow-none" @bind="WatchlistSvc.SelectedGenre">
                            <option value="All">All genres</option>
                            @foreach (var g in AvailableGenres) { <option value="@g">@g</option> }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="filter-label">Type</label>
                        <select class="form-select form-select-sm bg-light shadow-none" @bind="WatchlistSvc.SelectedType">
                            <option value="All">All types</option>
                            <option value="Movie">Movies</option>
                            <option value="TV Series">TV Series</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="filter-label">Year range</label>
                        <div class="d-flex gap-2">
                            <input type="number" class="form-control form-control-sm bg-light shadow-none" placeholder="From" @bind="WatchlistSvc.StartYear" />
                            <input type="number" class="form-control form-control-sm bg-light shadow-none" placeholder="To" @bind="WatchlistSvc.EndYear" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="filter-label">TMDB rating</label>
                        <div class="d-flex gap-2 align-items-center">
                            <select class="form-select form-select-sm bg-light shadow-none"
                                    value="@WatchlistSvc.FilterMinVote"
                                    @onchange="@(e => WatchlistSvc.FilterMinVote = double.Parse(e.Value?.ToString() ?? "0", System.Globalization.CultureInfo.InvariantCulture))">
                                @for (int i = 0; i <= 10; i++) { <option value="@i">@i</option> }
                            </select>
                            <span class="text-secondary" style="font-size:0.75rem;">–</span>
                            <select class="form-select form-select-sm bg-light shadow-none"
                                    value="@WatchlistSvc.FilterMaxVote"
                                    @onchange="@(e => WatchlistSvc.FilterMaxVote = double.Parse(e.Value?.ToString() ?? "10", System.Globalization.CultureInfo.InvariantCulture))">
                                @for (int i = 0; i <= 10; i++) { <option value="@i">@i</option> }
                            </select>
                        </div>
                    </div>
                    <div class="d-grid gap-2 mt-4">
                        <button class="btn btn-dark btn-sm rounded-pill fw-semibold" @onclick="WatchlistSvc.ShowRandomMovieAsync">
                            <i class="bi bi-dice-5 me-1"></i> Random pick
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="ClearFilters">
                            <i class="bi bi-eraser me-1"></i> Clear filters
                        </button>
                    </div>
                </div>
            }

            <!-- Main: table or card -->
            <div class="content-scroll">
                @if (!isCardView)
                {
                    <!-- TABLE VIEW -->
                    <div class="table-wrap">
                    <table class="table table-hover align-middle mb-0">
                        <tbody>
                            @if (!_filteredItems.Any())
                            {
                                <tr><td colspan="6" class="py-5 text-center text-secondary fst-italic opacity-50">No movies match your filters.</td></tr>
                            }
                            <Virtualize Items="_filteredItems" Context="item" ItemSize="72" OverscanCount="5">
                                <tr @key="item.ImdbId" style="cursor:pointer;" class="@(_selectedIds.Contains(item.ImdbId) ? "row-selected" : "")" @onclick="() => WatchlistSvc.ShowDetailsAsync(item)">
                                    @if (isEditing)
                                    {
                                        <td class="px-3 text-center" style="width:1%;white-space:nowrap;" @onclick:stopPropagation="true">
                                            <input type="checkbox" class="form-check-input shadow-none" style="width:17px;height:17px;cursor:pointer;"
                                                   checked="@_selectedIds.Contains(item.ImdbId)"
                                                   @onchange="() => ToggleSelect(item.ImdbId)" />
                                        </td>
                                    }
                                    <td class="px-2 py-1" style="width:52px;">
                                        <div class="poster-thumb">
                                            @if (!string.IsNullOrEmpty(item.FullPosterUrl) && !item.FullPosterUrl.Contains("data:image/png;base64"))
                                            {
                                                <img src="@item.FullPosterUrl" alt="@item.Title" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                                <div class="poster-fallback" style="display:none;"><i class="bi bi-film"></i></div>
                                            }
                                            else { <div class="poster-fallback"><i class="bi bi-film"></i></div> }
                                        </div>
                                    </td>
                                    <td class="px-3">
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="fw-bold text-dark title-hover">@item.Title</span>
                                            <a class="ext-link" href="@Get1337xSearchUrl(item)" target="_blank" rel="noopener noreferrer" title="Search on 1337x" @onclick:stopPropagation="true">
                                                <i class="bi bi-box-arrow-up-right"></i>
                                            </a>
                                        </div>
                                        @if (!string.IsNullOrEmpty(item.Director))
                                        {
                                            <span class="text-secondary d-block" style="font-size:0.72rem;opacity:0.75;">@item.Director</span>
                                        }
                                        <span class="row-meta">@item.Year · Added @item.DateAdded.ToString("MMM dd, yyyy")</span>
                                    </td>
                                    <td class="px-3 d-none d-md-table-cell">
                                        <span class="badge rounded-pill @(item.TitleType?.Contains("TV", StringComparison.OrdinalIgnoreCase) == true ? "bg-light text-dark border" : "bg-secondary text-white")">@item.TitleType</span>
                                    </td>
                                    <td class="px-3 d-none d-lg-table-cell">
                                        <div class="d-flex flex-wrap gap-1">
                                            @foreach (var genre in (item.Genres ?? "").Split(',').Take(3))
                                            {
                                                if (!string.IsNullOrWhiteSpace(genre)) { <span class="genre-pill">@genre.Trim()</span> }
                                            }
                                        </div>
                                    </td>
                                </tr>
                            </Virtualize>
                        </tbody>
                    </table>
                    </div>
                }
                else
                {
                    <!-- CARD VIEW -->
                    @if (!_filteredItems.Any())
                    {
                        <p class="text-center text-secondary opacity-50 fst-italic py-5">No movies match your filters.</p>
                    }
                    <div class="table-wrap table-wrap--wide p-3">
                        <div class="row row-cols-1 g-3">
                            @foreach (var item in _filteredItems)
                            {
                                <div class="col">
                                    <MovieCard Item="item"
                                               IsEditMode="@isEditing"
                                               IsSelected="@_selectedIds.Contains(item.ImdbId)"
                                               OnToggleSelect="@(() => ToggleSelect(item.ImdbId))"
                                               ShowActionButtons="true" />
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

        </div>
    }
</div>

@code {
    private bool isEditing = false;
    private bool showFilters = true;
    private bool isCardView = false;
    private HashSet<string> _selectedIds = new();
    private List<WatchlistItem> _filteredItems = new();
    private List<string> _availableGenres = new();

    private int activeFilterCount => (!string.IsNullOrEmpty(WatchlistSvc.StartYear) ? 1 : 0)
        + (!string.IsNullOrEmpty(WatchlistSvc.EndYear) ? 1 : 0)
        + (WatchlistSvc.SelectedType != "All" ? 1 : 0)
        + (WatchlistSvc.SelectedGenre != "All" ? 1 : 0)
        + (!string.IsNullOrEmpty(WatchlistSvc.SearchQuery) ? 1 : 0)
        + (WatchlistSvc.FilterMinVote > 0 ? 1 : 0)
        + (WatchlistSvc.FilterMaxVote < 10 ? 1 : 0);

    private bool IsAllSelected => _filteredItems.Count > 0 && _filteredItems.All(i => _selectedIds.Contains(i.ImdbId));
    private void ToggleSelectAll() { if (IsAllSelected) _selectedIds.Clear(); else _selectedIds = _filteredItems.Select(i => i.ImdbId).ToHashSet(); }
    private void ToggleSelect(string id) { if (!_selectedIds.Remove(id)) _selectedIds.Add(id); }
    private void ToggleEdit() { isEditing = !isEditing; if (!isEditing) _selectedIds.Clear(); }
    private void ToggleFilters() => showFilters = !showFilters;

    protected override void OnInitialized() { WatchlistSvc.OnStateChanged += HandleStateChanged; SyncItems(); }
    public void Dispose() => WatchlistSvc.OnStateChanged -= HandleStateChanged;
    private void HandleStateChanged() { SyncItems(); _selectedIds.IntersectWith(_filteredItems.Select(i => i.ImdbId).ToHashSet()); StateHasChanged(); }

    private void SyncItems()
    {
        _filteredItems = WatchlistSvc.FilteredItems.ToList();
        _availableGenres = WatchlistSvc.Items.SelectMany(m => (m.Genres ?? "").Split(','))
            .Select(g => g.Trim()).Where(g => !string.IsNullOrEmpty(g)).Distinct().OrderBy(g => g).ToList();
    }

    private async Task BulkStartWatching() { foreach (var i in _filteredItems.Where(i => _selectedIds.Contains(i.ImdbId)).ToList()) await WatchlistSvc.UpdateStatusAsync(i, WatchlistStatus.Watching); _selectedIds.Clear(); }
    private async Task BulkMarkWatched() { foreach (var i in _filteredItems.Where(i => _selectedIds.Contains(i.ImdbId)).ToList()) await WatchlistSvc.UpdateStatusAsync(i, WatchlistStatus.Watched); _selectedIds.Clear(); }
    private async Task BulkRemove() { foreach (var i in _filteredItems.Where(i => _selectedIds.Contains(i.ImdbId)).ToList()) await WatchlistSvc.RemoveFromWatchlistAsync(i); _selectedIds.Clear(); }

    private void ClearFilters()
    {
        WatchlistSvc.StartYear = ""; WatchlistSvc.EndYear = ""; WatchlistSvc.SelectedGenre = "All";
        WatchlistSvc.SelectedType = "All"; WatchlistSvc.SearchQuery = "";
        WatchlistSvc.FilterMinVote = 0; WatchlistSvc.FilterMaxVote = 10;
    }

    private List<string> AvailableGenres => _availableGenres;

    private static string Get1337xSearchUrl(WatchlistItem item)
    {
        var q = string.IsNullOrWhiteSpace(item.Year) ? item.Title?.Trim() ?? "" : $"{item.Title?.Trim()} {item.Year?.Trim()}".Trim();
        return $"https://1337x.to/search/{System.Net.WebUtility.UrlEncode(q)}/1/";
    }
}

<style>
    .filter-sidebar {
        width: 374px; flex-shrink: 0; overflow-y: auto;
        border-right: 1px solid rgba(0,0,0,0.08); padding: 16px; background: #fff;
    }
    .filter-label { display:block; font-size:0.67rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:#888; margin-bottom:6px; }
    .content-scroll { flex: 1; overflow-y: auto; overflow-x: hidden; min-height: 0; min-width: 0; }
    .title-hover { transition: opacity 0.15s; }
    .title-hover:hover { opacity: 0.6; }
    .ext-link { opacity: 0; width: 20px; height: 20px; display: inline-flex; align-items: center; justify-content: center; color: #888; font-size: 0.7rem; transition: opacity 0.15s; text-decoration: none; }
    tr:hover .ext-link { opacity: 1; }
    .poster-thumb { width: 40px; height: 60px; border-radius: 4px; overflow: hidden; background: #f0f0f0; flex-shrink: 0; }
    .poster-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .poster-fallback { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #ccc; font-size: 1rem; }
    .genre-pill { font-size: 0.62rem; font-weight: 500; color: #555; background: #f4f4f4; border: 1px solid #e4e4e4; border-radius: 20px; padding: 1px 7px; white-space: nowrap; }
    /* Mobile handled by app.css */
</style>
