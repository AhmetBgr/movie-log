@page "/watchlist"
@inject WatchlistService WatchlistSvc

<PageTitle>Watchlist Table</PageTitle>

<div class="container-fluid mt-4">
    @if (!WatchlistSvc.Items.Any())
    {
        <div class="alert alert-secondary border-0 shadow-sm text-center py-4 fs-5 rounded-2">
            Please import a watchlist CSV file on the Home tab first.
        </div>
    }
    else
    {
        <div class="card shadow border-0 overflow-hidden rounded-2">
            <div class="card-body p-0 table-responsive bg-white" style="max-height: 85vh; overflow-y: auto;">
                <table class="table table-hover align-middle mb-0 border-light">
                    <thead class="bg-light text-secondary fw-semibold" style="position: sticky; top: 0; z-index: 1;">
                        <tr>
                            <th scope="col" style="width: 50%;" class="border-bottom py-3 px-4">
                                Title <span class="badge bg-secondary text-white shadow-sm fw-normal ms-2 rounded-2 px-2 py-1">@WatchlistSvc.Items.Count Total Items</span>
                            </th>
                            <th scope="col" style="width: 10%;" class="border-bottom py-3">Year</th>
                            <th scope="col" style="width: 10%;" class="border-bottom py-3">Type</th>
                            <th scope="col" style="width: 20%;" class="border-bottom py-3">Genres</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        <Virtualize Items="WatchlistSvc.Items" Context="item" ItemSize="56">
                            <tr>
                                <td style="cursor: pointer;" class="px-4" @onclick="() => ShowMovieDetails(item)">
                                    <span class="fw-bold text-dark" style="transition: opacity 0.2s;" onmouseover="this.style.opacity='0.6'" onmouseout="this.style.opacity='1'">
                                        @item.Title
                                    </span>
                                </td>
                                <td class="text-secondary fw-medium">@item.Year</td>
                                <td>
                                    <span class="badge rounded-pill @(item.TitleType.Contains("Movie", StringComparison.OrdinalIgnoreCase) ? "bg-secondary text-white" : "bg-light text-dark border")">
                                        @item.TitleType
                                    </span>
                                </td>
                                <td class="text-secondary small">@item.Genres</td>
                            </tr>
                        </Virtualize>
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.85);">
            <div class="modal-dialog modal-dialog-centered justify-content-center">
                <div class="spinner-border text-light" style="width: 3rem; height: 3rem;" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        </div>
    }

    @if (selectedMovie != null && !isLoading)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.85);" @onclick="CloseModal">
            <div class="modal-dialog modal-dialog-centered modal-xl" @onclick:stopPropagation="true">
                <div class="modal-content bg-transparent border-0">
                    <div class="card bg-white text-dark shadow-lg border-0 rounded-2 overflow-hidden">
                        <div class="row g-0">
                            <div class="col-md-5 text-center p-0 bg-dark d-flex align-items-center justify-content-center">
                                <img src="@selectedMovie.FullPosterUrl" class="img-fluid px-2 py-2" alt="Poster" style="object-fit: contain; max-height: 100%; width: 100%;" />
                            </div>
                            <div class="col-md-7 position-relative">
                                <button type="button" class="btn-close position-absolute top-0 end-0 m-4" aria-label="Close" @onclick="CloseModal"></button>
                                <div class="card-body p-5 d-flex flex-column h-100">
                                    <h2 class="card-title fw-bolder text-dark mb-1 pe-4">
                                        <a href="https://www.imdb.com/title/@selectedItem!.ImdbId/" target="_blank" class="text-decoration-none text-dark" onmouseover="this.style.opacity='0.6'" onmouseout="this.style.opacity='1'">@selectedMovie.Title</a>
                                    </h2>
                                    
                                    @if (!string.IsNullOrEmpty(selectedMovie.ReleaseDate))
                                    {
                                        <p class="text-secondary fw-semibold small mb-4 text-uppercase tracking-wide">Released: @selectedMovie.ReleaseDate</p>
                                    }

                                    <div class="mb-4">
                                        <span class="badge bg-dark text-white fs-6 px-3 py-2 rounded-pill shadow-sm me-2">
                                            @selectedMovie.VoteAverage.ToString("0.0") / 10
                                        </span>
                                        @if (!string.IsNullOrEmpty(selectedItem!.Genres))
                                        {
                                            @foreach (var genre in selectedItem.Genres.Split(','))
                                            {
                                                <a href="https://www.imdb.com/search/title/?genres=@genre.Trim().ToLower()" target="_blank" class="badge bg-light text-dark border me-1 text-decoration-none rounded-pill shadow-sm px-3 py-2">
                                                    @genre.Trim()
                                                </a>
                                            }
                                        }
                                    </div>

                                    @if (selectedMovie.Directors.Any())
                                    {
                                        <p class="mb-2 text-dark fs-6"><strong>Director:</strong> 
                                            @foreach (var dir in selectedMovie.Directors)
                                            {
                                                <a href="https://www.imdb.com/find/?q=@System.Uri.EscapeDataString(dir)&s=nm" target="_blank" class="text-decoration-none text-secondary fw-semibold me-2">@dir</a>
                                            }
                                        </p>
                                    }

                                    @if (selectedMovie.Actors.Any())
                                    {
                                        <p class="mb-4 text-dark fs-6"><strong>Cast:</strong> 
                                            @foreach (var actor in selectedMovie.Actors)
                                            {
                                                <a href="https://www.imdb.com/find/?q=@System.Uri.EscapeDataString(actor)&s=nm" target="_blank" class="text-decoration-none text-secondary fw-semibold me-2">@actor</a>
                                            }
                                        </p>
                                    }
                                    
                                    <p class="card-text fs-6 text-secondary flex-grow-1" style="line-height: 1.7;">
                                        @(string.IsNullOrEmpty(selectedMovie.Overview) ? "No overview available." : selectedMovie.Overview)
                                    </p>
                                    
                                    <div class="mt-4 pt-4 border-top">
                                        <a href="https://www.imdb.com/title/@selectedItem.ImdbId/" target="_blank" class="btn btn-dark btn-lg px-5 rounded-pill shadow-sm w-100 fw-semibold">
                                            Open on IMDb
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private TmdbMovie? selectedMovie;
    private WatchlistItem? selectedItem;
    private bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        if (!WatchlistSvc.Items.Any())
        {
            await WatchlistSvc.InitializeAsync();
        }
    }

    private async Task ShowMovieDetails(WatchlistItem item)
    {
        selectedItem = item;
        isLoading = true;
        selectedMovie = await WatchlistSvc.GetTmdbDetailsAsync(item.ImdbId);
        isLoading = false;
    }

    private void CloseModal()
    {
        selectedMovie = null;
        selectedItem = null;
    }
}
