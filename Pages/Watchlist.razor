@page "/watchlist"
@inject NavigationManager NavManager

@code {
    protected override void OnInitialized()
    {
        NavManager.NavigateTo("/library/watchlist", true);
    }
}

<style>
    /* Filter panel styles removed, logic moved to component */
    .content-scroll { flex: 1; overflow-y: auto; overflow-x: hidden; min-height: 0; min-width: 0; }
    .title-hover { transition: opacity 0.15s; }
    .title-hover:hover { opacity: 0.6; }
    .poster-thumb { width: 40px; height: 60px; border-radius: 4px; overflow: hidden; background: #f0f0f0; flex-shrink: 0; }
    .poster-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .poster-fallback { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #ccc; font-size: 1rem; }
    .genre-pill { font-size: 0.62rem; font-weight: 500; color: #555; background: #f4f4f4; border: 1px solid #e4e4e4; border-radius: 20px; padding: 1px 7px; white-space: nowrap; }

    .filter-panel-wrapper {
        display: flex;
        z-index: 100;
    }

    @@media (max-width: 650px) {
        .filter-panel-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(16, 27, 75, 0.4); /* 161B4B with opacity */
            backdrop-filter: blur(4px);
            z-index: 2000;
        }
    }
</style>
