                                                        { <i class="bi bi-check-lg text-white" style="font-size:0.85rem;line-height:1;"></i> }
                                                    </div>
                                                </div>
                                            }


                                            <div style="width:80px;flex-shrink:0;overflow:hidden;background:#f0f0f0;">
                                                @if (!string.IsNullOrEmpty(item.FullPosterUrl) && !item.FullPosterUrl.Contains("data:image/png;base64"))
                                                {
                                                    <img src="@item.FullPosterUrl" alt="@item.Title"
                                                         style="width:100%;height:100%;object-fit:cover;display:block;min-height:110px;"
                                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
