@code {
    private bool showFilters = false;
    private double _touchStartX;
    private double _touchEndX;
    private bool isEditing = false;
    private DotNetObjectReference<Watched>? _holdRef;
    private bool isCardView = true;
    private bool showSavedIndicator = false;
    private HashSet<string> _selectedIds = new();
    private List<WatchlistItem> _watchedItems = new();
    private List<string> _availableGenres = new();

    private int gridPageIndex = 0;
    private int activeFilterCount => (WatchlistSvc.FilterMinRating20 > 0 ? 1 : 0)
        + (WatchlistSvc.FilterMaxRating20 < 100 ? 1 : 0)
        + (!string.IsNullOrEmpty(WatchlistSvc.StartYear) ? 1 : 0)
        + (!string.IsNullOrEmpty(WatchlistSvc.EndYear) ? 1 : 0)
        + (!string.IsNullOrEmpty(WatchlistSvc.SelectedGenre) && WatchlistSvc.SelectedGenre != "All" ? 1 : 0)
        + (!string.IsNullOrEmpty(WatchlistSvc.SelectedType) && WatchlistSvc.SelectedType != "All" ? 1 : 0)
        + (!string.IsNullOrEmpty(WatchlistSvc.SearchQuery) ? 1 : 0);

    private bool IsAllSelected => _watchedItems.Count > 0 && _watchedItems.All(i => _selectedIds.Contains(i.ImdbId));
    private void ToggleSelectAll() { if (IsAllSelected) _selectedIds.Clear(); else _selectedIds = _watchedItems.Select(i => i.ImdbId).ToHashSet(); }
    private void ToggleSelect(string id) { if (!_selectedIds.Remove(id)) _selectedIds.Add(id); }
    private void OnFilterTouchStart(TouchEventArgs e) => _touchStartX = e.Touches[0].ClientX;
    private void OnFilterTouchEnd(TouchEventArgs e)
    {
        _touchEndX = e.ChangedTouches[0].ClientX;
        if (_touchStartX - _touchEndX > 50) // swipe left to close
        {
            showFilters = false;
            StateHasChanged();
        }
    }
    private void ToggleFilters() => showFilters = !showFilters;
    private void ToggleEdit() { isEditing = !isEditing; if (!isEditing) _selectedIds.Clear(); }

    private void SetViewTable() { isCardView = false; _ = JS.InvokeVoidAsync("sessionStorage.setItem", "watched_view", "table"); }
    private void SetViewCard() { isCardView = true; _ = JS.InvokeVoidAsync("sessionStorage.setItem", "watched_view", "card"); }

    protected override void OnInitialized() { WatchlistSvc.OnStateChanged += HandleStateChanged; SyncItems(); }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { _holdRef = DotNetObjectReference.Create(this); await JS.InvokeVoidAsync("holdSelect.init", _holdRef); } catch {}

            var isDesktop = await JS.InvokeAsync<bool>("uiHelpers.isDesktop");
            if (isDesktop) { showFilters = true; StateHasChanged(); }

            // Restore session preferences
            try
            {
                var savedView = await JS.InvokeAsync<string?>("sessionStorage.getItem", "watched_view");
                if (!string.IsNullOrEmpty(savedView)) { isCardView = savedView == "card"; StateHasChanged(); }
            }
            catch { }
        }
    }

    private void HandleRowClick(WatchlistItem item)
    {
        if (isEditing) ToggleSelect(item.ImdbId);
        else _ = WatchlistSvc.ShowDetailsAsync(item);
    }

    [Microsoft.JSInterop.JSInvokable]
    public void OnHoldSelect(string imdbId)
    {
        if (!isEditing) isEditing = true;
        _selectedIds.Add(imdbId);
        StateHasChanged();
    }

        public void Dispose() { WatchlistSvc.OnStateChanged -= HandleStateChanged; _holdRef?.Dispose(); }

    private void HandleStateChanged()
    {
        SyncItems();
        _selectedIds.IntersectWith(_watchedItems.Select(i => i.ImdbId).ToHashSet());
        gridPageIndex = 0;
        StateHasChanged();
    }

    private void SyncItems()
    {
        _watchedItems = WatchlistSvc.WatchedItems.ToList();
        _availableGenres = WatchlistSvc.Items
            .Where(m => m.Status == WatchlistStatus.Watched)
            .SelectMany(m => (m.Genres ?? "").Split(','))
            .Select(g => g.Trim()).Where(g => !string.IsNullOrEmpty(g))
            .Distinct().OrderBy(g => g).ToList();
    }

    private async Task BulkMoveToWatchlist()
    {
        foreach (var item in _watchedItems.Where(i => _selectedIds.Contains(i.ImdbId)).ToList())
            await WatchlistSvc.UpdateStatusAsync(item, WatchlistStatus.Pending);
        _selectedIds.Clear();
    }
    private async Task BulkWatchAgain()
    {
        foreach (var item in _watchedItems.Where(i => _selectedIds.Contains(i.ImdbId)).ToList())
            await WatchlistSvc.UpdateStatusAsync(item, WatchlistStatus.Watching);
        _selectedIds.Clear();
    }
    private async Task BulkRemove()
    {
        foreach (var item in _watchedItems.Where(i => _selectedIds.Contains(i.ImdbId)).ToList())
            await WatchlistSvc.RemoveFromWatchlistAsync(item);
        _selectedIds.Clear();
    }

    private async Task UpdateRating20(WatchlistItem item, int? r)
    {
        if (r.HasValue) r = Math.Clamp(r.Value, 0, 100);
        await WatchlistSvc.UpdateRatingAsync(item, r);
        if (r.HasValue) { showSavedIndicator = true; StateHasChanged(); await Task.Delay(1500); showSavedIndicator = false; StateHasChanged(); }
    }

    private void ClearFilters()
    {
        WatchlistSvc.SearchQuery = ""; WatchlistSvc.SelectedType = "All"; WatchlistSvc.SelectedGenre = "All";
        WatchlistSvc.StartYear = ""; WatchlistSvc.EndYear = "";
        WatchlistSvc.FilterMinRating20 = 0; WatchlistSvc.FilterMaxRating20 = 100;
    }

    private List<string> AvailableGenres => _availableGenres;
    private string GetRatingColor(int val) { double hue = (val / 100.0) * 120; return $"hsl({hue},70%,45%)"; }
}

