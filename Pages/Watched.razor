@page "/watched"
@using MyPrivateWatchlist.Models
@using MyPrivateWatchlist.Components
@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc
@implements IDisposable

<PageTitle>Watched History</PageTitle>

<div class="page-shell">

    @if (!WatchlistSvc.Items.Any(i => i.Status == WatchlistStatus.Watched))
    {
        <div class="page-content" style="overflow-y:auto;display:flex;align-items:center;justify-content:center;">
            <div class="text-center py-5">
                <i class="bi bi-journal-check fs-1 d-block mb-3 text-secondary opacity-50"></i>
                <p class="fs-5 text-secondary">You haven't marked anything as watched yet.</p>
            </div>
        </div>
    }
    else
    {
        <!-- ── Primary toolbar ──────────────────────────────────── -->
        <div class="toolbar-primary">
            <button class="tb-btn @(showFilters ? "active" : "") position-relative" @onclick="ToggleFilters">
                <i class="bi bi-funnel"></i>
                <span class="tb-label">Filters</span>
                @if (activeFilterCount > 0 && !showFilters)
                {
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                          style="font-size:0.55rem;padding:2px 5px;min-width:16px;">@activeFilterCount</span>
                }
            </button>

            <button class="tb-btn @(isEditing ? "active" : "")" @onclick="ToggleEdit">
                <i class="bi @(isEditing ? "bi-check-lg" : "bi-pencil")"></i>
                <span class="tb-label">@(isEditing ? "Done" : "Edit")</span>
            </button>

            <div class="tb-divider"></div>

            <button class="tb-btn tb-btn-sort @(WatchlistSvc.WatchedSortColumn == "Title" ? "sorted" : "")"
                    @onclick='() => WatchlistSvc.ToggleWatchedSort("Title")'>
                <i class="bi @(WatchlistSvc.WatchedSortColumn == "Title"
                    ? (WatchlistSvc.WatchedSortDescending ? "bi-sort-alpha-up-alt" : "bi-sort-alpha-down")
                    : "bi-sort-alpha-down")"></i>
                <span class="tb-label">Title</span>
            </button>
            <button class="tb-btn tb-btn-sort @(WatchlistSvc.WatchedSortColumn == "Year" ? "sorted" : "")"
                    @onclick='() => WatchlistSvc.ToggleWatchedSort("Year")'>
                <i class="bi @(WatchlistSvc.WatchedSortColumn == "Year"
                    ? (WatchlistSvc.WatchedSortDescending ? "bi-sort-numeric-up-alt" : "bi-sort-numeric-down")
                    : "bi-sort-numeric-down")"></i>
                <span class="tb-label">Year</span>
            </button>
            <button class="tb-btn tb-btn-sort @(WatchlistSvc.WatchedSortColumn == "Rating" ? "sorted" : "")"
                    @onclick='() => WatchlistSvc.ToggleWatchedSort("Rating")'>
                <i class="bi bi-star"></i>
                <span class="tb-label">Rating</span>
            </button>
            <button class="tb-btn tb-btn-sort @(WatchlistSvc.WatchedSortColumn == "DateAdded" ? "sorted" : "")"
                    @onclick='() => WatchlistSvc.ToggleWatchedSort("DateAdded")'>
                <i class="bi bi-calendar-plus"></i>
                <span class="tb-label">Added</span>
            </button>

            <div class="tb-spacer"></div>
            <span class="text-secondary d-none d-sm-inline" style="font-size:0.76rem;white-space:nowrap;padding-right:4px;">@_watchedItems.Count items</span>
        </div>

        <!-- ── Action bar (edit mode only) ──────────────────────── -->
        @if (isEditing)
        {
            <div class="toolbar-actions @(_selectedIds.Count > 0 ? "has-selection" : "")">
                <input type="checkbox" class="form-check-input shadow-none flex-shrink-0"
                       style="width:17px;height:17px;cursor:pointer;margin-right:6px;"
                       checked="@IsAllSelected" @onchange="ToggleSelectAll"
                       title="Select all" />
                @if (_selectedIds.Count > 0)
                {
                    <span class="sel-badge">@_selectedIds.Count selected</span>
                    <button class="tb-btn tb-btn-primary live" @onclick="BulkMoveToWatchlist">
                        <i class="bi bi-list-nested"></i>
                        <span class="tb-label">To Watchlist</span>
                    </button>
                    <button class="tb-btn tb-btn-success live" @onclick="BulkWatchAgain">
                        <i class="bi bi-play-fill"></i>
                        <span class="tb-label">Watch Again</span>
                    </button>
                    <button class="tb-btn tb-btn-danger live" @onclick="BulkRemove">
                        <i class="bi bi-trash3-fill"></i>
                        <span class="tb-label">Remove</span>
                    </button>
                }
                else
                {
                    <span class="sel-hint"><i class="bi bi-check2-square me-1 opacity-50"></i>Select items to perform bulk actions</span>
                }
            </div>
        }

        <!-- ── Content: filter sidebar + table ──────────────────── -->
        <div class="page-content" style="position:relative;">

            @if (showSavedIndicator)
            {
                <div style="position:absolute;top:16px;left:50%;transform:translateX(-50%);z-index:50;pointer-events:none;">
                    <span class="badge bg-success shadow rounded-pill px-3 py-2 animate-fade-out" style="font-size:0.72rem;">✓ Rating saved</span>
                </div>
            }

            <!-- Filter sidebar -->
            @if (showFilters)
            {
                <div class="filter-sidebar">
                    <h6 class="fw-bold mb-3">Refine History</h6>

                    <div class="mb-3">
                        <label class="filter-label">Search</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-search text-secondary"></i></span>
                            <input type="text" class="form-control border-start-0 bg-light shadow-none" placeholder="Title or director…"
                                   @bind="WatchlistSvc.SearchQuery" @bind:event="oninput" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="filter-label">Rating range</label>
                        <div class="d-flex gap-2 align-items-center">
                            <select class="form-select form-select-sm bg-light shadow-none"
                                    value="@WatchlistSvc.FilterMinRating20"
                                    @onchange="@(e => WatchlistSvc.FilterMinRating20 = int.Parse(e.Value?.ToString() ?? "0"))">
                                @for (int i = 0; i <= 100; i += 5) { <option value="@i">@(i == 0 ? "Min" : i.ToString())</option> }
                            </select>
                            <span class="text-secondary" style="font-size:0.75rem;">–</span>
                            <select class="form-select form-select-sm bg-light shadow-none"
                                    value="@WatchlistSvc.FilterMaxRating20"
                                    @onchange="@(e => WatchlistSvc.FilterMaxRating20 = int.Parse(e.Value?.ToString() ?? "100"))">
                                @for (int i = 0; i <= 100; i += 5) { <option value="@i">@(i == 100 ? "Max" : i.ToString())</option> }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="filter-label">Genre</label>
                        <select class="form-select form-select-sm bg-light shadow-none" @bind="WatchlistSvc.SelectedGenre">
                            <option value="All">All genres</option>
                            @foreach (var g in AvailableGenres) { <option value="@g">@g</option> }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="filter-label">Type</label>
                        <select class="form-select form-select-sm bg-light shadow-none" @bind="WatchlistSvc.SelectedType">
                            <option value="All">All types</option>
                            <option value="Movie">Movies</option>
                            <option value="TV Series">TV Series</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="filter-label">Year range</label>
                        <div class="d-flex gap-2">
                            <input type="number" class="form-control form-control-sm bg-light shadow-none" placeholder="From" @bind="WatchlistSvc.StartYear" />
                            <input type="number" class="form-control form-control-sm bg-light shadow-none" placeholder="To" @bind="WatchlistSvc.EndYear" />
                        </div>
                    </div>
                    <div class="d-grid gap-2 mt-4">
                        <button class="btn btn-dark btn-sm rounded-pill fw-semibold" @onclick="WatchlistSvc.ShowRandomMovieAsync">
                            <i class="bi bi-dice-5 me-1"></i> Random pick
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="ClearFilters">
                            <i class="bi bi-eraser me-1"></i> Clear filters
                        </button>
                    </div>
                </div>
            }

            <!-- Table -->
            <div class="content-scroll">
                <div class="table-wrap">
                <table class="table table-hover align-middle mb-0">
                    <tbody>
                        @if (!_watchedItems.Any())
                        {
                            <tr><td colspan="6" class="py-5 text-center text-secondary fst-italic opacity-50">No movies match your filters.</td></tr>
                        }
                        <Virtualize Items="_watchedItems" Context="item" ItemSize="72" OverscanCount="5">
                            <tr @key="item.ImdbId" class="@(_selectedIds.Contains(item.ImdbId) ? "row-selected" : "")">
                                @if (isEditing)
                                {
                                    <td class="px-3 text-center" style="width:1%;white-space:nowrap;" @onclick:stopPropagation="true">
                                        <input type="checkbox" class="form-check-input shadow-none" style="width:17px;height:17px;cursor:pointer;"
                                               checked="@_selectedIds.Contains(item.ImdbId)"
                                               @onchange="() => ToggleSelect(item.ImdbId)" />
                                    </td>
                                }
                                <td class="px-2 py-1" style="width:52px;">
                                    <div class="poster-thumb">
                                        @if (!string.IsNullOrEmpty(item.FullPosterUrl) && !item.FullPosterUrl.Contains("data:image/png;base64"))
                                        {
                                            <img src="@item.FullPosterUrl" alt="@item.Title" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
                                            <div class="poster-fallback" style="display:none;"><i class="bi bi-film"></i></div>
                                        }
                                        else { <div class="poster-fallback"><i class="bi bi-film"></i></div> }
                                    </div>
                                </td>
                                <td class="px-3" style="cursor:pointer;" @onclick="() => WatchlistSvc.ShowDetailsAsync(item)">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="fw-bold text-dark title-hover">@item.Title</span>
                                        <a class="ext-link" href="@Get1337xSearchUrl(item)" target="_blank" rel="noopener noreferrer"
                                           title="Search on 1337x" @onclick:stopPropagation="true">
                                            <i class="bi bi-box-arrow-up-right"></i>
                                        </a>
                                    </div>
                                    @if (!string.IsNullOrEmpty(item.Director))
                                    {
                                        <span class="d-block text-secondary" style="font-size:0.73rem;opacity:0.75;">@item.Director</span>
                                    }
                                    <span class="row-meta">@item.Year · @item.DateAdded.ToString("MMM dd, yyyy")</span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex align-items-center justify-content-center gap-2 py-1">
                                        <div class="rating-box @(item.Rating20 == null ? "rating-empty" : "")"
                                             style="@(item.Rating20 != null ? $"background:{GetRatingColor(item.Rating20.Value)};" : "")">
                                            <input type="number" class="rating-input @(item.Rating20 == null ? "" : "text-white")"
                                                   min="0" max="100" placeholder="–"
                                                   value="@item.Rating20"
                                                   @onchange="(e) => UpdateRating20(item, string.IsNullOrEmpty(e.Value?.ToString()) ? null : int.Parse(e.Value.ToString()!))" />
                                        </div>
                                        @if (isEditing && item.Rating20 != null)
                                        {
                                            <button class="btn btn-link btn-sm p-0 text-secondary opacity-40" style="text-decoration:none;"
                                                    @onclick="() => UpdateRating20(item, null)" title="Clear rating">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                                <td class="px-3 d-none d-lg-table-cell">
                                    <span class="badge rounded-pill @(item.TitleType == "Movie" ? "bg-secondary" : "bg-light text-dark border")">@item.TitleType</span>
                                </td>
                            </tr>
                        </Virtualize>
                    </tbody>
                </table>
                </div>
            </div>

        </div>
    }
</div>

@code {
    private bool showFilters = false;
    private bool isEditing = false;
    private bool showSavedIndicator = false;
    private HashSet<string> _selectedIds = new();
    private List<WatchlistItem> _watchedItems = new();
    private List<string> _availableGenres = new();

    private int activeFilterCount => (WatchlistSvc.FilterMinRating20 > 0 ? 1 : 0)
        + (WatchlistSvc.FilterMaxRating20 < 100 ? 1 : 0)
        + (!string.IsNullOrEmpty(WatchlistSvc.StartYear) ? 1 : 0)
        + (!string.IsNullOrEmpty(WatchlistSvc.EndYear) ? 1 : 0)
        + (!string.IsNullOrEmpty(WatchlistSvc.SelectedGenre) && WatchlistSvc.SelectedGenre != "All" ? 1 : 0)
        + (!string.IsNullOrEmpty(WatchlistSvc.SelectedType) && WatchlistSvc.SelectedType != "All" ? 1 : 0)
        + (!string.IsNullOrEmpty(WatchlistSvc.SearchQuery) ? 1 : 0);

    private bool IsAllSelected => _watchedItems.Count > 0 && _watchedItems.All(i => _selectedIds.Contains(i.ImdbId));
    private void ToggleSelectAll() { if (IsAllSelected) _selectedIds.Clear(); else _selectedIds = _watchedItems.Select(i => i.ImdbId).ToHashSet(); }
    private void ToggleSelect(string id) { if (!_selectedIds.Remove(id)) _selectedIds.Add(id); }
    private void ToggleFilters() => showFilters = !showFilters;
    private void ToggleEdit() { isEditing = !isEditing; if (!isEditing) _selectedIds.Clear(); }

    protected override void OnInitialized() { WatchlistSvc.OnStateChanged += HandleStateChanged; SyncItems(); }
    public void Dispose() => WatchlistSvc.OnStateChanged -= HandleStateChanged;

    private void HandleStateChanged()
    {
        SyncItems();
        _selectedIds.IntersectWith(_watchedItems.Select(i => i.ImdbId).ToHashSet());
        StateHasChanged();
    }

    private void SyncItems()
    {
        _watchedItems = WatchlistSvc.WatchedItems.ToList();
        _availableGenres = WatchlistSvc.Items
            .Where(m => m.Status == WatchlistStatus.Watched)
            .SelectMany(m => (m.Genres ?? "").Split(','))
            .Select(g => g.Trim()).Where(g => !string.IsNullOrEmpty(g))
            .Distinct().OrderBy(g => g).ToList();
    }

    private async Task BulkMoveToWatchlist()
    {
        foreach (var item in _watchedItems.Where(i => _selectedIds.Contains(i.ImdbId)).ToList())
            await WatchlistSvc.UpdateStatusAsync(item, WatchlistStatus.Pending);
        _selectedIds.Clear();
    }
    private async Task BulkWatchAgain()
    {
        foreach (var item in _watchedItems.Where(i => _selectedIds.Contains(i.ImdbId)).ToList())
            await WatchlistSvc.UpdateStatusAsync(item, WatchlistStatus.Watching);
        _selectedIds.Clear();
    }
    private async Task BulkRemove()
    {
        foreach (var item in _watchedItems.Where(i => _selectedIds.Contains(i.ImdbId)).ToList())
            await WatchlistSvc.RemoveFromWatchlistAsync(item);
        _selectedIds.Clear();
    }

    private async Task UpdateRating20(WatchlistItem item, int? r)
    {
        if (r.HasValue) r = Math.Clamp(r.Value, 0, 100);
        await WatchlistSvc.UpdateRatingAsync(item, r);
        if (r.HasValue) { showSavedIndicator = true; StateHasChanged(); await Task.Delay(1500); showSavedIndicator = false; StateHasChanged(); }
    }

    private void ClearFilters()
    {
        WatchlistSvc.SearchQuery = ""; WatchlistSvc.SelectedType = "All"; WatchlistSvc.SelectedGenre = "All";
        WatchlistSvc.StartYear = ""; WatchlistSvc.EndYear = "";
        WatchlistSvc.FilterMinRating20 = 0; WatchlistSvc.FilterMaxRating20 = 100;
    }

    private List<string> AvailableGenres => _availableGenres;
    private string GetRatingColor(int val) { double hue = (val / 100.0) * 120; return $"hsl({hue},70%,45%)"; }

    private static string Get1337xSearchUrl(WatchlistItem item)
    {
        var q = string.IsNullOrWhiteSpace(item.Year) ? item.Title?.Trim() ?? "" : $"{item.Title?.Trim()} {item.Year?.Trim()}".Trim();
        return $"https://1337x.to/search/{System.Net.WebUtility.UrlEncode(q)}/1/";
    }
}

<style>
    /* Sidebar */
    .filter-sidebar {
        width: 260px;
        flex-shrink: 0;
        overflow-y: auto;
        border-right: 1px solid rgba(0,0,0,0.08);
        padding: 16px;
        background: #fff;
    }
    .filter-label {
        display: block;
        font-size: 0.67rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #888;
        margin-bottom: 6px;
    }

    /* Scrollable content column */
    .content-scroll {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
        min-height: 0;
        min-width: 0;
    }

    .poster-thumb { width: 40px; height: 60px; border-radius: 4px; overflow: hidden; background: #f0f0f0; flex-shrink: 0; }
    .poster-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .poster-fallback { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #ccc; font-size: 1rem; }

    /* Row interactions */
    .title-hover { transition: opacity 0.15s; }
    .title-hover:hover { opacity: 0.6; }
    .ext-link {
        opacity: 0; width: 20px; height: 20px;
        display: inline-flex; align-items: center; justify-content: center;
        color: #888; font-size: 0.7rem; transition: opacity 0.15s;
        text-decoration: none;
    }
    tr:hover .ext-link { opacity: 1; }

    /* Rating box */
    .rating-box {
        width: 50px; height: 50px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        border: 2px dashed #dee2e6; background: #f8f9fa;
        transition: border-color 0.2s, background 0.2s, transform 0.15s;
    }
    .rating-box:focus-within { transform: scale(1.08); border-style: solid; border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.15); }
    .rating-box:not(.rating-empty) { border: none; }
    .rating-input {
        width: 50px; height: 50px; text-align: center; font-weight: 900;
        font-size: 1.15rem; background: transparent; border: none; outline: none;
        cursor: pointer; color: #555;
    }
    .rating-input.text-white { color: #fff !important; caret-color: #fff; }
    input[type=number].rating-input::-webkit-inner-spin-button,
    input[type=number].rating-input::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
    input[type=number].rating-input { -moz-appearance: textfield; }

    @@keyframes fadeOutUp {
        0%   { opacity:0; transform:translate(-50%,0); }
        20%  { opacity:1; transform:translate(-50%,-4px); }
        80%  { opacity:1; transform:translate(-50%,-4px); }
        100% { opacity:0; transform:translate(-50%,-10px); }
    }
    .animate-fade-out { animation: fadeOutUp 1.5s ease-out forwards; }

    /* Mobile handled by app.css */
</style>
