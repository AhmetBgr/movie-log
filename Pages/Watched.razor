                                                        <span class="rating-badge-w" style="background:@GetRatingColor(item.Rating20.Value);">@item.UserRating</span>
                                                    </div>
                                                }
                                                <div class="d-flex align-items-center gap-2" style="padding-right:@(item.Rating20.HasValue ? "46px" : "4px");">
                                                    <div class="fw-bold" style="font-size:0.9rem;color:#111;">@item.Title</div>
                                                    <OpenOnMenu Item="item" />
                                                </div>
                                                <div class="row-meta">@item.Year &middot; @item.DateAdded.ToString("MMM dd, yyyy")</div>
                                                @if (!string.IsNullOrEmpty(item.Director))
                                                {
                                                    <div class="row-meta"><i class="bi bi-person me-1 opacity-40"></i>@item.Director</div>
                                                }
                                                @if (!string.IsNullOrEmpty(item.TitleType))
                                                {
