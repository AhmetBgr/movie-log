@page "/watched"
@using MyPrivateWatchlist.Models
@using MyPrivateWatchlist.Components
@inject MyPrivateWatchlist.Services.WatchlistService WatchlistSvc
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Watched History</PageTitle>

<div class="page-shell">

    @if (!WatchlistSvc.Items.Any(i => i.Status == WatchlistStatus.Watched))
    {
        <div class="page-content" style="overflow-y:auto;display:flex;align-items:center;justify-content:center;">
            <div class="text-center py-5">
                <i class="bi bi-journal-check fs-1 d-block mb-3 text-secondary opacity-50"></i>
                <p class="fs-5 text-secondary">You haven't marked anything as watched yet.</p>
            </div>
        </div>
    }
    else
    {
        <!-- â”€â”€ Primary toolbar â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
        <div class="toolbar-primary">
            <button class="tb-btn @(showFilters ? "active" : "") position-relative" @onclick="ToggleFilters">
                <i class="bi bi-funnel"></i>
                <span class="tb-label">Filters</span>
                @if (activeFilterCount > 0 && !showFilters)
                {
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                          style="font-size:0.55rem;padding:2px 5px;min-width:16px;">@activeFilterCount</span>
                }
            </button>

            <button class="tb-btn @(isEditing ? "active" : "")" @onclick="ToggleEdit">
                <i class="bi @(isEditing ? "bi-check-lg" : "bi-pencil")"></i>
                <span class="tb-label">@(isEditing ? "Done" : "Edit")</span>
            </button>

            <div class="tb-divider"></div>

            <button class="tb-btn tb-btn-sort @(WatchlistSvc.WatchedSortColumn == "Title" ? "sorted" : "")"
                    @onclick='() => WatchlistSvc.ToggleWatchedSort("Title")'>
                <i class="bi @(WatchlistSvc.WatchedSortColumn == "Title"
                    ? (WatchlistSvc.WatchedSortDescending ? "bi-sort-alpha-up-alt" : "bi-sort-alpha-down")
                    : "bi-sort-alpha-down")"></i>
                <span class="tb-label">Title</span>
            </button>
            <button class="tb-btn tb-btn-sort @(WatchlistSvc.WatchedSortColumn == "Year" ? "sorted" : "")"
                    @onclick='() => WatchlistSvc.ToggleWatchedSort("Year")'>
                <i class="bi @(WatchlistSvc.WatchedSortColumn == "Year"
                    ? (WatchlistSvc.WatchedSortDescending ? "bi-sort-numeric-up-alt" : "bi-sort-numeric-down")
                    : "bi-sort-numeric-down")"></i>
                <span class="tb-label">Year</span>
            </button>
            <button class="tb-btn tb-btn-sort @(WatchlistSvc.WatchedSortColumn == "Rating" ? "sorted" : "")"
                    @onclick='() => WatchlistSvc.ToggleWatchedSort("Rating")'>
                <i class="bi bi-star"></i>
                <span class="tb-label">Rating</span>
            </button>
            <button class="tb-btn tb-btn-sort @(WatchlistSvc.WatchedSortColumn == "DateAdded" ? "sorted" : "")"
                    @onclick='() => WatchlistSvc.ToggleWatchedSort("DateAdded")'>
                <i class="bi bi-calendar-plus"></i>
                <span class="tb-label">Added</span>
            </button>

            <div class="tb-divider"></div>

            <!-- View toggle -->
            <button class="tb-btn @(!isCardView ? "active" : "")" @onclick="SetViewTable" title="Table view">
                <i class="bi bi-list-ul"></i>
            </button>
            <button class="tb-btn @(isCardView ? "active" : "")" @onclick="SetViewCard" title="Card view">
                <i class="bi bi-grid-3x2-gap"></i>
            </button>

            <div class="tb-spacer"></div>
            <span class="text-secondary d-none d-sm-inline" style="font-size:0.76rem;white-space:nowrap;padding-right:4px;">@_watchedItems.Count items</span>
        </div>

        <!-- â”€â”€ Action bar (edit mode only) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
        @if (isEditing)
        {
            <div class="toolbar-actions @(_selectedIds.Count > 0 ? "has-selection" : "")">
                <input type="checkbox" class="form-check-input shadow-none flex-shrink-0"
                       style="width:17px;height:17px;cursor:pointer;margin-right:6px;"
                       checked="@IsAllSelected" @onchange="ToggleSelectAll"
                       title="Select all" />
                @if (_selectedIds.Count > 0)
                {
                    <span class="sel-badge">@_selectedIds.Count selected</span>
                    <button class="tb-btn tb-btn-primary live" @onclick="BulkMoveToWatchlist">
                        <i class="bi bi-list-nested"></i>
                        <span class="tb-label">To Watchlist</span>
                    </button>
                    <button class="tb-btn tb-btn-success live" @onclick="BulkWatchAgain">
                        <i class="bi bi-play-fill"></i>
                        <span class="tb-label">Watch Again</span>
                    </button>
                    <button class="tb-btn tb-btn-danger live" @onclick="BulkRemove">
                        <i class="bi bi-trash3-fill"></i>
                        <span class="tb-label">Remove</span>
                    </button>
                }
                else
                {
                    <span class="sel-hint"><i class="bi bi-check2-square me-1 opacity-50"></i>Select items to perform bulk actions</span>
                }
            </div>
        }

        <!-- ──────────────────────── Content: filter sidebar + table ──────────────────────── -->
        <div class="page-content" style="position:relative;">

            @if (showSavedIndicator)
            {
                <div style="position:absolute;top:16px;left:50%;transform:translateX(-50%);z-index:50;pointer-events:none;">
                    <span class="badge bg-success shadow rounded-pill px-3 py-2 animate-fade-out" style="font-size:0.72rem;">✓ Rating saved</span>
                </div>
            }

            <!-- Filter sidebar -->
            @if (showFilters)
            {
                <div class="filter-panel-wrapper" @onclick="@(() => showFilters = false)">
                    <div @onclick:stopPropagation="true" class="d-flex">
                        <AdvancedFilterPanel Title="Filters"
                                             AvailableGenres="@AvailableGenres"
                                             ShowUserRatingFilter="true"
                                             OnClearFilters="ClearFilters"
                                             OnClose="@(() => showFilters = false)"
                                             OnTouchStart="OnFilterTouchStart"
                                             OnTouchEnd="OnFilterTouchEnd"
                                             CurrentStatus="WatchlistStatus.Watched" />
                    </div>
                </div>
            }

            <!-- Main: table or card -->
            <div class="content-scroll">
                @if (!isCardView)
                {
                    <MovieGridTable Items="_watchedItems" 
                                   IsEditing="isEditing" 
                                   SelectedIds="_selectedIds" 
                                   OnItemClick="HandleRowClick" 
                                   OnToggleSelect="ToggleSelect" 
                                   TotalCount="@WatchlistSvc.WatchedItems.Where(i => i.Status == WatchlistStatus.Watched).Count()" 
                                   SortInfo="@(WatchlistSvc.WatchedSortColumn + (WatchlistSvc.WatchedSortDescending ? " (Desc)" : " (Asc)"))"
                                   @bind-PageIndex="gridPageIndex" />
                }
                else
                {

                    <!-- CARD VIEW -->
                    @if (!_watchedItems.Any())
                    {
                        <p class="text-center text-secondary opacity-50 fst-italic py-5">No movies match your filters.</p>
                    }
                    <div class="table-wrap table-wrap--wide p-3">
                        <div class="row row-cols-1 g-3">
                            <Virtualize Items="_watchedItems" Context="item" ItemSize="228" OverscanCount="2">
                                <div class="col" @key="item.ImdbId">
                                    <MovieCard Item="item"
                                               IsEditMode="@isEditing"
                                               IsSelected="@_selectedIds.Contains(item.ImdbId)"
                                               OnToggleSelect="@(() => ToggleSelect(item.ImdbId))"
                                               ShowActionButtons="true"
                                               ShowTracking="false"
                                               ShowRating="true"/>
                                </div>
                            </Virtualize>
                        </div>
                    </div>
                }
            </div>

        </div>
    }
</div>

@code {
    private bool showFilters = false;
    private double _touchStartX;
    private double _touchEndX;
    private bool isEditing = false;
    private DotNetObjectReference<Watched>? _holdRef;
    private bool isCardView = true;
    private bool showSavedIndicator = false;
    private HashSet<string> _selectedIds = new();
    private List<WatchlistItem> _watchedItems = new();
    private List<string> _availableGenres = new();

    private int gridPageIndex = 0;
    private int activeFilterCount
    {
        get
        {
            int count = (!string.IsNullOrEmpty(WatchlistSvc.SearchQuery) ? 1 : 0)
                + (WatchlistSvc.SelectedType != "All" ? 1 : 0)
                + (!string.IsNullOrEmpty(WatchlistSvc.AdvancedFilter.TitleSearch) ? 1 : 0)
                + (WatchlistSvc.AdvancedFilter.MinYear.HasValue ? 1 : 0)
                + (WatchlistSvc.AdvancedFilter.MaxYear.HasValue ? 1 : 0)
                + (WatchlistSvc.AdvancedFilter.IncludedGenres.Count + WatchlistSvc.AdvancedFilter.ExcludedGenres.Count > 0 ? 1 : 0);
            return count;
        }
    }

    private bool IsAllSelected => _watchedItems.Count > 0 && _watchedItems.All(i => _selectedIds.Contains(i.ImdbId));
    private void ToggleSelectAll() { if (IsAllSelected) _selectedIds.Clear(); else _selectedIds = _watchedItems.Select(i => i.ImdbId).ToHashSet(); }
    private void ToggleSelect(string id) { if (!_selectedIds.Remove(id)) _selectedIds.Add(id); }
    private void OnFilterTouchStart(TouchEventArgs e) => _touchStartX = e.Touches[0].ClientX;
    private void OnFilterTouchEnd(TouchEventArgs e)
    {
        _touchEndX = e.ChangedTouches[0].ClientX;
        if (_touchStartX - _touchEndX > 50) // swipe left to close
        {
            showFilters = false;
            StateHasChanged();
        }
    }
    private void ToggleFilters() => showFilters = !showFilters;
    private void ToggleEdit() { isEditing = !isEditing; if (!isEditing) _selectedIds.Clear(); }

    private void SetViewTable() { isCardView = false; _ = JS.InvokeVoidAsync("sessionStorage.setItem", "watched_view", "table"); }
    private void SetViewCard() { isCardView = true; _ = JS.InvokeVoidAsync("sessionStorage.setItem", "watched_view", "card"); }

    protected override void OnInitialized() { WatchlistSvc.OnStateChanged += HandleStateChanged; SyncItems(); }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { _holdRef = DotNetObjectReference.Create(this); await JS.InvokeVoidAsync("holdSelect.init", _holdRef); } catch {}

            var isDesktop = await JS.InvokeAsync<bool>("uiHelpers.isDesktop");
            if (isDesktop) { showFilters = true; StateHasChanged(); }

            // Restore session preferences
            try
            {
                var savedView = await JS.InvokeAsync<string?>("sessionStorage.getItem", "watched_view");
                if (!string.IsNullOrEmpty(savedView)) { isCardView = savedView == "card"; StateHasChanged(); }
            }
            catch { }
        }
    }

    private void HandleRowClick(WatchlistItem item)
    {
        if (isEditing) ToggleSelect(item.ImdbId);
        else _ = WatchlistSvc.ShowDetailsAsync(item);
    }

    [Microsoft.JSInterop.JSInvokable]
    public void OnHoldSelect(string imdbId)
    {
        if (!isEditing) isEditing = true;
        _selectedIds.Add(imdbId);
        StateHasChanged();
    }

    public void Dispose() { WatchlistSvc.OnStateChanged -= HandleStateChanged; _holdRef?.Dispose(); }

    private void HandleStateChanged()
    {
        SyncItems();
        _selectedIds.IntersectWith(_watchedItems.Select(i => i.ImdbId).ToHashSet());
        gridPageIndex = 0;
        StateHasChanged();
    }

    private void SyncItems()
    {
        _watchedItems = WatchlistSvc.WatchedItems.ToList();
        _availableGenres = WatchlistSvc.Items
            .Where(m => m.Status == WatchlistStatus.Watched)
            .SelectMany(m => (m.Genres ?? "").Split(','))
            .Select(g => g.Trim()).Where(g => !string.IsNullOrEmpty(g))
            .Distinct().OrderBy(g => g).ToList();
    }

    private async Task BulkMoveToWatchlist()
    {
        foreach (var item in _watchedItems.Where(i => _selectedIds.Contains(i.ImdbId)).ToList())
            await WatchlistSvc.UpdateStatusAsync(item, WatchlistStatus.Pending);
        _selectedIds.Clear();
    }
    private async Task BulkWatchAgain()
    {
        foreach (var item in _watchedItems.Where(i => _selectedIds.Contains(i.ImdbId)).ToList())
            await WatchlistSvc.UpdateStatusAsync(item, WatchlistStatus.Watching);
        _selectedIds.Clear();
    }
    private async Task BulkRemove()
    {
        foreach (var item in _watchedItems.Where(i => _selectedIds.Contains(i.ImdbId)).ToList())
            await WatchlistSvc.RemoveFromWatchlistAsync(item);
        _selectedIds.Clear();
    }

    private async Task UpdateRating20(WatchlistItem item, int? r)
    {
        if (r.HasValue) r = Math.Clamp(r.Value, 0, 100);
        await WatchlistSvc.UpdateRatingAsync(item, r);
        if (r.HasValue) { showSavedIndicator = true; StateHasChanged(); await Task.Delay(1500); showSavedIndicator = false; StateHasChanged(); }
    }

    private void ClearFilters()
    {
        WatchlistSvc.SearchQuery = ""; WatchlistSvc.SelectedType = "All"; WatchlistSvc.SelectedGenre = "All";
        WatchlistSvc.StartYear = ""; WatchlistSvc.EndYear = "";
        WatchlistSvc.FilterMinRating20 = 0; WatchlistSvc.FilterMaxRating20 = 100;
    }

    private List<string> AvailableGenres => _availableGenres;
    private string GetRatingColor(int val) { double hue = (val / 100.0) * 120; return $"hsl({hue},70%,45%)"; }
}

<style>
    /* Removed inline filter styles in favor of FilterPanel component */

    .content-scroll { flex: 1; overflow-y: auto; overflow-x: hidden; min-height: 0; min-width: 0; }
    .title-hover { transition: opacity 0.15s; }
    .title-hover:hover { opacity: 0.6; }

    .filter-panel-wrapper {
        display: flex;
        z-index: 100;
    }

    @@media (max-width: 650px) {
        .filter-panel-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(16, 27, 75, 0.4);
            backdrop-filter: blur(4px);
            z-index: 2000;
        }
    }
</style>
