        color: #888;
        margin-bottom: 6px;
    }

    /* Scrollable content column */
    .content-scroll {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
        min-height: 0;
        min-width: 0;
    }

    .content-scroll { 
        flex: 1; 
        overflow-y: auto; 
        overflow-x: hidden; 
        min-height: 0; 
        min-width: 0; 
        background: #fff;
    }
</style>
